# Local development
NODE_ENV=development
PORT=3000
PUBLIC_SITE_URL=http://localhost:4321

# Discord off while developing local, unless you explicitly enable it later
DISCORD_ENABLED=false

# stracker SFTP sync from GTX
STRACKER_SYNC_SECRET=change-this-local-secret
GTX_SFTP_HOST=185.216.144.78
GTX_SFTP_PORT=8822
GTX_SFTP_USER=
GTX_SFTP_PASS=
GTX_STRACKER_REMOTE_PATH=185.216.144.78_9800/stracker/stracker.db3

# stracker auto-sync
STRACKER_AUTO_SYNC_ENABLED=true
STRACKER_AUTO_SYNC_INTERVAL_MINUTES=5
STRACKER_AUTO_SYNC_INITIAL_DELAY_SECONDS=30

# Auth real fase 1
APP_USERS_PATH=./data/app/users.json
AUTH_REGISTRATION_ENABLED=true
AUTH_SESSION_DAYS=14
AUTH_COOKIE_SECURE=auto
FIRST_USER_ADMIN=false

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Storage persistente. En Hostinger debe apuntar fuera del directorio nodejs.
# Ejemplo producción: APP_DATA_DIR=/home/u303801827/gc-persistent
APP_DATA_DIR=./.gc-persistent

# Si defines APP_DATA_DIR, estas rutas se calculan solas. Puedes forzarlas si lo necesitas.
# APP_USERS_PATH=/home/u303801827/gc-persistent/app/users.json
# APP_DISPLAY_NAMES_PATH=/home/u303801827/gc-persistent/app/display-names.json
# STRACKER_DB_PATH=/home/u303801827/gc-persistent/stracker/stracker.db3

AUTH_REGISTRATION_ENABLED=true
AUTH_SESSION_DAYS=14
AUTH_COOKIE_SECURE=auto
FIRST_USER_ADMIN=false

---
export const prerender = false;

import MarketingLayout from '../../layouts/MarketingLayout.astro';
import '../../styles/home2.css';

const slug = Astro.params.slug || '';
---

<MarketingLayout title="Noticia | GrassCutters" description="Detalle de noticia GrassCutters Racing.">
  <main class="gc-home2 gc-news-detail-page-v43" data-news-detail data-news-slug={slug}>
    <section class="gc-news-detail-hero-v43">
      <div class="gc-home2-shell gc-news-detail-hero-v43__grid">
        <div class="gc-news-detail-hero-v43__copy">
          <p class="gc-home2-kicker">GRASSCUTTERS RACE CONTROL</p>
          <h1 data-detail-title>Cargando noticia</h1>
          <p class="gc-home2-lead" data-detail-category>Noticias</p>
          <p class="gc-news-detail-hero-v43__excerpt" data-detail-excerpt>
            Esperando datos del sistema de noticias.
          </p>

          <div class="gc-home2-statusline gc-news-detail-hero-v43__meta">
            <span class="gc-home2-badge" data-detail-date>Actualizando</span>
            <a class="gc-home2-badge gc-news-detail-back-v43" href="/noticias">← Volver a noticias</a>
          </div>
        </div>

        <aside class="gc-news-detail-hero-v43__side">
          <span>News detail</span>
          <strong data-detail-status>Conectando</strong>
          <small>Ruta dinámica /noticias/[slug]</small>
        </aside>
      </div>
    </section>

    <section class="gc-home2-section gc-home2-shell gc-news-detail-layout-v43">
      <article class="gc-news-detail-article-v43">
        <div class="gc-news-detail-article-v43__media">
          <img data-detail-image src="/ui/home2/gc-home2-news-sim.svg" alt="" width="1180" height="620" loading="eager" decoding="async" />
        </div>

        <div class="gc-news-detail-article-v43__body" data-detail-body>
          <p>Cargando contenido...</p>
        </div>
      </article>

      <aside class="gc-news-detail-aside-v43">
        <div class="gc-home2-panel gc-news-detail-box-v43">
          <p class="gc-home2-panel__eyebrow">Noticias GC</p>
          <h2>Archivo de noticias</h2>
          <p>Esta entrada se carga desde el sistema persistente creado en /admin/noticias.</p>
          <a href="/noticias" class="gc-home2-btn gc-home2-btn--primary gc-home2-btn--wide">Ver noticias →</a>
        </div>

        <div class="gc-home2-panel gc-news-detail-box-v43">
          <p class="gc-home2-panel__eyebrow">Estado</p>
          <h2 data-detail-mini-status>Actualizando</h2>
          <p data-detail-updated>Comprobando última edición.</p>
        </div>
      </aside>
    </section>
  </main>

  <style is:global>
    .gc-news-detail-page-v43 {
      min-height: 100vh;
      background:
        radial-gradient(circle at 82% 8%, rgba(150,255,47,.10), transparent 26rem),
        radial-gradient(circle at 18% 30%, rgba(255,154,61,.055), transparent 24rem),
        linear-gradient(180deg, #050806 0%, #020302 48%, #060906 100%);
      isolation: isolate;
    }

    .gc-news-detail-page-v43::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: -1;
      opacity: .20;
      background:
        linear-gradient(90deg, rgba(255,255,255,.045) 1px, transparent 1px),
        linear-gradient(0deg, rgba(255,255,255,.026) 1px, transparent 1px);
      background-size: 46px 46px;
      mask-image: radial-gradient(circle at 50% 0%, black, transparent 72%);
    }

    .gc-news-detail-hero-v43 {
      position: relative;
      overflow: hidden;
      padding: clamp(72px, 8vw, 108px) 0 clamp(22px, 4vw, 44px);
      border-bottom: 1px solid rgba(150,255,47,.11);
      background:
        linear-gradient(90deg, rgba(2,4,2,.44), rgba(2,4,2,.82)),
        radial-gradient(circle at 62% 28%, rgba(150,255,47,.15), transparent 18rem),
        linear-gradient(180deg, rgba(255,255,255,.045), rgba(0,0,0,.78));
    }

    .gc-news-detail-hero-v43::after {
      content: "";
      position: absolute;
      inset: auto 0 0;
      height: 54px;
      pointer-events: none;
      background: linear-gradient(180deg, transparent, #050806);
    }

    .gc-news-detail-hero-v43__grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 330px);
      gap: clamp(18px, 4vw, 48px);
      align-items: end;
    }

    .gc-news-detail-hero-v43__copy h1 {
      margin: 8px 0 0;
      max-width: 780px;
      font-size: clamp(42px, 6.8vw, 76px);
      line-height: .88;
      letter-spacing: -.055em;
      text-transform: uppercase;
      text-wrap: balance;
    }

    .gc-news-detail-hero-v43__excerpt {
      max-width: 760px;
      margin: 14px 0 0;
      color: rgba(232,242,226,.78);
      font-size: clamp(.96rem, 1.1vw, 1.12rem);
      line-height: 1.45;
    }

    .gc-news-detail-hero-v43__meta {
      margin-top: 18px;
    }

    .gc-news-detail-back-v43 {
      text-decoration: none;
    }

    .gc-news-detail-hero-v43__side {
      border: 1px solid rgba(150,255,47,.16);
      background:
        radial-gradient(circle at 100% 0%, rgba(150,255,47,.10), transparent 8rem),
        linear-gradient(180deg, rgba(9,14,10,.86), rgba(3,6,4,.96));
      padding: 16px;
      min-height: 150px;
      display: flex;
      flex-direction: column;
      justify-content: end;
      box-shadow:
        inset 0 0 0 1px rgba(255,255,255,.035),
        0 18px 60px rgba(0,0,0,.24);
    }

    .gc-news-detail-hero-v43__side span,
    .gc-news-detail-hero-v43__side small {
      color: var(--muted);
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .gc-news-detail-hero-v43__side strong {
      display: block;
      margin: 8px 0;
      color: var(--green);
      font-size: 24px;
      line-height: 1;
      text-transform: uppercase;
    }

    .gc-news-detail-layout-v43 {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 340px);
      gap: 14px;
      align-items: start;
      margin-top: clamp(16px, 3vw, 26px);
    }

    .gc-news-detail-article-v43 {
      border: 1px solid rgba(150,255,47,.13);
      background:
        radial-gradient(circle at 72% 0%, rgba(150,255,47,.075), transparent 10rem),
        linear-gradient(180deg, rgba(9,14,10,.88), rgba(3,6,4,.96));
      overflow: hidden;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,.035);
    }

    .gc-news-detail-article-v43__media {
      width: 100%;
      max-height: 460px;
      overflow: hidden;
      background: #080c08;
    }

    .gc-news-detail-article-v43__media img {
      width: 100%;
      height: 100%;
      max-height: 460px;
      object-fit: cover;
      filter: saturate(.88) brightness(.72) contrast(1.06);
    }

    .gc-news-detail-article-v43__body {
      padding: clamp(18px, 3vw, 34px);
      color: rgba(232,242,226,.84);
      font-size: 1rem;
      line-height: 1.7;
    }

    .gc-news-detail-article-v43__body p {
      margin: 0 0 1em;
    }

    .gc-news-detail-article-v43__body h2,
    .gc-news-detail-article-v43__body h3 {
      margin: 1.15em 0 .45em;
      color: var(--text);
      line-height: 1;
      text-transform: uppercase;
      letter-spacing: -.035em;
    }

    .gc-news-detail-article-v43__body a {
      color: var(--green);
      font-weight: 900;
    }

    .gc-news-detail-aside-v43 {
      display: grid;
      gap: 12px;
      position: sticky;
      top: 84px;
    }

    .gc-news-detail-box-v43 {
      min-height: auto !important;
      padding: 16px !important;
    }

    .gc-news-detail-box-v43 h2 {
      margin: 7px 0 8px;
      font-size: 22px;
      line-height: .95;
      text-transform: uppercase;
    }

    .gc-news-detail-box-v43 p {
      color: rgba(232,242,226,.72);
      line-height: 1.45;
    }

    @media (max-width: 960px) {
      .gc-news-detail-hero-v43__grid,
      .gc-news-detail-layout-v43 {
        grid-template-columns: 1fr;
      }

      .gc-news-detail-aside-v43 {
        position: static;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-news-detail]');
      const slug = root?.dataset.newsSlug || '';
      const $ = (selector) => root?.querySelector(selector);
      const esc = (v) => String(v ?? '').replace(/[&<>'"]/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));
      const fallbackImage = '/ui/home2/gc-home2-news-sim.svg';

      const paragraphsToHtml = (body) => {
        const raw = String(body || '').trim();
        if (!raw) return '<p>Esta noticia todavía no tiene cuerpo publicado.</p>';

        if (raw.includes('<p') || raw.includes('<h2') || raw.includes('<ul') || raw.includes('<ol')) {
          return raw;
        }

        return raw
          .split(/\n{2,}/)
          .map((block) => `<p>${esc(block).replace(/\n/g, '<br />')}</p>`)
          .join('');
      };

      const setText = (selector, value) => {
        const node = $(selector);
        if (node) node.textContent = value;
      };

      fetch(`/api/noticias/${encodeURIComponent(slug)}`, { cache: 'no-store' })
        .then((res) => {
          if (res.status === 404) throw new Error('Noticia no encontrada');
          return res.ok ? res.json() : Promise.reject(new Error(`HTTP ${res.status}`));
        })
        .then((data) => {
          const post = data.post || {};
          const title = post.title || 'Noticia';
          const image = post.image || fallbackImage;

          document.title = `${title} | GrassCutters`;

          setText('[data-detail-title]', title);
          setText('[data-detail-category]', post.category || 'Noticias');
          setText('[data-detail-excerpt]', post.excerpt || '');
          setText('[data-detail-date]', post.date || 'Publicado');
          setText('[data-detail-status]', 'Publicado');
          setText('[data-detail-mini-status]', post.category || 'Noticias');
          setText('[data-detail-updated]', post.updatedAt ? `Actualizada: ${new Date(post.updatedAt).toLocaleDateString('es-ES')}` : 'Actualizada desde admin.');

          const img = $('[data-detail-image]');
          if (img) {
            img.src = image;
            img.alt = post.imageAlt || title;
          }

          const body = $('[data-detail-body]');
          if (body) {
            body.innerHTML = paragraphsToHtml(post.body || post.excerpt || '');
          }
        })
        .catch((error) => {
          setText('[data-detail-title]', 'Noticia no encontrada');
          setText('[data-detail-category]', 'Error');
          setText('[data-detail-excerpt]', error.message || 'No se pudo cargar la noticia.');
          setText('[data-detail-status]', 'Error');

          const body = $('[data-detail-body]');
          if (body) {
            body.innerHTML = `
              <h2>No se pudo cargar esta noticia</h2>
              <p>${esc(error.message || 'Error desconocido')}</p>
              <p><a href="/noticias">Volver a noticias</a></p>
            `;
          }
        });
    })();
  </script>
</MarketingLayout>

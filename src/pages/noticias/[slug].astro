---
export const prerender = false;

import MarketingLayout from '../../layouts/MarketingLayout.astro';
import '../../styles/home2.css';
import '../../styles/archive-home2-polish.css';

const slug = Astro.params.slug || '';
---

<MarketingLayout title="Noticia | GrassCutters Newsroom" description="Detalle de noticia GrassCutters Racing, sim racing y motorsport.">
  <main class="gc-archive-home2 gc-news-detail-archive-v1" data-news-detail data-news-slug={slug}>
    <section class="gc-archive-race-hero" data-detail-hero>
      <div class="gc-archive-shell gc-archive-race-hero__grid">
        <div>
          <p class="gc-archive-breadcrumb">
            <a href="/noticias/">Noticias</a> / <strong data-detail-breadcrumb>Newsroom</strong>
          </p>
          <p class="gc-archive-kicker">GRASSCUTTERS NEWSROOM</p>
          <h1 data-detail-title>Cargando noticia</h1>
          <p class="gc-archive-race-hero__lead" data-detail-excerpt>
            Esperando datos del sistema de noticias.
          </p>

          <div class="gc-archive-statusline">
            <span class="gc-archive-badge" data-detail-category>Noticias</span>
            <span class="gc-archive-badge" data-detail-date>Actualizando</span>
            <a class="gc-archive-badge" href="/noticias/">← Volver a noticias</a>
          </div>
        </div>

        <aside class="gc-archive-command-card" aria-label="Resumen de noticia">
          <span>Ficha de noticia</span>
          <strong data-detail-short>GC</strong>
          <small data-detail-side-meta>Newsroom</small>

          <div class="gc-archive-command-grid">
            <a href="/noticias/">
              <small>Canal</small>
              <strong>News</strong>
            </a>
            <a href="/archivo/">
              <small>Contexto</small>
              <strong>Archivo</strong>
            </a>
          </div>
        </aside>
      </div>
    </section>

    <section class="gc-archive-shell gc-archive-section">
      <article class="gc-archive-spotlight gc-news-detail-spotlight-v1">
        <div class="gc-archive-spotlight__copy">
          <span class="gc-archive-panel__eyebrow">Noticia</span>
          <h2 data-detail-spot-title>Cargando contenido</h2>
          <p data-detail-spot-excerpt>Esperando publicación.</p>

          <dl>
            <div>
              <dt>Categoría</dt>
              <dd data-detail-meta-category>Noticias</dd>
            </div>
            <div>
              <dt>Fecha</dt>
              <dd data-detail-meta-date>Actualizando</dd>
            </div>
            <div>
              <dt>Canal</dt>
              <dd>GC News</dd>
            </div>
          </dl>

          <a href="#contenido-noticia">Leer contenido</a>
        </div>

        <figure>
          <img data-detail-image src="/ui/home2/gc-home2-news-sim.svg" alt="" loading="eager" />
        </figure>
      </article>
    </section>

    <section class="gc-archive-shell gc-archive-section gc-news-detail-layout-v1">
      <article id="contenido-noticia" class="gc-archive-section--panel gc-news-detail-body-v1">
        <div class="gc-archive-section-head">
          <div>
            <span>Contenido</span>
            <h2>Artículo</h2>
          </div>
          <p data-detail-updated>Actualizando datos de publicación.</p>
        </div>

        <div class="gc-news-detail-prose-v1" data-detail-body>
          <p>Cargando contenido...</p>
        </div>
      </article>

      <aside class="gc-news-detail-side-v1">
        <section class="gc-archive-type-card">
          <small>Newsroom</small>
          <strong>Noticias</strong>
          <p>Actualidad de GrassCutters, sim racing, herramientas, carreras y motorsport.</p>
          <small><a href="/noticias/">Volver al canal</a></small>
        </section>

        <section class="gc-archive-type-card">
          <small>Contexto</small>
          <strong>Archivo</strong>
          <p>Base de datos editorial con circuitos, coches, pilotos y conceptos técnicos.</p>
          <small><a href="/archivo/">Abrir archivo</a></small>
        </section>
      </aside>
    </section>
  </main>

  <style is:global>
    .gc-news-detail-archive-v1 .gc-archive-race-hero h1 {
      max-width: 900px;
    }

    .gc-news-detail-spotlight-v1 h2 {
      font-size: clamp(26px, 3.05vw, 40px);
      line-height: .94;
      letter-spacing: -.04em;
      max-width: 760px;
    }

    .gc-news-detail-spotlight-v1 figure {
      min-height: 100%;
      background:
        linear-gradient(180deg, rgba(8,14,10,.72), rgba(4,8,5,.8)),
        url("/ui/home2/gc-home2-grid.svg");
      background-size: cover;
    }

    .gc-news-detail-spotlight-v1 img {
      width: 100%;
      height: 100%;
      min-height: 300px;
      object-fit: cover;
      filter: saturate(.88) brightness(.74);
    }

    .gc-news-detail-layout-v1 {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 300px;
      gap: 12px;
      align-items: start;
    }

    .gc-news-detail-body-v1 {
      margin-top: 0;
    }

    .gc-news-detail-prose-v1 {
      position: relative;
      z-index: 1;
      color: var(--soft);
      font-size: 15px;
      line-height: 1.68;
    }

    .gc-news-detail-prose-v1 p {
      margin: 0 0 1em;
    }

    .gc-news-detail-prose-v1 p:first-child {
      color: var(--text);
      font-size: 16px;
      line-height: 1.6;
    }

    .gc-news-detail-prose-v1 h2,
    .gc-news-detail-prose-v1 h3 {
      margin: 1.25em 0 .5em;
      color: var(--text);
      line-height: .98;
      letter-spacing: -.04em;
      text-transform: uppercase;
    }

    .gc-news-detail-prose-v1 h2 {
      font-size: clamp(26px, 3.05vw, 40px);
    }

    .gc-news-detail-prose-v1 h3 {
      font-size: clamp(20px, 2.2vw, 30px);
    }

    .gc-news-detail-prose-v1 a {
      color: var(--green);
      font-weight: 900;
      text-underline-offset: 3px;
    }

    .gc-news-detail-prose-v1 ul,
    .gc-news-detail-prose-v1 ol {
      margin: 1em 0 1.2em;
      padding-left: 1.2em;
    }

    .gc-news-detail-prose-v1 li + li {
      margin-top: .45em;
    }

    .gc-news-detail-side-v1 {
      display: grid;
      gap: 12px;
      position: sticky;
      top: 84px;
    }

    .gc-news-detail-side-v1 .gc-archive-type-card {
      min-height: 150px;
    }

    .gc-news-detail-side-v1 a {
      color: var(--green);
      text-decoration: none;
    }

    @media (max-width: 960px) {
      .gc-news-detail-layout-v1 {
        grid-template-columns: 1fr;
      }

      .gc-news-detail-side-v1 {
        position: static;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-news-detail]');
      const slug = root?.dataset.newsSlug || '';
      const $ = (selector) => root?.querySelector(selector);
      const fallbackImage = '/ui/home2/gc-home2-news-sim.svg';

      const esc = (value) => String(value ?? '').replace(/[&<>'"]/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        "'": '&#39;',
        '"': '&quot;',
      }[char]));

      const normalizeCategory = (value) => {
        const allowed = ['Update', 'Sim racing', 'Motorsport', 'Herramientas', 'GrassCutters'];
        const raw = String(value || '').trim();
        const simple = raw.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        return allowed.find((item) => item.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '') === simple) || 'Update';
      };

      const paragraphsToHtml = (body) => {
        const raw = String(body || '').trim();
        if (!raw) return '<p>Esta noticia todavía no tiene contenido publicado.</p>';

        if (/<(p|h2|h3|ul|ol|blockquote|figure|img|a)\b/i.test(raw)) {
          return raw;
        }

        return raw
          .split(/\n{2,}/)
          .map((block) => `<p>${esc(block).replace(/\n/g, '<br />')}</p>`)
          .join('');
      };

      const setText = (selector, value) => {
        const node = $(selector);
        if (node) node.textContent = value;
      };

      fetch(`/api/noticias/${encodeURIComponent(slug)}`, { cache: 'no-store' })
        .then((response) => {
          if (response.status === 404) throw new Error('Noticia no encontrada');
          return response.ok ? response.json() : Promise.reject(new Error(`HTTP ${response.status}`));
        })
        .then((data) => {
          const post = data.post || {};
          const title = post.title || 'Noticia';
          const category = normalizeCategory(post.category);
          const image = post.image || fallbackImage;

          document.title = `${title} | GrassCutters Newsroom`;

          setText('[data-detail-title]', title);
          setText('[data-detail-breadcrumb]', title);
          setText('[data-detail-excerpt]', post.excerpt || 'Publicación del newsroom GrassCutters.');
          setText('[data-detail-category]', category);
          setText('[data-detail-date]', post.date || 'Publicado');
          setText('[data-detail-side-meta]', category);
          setText('[data-detail-short]', category === 'GrassCutters' ? 'GC' : 'News');

          setText('[data-detail-spot-title]', title);
          setText('[data-detail-spot-excerpt]', post.excerpt || 'Publicación del newsroom GrassCutters.');
          setText('[data-detail-meta-category]', category);
          setText('[data-detail-meta-date]', post.date || 'Publicado');
          setText('[data-detail-updated]', post.updatedAt ? `Actualizada: ${new Date(post.updatedAt).toLocaleDateString('es-ES')}` : 'Publicación del newsroom GrassCutters.');

          const img = $('[data-detail-image]');
          if (img) {
            img.src = image;
            img.alt = post.imageAlt || title;
          }

          const body = $('[data-detail-body]');
          if (body) {
            body.innerHTML = paragraphsToHtml(post.body || post.excerpt || '');
          }
        })
        .catch((error) => {
          setText('[data-detail-title]', 'Noticia no encontrada');
          setText('[data-detail-excerpt]', error.message || 'No se pudo cargar la noticia.');
          setText('[data-detail-category]', 'Error');
          setText('[data-detail-date]', 'Revisar URL');
          setText('[data-detail-spot-title]', 'No se pudo cargar esta noticia');
          setText('[data-detail-spot-excerpt]', error.message || 'Error desconocido');
          setText('[data-detail-meta-category]', 'Error');
          setText('[data-detail-meta-date]', 'No disponible');

          const body = $('[data-detail-body]');
          if (body) {
            body.innerHTML = `
              <h2>No se pudo cargar esta noticia</h2>
              <p>${esc(error.message || 'Error desconocido')}</p>
              <p><a href="/noticias/">Volver a noticias</a></p>
            `;
          }
        });
    })();
  </script>
</MarketingLayout>

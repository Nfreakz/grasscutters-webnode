---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="Perfil piloto | GrassCutters">
  <div class="gc-page gc-profile-page">
    <section class="gc-hero gc-hero--compact">
      <div>
        <span class="gc-kicker">Mi perfil</span>
        <h1 class="gc-title" id="profileTitle">Panel de piloto.</h1>
        <p class="gc-subtitle" id="profileText">Tu garaje competitivo: ritmo, limpieza, combos, coches y circuitos desde stracker.</p>
        <div class="gc-hero__meta" id="profileBadges">
          <span class="gc-chip">Cuenta</span>
          <span class="gc-chip">Piloto stracker</span>
          <span class="gc-chip">Perfil Pro v2</span>
        </div>
      </div>
      <aside class="gc-live-panel">
        <div class="gc-live-panel__title"><span>Cuenta</span><strong id="accountState">...</strong></div>
        <div class="gc-status-list" id="profileMeta"><div class="gc-status-row"><span>Estado</span><strong>Cargando</strong></div></div>
      </aside>
    </section>

    <section class="gc-metrics" id="profileMetrics">
      <div class="gc-metric"><span>Mejor vuelta</span><strong id="metricBestLap">...</strong><small>personal</small></div>
      <div class="gc-metric"><span>Ranking global</span><strong id="metricRank">...</strong><small>por mejor vuelta</small></div>
      <div class="gc-metric"><span>Vueltas válidas</span><strong id="metricValid">...</strong><small>limpieza</small></div>
      <div class="gc-metric"><span>Consistencia</span><strong id="metricConsistency">...</strong><small>desviación</small></div>
    </section>

    <section class="gc-grid-2">
      <div class="gc-section">
        <div class="gc-section-head"><h2>Resumen competitivo</h2><p id="summaryMeta">Cargando métricas...</p></div>
        <div class="gc-slab-list" id="summaryRows">
          <div><span>Estado</span><strong>Cargando</strong></div>
        </div>
      </div>

      <aside class="gc-section">
        <div class="gc-section-head"><h2>Piloto vinculado</h2><p>Cuenta y vínculo stracker</p></div>
        <div class="gc-slab" id="linkedPilot">Cargando...</div>
        <div class="gc-actions">
          <a class="gc-btn" href="/login">Cambiar cuenta</a>
          <a class="gc-btn" id="publicProfileAction" href="/pilotos" hidden>Perfil público</a>
          <a class="gc-btn gc-btn--primary" href="/hotlaps">Ver hotlaps</a>
        </div>
      </aside>
    </section>

    <section class="gc-grid-2">
      <div class="gc-section">
        <div class="gc-section-head"><h2>Mejores combos</h2><p>Coche + circuito con posición de referencia</p></div>
        <div class="gc-table-wrap">
          <table class="gc-table gc-table--compact">
            <thead><tr><th>#</th><th>Coche</th><th>Circuito</th><th>Tiempo</th><th>Rank</th><th>Limpias</th></tr></thead>
            <tbody id="bestCombos"><tr><td colspan="6">Cargando...</td></tr></tbody>
          </table>
        </div>
      </div>

      <div class="gc-section">
        <div class="gc-section-head"><h2>Últimas vueltas</h2><p>Actividad reciente real</p></div>
        <div class="gc-table-wrap">
          <table class="gc-table gc-table--compact">
            <thead><tr><th>Fecha</th><th>Coche</th><th>Circuito</th><th>Tiempo</th><th>Estado</th><th>Vmax</th></tr></thead>
            <tbody id="recentLaps"><tr><td colspan="6">Cargando...</td></tr></tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="gc-grid-2">
      <div class="gc-section">
        <div class="gc-section-head"><h2>Garaje</h2><p>Coches usados por el piloto</p></div>
        <div class="gc-table-wrap">
          <table class="gc-table gc-table--compact">
            <thead><tr><th>Coche</th><th>Vueltas</th><th>Limpias</th><th>Mejor</th><th>Circuitos</th><th>Vmax</th></tr></thead>
            <tbody id="garageRows"><tr><td colspan="6">Cargando...</td></tr></tbody>
          </table>
        </div>
      </div>

      <div class="gc-section">
        <div class="gc-section-head"><h2>Circuitos</h2><p>Pistas donde ha rodado</p></div>
        <div class="gc-table-wrap">
          <table class="gc-table gc-table--compact">
            <thead><tr><th>Circuito</th><th>Vueltas</th><th>Limpias</th><th>Mejor</th><th>Coches</th><th>Última</th></tr></thead>
            <tbody id="trackRows"><tr><td colspan="6">Cargando...</td></tr></tbody>
          </table>
        </div>
      </div>
    </section>
  </div>

  <script>
    const $ = (id) => document.getElementById(id);
    const escapeHtml = (value) => String(value ?? '-').replace(/[&<>'"]/g, (char) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[char]));
    const fmtMs = (ms) => {
      const n = Number(ms);
      if (!Number.isFinite(n) || n <= 0) return '--';
      const m = Math.floor(n / 60000);
      const s = Math.floor((n % 60000) / 1000);
      const x = String(Math.floor(n % 1000)).padStart(3, '0');
      return `${m}:${String(s).padStart(2, '0')}.${x}`;
    };
    const fmtDate = (value) => {
      if (!value) return '-';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return '-';
      return date.toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'short' });
    };
    const fmtSpeed = (value) => Number.isFinite(Number(value)) && Number(value) > 0 ? `${Math.round(Number(value))} km/h` : '--';
    const lapTime = (lap) => lap?.lapTimeFormatted || lap?.lapTime || fmtMs(lap?.lapTimeMs);
    const carName = (lap) => lap?.carName || lap?.car?.name || lap?.car?.uiName || lap?.car?.code || '-';
    const trackName = (lap) => lap?.trackName || lap?.track?.name || lap?.track?.uiName || lap?.track?.code || '-';
    const cleanRate = (valid, total) => total ? `${Math.round((Number(valid || 0) / Number(total || 0)) * 1000) / 10}%` : '--';

    function setMetric(id, value) {
      const el = $(id);
      if (el) el.textContent = String(value ?? '--');
    }

    function noRows(cols, text) {
      return `<tr><td colspan="${cols}">${escapeHtml(text)}</td></tr>`;
    }

    function pilotLabel(pilot) {
      const name = pilot?.name || pilot?.displayName || 'Piloto sin nombre';
      const id = pilot?.id ?? pilot?.playerId ?? '-';
      const guid = pilot?.steamGuid ? ` · ${pilot.steamGuid}` : '';
      const laps = Number(pilot?.totalLaps || 0) ? ` · ${pilot.totalLaps} vueltas` : '';
      return `${name} · ID ${id}${guid}${laps}`;
    }

    async function initPilotLinker() {
      const panel = $('profileLinkPilotPanel');
      if (!panel) return;

      try {
        const response = await fetch('/api/pilots?valid=all', { credentials: 'same-origin' });
        const data = await response.json();
        const pilots = Array.isArray(data.items) ? data.items : [];

        if (!pilots.length) {
          panel.innerHTML = '<p>No hay pilotos disponibles para vincular.</p>';
          return;
        }

        const sortedPilots = [...pilots].sort((a, b) => String(a.name || '').localeCompare(String(b.name || ''), 'es'));
        const options = sortedPilots.map((pilot) => `
          <option value="${escapeHtml(pilot.id ?? pilot.playerId ?? '')}" data-search="${escapeHtml(pilotLabel(pilot).toLowerCase())}">
            ${escapeHtml(pilotLabel(pilot))}
          </option>
        `).join('');

        panel.innerHTML = `
          <div class="gc-form-grid">
            <label class="gc-field">
              <span>Buscar piloto</span>
              <input class="gc-input" id="profilePilotSearch" type="search" placeholder="Nombre, ID o Steam GUID" />
            </label>
            <label class="gc-field">
              <span>Piloto stracker</span>
              <select class="gc-select" id="profilePilotSelect">${options}</select>
            </label>
          </div>
          <div class="gc-actions">
            <button class="gc-btn gc-btn--primary" id="profileLinkPilotBtn" type="button">Vincular piloto</button>
          </div>
          <p class="gc-message" id="profileLinkPilotMessage"></p>
        `;

        const search = $('profilePilotSearch');
        const select = $('profilePilotSelect');
        const button = $('profileLinkPilotBtn');
        const message = $('profileLinkPilotMessage');

        search?.addEventListener('input', () => {
          const query = String(search.value || '').trim().toLowerCase();
          Array.from(select.options).forEach((option) => {
            option.hidden = Boolean(query) && !String(option.dataset.search || '').includes(query);
          });
          const firstVisible = Array.from(select.options).find((option) => !option.hidden);
          if (firstVisible) select.value = firstVisible.value;
        });

        button?.addEventListener('click', async () => {
          const playerId = Number(select?.value);
          if (!Number.isFinite(playerId)) {
            if (message) message.textContent = 'Selecciona un piloto válido.';
            return;
          }

          button.disabled = true;
          if (message) message.textContent = 'Vinculando piloto...';

          try {
            const linkResponse = await fetch('/api/auth/link-pilot', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ playerId })
            });
            const result = await linkResponse.json().catch(() => ({}));
            if (!linkResponse.ok || result.ok === false) throw new Error(result.message || 'No se pudo vincular el piloto.');
            if (message) message.textContent = result.message || 'Piloto vinculado correctamente.';
            window.location.reload();
          } catch (error) {
            if (message) message.textContent = error.message || 'Error vinculando piloto.';
          } finally {
            button.disabled = false;
          }
        });
      } catch (error) {
        panel.innerHTML = `<p>No se pudieron cargar pilotos.</p><p class="gc-note">${escapeHtml(error.message || 'Error desconocido')}</p>`;
      }
    }

    function renderUnauthenticated(data) {
      $('accountState').textContent = 'Sin login';
      $('accountState').style.color = 'var(--warn)';
      $('profileText').textContent = data.message || 'Entra con tu cuenta para ver tus datos de piloto.';
      $('profileBadges').innerHTML = '<span class="gc-chip gc-chip--warn">Sesión requerida</span>';
      $('profileMeta').innerHTML = '<div class="gc-status-row"><span>Sesión</span><strong>No activa</strong></div>';
      const publicAction = $('publicProfileAction');
      if (publicAction) publicAction.hidden = true;
      $('linkedPilot').innerHTML = '<p>No hay sesión activa.</p><div class="gc-actions"><a class="gc-btn gc-btn--primary" href="/login">Entrar ahora</a></div>';
      ['metricBestLap','metricRank','metricValid','metricConsistency'].forEach((id) => setMetric(id, '-'));
      $('summaryRows').innerHTML = '<div><span>Estado</span><strong>Login requerido</strong></div>';
      $('bestCombos').innerHTML = noRows(6, 'Inicia sesión para ver combos.');
      $('recentLaps').innerHTML = noRows(6, 'Inicia sesión para ver actividad.');
      $('garageRows').innerHTML = noRows(6, 'Inicia sesión para ver garaje.');
      $('trackRows').innerHTML = noRows(6, 'Inicia sesión para ver circuitos.');
    }

    function renderProfile(data) {
      const summary = data.summary || {};
      const user = data.user || {};
      const pilot = data.pilot || {};

      $('profileTitle').textContent = pilot.name || user.displayName || 'Perfil piloto';
      $('profileText').textContent = data.linked ? 'Datos reales de rendimiento desde stracker.' : 'Cuenta activa, pendiente de vincular a un piloto real.';
      $('accountState').textContent = data.linked ? 'Vinculado' : 'Sin piloto';
      $('accountState').style.color = data.linked ? 'var(--accent)' : 'var(--warn)';
      $('profileBadges').innerHTML = `
        <span class="gc-chip gc-chip--accent">${escapeHtml(user.role || 'pilot')}</span>
        <span class="gc-chip">${escapeHtml(pilot.name || 'Sin piloto')}</span>
        <span class="gc-chip">${escapeHtml(summary.totalLaps || 0)} vueltas</span>
      `;
      $('profileMeta').innerHTML = `
        <div class="gc-status-row"><span>Email</span><strong>${escapeHtml(user.email)}</strong></div>
        <div class="gc-status-row"><span>Rol</span><strong>${escapeHtml(user.role || 'pilot')}</strong></div>
        <div class="gc-status-row"><span>Última actividad</span><strong>${escapeHtml(fmtDate(summary.lastSeenAt))}</strong></div>
      `;

      const rank = summary.bestRank ? `${summary.bestRank.position}/${summary.bestRank.total}` : '--';
      setMetric('metricBestLap', lapTime(summary.bestLap));
      setMetric('metricRank', rank);
      setMetric('metricValid', `${summary.validLaps || 0}/${summary.totalLaps || 0}`);
      setMetric('metricConsistency', summary.consistency || '--');

      $('summaryMeta').textContent = `${summary.carsCount || 0} coches · ${summary.tracksCount || 0} circuitos · ${summary.combosCount || 0} combos`;
      $('summaryRows').innerHTML = `
        <div><span>Limpieza</span><strong>${escapeHtml(summary.cleanRate ?? summary.validityRate ?? 0)}%</strong></div>
        <div><span>Media mejores 10</span><strong>${escapeHtml(summary.best10Average || '--')}</strong></div>
        <div><span>Delta top 10</span><strong>${escapeHtml(summary.best10Delta || '--')}</strong></div>
        <div><span>Vmax</span><strong>${escapeHtml(fmtSpeed(summary.maxSpeedKmh))}</strong></div>
        <div><span>Cortes totales</span><strong>${escapeHtml(summary.totalCuts ?? 0)}</strong></div>
        <div><span>Coche favorito</span><strong>${escapeHtml(summary.favoriteCar?.car?.name || summary.favoriteCar?.name || '-')}</strong></div>
        <div><span>Circuito favorito</span><strong>${escapeHtml(summary.favoriteTrack?.track?.name || summary.favoriteTrack?.name || '-')}</strong></div>
      `;

      const linkedPlayerId = pilot.id || data.pilotLink?.playerId || null;
      const publicAction = $('publicProfileAction');
      if (publicAction) {
        publicAction.hidden = !data.linked || !linkedPlayerId;
        if (data.linked && linkedPlayerId) publicAction.href = `/pilotos/${encodeURIComponent(linkedPlayerId)}`;
      }

      const rawGuid = String(pilot.steamGuid || data.pilotLink?.steamGuid || '');
      const shortGuid = rawGuid ? `${rawGuid.slice(0, 16)}...${rawGuid.slice(-8)}` : '-';

      $('linkedPilot').innerHTML = data.linked ? `
        <p><strong>${escapeHtml(pilot.name || data.pilotLink?.strackerName || '-')}</strong></p>
        <p class="gc-small">Player ID: ${escapeHtml(linkedPlayerId || '-')}</p>
        <p class="gc-small" title="${escapeHtml(rawGuid)}">Steam GUID: ${escapeHtml(shortGuid)}</p>
        <p class="gc-note">Vínculo creado: ${escapeHtml(fmtDate(data.pilotLink?.linkedAt))}</p>
        <div class="gc-actions">
          <a class="gc-btn gc-btn--primary" href="/pilotos/${encodeURIComponent(linkedPlayerId || '')}">Abrir perfil público</a>
          <button class="gc-btn" id="profileUnlinkPilotBtn" type="button">Desvincular piloto</button>
        </div>
        <p class="gc-message" id="profileUnlinkPilotMessage"></p>
      ` : `
        <p>Tu cuenta todavía no está vinculada a un piloto de stracker.</p>
        <p class="gc-note">Selecciona tu piloto real sin salir del perfil. Si hay nombres repetidos, usa el Player ID o Steam GUID para distinguirlos.</p>
        <div id="profileLinkPilotPanel" class="gc-slab"><p>Cargando pilotos disponibles...</p></div>
      `;

      if (!data.linked) initPilotLinker();
      else {
        const unlinkBtn = $('profileUnlinkPilotBtn');
        const unlinkMsg = $('profileUnlinkPilotMessage');
        unlinkBtn?.addEventListener('click', async () => {
          if (!window.confirm('¿Seguro que quieres desvincular este piloto de tu cuenta?')) return;
          unlinkBtn.disabled = true;
          if (unlinkMsg) unlinkMsg.textContent = 'Desvinculando piloto...';
          try {
            const response = await fetch('/api/auth/unlink-pilot', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: '{}'
            });
            const result = await response.json().catch(() => ({}));
            if (!response.ok || result.ok === false) throw new Error(result.message || 'No se pudo desvincular el piloto.');
            if (unlinkMsg) unlinkMsg.textContent = result.message || 'Piloto desvinculado.';
            window.location.reload();
          } catch (error) {
            if (unlinkMsg) unlinkMsg.textContent = error.message || 'Error desvinculando piloto.';
          } finally {
            unlinkBtn.disabled = false;
          }
        });
      }

      const combos = data.bestCombos || [];
      $('bestCombos').innerHTML = combos.length ? combos.slice(0, 18).map((lap, index) => `
        <tr>
          <td>${index + 1}</td>
          <td>${escapeHtml(carName(lap))}</td>
          <td>${escapeHtml(trackName(lap))}</td>
          <td><strong>${escapeHtml(lapTime(lap))}</strong></td>
          <td>${lap.rank ? `${escapeHtml(lap.rank.position)}/${escapeHtml(lap.rank.total)}` : '-'}</td>
          <td>${escapeHtml(cleanRate(lap.validLaps, lap.totalLaps))}</td>
        </tr>
      `).join('') : noRows(6, 'Sin combos válidos todavía.');

      const recent = data.recentLaps || [];
      $('recentLaps').innerHTML = recent.length ? recent.slice(0, 18).map((lap) => `
        <tr>
          <td>${escapeHtml(fmtDate(lap.timestampIso))}</td>
          <td>${escapeHtml(carName(lap))}</td>
          <td>${escapeHtml(trackName(lap))}</td>
          <td><strong>${escapeHtml(lapTime(lap))}</strong></td>
          <td>${lap.valid ? '<span class="gc-chip gc-chip--accent">Válida</span>' : '<span class="gc-chip">No válida</span>'}</td>
          <td>${escapeHtml(fmtSpeed(lap.maxSpeedKmh))}</td>
        </tr>
      `).join('') : noRows(6, 'Sin vueltas recientes.');

      const cars = data.cars || [];
      $('garageRows').innerHTML = cars.length ? cars.slice(0, 18).map((item) => `
        <tr>
          <td><strong>${escapeHtml(item.car?.name || '-')}</strong><br><span class="gc-muted-text">${escapeHtml(item.car?.brand || item.car?.code || '')}</span></td>
          <td>${escapeHtml(item.totalLaps || 0)}</td>
          <td>${escapeHtml(cleanRate(item.validLaps, item.totalLaps))}</td>
          <td><strong>${escapeHtml(item.bestLap || fmtMs(item.bestLapMs))}</strong></td>
          <td>${escapeHtml(item.tracksCount || 0)}</td>
          <td>${escapeHtml(fmtSpeed(item.maxSpeedKmh))}</td>
        </tr>
      `).join('') : noRows(6, 'Sin coches usados.');

      const tracks = data.tracks || [];
      $('trackRows').innerHTML = tracks.length ? tracks.slice(0, 18).map((item) => `
        <tr>
          <td><strong>${escapeHtml(item.track?.name || '-')}</strong><br><span class="gc-muted-text">${escapeHtml(item.track?.code || '')}</span></td>
          <td>${escapeHtml(item.totalLaps || 0)}</td>
          <td>${escapeHtml(cleanRate(item.validLaps, item.totalLaps))}</td>
          <td><strong>${escapeHtml(item.bestLap || fmtMs(item.bestLapMs))}</strong></td>
          <td>${escapeHtml(item.carsCount || 0)}</td>
          <td>${escapeHtml(fmtDate(item.lastSeenAt))}</td>
        </tr>
      `).join('') : noRows(6, 'Sin circuitos usados.');
    }

    fetch('/api/profile', { credentials: 'same-origin' })
      .then((response) => response.json())
      .then((data) => {
        if (!data.ok && data.authenticated === false) renderUnauthenticated(data);
        else renderProfile(data);
      })
      .catch((error) => {
        $('accountState').textContent = 'Error';
        $('accountState').style.color = 'var(--warn)';
        $('profileText').textContent = error.message || 'No se pudo cargar /api/profile.';
        $('recentLaps').innerHTML = noRows(6, 'No se pudo cargar el perfil.');
      });
  </script>
</AppLayout>

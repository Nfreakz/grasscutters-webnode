---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---
<MarketingLayout title="404 | GrassCutters Racing" description="Página no encontrada en GrassCutters Racing.">
  <section class="gc-page gc-page-narrow">
    <div class="gc-cta-box">
      <div>
        <span class="gc-kicker">404</span>
        <h1 class="gc-title">Esta curva no estaba en el mapa.</h1>
        <p>La página no existe o ha cambiado de sitio. Puedes volver a la landing o entrar directamente a la plataforma.</p>
      </div>
      <div class="gc-actions">
        <a class="gc-btn gc-btn-primary" href="/">Volver al inicio</a>
        <a class="gc-btn" href="/app">Abrir plataforma</a>
      </div>
    </div>
  </section>
</MarketingLayout>

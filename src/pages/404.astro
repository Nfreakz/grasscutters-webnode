---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---
<MarketingLayout title="404 | GrassCutters Racing" description="Página no encontrada en GrassCutters Racing.">
  <section class="gc-public-shell gc-public-section">
    <div class="gc-public-cta">
      <div>
        <span class="gc-public-kicker">404</span>
        <h1 class="gc-public-title">Esta curva no estaba en el mapa.</h1>
        <p class="gc-public-description">La página no existe o ha cambiado de sitio. Puedes volver a la landing o entrar directamente a la plataforma.</p>
      </div>
      <div class="gc-actions">
        <a class="gc-public-btn gc-public-btn-primary" href="/">Volver al inicio</a>
        <a class="gc-public-btn" href="/app">Abrir plataforma</a>
      </div>
    </div>
  </section>
</MarketingLayout>

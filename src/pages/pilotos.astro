---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout
  title="Pilotos | GrassCutters Racing"
  description="Directorio de pilotos de GrassCutters Racing con perfiles públicos, actividad reciente y datos desde stracker."
  canonicalPath="/pilotos"
  ogImage="/og/pilotos-og-v1531.png"
  ogImageAlt="Pilotos GrassCutters Racing"
>
  <div class="gc-page gc-pilotos-pro-v10">
    <section class="gc-hero gc-hero--compact gc-pilotos-hero-v10">
      <div>
        <span class="gc-kicker">Directorio de pilotos</span>
        <h1 class="gc-title">Pilotos.</h1>
        <p class="gc-subtitle">Actividad de la comunidad, perfiles públicos y referencias rápidas de cada piloto detectado por stracker.</p>
        <div class="gc-hero__meta">
          <span class="gc-chip gc-chip--accent">Nombres corregidos</span>
          <span class="gc-chip">Ficha pública</span>
          <span class="gc-chip">Actividad reciente</span>
        </div>
      </div>

      <aside class="gc-live-panel gc-pilotos-status-v10">
        <div class="gc-live-panel__title"><span>Directorio</span><strong id="pilotCount">...</strong></div>
        <div class="gc-status-list">
          <div class="gc-status-row"><span>Fuente</span><strong>stracker</strong></div>
          <div class="gc-status-row"><span>Visibles</span><strong id="pilotVisible">...</strong></div>
          <div class="gc-status-row"><span>Actualizado</span><strong id="pilotUpdated">...</strong></div>
        </div>
      </aside>
    </section>

    <section class="gc-metrics gc-pilotos-metrics-v10" aria-label="Resumen de pilotos">
      <div class="gc-metric"><span>Pilotos</span><strong id="metricPilots">...</strong><small>detectados</small></div>
      <div class="gc-metric"><span>Activos</span><strong id="metricActive">...</strong><small>últimos 7 días</small></div>
      <div class="gc-metric"><span>Vueltas</span><strong id="metricLaps">...</strong><small>total visible</small></div>
      <div class="gc-metric"><span>Más activo</span><strong id="metricTopLaps">...</strong><small id="metricTopPilot">cargando</small></div>
    </section>

    <section class="gc-toolbar gc-pilotos-toolbar-v10" aria-label="Filtros de pilotos">
      <div class="gc-field gc-pilotos-search-v10">
        <label for="pilotSearch">Buscar piloto</label>
        <input class="gc-input" id="pilotSearch" placeholder="Nombre, ID o Steam GUID" autocomplete="off" />
      </div>

      <div class="gc-field">
        <label for="pilotActivity">Actividad</label>
        <select class="gc-select" id="pilotActivity">
          <option value="all">Todos</option>
          <option value="recent">Activos recientes</option>
          <option value="withlaps">Con vueltas</option>
          <option value="online">Online</option>
          <option value="historic">Históricos</option>
        </select>
      </div>

      <div class="gc-field">
        <label for="pilotSort">Orden</label>
        <select class="gc-select" id="pilotSort">
          <option value="recent">Última actividad</option>
          <option value="laps">Más vueltas</option>
          <option value="age">Más antigüedad</option>
          <option value="name">Nombre</option>
        </select>
      </div>

      <div class="gc-pilotos-toolbar-v10__actions">
        <button class="gc-btn gc-btn--primary" id="reloadPilots" type="button">Actualizar</button>
        <button class="gc-btn" id="clearPilots" type="button">Limpiar</button>
      </div>
    </section>

    <section class="gc-section gc-pilotos-featured-v9 gc-pilotos-featured-restore">
      <div class="gc-section-head">
        <div>
          <span class="gc-kicker">Movimiento</span>
          <h2>Pilotos destacados</h2>
          <p>Lectura rápida de los pilotos con más actividad o movimiento reciente.</p>
        </div>
        <span class="gc-chip" id="pilotFeaturedCount">...</span>
      </div>

      <div class="gc-pilot-card-grid-v9" id="pilotCards">
        <article class="gc-pilot-card-v9"><strong>Cargando pilotos...</strong></article>
      </div>
    </section>

    <section class="gc-section gc-pilotos-table-section-v10">
      <div class="gc-section-head">
        <div>
          <span class="gc-kicker">Directorio</span>
          <h2>Listado completo</h2>
          <p id="pilotHint">Cargando listado...</p>
        </div>
        <a class="gc-btn gc-btn--primary" href="/hotlaps">Ver hotlaps</a>
      </div>

      <div class="gc-table-wrap gc-pilotos-table-wrap-v10">
        <table class="gc-table gc-pilotos-table-v10">
          <thead>
            <tr>
              <th>Avatar</th>
              <th>Piloto</th>
              <th>Estado</th>
              <th>Vueltas</th>
              <th>Antigüedad</th>
              <th>Última actividad</th>
              <th>Perfil</th>
            </tr>
          </thead>
          <tbody id="pilotRows"><tr><td colspan="7">Cargando pilotos...</td></tr></tbody>
        </table>
      </div>
    </section>
  </div>

  <style is:global>
    .gc-pilotos-pro-v10{
      display:grid;
      gap:clamp(18px,2.3vw,28px);
      width:100%;
      max-width:1480px;
      margin-inline:auto;
      padding-inline:clamp(8px,1.2vw,18px);
      box-sizing:border-box;
    }

    .gc-pilotos-hero-v10{
      position:relative;
      overflow:hidden;
      padding-block:clamp(26px,3.4vw,40px)!important;
      margin:0;
      border:1px solid color-mix(in srgb,var(--accent,#9dff00) 30%,var(--line));
      border-radius:28px;
      background:
        linear-gradient(120deg,rgba(255,255,255,.07),rgba(255,255,255,.018)),
        radial-gradient(circle at 82% 12%, color-mix(in srgb,var(--accent2,#35d3ff) 10%,transparent), transparent 22rem),
        radial-gradient(circle at 8% 18%, color-mix(in srgb,var(--accent,#9dff00) 12%,transparent), transparent 20rem);
      box-shadow:0 18px 70px rgba(0,0,0,.20), inset 0 0 0 1px rgba(255,255,255,.035);
    }

    .gc-pilotos-hero-v10::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background:
        linear-gradient(90deg,rgba(255,255,255,.045) 1px,transparent 1px),
        linear-gradient(0deg,rgba(255,255,255,.026) 1px,transparent 1px);
      background-size:42px 42px;
      opacity:.34;
      mask-image:linear-gradient(90deg,rgba(0,0,0,.48),transparent 72%);
    }

    .gc-pilotos-hero-v10 > *{
      position:relative;
      z-index:1;
    }

    .gc-pilotos-hero-v10 > div:first-child{
      padding-left:clamp(30px,4.2vw,86px);
    }

    .gc-pilotos-hero-v10 .gc-title{
      font-size:clamp(3.2rem,7vw,6rem);
      line-height:.86;
      letter-spacing:-.075em;
      margin:8px 0 12px;
    }

    .gc-pilotos-hero-v10 .gc-subtitle{
      max-width:820px;
      color:color-mix(in srgb,var(--text,#f2fff0) 74%,var(--muted));
    }

    .gc-pilotos-status-v10{
      width:min(420px,100%);
      justify-self:end;
      margin-right:clamp(28px,4vw,78px);
      align-self:center;
      min-height:auto;
      padding:0;
      overflow:hidden;
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb,var(--accent,#9dff00) 16%,transparent), transparent 10rem),
        rgba(0,0,0,.18);
      border-color:color-mix(in srgb,var(--accent,#9dff00) 18%,var(--line));
      box-shadow:inset 0 0 0 1px rgba(255,255,255,.035);
    }

    .gc-pilotos-status-v10 .gc-live-panel__title{
      padding:14px 16px;
      margin:0;
      border-bottom:1px solid rgba(255,255,255,.08);
      background:rgba(0,0,0,.14);
    }

    .gc-pilotos-status-v10 .gc-status-list{
      padding:0;
      gap:0;
    }

    .gc-pilotos-status-v10 .gc-status-row{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      padding:13px 16px;
      border-width:0 0 1px;
      border-radius:0;
      background:rgba(0,0,0,.08);
    }

    .gc-pilotos-status-v10 .gc-status-row:last-child{
      border-bottom:0;
    }

    .gc-pilotos-metrics-v10{
      margin:0;
      gap:0;
      border:1px solid color-mix(in srgb,var(--accent,#9dff00) 18%,var(--line));
      border-radius:0;
      overflow:hidden;
      background:rgba(255,255,255,.018);
    }

    .gc-pilotos-metrics-v10 .gc-metric{
      border-width:0 1px 0 0;
      border-radius:0;
      min-height:112px;
      box-shadow:none;
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb,var(--accent,#9dff00) 9%,transparent), transparent 8rem),
        linear-gradient(135deg,rgba(255,255,255,.052),rgba(255,255,255,.018));
    }

    .gc-pilotos-metrics-v10 .gc-metric:last-child{
      border-right:0;
    }

    .gc-pilotos-metrics-v10 .gc-metric strong{
      max-width:100%;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      font-size:clamp(1.85rem,3.2vw,2.85rem);
      line-height:.92;
      letter-spacing:-.06em;
      color:var(--text);
      font-variant-numeric:tabular-nums;
    }

    .gc-pilotos-toolbar-v10{
      display:grid;
      grid-template-columns:minmax(300px,1.7fr) minmax(170px,.8fr) minmax(170px,.8fr) auto;
      gap:10px;
      align-items:end;
      margin:0;
      padding:18px;
      border:1px solid rgba(255,255,255,.08);
      border-radius:24px;
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb,var(--accent,#9dff00) 7%,transparent), transparent 10rem),
        linear-gradient(135deg,rgba(255,255,255,.05),rgba(255,255,255,.016));
    }

    .gc-pilotos-toolbar-v10 .gc-field{
      min-width:0;
    }

    .gc-pilotos-toolbar-v10 .gc-input,
    .gc-pilotos-toolbar-v10 .gc-select{
      min-width:0;
      width:100%;
    }

    .gc-pilotos-toolbar-v10__actions{
      display:flex;
      gap:10px;
      align-items:end;
      justify-content:flex-end;
      flex-wrap:wrap;
    }

    .gc-pilotos-toolbar-v10__actions .gc-btn{
      min-height:40px;
      border-radius:999px;
    }

    .gc-pilotos-featured-restore,
    .gc-pilotos-table-section-v10{
      min-width:0;
      margin:0;
      border-radius:28px;
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb,var(--accent,#9dff00) 7%,transparent), transparent 16rem),
        linear-gradient(135deg,rgba(255,255,255,.045),rgba(255,255,255,.014));
      border:1px solid rgba(255,255,255,.08);
      box-shadow:0 18px 70px rgba(0,0,0,.16);
    }

    .gc-pilot-card-grid-v9{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:12px;
    }

    .gc-pilot-card-v9{
      position:relative;
      overflow:hidden;
      display:grid;
      gap:12px;
      min-height:156px;
      padding:14px;
      border:1px solid var(--line);
      border-radius:18px;
      background:linear-gradient(135deg,rgba(255,255,255,.052),rgba(255,255,255,.018));
      box-shadow:0 16px 48px rgba(0,0,0,.14);
    }

    .gc-pilot-card-v9::after{
      content:"";
      position:absolute;
      right:-44px;
      bottom:-54px;
      width:130px;
      height:130px;
      border:1px solid color-mix(in srgb,var(--accent) 24%,transparent);
      border-radius:50%;
      opacity:.2;
      pointer-events:none;
    }

    .gc-pilot-card-v9__top{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:10px;
    }

    .gc-pilot-card-v9__name{
      display:block;
      color:var(--text);
      font-size:1.08rem;
      line-height:1.05;
      font-weight:950;
      letter-spacing:-.04em;
      word-break:break-word;
    }

    .gc-pilot-card-v9__state{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:26px;
      padding:0 8px;
      border:1px solid var(--line);
      color:var(--soft);
      font-size:.62rem;
      font-weight:950;
      text-transform:uppercase;
      letter-spacing:.09em;
      white-space:nowrap;
      background:rgba(255,255,255,.025);
    }

    .gc-pilot-card-v9__state.is-online,
    .gc-pilot-card-v9__state.is-recent{
      color:var(--accent);
      border-color:color-mix(in srgb,var(--accent) 46%,transparent);
      background:color-mix(in srgb,var(--accent) 10%,transparent);
    }

    .gc-pilot-card-v9__meta{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:8px;
    }

    .gc-pilot-card-v9__metric{
      padding:9px;
      border:1px solid var(--line);
      border-radius:12px;
      background:rgba(255,255,255,.02);
    }

    .gc-pilot-card-v9__metric span{
      display:block;
      color:var(--dim);
      font-size:.62rem;
      font-weight:950;
      text-transform:uppercase;
      letter-spacing:.1em;
    }

    .gc-pilot-card-v9__metric strong{
      display:block;
      margin-top:5px;
      color:var(--text);
      font-size:1rem;
      line-height:1;
    }

    .gc-pilot-card-v9__last{
      margin:0;
      color:var(--soft);
      line-height:1.35;
      font-size:.84rem;
      min-height:2.35em;
    }

    .gc-pilot-card-v9__actions{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      margin-top:auto;
    }

    .gc-pilot-card-v9__actions small{
      color:var(--muted);
      font-size:.74rem;
    }


    .gc-pilotos-featured-restore .gc-section-head,
    .gc-pilotos-table-section-v10 .gc-section-head{
      padding:clamp(22px,2.4vw,32px) clamp(22px,2.6vw,34px) 16px;
      margin:0;
      border-bottom:1px solid rgba(255,255,255,.07);
    }

    .gc-pilotos-featured-restore .gc-pilot-card-grid-v9{
      padding:clamp(16px,2vw,24px) clamp(22px,2.6vw,34px) clamp(22px,2.6vw,34px);
    }

    .gc-pilotos-table-section-v10 .gc-table-wrap{
      margin:clamp(16px,2vw,22px) clamp(22px,2.6vw,34px) clamp(22px,2.6vw,34px);
    }

    .gc-pilotos-table-wrap-v10{
      max-height:calc(100vh - 260px);
      min-height:360px;
      overflow:auto;
      border:1px solid rgba(255,255,255,.08);
      border-radius:22px;
      background:rgba(0,0,0,.12);
    }

    .gc-pilotos-table-v10{
      min-width:980px;
    }

    .gc-pilotos-table-v10 thead th{
      position:sticky;
      top:0;
      z-index:2;
      background:color-mix(in srgb,var(--panel,#07110a) 92%,#000);
      color:color-mix(in srgb,var(--accent,#9dff00) 52%,var(--soft));
      backdrop-filter:blur(12px);
    }

    .gc-pilotos-table-v10 tbody tr{
      transition:background .16s ease;
    }

    .gc-pilotos-table-v10 tbody tr:hover td{
      background:color-mix(in srgb,var(--accent,#9dff00) 7%,transparent);
    }

    .gc-pilotos-table-v10 td:nth-child(4),
    .gc-pilotos-table-v10 td:nth-child(5),
    .gc-pilotos-table-v10 td:nth-child(6){
      white-space:nowrap;
      font-variant-numeric:tabular-nums;
    }


    .gc-pilotos-table-v10 th:first-child,
    .gc-pilotos-table-v10 td:first-child{
      width:86px;
      text-align:center;
    }

    .gc-piloto-avatar-cell-v14{
      display:inline-flex;
      width:46px;
      height:46px;
      align-items:center;
      justify-content:center;
      border:1px solid color-mix(in srgb,var(--accent,#9dff00) 34%,var(--line));
      border-radius:50%;
      background:
        radial-gradient(circle at 50% 50%, color-mix(in srgb,var(--accent,#9dff00) 18%,transparent), transparent 64%),
        rgba(0,0,0,.2);
      box-shadow:
        0 0 18px color-mix(in srgb,var(--accent,#9dff00) 12%,transparent),
        inset 0 0 0 2px rgba(0,0,0,.36);
      overflow:hidden;
    }

    .gc-piloto-avatar-cell-v14 img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
      border-radius:50%;
    }

    .gc-pilotos-toolbar-v10 .gc-field:has(#pilotSort){
      min-width:180px;
    }

    .gc-pilotos-rank-v10{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:32px;
      height:28px;
      border:1px solid var(--line);
      color:var(--soft);
      background:rgba(255,255,255,.025);
      font-weight:950;
      font-variant-numeric:tabular-nums;
    }

    .gc-pilotos-rank-v10.is-top{
      border-color:transparent;
      color:#061006;
      background:linear-gradient(135deg,var(--accent),var(--accent2));
      box-shadow:0 0 18px color-mix(in srgb,var(--accent,#9dff00) 16%,transparent);
    }

    .gc-piloto-name-v10{
      display:block;
      color:var(--text);
      font-weight:950;
      font-size:1rem;
      line-height:1.2;
      word-break:break-word;
    }

    .gc-piloto-sub-v10{
      display:block;
      margin-top:4px;
      color:var(--muted);
      font-size:.72rem;
      text-transform:uppercase;
      letter-spacing:.08em;
    }

    @media(max-width:1280px){
      .gc-pilot-card-grid-v9{
        grid-template-columns:repeat(3,minmax(0,1fr));
      }

      .gc-pilotos-toolbar-v10{
        grid-template-columns:repeat(3,minmax(0,1fr));
      }

      .gc-pilotos-toolbar-v10__actions{
        grid-column:1 / -1;
        justify-content:flex-start;
      }
    }

    @media(max-width:980px){
      .gc-pilotos-hero-v10 > div:first-child{
        padding-left:clamp(12px,2vw,24px);
      }

      .gc-pilotos-status-v10{
        margin-right:0;
        justify-self:stretch;
        width:100%;
      }

      .gc-pilot-card-grid-v9{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }

      .gc-pilotos-table-wrap-v10{
        max-height:none;
      }

      .gc-pilotos-metrics-v10{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }

      .gc-pilotos-metrics-v10 .gc-metric:nth-child(2){
        border-right:0;
      }

      .gc-pilotos-metrics-v10 .gc-metric:nth-child(n+3){
        border-top:1px solid var(--line);
      }
    }

    @media(max-width:640px){
      .gc-pilotos-pro-v10{
        padding-inline:0;
      }

      .gc-pilotos-hero-v10 > div:first-child{
        padding-left:0;
      }

      .gc-pilot-card-grid-v9,
      .gc-pilotos-toolbar-v10,
      .gc-pilotos-metrics-v10{
        grid-template-columns:1fr;
      }

      .gc-pilotos-toolbar-v10__actions{
        flex-direction:column;
      }

      .gc-pilotos-toolbar-v10__actions .gc-btn{
        width:100%;
        justify-content:center;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const rowsEl = document.getElementById('pilotRows');
      const cardsEl = document.getElementById('pilotCards');
      const countEl = document.getElementById('pilotCount');
      const visibleEl = document.getElementById('pilotVisible');
      const updatedEl = document.getElementById('pilotUpdated');
      const hintEl = document.getElementById('pilotHint');
      const featuredCountEl = document.getElementById('pilotFeaturedCount');
      const searchEl = document.getElementById('pilotSearch');
      const activityEl = document.getElementById('pilotActivity');
      const sortEl = document.getElementById('pilotSort');
      const reloadEl = document.getElementById('reloadPilots');
      const clearEl = document.getElementById('clearPilots');
      const metricPilots = document.getElementById('metricPilots');
      const metricActive = document.getElementById('metricActive');
      const metricLaps = document.getElementById('metricLaps');
      const metricTopLaps = document.getElementById('metricTopLaps');
      const metricTopPilot = document.getElementById('metricTopPilot');

      let pilots = [];
      let firstLapByPilot = new Map();

      const escapeHtml = (value) => String(value ?? '-').replace(/[&<>'"]/g, (char) => ({
        '&':'&amp;', '<':'&lt;', '>':'&gt;', "'":'&#39;', '"':'&quot;'
      }[char]));

      const valueAt = (source, path) => {
        if (!source || typeof source !== 'object') return undefined;
        if (Object.prototype.hasOwnProperty.call(source, path)) return source[path];
        return String(path).split('.').reduce((acc, part) => acc == null ? undefined : acc[part], source);
      };

      const firstValue = (source, paths) => {
        for (const path of paths) {
          const value = valueAt(source, path);
          if (value !== undefined && value !== null && value !== '') return value;
        }
        return '';
      };

      const textValue = (value, fallback = '-') => {
        if (value === undefined || value === null || value === '') return fallback;
        if (typeof value === 'object') {
          return String(
            value.displayName ??
            value.visibleName ??
            value.cleanName ??
            value.uiName ??
            value.name ??
            value.Name ??
            value.code ??
            fallback
          ).trim();
        }
        return String(value).trim() || fallback;
      };

      const cleanFallbackName = (value, fallback = '-') => {
        const raw = textValue(value, fallback);
        if (raw === fallback) return fallback;
        return raw.replace(/_/g, ' ').replace(/\s+/g, ' ').trim();
      };

      const normalize = (value) => cleanFallbackName(value, '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
      const displayFrom = (source, paths, fallback = '-') => cleanFallbackName(firstValue(source, paths), fallback);

      const pilotId = (pilot) => firstValue(pilot, ['id','playerId','PlayerId','driverId','pilotId']);
      const pilotName = (pilot) => displayFrom(pilot, ['displayName','visibleName','cleanName','name','Name','driverName','playerName','pilotName','driver.displayName','driver.name','player.name'], 'Piloto');
      const pilotGuid = (pilot) => firstValue(pilot, ['steamGuid','SteamGuid','guid','steamGUID']);
      const totalLaps = (pilot) => Number(firstValue(pilot, ['totalLaps','laps','lapCount','validLaps','stats.totalLaps'])) || 0;
      const bestLap = (pilot) => displayFrom(pilot, ['bestLap','bestLapTime','bestLapTimeFormatted','stats.bestLap','stats.bestLapTime'], '--');
      const lastCar = (pilot) => displayFrom(pilot, ['lastCarDisplayName','lastCarName','carDisplayName','carName','lastCar.displayName','lastCar.visibleName','lastCar.uiCarName','lastCar.name','car.displayName','car.name'], '-');
      const lastSeenRaw = (pilot) => firstValue(pilot, ['lastSeenAt','lastActivityAt','latestLapAt','updatedAt','timestampIso','lastLapAt','stats.lastSeenAt']);
      const firstSeenRaw = (pilot) => firstValue(pilot, ['firstSeenAt','firstActivityAt','firstLapAt','createdAt','registeredAt','stats.firstSeenAt','stats.firstLapAt']) || lastSeenRaw(pilot);
      const isOnline = (pilot) => Boolean(firstValue(pilot, ['isOnline','IsOnline','online','is_online']));

      const dateMs = (value) => {
        if (!value) return 0;
        if (typeof value === 'number') return value > 20000000000 ? value : value * 1000;
        const parsed = Date.parse(String(value));
        return Number.isFinite(parsed) ? parsed : 0;
      };

      const isRecent = (pilot) => {
        const ms = dateMs(lastSeenRaw(pilot));
        return ms > 0 && (Date.now() - ms) <= 7 * 24 * 60 * 60 * 1000;
      };

      const dateText = (value) => {
        const ms = dateMs(value);
        if (!ms) return '--';
        return new Date(ms).toLocaleString('es-ES', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
      };

      const ageText = (value) => {
        const ms = dateMs(value);
        if (!ms) return '--';

        const days = Math.max(0, Math.floor((Date.now() - ms) / (24 * 60 * 60 * 1000)));
        if (days <= 0) return 'Hoy';
        if (days === 1) return '1 día';
        if (days < 30) return `${days} días`;

        const years = Math.floor(days / 365);
        const remainingAfterYears = days - (years * 365);
        const months = Math.floor(remainingAfterYears / 30);
        const remainingDays = remainingAfterYears - (months * 30);

        const parts = [];
        if (years) parts.push(years === 1 ? '1 año' : `${years} años`);
        if (months) parts.push(months === 1 ? '1 mes' : `${months} meses`);
        if (!years && remainingDays) parts.push(remainingDays === 1 ? '1 día' : `${remainingDays} días`);

        return parts.slice(0, 2).join(' y ') || `${days} días`;
      };

      const pilotLookupKeys = (pilot) => {
        const keys = [
          pilotId(pilot),
          pilotGuid(pilot),
          pilotName(pilot),
          normalize(pilotName(pilot))
        ].filter(Boolean);

        return [...new Set(keys.map((key) => String(key)))];
      };

      const hotlapPilotKeys = (row) => {
        const values = [
          firstValue(row, ['playerId','driverId','PlayerId','driver.id','driver.playerId','pilot.id']),
          firstValue(row, ['steamGuid','SteamGuid','guid','driver.guid','player.guid']),
          displayFrom(row, ['driverDisplayName','driverVisibleName','displayName','driverName','playerName','pilotName','name','Name','driver.displayName','driver.visibleName','driver.name','player.displayName','player.name','driver'], '')
        ].filter(Boolean);

        const expanded = [];
        values.forEach((value) => {
          expanded.push(String(value));
          expanded.push(normalize(value));
        });

        return [...new Set(expanded.filter(Boolean))];
      };

      const hotlapDateMs = (row) => {
        const raw = firstValue(row, ['timestampIso','dateIso','createdAt','session.endTimeIso','session.startTimeIso','lastSeenAt','updatedAt']);
        return dateMs(raw);
      };

      const firstLapMs = (pilot) => {
        for (const key of pilotLookupKeys(pilot)) {
          const value = firstLapByPilot.get(key) || firstLapByPilot.get(normalize(key));
          if (value) return value;
        }

        return dateMs(firstSeenRaw(pilot));
      };

      const stateText = (pilot) => isOnline(pilot) ? 'Online' : isRecent(pilot) ? 'Activo' : 'Histórico';
      const stateClass = (pilot) => isOnline(pilot) ? 'is-online' : isRecent(pilot) ? 'is-recent' : '';
      const profileUrl = (pilot) => {
        const id = pilotId(pilot);
        return id ? `/pilotos/${encodeURIComponent(id)}` : '';
      };

      const pilotAvatarUrl = (pilot) => {
        const direct = firstValue(pilot, ['avatarUrl','avatar_url','imageUrl','image','driver.avatarUrl','player.avatarUrl','pilot.avatarUrl']);
        if (direct) return String(direct);

        const id = pilotId(pilot);
        if (id !== undefined && id !== null && id !== '') return `/api/pilot-avatar/${encodeURIComponent(String(id))}`;

        return '/images/pilot-avatar-default.png';
      };

      function sortedRows(rows) {
        const next = [...rows];
        const mode = sortEl.value;

        if (mode === 'name') {
          next.sort((a,b) => pilotName(a).localeCompare(pilotName(b), 'es', { sensitivity:'base' }));
        } else if (mode === 'laps') {
          next.sort((a,b) => totalLaps(b) - totalLaps(a) || dateMs(lastSeenRaw(b)) - dateMs(lastSeenRaw(a)));
        } else if (mode === 'age') {
          next.sort((a,b) => {
            const av = firstLapMs(a) || Number.MAX_SAFE_INTEGER;
            const bv = firstLapMs(b) || Number.MAX_SAFE_INTEGER;
            return av - bv || totalLaps(b) - totalLaps(a);
          });
        } else {
          next.sort((a,b) => dateMs(lastSeenRaw(b)) - dateMs(lastSeenRaw(a)) || totalLaps(b) - totalLaps(a));
        }

        return next;
      }

      function filteredRows() {
        const q = normalize(searchEl.value || '');
        const mode = activityEl.value;

        return sortedRows(pilots.filter((pilot) => {
          const haystack = normalize(`${pilotName(pilot)} ${pilotId(pilot) || ''} ${pilotGuid(pilot) || ''} ${lastCar(pilot) || ''}`);
          if (q && !haystack.includes(q)) return false;
          if (mode === 'recent' && !isRecent(pilot)) return false;
          if (mode === 'withlaps' && totalLaps(pilot) <= 0) return false;
          if (mode === 'online' && !isOnline(pilot)) return false;
          if (mode === 'historic' && (isRecent(pilot) || isOnline(pilot))) return false;
          return true;
        }));
      }

      function updateMetrics(rows) {
        const active = rows.filter(isRecent).length;
        const laps = rows.reduce((sum, pilot) => sum + totalLaps(pilot), 0);
        const top = [...rows].sort((a, b) => totalLaps(b) - totalLaps(a))[0];

        metricPilots.textContent = String(rows.length);
        metricActive.textContent = String(active);
        metricLaps.textContent = laps.toLocaleString('es-ES');
        metricTopLaps.textContent = top ? totalLaps(top).toLocaleString('es-ES') : '—';
        metricTopPilot.textContent = top ? pilotName(top) : 'sin datos';
      }

      function drawCards(rows) {
        const featured = sortedRows(rows.filter((pilot) => isRecent(pilot) || totalLaps(pilot) > 0)).slice(0, 8);
        featuredCountEl.textContent = `${featured.length} destacados`;

        cardsEl.innerHTML = featured.length ? featured.map((pilot) => {
          const url = profileUrl(pilot);

          return `
            <article class="gc-pilot-card-v9">
              <div class="gc-pilot-card-v9__top">
                <strong class="gc-pilot-card-v9__name">${escapeHtml(pilotName(pilot))}</strong>
                <span class="gc-pilot-card-v9__state ${stateClass(pilot)}">${escapeHtml(stateText(pilot))}</span>
              </div>

              <div class="gc-pilot-card-v9__meta">
                <div class="gc-pilot-card-v9__metric"><span>Vueltas</span><strong>${escapeHtml(totalLaps(pilot).toLocaleString('es-ES'))}</strong></div>
                <div class="gc-pilot-card-v9__metric"><span>Última conexión</span><strong>${escapeHtml(dateText(lastSeenRaw(pilot)))}</strong></div>
              </div>

              <p class="gc-pilot-card-v9__last">${escapeHtml(ageText(firstLapMs(pilot)))} en el servidor</p>

              <div class="gc-pilot-card-v9__actions">
                <small>${escapeHtml(isRecent(pilot) ? 'Actividad reciente' : 'Histórico')}</small>
                ${url ? `<a class="gc-btn gc-btn--mini" href="${escapeHtml(url)}">Abrir ficha</a>` : '<span class="gc-muted-text">Sin ficha</span>'}
              </div>
            </article>
          `;
        }).join('') : '<article class="gc-pilot-card-v9"><strong>Sin pilotos con movimiento.</strong><p class="gc-muted-text">No hay actividad reciente disponible.</p></article>';
      }

      function drawTable(rows) {
        visibleEl.textContent = String(rows.length);
        hintEl.textContent = `${rows.length} pilotos visibles de ${pilots.length}`;

        rowsEl.innerHTML = rows.map((pilot, index) => {
          const url = profileUrl(pilot);
          return `
            <tr>
              <td>
                <span class="gc-piloto-avatar-cell-v14">
                  <img src="${escapeHtml(pilotAvatarUrl(pilot))}" alt="Avatar de ${escapeHtml(pilotName(pilot))}" loading="lazy" onerror="this.onerror=null;this.src='/images/pilot-avatar-default.png';" />
                </span>
              </td>
              <td><strong class="gc-piloto-name-v10">${escapeHtml(pilotName(pilot))}</strong><span class="gc-piloto-sub-v10">${escapeHtml(isRecent(pilot) ? 'Actividad reciente' : 'Piloto registrado')}</span></td>
              <td><span class="gc-chip ${stateClass(pilot) ? 'gc-chip--accent' : ''}">${escapeHtml(stateText(pilot))}</span></td>
              <td><strong>${escapeHtml(totalLaps(pilot).toLocaleString('es-ES'))}</strong></td>
              <td>${escapeHtml(ageText(firstLapMs(pilot)))}</td>
              <td>${escapeHtml(dateText(lastSeenRaw(pilot)))}</td>
              <td>${url ? `<a class="gc-btn gc-btn--mini" href="${escapeHtml(url)}">Abrir ficha</a>` : '<span class="gc-muted-text">Sin ficha</span>'}</td>
            </tr>
          `;
        }).join('') || '<tr><td colspan="7">Sin pilotos con esos filtros.</td></tr>';
      }

      function draw() {
        const rows = filteredRows();
        updateMetrics(rows);
        drawCards(rows);
        drawTable(rows);

        console.info('[GC pilotos v2.4 avatar-sort]', {
          loaded: pilots.length,
          visible: rows.length,
          sort: sortEl.value,
          activity: activityEl.value
        });
      }


      async function loadFirstLapIndex() {
        firstLapByPilot = new Map();

        try {
          const response = await fetch('/api/gc/leaderboard?limit=25000&valid=all', { cache:'no-store', credentials:'include' });
          if (!response.ok) return;

          const data = await response.json();
          const hotlaps = Array.isArray(data) ? data : (data.items || data.hotlaps || data.laps || data.data || []);

          hotlaps.forEach((row) => {
            const ms = hotlapDateMs(row);
            if (!ms) return;

            hotlapPilotKeys(row).forEach((key) => {
              const current = firstLapByPilot.get(key);
              if (!current || ms < current) firstLapByPilot.set(key, ms);
            });
          });

          console.info('[GC pilotos v2.4] first lap index', {
            hotlaps: hotlaps.length,
            keys: firstLapByPilot.size
          });
        } catch (error) {
          console.warn('[GC pilotos v2.4] No se pudo crear índice de primera vuelta', error);
        }
      }

      async function load() {
        reloadEl.disabled = true;
        rowsEl.innerHTML = '<tr><td colspan="7">Cargando pilotos...</td></tr>';

        try {
          const response = await fetch('/api/pilots?limit=800&valid=all', { cache:'no-store', credentials:'include' });
          if (!response.ok) throw new Error('Endpoint no disponible');

          const data = await response.json();
          pilots = Array.isArray(data) ? data : (data.items || data.pilots || data.drivers || data.data || []);
          await loadFirstLapIndex();

          countEl.textContent = String(data.total ?? data.count ?? pilots.length);
          updatedEl.textContent = new Date().toLocaleTimeString('es-ES', { hour:'2-digit', minute:'2-digit' });

          draw();
        } catch (error) {
          countEl.textContent = 'Error';
          countEl.style.color = 'var(--warn)';
          hintEl.textContent = 'No se pudo cargar /api/pilots.';
          rowsEl.innerHTML = '<tr><td colspan="7">No se pudo cargar /api/pilots.</td></tr>';
          cardsEl.innerHTML = '<article class="gc-pilot-card-v9"><strong>Error cargando pilotos.</strong><p class="gc-muted-text">Revisa el endpoint /api/pilots.</p></article>';
          console.warn('[GC pilotos v2.4 avatar-sort] Error', error);
        } finally {
          reloadEl.disabled = false;
        }
      }

      [searchEl, activityEl, sortEl].forEach((input) => {
        input.addEventListener('input', draw);
        input.addEventListener('change', draw);
      });

      reloadEl.addEventListener('click', load);

      clearEl.addEventListener('click', () => {
        searchEl.value = '';
        activityEl.value = 'all';
        sortEl.value = 'recent';
        draw();
      });

      load();
    })();
  </script>
</AppLayout>

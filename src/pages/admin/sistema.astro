---
import AppLayout from '../../layouts/AppLayout.astro';
import AdminSubnav from '../../components/AdminSubnav.astro';
---
<AppLayout title="Admin sistema | GrassCutters">
  <div class="gc-page gc-admin-page-clean">
    <section class="gc-hero gc-hero--compact">
      <div><span class="gc-kicker">Administración</span><h1 class="gc-title">Sistema.</h1><p class="gc-subtitle">Storage, stracker, ACSM y herramientas de diagnóstico.</p></div>
      <aside class="gc-live-panel"><div class="gc-live-panel__title"><span>Sistema</span><strong id="systemState">Comprobando</strong></div><div class="gc-status-list"><div class="gc-status-row"><span>Storage</span><strong id="storageSource">...</strong></div><div class="gc-status-row"><span>stracker</span><strong id="strackerState">...</strong></div><div class="gc-status-row"><span>ACSM</span><strong id="acsmState">...</strong></div></div></aside>
    </section>
    <AdminSubnav />
    <section class="gc-section" id="adminGate" hidden><div class="gc-section-head"><h2>Acceso restringido</h2><p>Solo administradores</p></div><div class="gc-slab"><p>Inicia sesión con una cuenta administradora.</p><div class="gc-actions"><a class="gc-btn gc-btn--primary" href="/login">Login</a><button class="gc-btn" id="retryAdmin" type="button">Reintentar</button></div></div></section>
    <section id="adminContent" hidden>
      <section class="gc-grid-2">
        <div class="gc-section"><div class="gc-section-head"><h2>Storage persistente</h2><p>Usuarios, sesiones, alias y calendario.</p></div><div class="gc-slab-list" id="storageRows"><div><span>Storage</span><strong>Cargando...</strong></div></div><p class="gc-message" id="storageMessage"></p></div>
        <div class="gc-section"><div class="gc-section-head"><h2>stracker</h2><p>Base de datos de vueltas.</p></div><div class="gc-slab-list" id="strackerRows"><div><span>DB</span><strong>Cargando...</strong></div></div><div class="gc-actions"><button class="gc-btn gc-btn--primary" id="forceSyncBtn" type="button">Forzar sync</button><a class="gc-btn" href="/app">Ver panel</a></div><p class="gc-message" id="syncMessage"></p></div>
      </section>
      <section class="gc-section"><div class="gc-section-head"><h2>ACSM</h2><p>Sincronización del combo activo desde Assetto Corsa Server Manager.</p></div><div class="gc-slab-list" id="acsmRows"><div><span>Estado</span><strong>Cargando...</strong></div></div><div class="gc-actions"><button class="gc-btn" id="checkAcsmBtn" type="button">Probar conexión</button><button class="gc-btn gc-btn--primary" id="syncAcsmBtn" type="button">Sincronizar combo</button><a class="gc-btn" href="/admin/calendario">Ver calendario admin</a></div><p class="gc-message" id="acsmMessage"></p></section>
    </section>
  </div>
  <script is:inline>
    (()=>{const $=(id)=>document.getElementById(id);const els={gate:$('adminGate'),content:$('adminContent'),retry:$('retryAdmin'),system:$('systemState'),storageSource:$('storageSource'),strackerState:$('strackerState'),acsmState:$('acsmState'),storageRows:$('storageRows'),storageMessage:$('storageMessage'),strackerRows:$('strackerRows'),syncMessage:$('syncMessage'),forceSyncBtn:$('forceSyncBtn'),acsmRows:$('acsmRows'),acsmMessage:$('acsmMessage'),checkAcsmBtn:$('checkAcsmBtn'),syncAcsmBtn:$('syncAcsmBtn')};const esc=(v)=>String(v??'').replace(/[&<>'"]/g,(c)=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));const short=(v)=>{const t=String(v||'-');return t.length>60?'...'+t.slice(-57):t};async function fetchJson(url,options={}){const r=await fetch(url,{credentials:'include',cache:'no-store',headers:{'Content-Type':'application/json'},...options});const d=await r.json().catch(()=>({}));if(!r.ok||d.ok===false)throw new Error(d.message||`HTTP ${r.status}`);return d}async function isAdmin(){try{const s=await fetchJson('/api/admin/status');if(s.authorized===true)return s}catch{}const p=await fetchJson('/api/profile');if(p.user?.role==='admin')return {authorized:true,currentUser:p.user,admin:{}};return null}function show(mode){els.gate.hidden=mode!=='gate';els.content.hidden=mode!=='content'}function renderStatus(data){els.system.textContent='OK';const storage=data.admin?.storage||{};const storageRoot=storage.storage||storage;const files=storage.files||{};els.storageSource.textContent=files.users?.source||storageRoot.source||'-';els.storageRows.innerHTML=`<div><span>Usuarios</span><strong>${esc(files.users?.source||storageRoot.source||'-')}</strong></div><div><span>Nombres</span><strong>${esc(files.displayNames?.source||storageRoot.source||'-')}</strong></div><div><span>Persistente</span><strong>${storageRoot.persistent===false?'No':'Sí'}</strong></div><div><span>Ruta</span><strong>${esc(short(storageRoot.dataRoot||files.users?.resolvedPath||'-'))}</strong></div>`;const s=data.admin?.stracker||{};els.strackerState.textContent=s.exists?'OK':'No';els.strackerRows.innerHTML=`<div><span>Existe</span><strong>${s.exists?'Sí':'No'}</strong></div><div><span>SQLite</span><strong>${s.validSQLite?'Válido':'-'}</strong></div><div><span>Tamaño</span><strong>${Math.round(((s.sizeBytes||0)/1024/1024)*10)/10} MB</strong></div><div><span>Ruta</span><strong>${esc(short(s.resolvedPath||'-'))}</strong></div>`}async function checkAcsm(){try{els.acsmMessage.textContent='Comprobando ACSM...';const d=await fetchJson('/api/admin/acsm/status');els.acsmState.textContent=d.authorized?'OK':'No';els.acsmRows.innerHTML=`<div><span>Guard</span><strong>${esc(d.source||'-')}</strong></div><div><span>Host</span><strong>${d.config?.hostConfigured?'OK':'Falta'}</strong></div><div><span>User</span><strong>${d.config?.userConfigured?'OK':'Falta'}</strong></div><div><span>Password</span><strong>${d.config?.passwordConfigured?'OK':'Falta'}</strong></div>`;els.acsmMessage.textContent='ACSM disponible.';els.acsmMessage.style.color='var(--accent)'}catch(e){els.acsmState.textContent='Error';els.acsmRows.innerHTML=`<div><span>Error</span><strong>${esc(e.message||'No disponible')}</strong></div>`;els.acsmMessage.textContent=e.message||'No se pudo comprobar ACSM.'}}async function syncAcsm(){try{els.acsmMessage.textContent='Sincronizando combo...';const d=await fetchJson('/api/admin/acsm/sync-current-combo',{method:'POST'});els.acsmMessage.textContent=`Combo sincronizado. Storage: ${d.source||'-'}. Eventos: ${d.totalEvents??'-'}`;els.acsmMessage.style.color='var(--accent)';await checkAcsm()}catch(e){els.acsmMessage.textContent=e.message||'No se pudo sincronizar.';els.acsmMessage.style.color='var(--soft)'}}async function forceSync(){try{els.syncMessage.textContent='Solicitando sync...';await fetchJson('/api/admin/stracker/sync',{method:'POST'});els.syncMessage.textContent='Sync solicitado.';els.syncMessage.style.color='var(--accent)'}catch(e){els.syncMessage.textContent=e.message||'No se pudo forzar sync.'}}async function init(){show('gate');try{const status=await isAdmin();if(!status?.authorized)return show('gate');show('content');let full=status;try{full=await fetchJson('/api/admin/status')}catch{}renderStatus(full);await checkAcsm()}catch{show('gate')}}els.retry.addEventListener('click',init);els.checkAcsmBtn.addEventListener('click',checkAcsm);els.syncAcsmBtn.addEventListener('click',syncAcsm);els.forceSyncBtn.addEventListener('click',forceSync);init()})();
  </script>
</AppLayout>

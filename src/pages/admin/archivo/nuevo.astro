---
export const prerender = false;
import AppLayout from '../../../layouts/AppLayout.astro';
import AdminSubnav from '../../../components/AdminSubnav.astro';
---
<AppLayout title="Nueva ficha | Archivo Motorsport">
  <div class="gc-page gc-admin-page-clean">
    <section class="gc-hero gc-hero--compact"><div><span class="gc-kicker">Archivo Motorsport</span><h1 class="gc-title">Nueva ficha.</h1><p class="gc-subtitle">Crear ficha nueva con API unificada.</p></div></section>
    <AdminSubnav />
    <section class="gc-section">
      <form class="gc-form" id="newArchiveForm">
        <div class="gc-field"><label>Título</label><input id="title" required /></div>
        <div class="gc-field"><label>Slug</label><input id="slug" /></div>
        <div class="gc-field"><label>Categoría</label><select id="category"><option value="circuitos">Circuito</option><option value="pilotos">Piloto</option><option value="vehiculos">Vehículo</option><option value="campeonatos">Campeonato</option><option value="records">Récord</option><option value="glosario">Glosario</option></select></div>
        <div class="gc-field"><label>Estado</label><select id="status"><option value="draft">Borrador</option><option value="published">Publicado</option></select></div>
        <div class="gc-field"><label>Resumen</label><textarea id="summary" rows="4"></textarea></div>
        <div class="gc-field"><label>Texto largo</label><textarea id="body" rows="8"></textarea></div>
        <div class="gc-actions"><button class="gc-btn gc-btn--primary" type="submit">Crear ficha</button><a class="gc-btn" href="/admin/archivo">Volver</a></div>
        <p class="gc-message" id="msg"></p>
      </form>
    </section>
  </div>
  <script is:inline>
    (()=>{const API='/api/admin/archive/unified'; const $=(id)=>document.getElementById(id); const slugify=(v)=>String(v||'').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,''); $('title').addEventListener('input',()=>{ if(!$('slug').dataset.touched) $('slug').value=slugify($('title').value); }); $('slug').addEventListener('input',()=>{$('slug').dataset.touched='1';}); async function post(payload){ const r=await fetch(`${API}/items`,{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}); const d=await r.json().catch(()=>({})); if(!r.ok||d.ok===false) throw new Error(d.message||`HTTP ${r.status}`); return d;} $('newArchiveForm').addEventListener('submit',async(e)=>{e.preventDefault(); $('msg').textContent='Creando...'; try{const d=await post({title:$('title').value,slug:$('slug').value,category:$('category').value,status:$('status').value,summary:$('summary').value,body:$('body').value}); window.location.href=`/admin/archivo/editar/${encodeURIComponent(d.item.id)}`;}catch(err){$('msg').textContent=err.message||'No se pudo crear.';}});})();
  </script>
</AppLayout>

---
export const prerender = false;
import AppLayout from '../../../layouts/AppLayout.astro';
import AdminSubnav from '../../../components/AdminSubnav.astro';
---
<AppLayout title="Archivo Motorsport · Imagen por URL">
  <section class="gc-archive-url-page">
    <AdminSubnav />
    <header class="gc-archive-url-hero"><p class="gc-archive-kicker">Archivo Motorsport</p><h1>Añadir imagen desde URL</h1><p>Selecciona una ficha desde MySQL/local y añade una imagen externa como media.</p></header>
    <div class="gc-archive-url-card">
      <form id="media-url-form" class="gc-archive-url-form">
        <label class="gc-field gc-field--full"><span>Ficha</span><select id="itemId" name="itemId" required><option value="">Cargando fichas...</option></select></label>
        <label class="gc-field gc-field--full"><span>URL de imagen</span><div class="gc-url-row"><input id="imageUrl" name="imageUrl" type="url" required placeholder="https://..." /><button type="button" id="inspectBtn" class="gc-button-secondary">Leer datos</button></div></label>
        <label class="gc-field gc-field--full"><span>Texto alternativo</span><input id="alt" name="alt" type="text" /></label>
        <label class="gc-field"><span>Fuente</span><input id="source" name="source" type="text" value="URL externa" /></label>
        <label class="gc-field"><span>URL fuente</span><input id="sourceUrl" name="sourceUrl" type="url" /></label>
        <label class="gc-field"><span>Autor</span><input id="author" name="author" type="text" /></label>
        <label class="gc-field"><span>Licencia</span><input id="license" name="license" type="text" /></label>
        <div class="gc-checks gc-field--full"><label><input type="checkbox" id="makePrimary" name="makePrimary" checked /> Marcar como portada</label><label><input type="checkbox" id="locked" name="locked" checked /> Bloquear imagen buena</label></div>
        <div class="gc-actions gc-field--full"><button type="submit" class="gc-button-primary">Añadir imagen</button><a class="gc-button-secondary" href="/admin/archivo">Volver</a></div>
      </form>
      <aside class="gc-archive-url-preview"><h2>Vista previa</h2><div class="gc-preview-frame"><img id="previewImg" src="" alt="" hidden /><span id="previewEmpty">Sin imagen todavía</span></div><div id="metaBox" class="gc-meta-box">Pega una URL y pulsa “Leer datos”.</div></aside>
    </div>
    <div id="status" class="gc-status" hidden></div>
  </section>
  <style is:global>.gc-archive-url-page{max-width:1180px;margin:0 auto;padding:24px 18px 56px}.gc-archive-url-hero{margin:18px 0 20px;padding:24px;border:1px solid rgba(137,195,92,.22);border-radius:24px;background:linear-gradient(135deg,rgba(137,195,92,.10),rgba(255,255,255,.03))}.gc-archive-kicker{margin:0 0 8px;color:#9fd46f;font-weight:800;letter-spacing:.08em;text-transform:uppercase;font-size:.78rem}.gc-archive-url-card{display:grid;grid-template-columns:minmax(0,1.2fr) 360px;gap:18px}.gc-archive-url-form,.gc-archive-url-preview{padding:20px;border:1px solid rgba(255,255,255,.10);border-radius:24px;background:rgba(255,255,255,.04)}.gc-archive-url-form{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}.gc-field{display:grid;gap:7px}.gc-field--full{grid-column:1/-1}.gc-field input,.gc-field select{width:100%;box-sizing:border-box;padding:12px 14px;border-radius:14px;border:1px solid rgba(255,255,255,.14);background:rgba(5,10,8,.68);color:inherit}.gc-url-row{display:grid;grid-template-columns:1fr auto;gap:10px}.gc-button-primary,.gc-button-secondary{border:0;border-radius:999px;padding:12px 18px;font-weight:800;text-decoration:none;cursor:pointer}.gc-button-primary{background:#89c35c;color:#081008}.gc-button-secondary{background:rgba(255,255,255,.08);color:rgba(255,255,255,.9);border:1px solid rgba(255,255,255,.12)}.gc-preview-frame{display:grid;place-items:center;aspect-ratio:16/10;border-radius:18px;background:rgba(0,0,0,.28);overflow:hidden}.gc-preview-frame img{width:100%;height:100%;object-fit:cover}.gc-meta-box{margin-top:14px;padding:14px;border-radius:16px;background:rgba(0,0,0,.18)}.gc-status{max-width:1180px;margin:18px auto 0;padding:14px 16px;border-radius:16px}.gc-status.ok{display:block;background:rgba(64,168,96,.15);border:1px solid rgba(64,168,96,.45);color:#c4f4d4}.gc-status.error{display:block;background:rgba(205,61,75,.14);border:1px solid rgba(205,61,75,.45);color:#ffd0d6}@media(max-width:900px){.gc-archive-url-card{grid-template-columns:1fr}.gc-archive-url-form{grid-template-columns:1fr}.gc-url-row{grid-template-columns:1fr}}</style>
  <script is:inline>
    (()=>{const API='/api/admin/archive/unified'; const $=(id)=>document.getElementById(id); function showStatus(kind,msg){$('status').hidden=false;$('status').className=`gc-status ${kind}`;$('status').innerHTML=msg;} function preview(url){if(!url)return;$('previewImg').src=url;$('previewImg').hidden=false;$('previewEmpty').hidden=true;} async function json(url,opt={}){const r=await fetch(url,{credentials:'include',cache:'no-store',headers:{'Content-Type':'application/json'},...opt});const d=await r.json().catch(()=>({}));if(!r.ok||d.ok===false)throw new Error(d.message||`HTTP ${r.status}`);return d;} async function loadItems(){try{const d=await json(`${API}/items`);$('itemId').innerHTML='<option value="">Selecciona una ficha</option>'+(d.items||[]).map(i=>`<option value="${i.id}">${i.title} · ${i.category} · ${i.status}</option>`).join('');}catch(e){$('itemId').innerHTML='<option value="">No se pudieron cargar fichas</option>';showStatus('error',e.message);}} $('inspectBtn').addEventListener('click',async()=>{const url=$('imageUrl').value.trim();if(!url)return showStatus('error','Pega una URL primero.');preview(url);try{const d=await json(`${API}/media/inspect-url`,{method:'POST',body:JSON.stringify({imageUrl:url})});const m=d.metadata||{};$('source').value=m.source||$('source').value;$('sourceUrl').value=m.sourceUrl||url;$('metaBox').innerHTML=`Fuente: ${m.source||'pendiente'}<br>Licencia: ${m.license||'pendiente'}`;showStatus('ok','Metadatos leídos.');}catch(e){showStatus('error',e.message||'No se pudieron leer datos.');}}); $('media-url-form').addEventListener('submit',async(e)=>{e.preventDefault();const itemId=$('itemId').value; if(!itemId)return showStatus('error','Selecciona una ficha.'); const payload={imageUrl:$('imageUrl').value,alt:$('alt').value,source:$('source').value,sourceUrl:$('sourceUrl').value,author:$('author').value,license:$('license').value,makePrimary:$('makePrimary').checked,locked:$('locked').checked}; try{const d=await json(`${API}/items/${encodeURIComponent(itemId)}/media/from-url`,{method:'POST',body:JSON.stringify(payload)});showStatus('ok',`Imagen añadida a <strong>${d.itemTitle}</strong>.`);}catch(err){showStatus('error',err.message||'No se pudo añadir.');}});loadItems();})();
  </script>
</AppLayout>

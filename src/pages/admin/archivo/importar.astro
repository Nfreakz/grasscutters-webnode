---
export const prerender = false;

import AppLayout from '../../../layouts/AppLayout.astro';
import AdminSubnav from '../../../components/AdminSubnav.astro';
---

<AppLayout title="Importar Archivo | Admin GrassCutters">
  <div class="gc-page gc-admin-page-clean gc-archive-import-page">
    <section class="gc-hero gc-hero--compact">
      <div>
        <span class="gc-kicker">Archivo</span>
        <h1 class="gc-title">Importar CSV.</h1>
        <p class="gc-subtitle">
          Importa fichas por lotes con plantillas PRO preparadas para dossiers completos:
          historia, contexto, datos técnicos, referencias, imágenes y conexiones.
        </p>
      </div>

      <aside class="gc-live-panel">
        <div class="gc-live-panel__title">
          <span>Modo seguro</span>
          <strong>Dry-run</strong>
        </div>
        <div class="gc-status-list">
          <div class="gc-status-row"><span>Taxonomía</span><strong>4 tipos</strong></div>
          <div class="gc-status-row"><span>Récords</span><strong>Internos</strong></div>
          <div class="gc-status-row"><span>Campeonatos</span><strong>Internos</strong></div>
        </div>
      </aside>
    </section>

    <AdminSubnav />

    <section class="gc-section gc-archive-import-templates">
      <div class="gc-section-head">
        <div>
          <h2>Plantillas PRO</h2>
          <p>
            Descarga una plantilla según el tipo de ficha. Ya incluyen los campos editoriales nuevos
            para que la ficha pública no quede pobre después de importar.
          </p>
        </div>
      </div>

      <div class="gc-archive-import-template-grid">
        <article>
          <span>Circuitos PRO</span>
          <h3>Dossier de trazado</h3>
          <p>Historia, importancia, zonas clave, eventos, récords, referencias y notas de sim racing.</p>
          <button class="gc-btn gc-btn--primary" type="button" data-template-download="circuitos">Descargar CSV</button>
        </article>

        <article>
          <span>Coches PRO</span>
          <h3>Ficha técnica + historia</h3>
          <p>Fabricante, specs, variantes, campeonatos, equipos, victorias y contexto competitivo.</p>
          <button class="gc-btn gc-btn--primary" type="button" data-template-download="vehiculos">Descargar CSV</button>
        </article>

        <article>
          <span>Pilotos PRO</span>
          <h3>Trayectoria completa</h3>
          <p>Biografía, palmarés, estilo, momentos clave, coches asociados y circuitos asociados.</p>
          <button class="gc-btn gc-btn--primary" type="button" data-template-download="pilotos">Descargar CSV</button>
        </article>

        <article>
          <span>Glosario PRO</span>
          <h3>Conceptos útiles</h3>
          <p>Definición, uso práctico, errores comunes, ejemplos, relaciones y notas para sim racing.</p>
          <button class="gc-btn gc-btn--primary" type="button" data-template-download="glosario">Descargar CSV</button>
        </article>
      </div>
    </section>

    <section class="gc-section gc-archive-import-guide">
      <div class="gc-section-head">
        <div>
          <h2>Reglas de formato</h2>
          <p>Pequeño mapa para que el CSV salga bien a la primera.</p>
        </div>
      </div>

      <div class="gc-archive-import-guide-grid">
        <article>
          <strong>Listas</strong>
          <p>Usa <code>||</code> para separar elementos.</p>
          <pre>Ferrari||Porsche||BMW</pre>
        </article>
        <article>
          <strong>Pares título + dato</strong>
          <p>Usa <code>Título::Descripción</code>.</p>
          <pre>Karussell::Curva peraltada icónica</pre>
        </article>
        <article>
          <strong>Fuentes</strong>
          <p>Usa el mismo sistema de pares.</p>
          <pre>Wikipedia::https://...</pre>
        </article>
        <article>
          <strong>No crear categorías antiguas</strong>
          <p><code>records</code> y <code>campeonatos</code> van dentro de fichas.</p>
          <pre>records_destacados / campeonatos</pre>
        </article>
      </div>
    </section>

    <section class="gc-section">
      <div class="gc-section-head">
        <div>
          <h2>Subir CSV</h2>
          <p>
            Sube uno o varios archivos. Mantén activado “solo probar” hasta que el resumen sea correcto.
          </p>
        </div>
      </div>

      <div class="gc-slab gc-import-box">
        <label class="gc-field">
          <span>CSV</span>
          <input class="gc-input" id="archivoCsvFiles" type="file" accept=".csv,text/csv" multiple />
          <small>Admite varios CSV a la vez. Separador recomendado: punto y coma.</small>
        </label>

        <div class="gc-archive-import-options">
          <label class="gc-check"><input id="archivoDryRun" type="checkbox" checked /> Solo probar, no escribir</label>
          <label class="gc-check"><input id="archivoPublish" type="checkbox" /> Publicar directamente</label>
          <label class="gc-check"><input id="archivoForce" type="checkbox" /> Actualizar existentes</label>
        </div>

        <div class="gc-archive-import-warning">
          <strong>Regla actual</strong>
          <p>
            Si un CSV trae <code>records</code> o <code>campeonatos</code> como categoría, el backend lo convertirá en
            <code>general</code>. Usa los campos internos <code>records_destacados</code>, <code>campeonatos</code>,
            <code>palmares</code> o <code>eventos_destacados</code>.
          </p>
        </div>

        <div class="gc-admin-actions">
          <button class="gc-btn gc-btn--primary" id="archivoImportBtn" type="button">Importar CSV</button>
          <a class="gc-btn" href="/admin/archivo">Volver</a>
        </div>

        <p class="gc-message" id="archivoImportMsg"></p>
      </div>
    </section>

    <section class="gc-section" id="archivoImportSummarySection" hidden>
      <div class="gc-section-head">
        <div>
          <h2>Resumen</h2>
          <p>Resultado legible de la prueba o importación.</p>
        </div>
      </div>

      <div class="gc-archive-import-summary" id="archivoImportSummary"></div>
    </section>

    <section class="gc-section" id="archivoImportResultSection" hidden>
      <div class="gc-section-head">
        <div>
          <h2>Respuesta técnica</h2>
          <p>JSON completo devuelto por la API.</p>
        </div>
      </div>
      <pre class="gc-import-result" id="archivoImportResult"></pre>
    </section>
  </div>

  <style is:global>
    .gc-archive-import-page code{
      padding:.12rem .32rem;
      border:1px solid rgba(255,255,255,.10);
      border-radius:7px;
      background:rgba(0,0,0,.22);
      color:var(--accent,#9cff3f);
      font-size:.9em;
    }

    .gc-archive-import-templates{
      overflow:visible;
    }

    .gc-archive-import-template-grid,
    .gc-archive-import-guide-grid{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:12px;
    }

    .gc-archive-import-template-grid article,
    .gc-archive-import-guide-grid article{
      display:grid;
      align-content:start;
      gap:10px;
      min-height:230px;
      padding:18px;
      border:1px solid var(--line);
      border-radius:22px;
      background:
        radial-gradient(circle at 90% 12%, rgba(156,255,63,.10), transparent 36%),
        rgba(255,255,255,.025);
    }

    .gc-archive-import-guide-grid article{
      min-height:0;
    }

    .gc-archive-import-template-grid span,
    .gc-field small,
    .gc-archive-import-summary-card span{
      color:var(--dim);
      font-size:.72rem;
      font-weight:900;
      letter-spacing:.11em;
      text-transform:uppercase;
    }

    .gc-archive-import-template-grid h3{
      margin:0;
      color:var(--text);
      font-size:1.35rem;
      line-height:1.05;
      letter-spacing:-.04em;
    }

    .gc-archive-import-template-grid p,
    .gc-archive-import-warning p,
    .gc-archive-import-guide-grid p{
      margin:0;
      color:var(--soft);
      line-height:1.55;
    }

    .gc-archive-import-guide-grid strong{
      font-size:1.1rem;
      line-height:1.1;
    }

    .gc-archive-import-guide-grid pre{
      margin:0;
      padding:10px;
      border:1px solid rgba(255,255,255,.08);
      border-radius:12px;
      background:rgba(0,0,0,.22);
      color:var(--soft);
      white-space:pre-wrap;
      overflow-wrap:anywhere;
      font-size:.82rem;
    }

    .gc-import-box{
      display:grid;
      gap:16px;
    }

    .gc-field{
      display:grid;
      gap:7px;
    }

    .gc-field small{
      display:block;
      margin-top:2px;
      line-height:1.35;
    }

    .gc-archive-import-options{
      display:flex;
      flex-wrap:wrap;
      gap:12px;
      align-items:center;
    }

    .gc-check{
      display:flex;
      gap:8px;
      align-items:center;
      color:var(--soft);
      padding:10px 12px;
      border:1px solid rgba(255,255,255,.08);
      border-radius:999px;
      background:rgba(255,255,255,.025);
    }

    .gc-archive-import-warning{
      padding:14px;
      border:1px solid rgba(255,194,87,.22);
      border-radius:18px;
      background:rgba(255,194,87,.065);
    }

    .gc-archive-import-warning strong{
      display:block;
      margin-bottom:6px;
      color:#ffe0a3;
      font-size:.75rem;
      font-weight:950;
      letter-spacing:.12em;
      text-transform:uppercase;
    }

    .gc-archive-import-summary{
      display:grid;
      gap:12px;
    }

    .gc-archive-import-summary-grid{
      display:grid;
      grid-template-columns:repeat(5,minmax(0,1fr));
      gap:10px;
    }

    .gc-archive-import-summary-card{
      padding:16px;
      border:1px solid var(--line);
      border-radius:18px;
      background:rgba(255,255,255,.025);
    }

    .gc-archive-import-summary-card strong{
      display:block;
      margin-top:6px;
      color:var(--text);
      font-size:clamp(1.6rem,3vw,2.8rem);
      line-height:1;
      letter-spacing:-.06em;
    }

    .gc-archive-import-samples{
      display:grid;
      gap:8px;
    }

    .gc-archive-import-sample{
      display:grid;
      grid-template-columns:minmax(0,1fr) auto auto auto;
      gap:10px;
      align-items:center;
      padding:12px;
      border:1px solid rgba(255,255,255,.08);
      border-radius:16px;
      background:rgba(0,0,0,.14);
    }

    .gc-archive-import-sample strong{
      overflow-wrap:anywhere;
    }

    .gc-archive-import-sample span{
      display:inline-flex;
      align-items:center;
      min-height:28px;
      padding:0 9px;
      border:1px solid rgba(255,255,255,.10);
      border-radius:999px;
      color:var(--soft);
      font-size:.78rem;
    }

    .gc-import-result{
      white-space:pre-wrap;
      word-break:break-word;
      padding:16px;
      border:1px solid var(--line);
      border-radius:18px;
      background:rgba(0,0,0,.24);
      color:var(--soft);
      max-height:520px;
      overflow:auto;
    }

    @media(max-width:1180px){
      .gc-archive-import-template-grid,
      .gc-archive-import-guide-grid,
      .gc-archive-import-summary-grid{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }
    }

    @media(max-width:720px){
      .gc-archive-import-template-grid,
      .gc-archive-import-guide-grid,
      .gc-archive-import-summary-grid,
      .gc-archive-import-sample{
        grid-template-columns:1fr;
      }

      .gc-archive-import-options{
        display:grid;
      }
    }
  </style>


---
export const prerender = false;
import AppLayout from '../../../layouts/AppLayout.astro';
import AdminSubnav from '../../../components/AdminSubnav.astro';
---
<AppLayout title="Importar Archivo Motorsport | GrassCutters">
  <div class="gc-page gc-admin-page-clean">
    <section class="gc-hero gc-hero--compact"><div><span class="gc-kicker">Archivo Motorsport</span><h1 class="gc-title">Importar CSV.</h1><p class="gc-subtitle">Subida web con API unificada. Prueba primero, importa después.</p></div></section>
    <AdminSubnav />
    <section class="gc-section"><div class="gc-slab gc-import-box">
      <label class="gc-field"><span>CSV</span><input class="gc-input" id="archivoCsvFiles" type="file" accept=".csv,text/csv" multiple /></label>
      <div class="gc-admin-actions"><label class="gc-check"><input id="archivoDryRun" type="checkbox" checked /> Solo probar, no escribir</label><label class="gc-check"><input id="archivoPublish" type="checkbox" /> Publicar directamente</label><label class="gc-check"><input id="archivoForce" type="checkbox" /> Actualizar existentes</label></div>
      <div class="gc-admin-actions"><button class="gc-btn gc-btn--primary" id="archivoImportBtn" type="button">Importar CSV</button><a class="gc-btn" href="/admin/archivo">Volver</a></div>
      <p class="gc-message" id="archivoImportMsg"></p>
    </div></section>
    <section class="gc-section" id="archivoImportResultSection" hidden><pre class="gc-import-result" id="archivoImportResult"></pre></section>
  </div>
  <style>.gc-import-box{display:grid;gap:16px}.gc-check{display:flex;gap:8px;align-items:center;color:var(--soft)}.gc-import-result{white-space:pre-wrap;word-break:break-word;padding:16px;border:1px solid var(--line);background:rgba(0,0,0,.24);color:var(--soft);max-height:520px;overflow:auto}</style>
  <script is:inline>
    (()=>{const API='/api/admin/archive/unified'; const $=(id)=>document.getElementById(id); async function readFile(file){return {name:file.name,content:await file.text()};} async function post(payload){const r=await fetch(`${API}/import-csv`,{method:'POST',credentials:'include',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)}); const d=await r.json().catch(()=>({})); if(!r.ok||d.ok===false) throw new Error(d.message||`HTTP ${r.status}`); return d;} $('archivoImportBtn').addEventListener('click',async()=>{const files=Array.from($('archivoCsvFiles').files||[]); if(!files.length){$('archivoImportMsg').textContent='Selecciona al menos un CSV.';return;} $('archivoImportBtn').disabled=true; $('archivoImportMsg').textContent='Leyendo CSV...'; try{const payload={files:await Promise.all(files.map(readFile)),dryRun:$('archivoDryRun').checked,publish:$('archivoPublish').checked,force:$('archivoForce').checked}; const data=await post(payload); $('archivoImportMsg').textContent=data.dryRun?`Prueba completada. Crear ${data.created}, actualizar ${data.updated}, omitidas ${data.skipped}, estado=${data.forcedStatus}.`:`Importación completada. Crear ${data.created}, actualizar ${data.updated}, omitidas ${data.skipped}, estado=${data.forcedStatus}.`; $('archivoImportResult').textContent=JSON.stringify(data,null,2); $('archivoImportResultSection').hidden=false;}catch(e){$('archivoImportMsg').textContent=e.message||'Error importando.';}finally{$('archivoImportBtn').disabled=false;}});})();
  </script>
</AppLayout>

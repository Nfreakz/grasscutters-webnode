---
export const prerender = false;
import AppLayout from '../../../layouts/AppLayout.astro';
import AdminSubnav from '../../../components/AdminSubnav.astro';
---
<AppLayout title="Relaciones | Archivo Motorsport">
  <div class="gc-page gc-admin-page-clean">
    <section class="gc-hero gc-hero--compact"><div><span class="gc-kicker">Archivo Motorsport</span><h1 class="gc-title">Relaciones.</h1><p class="gc-subtitle">Relaciones manuales guardadas con API unificada.</p></div></section>
    <AdminSubnav />
    <section class="gc-grid-2 archive-relations-shell">
      <aside class="gc-section"><div class="gc-section-head"><h2>Fichas</h2><p>Selecciona una ficha.</p></div><input class="gc-input" id="relationSearch" placeholder="Buscar..." /><div class="archive-relations-list" id="relationItems"></div></aside>
      <section class="gc-section"><div class="gc-section-head"><h2 id="selectedTitle">Relaciones</h2><p id="selectedSubtitle">Elige una ficha.</p></div><div class="gc-slab" id="emptySelection"><h3>Sin ficha seleccionada</h3></div><div id="relationEditor" hidden><div class="gc-slab"><h3>Manual</h3><div class="archive-manual-form"><select class="gc-input" id="manualRelationTarget"></select><input class="gc-input" id="manualRelationLabel" placeholder="Etiqueta" /><button class="gc-btn" id="addManualRelation" type="button">Añadir</button></div><div class="archive-relation-stack" id="manualRelations"></div></div><div class="gc-actions"><button class="gc-btn gc-btn--primary" id="saveRelations" type="button">Guardar relaciones</button><a class="gc-btn" id="editItemLink" href="#">Editar ficha</a></div><p class="gc-message" id="relationMessage"></p></div></section>
    </section>
  </div>
  <style is:global>.archive-relations-list{display:grid;gap:8px;max-height:62vh;overflow:auto}.archive-relations-item{width:100%;text-align:left;border:1px solid var(--line);background:rgba(255,255,255,.018);color:var(--text);padding:11px 12px;cursor:pointer}.archive-relations-item.is-active{border-color:var(--accent)}.archive-manual-form{display:grid;grid-template-columns:1.2fr 1fr auto;gap:8px}.archive-relation-row{display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center;border:1px solid var(--line);padding:10px 12px;background:rgba(255,255,255,.018);margin-top:8px}@media(max-width:900px){.archive-manual-form,.archive-relation-row{grid-template-columns:1fr}}</style>
  <script is:inline>
    (()=>{const API='/api/admin/archive/unified';const $=(id)=>document.getElementById(id);const esc=(v)=>String(v??'').replace(/[&<>'"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));let items=[],selected=null,draft={auto:[],manual:[],hidden:[],pinned:[]};async function json(url,opt={}){const r=await fetch(url,{credentials:'include',cache:'no-store',headers:{'Content-Type':'application/json'},...opt});const d=await r.json().catch(()=>({}));if(!r.ok||d.ok===false)throw new Error(d.message||`HTTP ${r.status}`);return d;}function relId(r){return r.id||r.targetId||r.target||'';}function renderList(){const q=$('relationSearch').value.toLowerCase();const list=items.filter(i=>(`${i.title} ${i.slug}`).toLowerCase().includes(q));$('relationItems').innerHTML=list.map(i=>`<button class="archive-relations-item ${selected?.id===i.id?'is-active':''}" data-id="${esc(i.id)}"><strong>${esc(i.title)}</strong><br><small>${esc(i.category)} · ${(i.relations?.manual||[]).length} manuales</small></button>`).join('')||'<div class="gc-admin-empty">No hay fichas.</div>';$('relationItems').querySelectorAll('[data-id]').forEach(b=>b.addEventListener('click',()=>select(b.dataset.id)));}function select(id){selected=items.find(i=>i.id===id);draft=JSON.parse(JSON.stringify(selected.relations||{auto:[],manual:[],hidden:[],pinned:[]}));draft.manual ||= [];$('emptySelection').hidden=true;$('relationEditor').hidden=false;$('selectedTitle').textContent=selected.title;$('selectedSubtitle').textContent=selected.slug||selected.id;$('editItemLink').href=`/admin/archivo/editar/${encodeURIComponent(selected.id)}`;renderRelations();renderList();}function renderRelations(){$('manualRelationTarget').innerHTML=items.filter(i=>i.id!==selected.id).map(i=>`<option value="${esc(i.id)}">${esc(i.title)}</option>`).join('');$('manualRelations').innerHTML=draft.manual.length?draft.manual.map(r=>`<div class="archive-relation-row"><span><strong>${esc(r.title||r.targetId)}</strong><small>${esc(r.label||'manual')}</small></span><button class="gc-btn" data-remove="${esc(relId(r))}">Quitar</button></div>`).join(''):'<div class="gc-admin-empty">Sin relaciones manuales.</div>';$('manualRelations').querySelectorAll('[data-remove]').forEach(b=>b.addEventListener('click',()=>{draft.manual=draft.manual.filter(r=>relId(r)!==b.dataset.remove);renderRelations();}));}$('addManualRelation').addEventListener('click',()=>{const id=$('manualRelationTarget').value;const target=items.find(i=>i.id===id);if(!target||draft.manual.some(r=>relId(r)===id))return;draft.manual.push({id,targetId:id,title:target.title,label:$('manualRelationLabel').value||'relación manual',source:'manual'});$('manualRelationLabel').value='';renderRelations();});$('saveRelations').addEventListener('click',async()=>{if(!selected)return;$('relationMessage').textContent='Guardando...';try{const d=await json(`${API}/items/${encodeURIComponent(selected.id)}`,{method:'PATCH',body:JSON.stringify({...selected,relations:draft})});items=items.map(i=>i.id===d.item.id?d.item:i);selected=d.item;$('relationMessage').textContent='Relaciones guardadas.';renderList();}catch(e){$('relationMessage').textContent=e.message||'No se pudo guardar.';}});$('relationSearch').addEventListener('input',renderList);async function load(){try{const d=await json(`${API}/items`);items=d.items||[];renderList();}catch(e){$('relationItems').innerHTML=`<div class="gc-admin-empty">${esc(e.message)}</div>`;}}load();})();
  </script>
</AppLayout>

---
import AppLayout from '../../../layouts/AppLayout.astro';
import AdminSubnav from '../../../components/AdminSubnav.astro';

export const prerender = false;
---
<AppLayout title="Relaciones | Archivo Motorsport">
  <div class="gc-page gc-admin-page-clean gc-archive-relations-page">
    <section class="gc-hero gc-hero--compact">
      <div>
        <span class="gc-kicker">Archivo Motorsport</span>
        <h1 class="gc-title">Relaciones.</h1>
        <p class="gc-subtitle">Revisa las relaciones automáticas, fija conexiones importantes, oculta las flojas y añade relaciones manuales sin tocar JSON.</p>
        <div class="gc-hero__meta">
          <span class="gc-chip gc-chip--accent">Auto + manual</span>
          <span class="gc-chip">No pisa locks</span>
          <span class="gc-chip">Admin</span>
        </div>
      </div>
      <aside class="gc-live-panel">
        <div class="gc-live-panel__title"><span>Relaciones</span><strong id="archiveRelationState">Cargando</strong></div>
        <div class="gc-status-list" id="archiveRelationStats">
          <div class="gc-status-row"><span>Fichas</span><strong>...</strong></div>
        </div>
      </aside>
    </section>

    <AdminSubnav />

    <section class="gc-section" id="relationGate" hidden>
      <div class="gc-section-head"><h2>Acceso restringido</h2><p>Solo administradores</p></div>
      <div class="gc-slab">
        <h3>No tienes permisos de admin</h3>
        <p>Inicia sesión con una cuenta administradora.</p>
        <div class="gc-actions"><a class="gc-btn gc-btn--primary" href="/login">Login</a><button class="gc-btn" id="relationRetry" type="button">Reintentar</button></div>
      </div>
    </section>

    <section id="relationContent" hidden>
      <section class="gc-grid-2 archive-relations-shell">
        <aside class="gc-section archive-relations-list-panel">
          <div class="gc-section-head"><h2>Fichas</h2><p>Selecciona una ficha para revisar relaciones.</p></div>
          <div class="gc-admin-actions">
            <input class="gc-input gc-input--compact" id="relationSearch" placeholder="Buscar ficha..." />
            <select class="gc-input gc-input--compact" id="relationTypeFilter">
              <option value="">Todas</option>
              <option value="circuit">Circuitos</option>
              <option value="driver">Pilotos</option>
              <option value="vehicle">Vehículos</option>
              <option value="championship">Campeonatos</option>
              <option value="record">Récords</option>
              <option value="glossary">Glosario</option>
            </select>
          </div>
          <div class="archive-relations-list" id="relationItems"></div>
        </aside>

        <section class="gc-section archive-relations-editor">
          <div class="gc-section-head"><h2 id="selectedTitle">Relaciones</h2><p id="selectedSubtitle">Elige una ficha.</p></div>

          <div class="gc-slab" id="emptySelection">
            <h3>Sin ficha seleccionada</h3>
            <p>Selecciona una ficha de la lista para ver sus relaciones automáticas y manuales.</p>
          </div>

          <div id="relationEditor" hidden>
            <div class="gc-slab">
              <h3>Relaciones automáticas</h3>
              <p class="gc-admin-note">Estas vienen del generador. Puedes ocultarlas o fijarlas como importantes.</p>
              <div class="archive-relation-stack" id="autoRelations"></div>
            </div>

            <div class="gc-slab">
              <h3>Relaciones manuales</h3>
              <p class="gc-admin-note">Añade relaciones que el sistema no haya detectado. Se guardan como manuales y tienen prioridad.</p>
              <div class="archive-manual-form">
                <select class="gc-input" id="manualRelationTarget"></select>
                <input class="gc-input" id="manualRelationLabel" placeholder="Etiqueta opcional, por ejemplo: trazado histórico" />
                <button class="gc-btn" id="addManualRelation" type="button">Añadir</button>
              </div>
              <div class="archive-relation-stack" id="manualRelations"></div>
            </div>

            <div class="gc-actions">
              <button class="gc-btn gc-btn--primary" id="saveRelations" type="button">Guardar relaciones</button>
              <a class="gc-btn" id="editItemLink" href="#">Editar ficha</a>
              <a class="gc-btn" id="publicItemLink" href="#" target="_blank" rel="noreferrer">Ver pública</a>
            </div>
            <p class="gc-message" id="relationMessage"></p>
          </div>
        </section>
      </section>
    </section>
  </div>

  <style is:global>
    .archive-relations-shell{align-items:start}.archive-relations-list-panel{position:sticky;top:16px}.archive-relations-list{display:grid;gap:8px;max-height:62vh;overflow:auto;padding-right:4px}.archive-relations-item{width:100%;text-align:left;border:1px solid var(--line);background:rgba(255,255,255,.018);color:var(--text);padding:11px 12px;cursor:pointer;display:grid;gap:3px}.archive-relations-item:hover,.archive-relations-item.is-active{border-color:var(--accent);background:rgba(122,255,144,.08)}.archive-relations-item strong{font-size:.9rem}.archive-relations-item small{color:var(--dim)}.archive-relation-stack{display:grid;gap:8px;margin-top:10px}.archive-relation-row{display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center;border:1px solid var(--line);padding:10px 12px;background:rgba(255,255,255,.018)}.archive-relation-row.is-hidden{opacity:.55}.archive-relation-row.is-pinned{border-color:var(--accent)}.archive-relation-row__meta{display:grid;gap:2px}.archive-relation-row__meta strong{font-size:.9rem}.archive-relation-row__meta small{color:var(--dim)}.archive-relation-actions{display:flex;gap:6px;flex-wrap:wrap;justify-content:flex-end}.archive-manual-form{display:grid;grid-template-columns:1.2fr 1fr auto;gap:8px}@media(max-width:900px){.archive-relations-list-panel{position:static}.archive-manual-form{grid-template-columns:1fr}.archive-relation-row{grid-template-columns:1fr}}
  </style>

  <script is:inline>
    (() => {
      const $ = (id) => document.getElementById(id);
      const els = {
        gate: $('relationGate'), content: $('relationContent'), retry: $('relationRetry'), state: $('archiveRelationState'), stats: $('archiveRelationStats'),
        search: $('relationSearch'), typeFilter: $('relationTypeFilter'), items: $('relationItems'), selectedTitle: $('selectedTitle'), selectedSubtitle: $('selectedSubtitle'),
        empty: $('emptySelection'), editor: $('relationEditor'), auto: $('autoRelations'), manual: $('manualRelations'), target: $('manualRelationTarget'), label: $('manualRelationLabel'), add: $('addManualRelation'), save: $('saveRelations'), msg: $('relationMessage'), editLink: $('editItemLink'), publicLink: $('publicItemLink')
      };
      const esc = (v) => String(v ?? '').replace(/[&<>'"]/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));
      let items = [];
      let selected = null;
      let draft = null;

      const typeLabel = (type) => ({ circuit:'Circuito', driver:'Piloto', vehicle:'Vehículo', championship:'Campeonato', record:'Récord', glossary:'Glosario' }[type] || type || 'Ficha');
      const categorySlug = (type) => ({ circuit:'circuitos', driver:'pilotos', vehicle:'vehiculos', championship:'campeonatos', record:'records', glossary:'glosario' }[type] || type || 'items');
      const publicUrl = (item) => `/archivo/${categorySlug(item.type)}/${item.slug}/`;

      async function fetchJson(url, options = {}) {
        const response = await fetch(url, { credentials:'include', cache:'no-store', headers:{ 'Content-Type':'application/json' }, ...options });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || data.ok === false) throw new Error(data.message || `HTTP ${response.status}`);
        return data;
      }
      async function isAdmin() {
        try { const s = await fetchJson('/api/admin/status'); if (s.authorized === true || s.setupRequired === true) return true; } catch {}
        try { const p = await fetchJson('/api/profile'); if (p?.user?.role === 'admin' || p?.role === 'admin') return true; } catch {}
        try { const a = await fetchJson('/api/admin/archive/status'); if (a.ok === true) return true; } catch {}
        return false;
      }
      function show(mode) { els.gate.hidden = mode !== 'gate'; els.content.hidden = mode !== 'content'; }
      function normalizeItem(raw) {
        return {
          ...raw,
          id: String(raw.id || raw.slug || cryptoRandom()),
          title: raw.title || raw.name || 'Sin título',
          type: raw.type || raw.category || 'circuit',
          slug: raw.slug || '',
          status: raw.status || 'draft',
          relations: raw.relations || { auto: [], manual: [], hidden: [], pinned: [] }
        };
      }
      function cryptoRandom(){ return Math.random().toString(36).slice(2); }
      async function loadItems() {
        const data = await fetchJson('/api/admin/archive/items');
        const list = Array.isArray(data.items) ? data.items : Array.isArray(data.data) ? data.data : Array.isArray(data) ? data : [];
        items = list.map(normalizeItem).sort((a,b) => String(a.title).localeCompare(String(b.title)));
        els.state.textContent = 'Activo';
        els.stats.innerHTML = `<div class="gc-status-row"><span>Fichas</span><strong>${items.length}</strong></div><div class="gc-status-row"><span>Con relaciones</span><strong>${items.filter((i)=>relationCount(i)>0).length}</strong></div>`;
        renderList();
      }
      function relationCount(item) {
        const r = item.relations || {};
        return (r.auto?.length || 0) + (r.manual?.length || 0);
      }
      function filteredItems() {
        const q = String(els.search.value || '').toLowerCase().trim();
        const t = els.typeFilter.value;
        return items.filter((item) => (!t || item.type === t) && (!q || `${item.title} ${item.slug}`.toLowerCase().includes(q)));
      }
      function renderList() {
        const list = filteredItems();
        els.items.innerHTML = list.length ? list.map((item) => `<button type="button" class="archive-relations-item ${selected?.id === item.id ? 'is-active' : ''}" data-id="${esc(item.id)}"><strong>${esc(item.title)}</strong><small>${esc(typeLabel(item.type))} · ${esc(item.status)} · ${relationCount(item)} relaciones</small></button>`).join('') : '<div class="gc-admin-empty">No hay fichas.</div>';
        els.items.querySelectorAll('[data-id]').forEach((btn) => btn.addEventListener('click', () => selectItem(btn.dataset.id)));
      }
      function selectItem(id) {
        selected = items.find((item) => item.id === id) || null;
        if (!selected) return;
        draft = JSON.parse(JSON.stringify(selected.relations || { auto: [], manual: [], hidden: [], pinned: [] }));
        draft.auto ||= []; draft.manual ||= []; draft.hidden ||= []; draft.pinned ||= [];
        els.empty.hidden = true; els.editor.hidden = false;
        els.selectedTitle.textContent = selected.title;
        els.selectedSubtitle.textContent = `${typeLabel(selected.type)} · ${selected.slug || selected.id}`;
        els.editLink.href = `/admin/archivo/editar/${encodeURIComponent(selected.id)}`;
        els.publicLink.href = publicUrl(selected);
        renderRelations();
        renderList();
      }
      function relationTargetTitle(targetId) {
        return items.find((item) => item.id === targetId)?.title || targetId;
      }
      function relationTargetMeta(targetId) {
        const item = items.find((x) => x.id === targetId);
        return item ? `${typeLabel(item.type)} · ${item.slug || item.id}` : 'Relación';
      }
      function relationId(rel) { return rel.id || rel.targetId || rel.target || rel.itemId || ''; }
      function isHidden(rel) { return draft.hidden.includes(relationId(rel)); }
      function isPinned(rel) { return draft.pinned.includes(relationId(rel)); }
      function renderRelations() {
        const auto = draft.auto || [];
        els.auto.innerHTML = auto.length ? auto.map((rel) => relationHtml(rel, 'auto')).join('') : '<div class="gc-admin-empty">No hay relaciones automáticas. Ejecuta rebuild-archivo-relations si quieres recalcularlas.</div>';
        els.manual.innerHTML = (draft.manual || []).length ? draft.manual.map((rel) => relationHtml(rel, 'manual')).join('') : '<div class="gc-admin-empty">No hay relaciones manuales.</div>';
        els.target.innerHTML = items.filter((item) => item.id !== selected.id).map((item) => `<option value="${esc(item.id)}">${esc(item.title)} · ${esc(typeLabel(item.type))}</option>`).join('');
        document.querySelectorAll('[data-rel-action]').forEach((btn) => btn.addEventListener('click', () => handleRelationAction(btn.dataset.relAction, btn.dataset.relId, btn.dataset.relKind)));
      }
      function relationHtml(rel, kind) {
        const id = relationId(rel);
        const title = rel.title || relationTargetTitle(id);
        const label = rel.label || rel.reason || rel.type || (kind === 'manual' ? 'manual' : 'auto');
        return `<div class="archive-relation-row ${isHidden(rel) ? 'is-hidden' : ''} ${isPinned(rel) ? 'is-pinned' : ''}"><div class="archive-relation-row__meta"><strong>${esc(title)}</strong><small>${esc(label)} · ${esc(relationTargetMeta(id))}</small></div><div class="archive-relation-actions"><button class="gc-btn" type="button" data-rel-kind="${kind}" data-rel-id="${esc(id)}" data-rel-action="pin">${isPinned(rel) ? 'Soltar' : 'Fijar'}</button><button class="gc-btn" type="button" data-rel-kind="${kind}" data-rel-id="${esc(id)}" data-rel-action="hide">${isHidden(rel) ? 'Mostrar' : 'Ocultar'}</button>${kind === 'manual' ? `<button class="gc-btn" type="button" data-rel-kind="manual" data-rel-id="${esc(id)}" data-rel-action="remove">Quitar</button>` : ''}</div></div>`;
      }
      function toggleInArray(arr, value) {
        const i = arr.indexOf(value);
        if (i >= 0) arr.splice(i, 1); else arr.push(value);
      }
      function handleRelationAction(action, id, kind) {
        if (!id) return;
        if (action === 'pin') toggleInArray(draft.pinned, id);
        if (action === 'hide') toggleInArray(draft.hidden, id);
        if (action === 'remove' && kind === 'manual') draft.manual = draft.manual.filter((rel) => relationId(rel) !== id);
        renderRelations();
      }
      els.add?.addEventListener('click', () => {
        const targetId = els.target.value;
        if (!targetId) return;
        const target = items.find((item) => item.id === targetId);
        if (!target) return;
        if ((draft.manual || []).some((rel) => relationId(rel) === targetId)) return;
        draft.manual.push({ id: targetId, targetId, title: target.title, label: els.label.value.trim() || 'relación manual', source: 'manual' });
        els.label.value = '';
        renderRelations();
      });
      els.save?.addEventListener('click', async () => {
        if (!selected) return;
        els.msg.textContent = 'Guardando relaciones...';
        const payload = { ...selected, relations: draft };
        try {
          let data;
          try {
            data = await fetchJson(`/api/admin/archive/items/${encodeURIComponent(selected.id)}`, { method:'PATCH', body: JSON.stringify(payload) });
          } catch (_) {
            data = await fetchJson(`/api/admin/archive/items/${encodeURIComponent(selected.id)}`, { method:'PUT', body: JSON.stringify(payload) });
          }
          const saved = normalizeItem(data.item || data.data || payload);
          items = items.map((item) => item.id === saved.id ? saved : item);
          selected = saved;
          draft = JSON.parse(JSON.stringify(saved.relations || draft));
          els.msg.textContent = 'Relaciones guardadas.';
          els.msg.style.color = 'var(--accent)';
          renderRelations(); renderList();
        } catch (error) {
          els.msg.textContent = error.message || 'No se pudieron guardar las relaciones.';
          els.msg.style.color = 'var(--soft)';
        }
      });
      els.search?.addEventListener('input', renderList);
      els.typeFilter?.addEventListener('change', renderList);
      els.retry?.addEventListener('click', init);
      async function init() {
        show('gate');
        const ok = await isAdmin();
        if (!ok) return;
        show('content');
        try { await loadItems(); } catch (error) { els.state.textContent = 'Error'; els.items.innerHTML = `<div class="gc-admin-empty">${esc(error.message || 'No se pudo cargar el Archivo Motorsport.')}</div>`; }
      }
      init();
    })();
  </script>
</AppLayout>

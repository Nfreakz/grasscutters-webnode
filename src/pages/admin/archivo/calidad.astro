---
export const prerender = false;
import AppLayout from '../../../layouts/AppLayout.astro';
import AdminSubnav from '../../../components/AdminSubnav.astro';
---
<AppLayout title="Calidad Archivo Motorsport | GrassCutters">
  <div class="gc-page gc-admin-page-clean">
    <section class="gc-hero gc-hero--compact"><div><span class="gc-kicker">Archivo Motorsport</span><h1 class="gc-title">Calidad y publicación.</h1><p class="gc-subtitle">Checklist calculado desde la API unificada.</p></div></section>
    <AdminSubnav />
    <section class="gc-metrics" id="qualityMetrics"></section>
    <section class="gc-section"><div class="gc-section-head"><h2>Checklist de fichas</h2><p>Portada, resumen, texto, datos y publicación.</p></div><div class="archive-quality-table" id="qualityRows"><div class="gc-admin-empty">Cargando...</div></div></section>
  </div>
  <style is:global>.archive-quality-table{display:grid;gap:8px}.archive-quality-row{display:grid;grid-template-columns:1.3fr .6fr .6fr .55fr 1.6fr auto;gap:10px;align-items:center;padding:12px 14px;border:1px solid var(--line);background:rgba(255,255,255,.018)}.archive-quality-row--head{font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;color:var(--dim)}.archive-quality-row small{display:block;color:var(--dim)}@media(max-width:980px){.archive-quality-row{grid-template-columns:1fr}.archive-quality-row--head{display:none}}</style>
  <script is:inline>
    (()=>{const API='/api/admin/archive/unified';const $=(id)=>document.getElementById(id);const esc=(v)=>String(v??'').replace(/[&<>'"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));async function json(url){const r=await fetch(url,{credentials:'include',cache:'no-store'});const d=await r.json().catch(()=>({}));if(!r.ok||d.ok===false)throw new Error(d.message||`HTTP ${r.status}`);return d;}function score(i){let s=0,issues=[];if(i.status==='published')s+=20;else issues.push('No publicada');if(String(i.summary||'').length>=80)s+=20;else issues.push('Resumen corto');if(String(i.body||'').length>=250)s+=25;else issues.push('Texto corto');const media=Array.isArray(i.media)?i.media:[];if(media.some(m=>m.isMain&&(m.url||m.localUrl)))s+=20;else if(media.length){s+=10;issues.push('Sin portada marcada');}else issues.push('Sin imagen');const facts=Array.isArray(i.facts)?i.facts.length:0;if(facts>=4)s+=15;else issues.push('Pocos datos');return {s,level:s>=80?'lista':s>=50?'revisar':'pobre',issues};}async function load(){try{const d=await json(`${API}/items`);const items=d.items||[];const stats={total:items.length,published:items.filter(i=>i.status==='published').length,draft:items.filter(i=>i.status!=='published').length};$('qualityMetrics').innerHTML=`<div class="gc-metric"><span>Total</span><strong>${stats.total}</strong><small>fichas</small></div><div class="gc-metric"><span>Publicadas</span><strong>${stats.published}</strong><small>visibles</small></div><div class="gc-metric"><span>Borradores</span><strong>${stats.draft}</strong><small>revisión</small></div>`;$('qualityRows').innerHTML='<div class="archive-quality-row archive-quality-row--head"><span>Ficha</span><span>Tipo</span><span>Estado</span><span>Calidad</span><span>Problemas</span><span></span></div>'+items.map(i=>{const q=score(i);return`<div class="archive-quality-row is-${q.level}"><span><strong>${esc(i.title||'Sin título')}</strong><small>${esc(i.slug||i.id)}</small></span><span>${esc(i.category||i.type)}</span><span>${esc(i.status||'draft')}</span><span><strong>${q.s}/100</strong><small>${q.level}</small></span><span>${esc(q.issues.join(' · ')||'OK')}</span><span><a class="gc-btn gc-btn--small" href="/admin/archivo/editar/${encodeURIComponent(i.id)}">Editar</a></span></div>`}).join('');}catch(e){$('qualityRows').innerHTML=`<div class="gc-admin-empty">${esc(e.message)}</div>`;}}load();})();
  </script>
</AppLayout>

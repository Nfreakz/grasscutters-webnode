---
export const prerender = false;
import AppLayout from '../../../../layouts/AppLayout.astro';
import AdminSubnav from '../../../../components/AdminSubnav.astro';
const itemId = Astro.params.id;
---
<AppLayout title="Editar ficha | Archivo Motorsport">
  <div class="gc-page gc-admin-page-clean gc-archive-editor" data-item-id={itemId}>
    <section class="gc-hero gc-hero--compact">
      <div><span class="gc-kicker">Archivo Motorsport</span><h1 class="gc-title">Editar ficha.</h1><p class="gc-subtitle">Editor unificado MySQL/local.</p></div>
      <aside class="gc-live-panel"><div class="gc-live-panel__title"><span>Estado</span><strong id="archiveEditorState">Cargando</strong></div><div class="gc-status-list"><div class="gc-status-row"><span>ID</span><strong>{itemId}</strong></div></div></aside>
    </section>
    <AdminSubnav />
    <section class="gc-section" id="archiveEditorError" hidden><div class="gc-slab"><h3>No se pudo cargar la ficha</h3><p id="archiveEditorErrorText">Error desconocido.</p><div class="gc-actions"><a class="gc-btn" href="/admin/archivo">Volver</a></div></div></section>
    <section id="archiveEditorContent" hidden>
      <section class="gc-grid-2">
        <form class="gc-section gc-form" id="archiveMainForm">
          <div class="gc-section-head"><h2>Contenido</h2><p>Datos editoriales de la ficha.</p></div>
          <div class="gc-field"><label>Título</label><input name="title" id="fieldTitle" required /></div>
          <div class="gc-field"><label>Slug</label><input name="slug" id="fieldSlug" required /></div>
          <div class="gc-field"><label>Categoría</label><select name="category" id="fieldCategory"><option value="circuitos">Circuito</option><option value="pilotos">Piloto</option><option value="vehiculos">Vehículo</option><option value="campeonatos">Campeonato</option><option value="records">Récord</option><option value="glosario">Glosario</option></select></div>
          <div class="gc-field"><label>Estado</label><select name="status" id="fieldStatus"><option value="draft">Borrador</option><option value="published">Publicado</option><option value="hidden">Oculto</option></select></div>
          <div class="gc-field"><label>Resumen</label><textarea name="summary" id="fieldSummary" rows="4"></textarea></div>
          <div class="gc-field"><label>Texto largo</label><textarea name="body" id="fieldBody" rows="10"></textarea></div>
          <div class="gc-actions"><button class="gc-btn gc-btn--primary" type="submit">Guardar ficha</button><a class="gc-btn" href="/admin/archivo">Volver</a><button type="button" class="gc-admin-danger-button gc-archive-delete-inline" id="deleteArchiveItemButton">Borrar ficha</button></div>
          <p class="gc-message" id="archiveSaveMsg"></p>
        </form>
        <section class="gc-section">
          <div class="gc-section-head"><h2>Portada y galería</h2><p>Media asociada a la ficha.</p></div>
          <div class="gc-slab gc-archive-cover-preview"><img id="archiveCoverPreview" src="/og/grasscutters-og.svg" alt="Portada" /><div><strong id="archiveCoverTitle">Sin portada</strong><p id="archiveCoverText">Añade una imagen desde URL o importación.</p></div></div>
          <div class="gc-slab"><p>Para añadir imagen nueva usa <a href="/admin/archivo/imagen-url">Añadir imagen desde URL</a>.</p></div>
        </section>
      </section>
      <section class="gc-section"><div class="gc-section-head"><h2>Media de la ficha</h2><p>Imágenes asociadas.</p></div><div class="gc-archive-media-grid" id="archiveMediaGrid"></div></section>
    </section>
  </div>
  <script is:inline>
    (() => {
      const API = '/api/admin/archive/unified';
      const root = document.querySelector('.gc-archive-editor');
      const itemId = root?.dataset?.itemId;
      const $ = (id) => document.getElementById(id);
      const esc = (v) => String(v ?? '').replace(/[&<>'"]/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));
      let currentItem = null;
      async function fetchJson(url, options={}) { const r = await fetch(url, { credentials:'include', cache:'no-store', headers:{'Content-Type':'application/json'}, ...options }); const d = await r.json().catch(()=>({})); if(!r.ok || d.ok===false) throw new Error(d.message || `HTTP ${r.status}`); return d; }
      function showError(message) { $('archiveEditorContent').hidden = true; $('archiveEditorError').hidden = false; $('archiveEditorErrorText').textContent = message; $('archiveEditorState').textContent = 'Error'; }
      function fillForm(item) { $('fieldTitle').value=item.title||''; $('fieldSlug').value=item.slug||''; $('fieldCategory').value=item.category||'circuitos'; $('fieldStatus').value=item.status||'draft'; $('fieldSummary').value=item.summary||''; $('fieldBody').value=item.body||''; renderMedia(item); $('archiveEditorContent').hidden=false; $('archiveEditorError').hidden=true; $('archiveEditorState').textContent=item.status||'OK'; }
      function renderMedia(item) {
        const media = Array.isArray(item.media) ? item.media : [];
        const main = media.find((m)=>m.isMain||m.isPrimary) || media[0];
        if (main?.url || main?.localUrl) { $('archiveCoverPreview').src = main.url || main.localUrl; $('archiveCoverTitle').textContent = main.alt || item.title || 'Portada'; $('archiveCoverText').textContent = `${main.source || 'Fuente no indicada'} · ${main.license || 'Licencia no indicada'}`; }
        const grid = $('archiveMediaGrid');
        if (!media.length) { grid.innerHTML='<div class="gc-admin-empty">Todavía no hay imágenes asociadas.</div>'; return; }
        grid.innerHTML = media.map((m)=>`<article class="gc-archive-media-card"><img src="${esc(m.url||m.localUrl)}" alt="${esc(m.alt||'')}" /><div><strong>${m.isMain?'Portada':'Imagen'}</strong><p>${esc(m.alt||'Sin alt')}</p><small>${esc(m.license||'Licencia no indicada')}</small></div></article>`).join('');
      }
      async function loadItem() { try { const d = await fetchJson(`${API}/items/${encodeURIComponent(itemId)}`); currentItem = d.item; fillForm(currentItem); } catch(e) { showError(e.message || 'No se pudo cargar.'); } }
      $('archiveMainForm').addEventListener('submit', async (event)=>{ event.preventDefault(); $('archiveSaveMsg').textContent='Guardando...'; const payload={ title:$('fieldTitle').value, slug:$('fieldSlug').value, category:$('fieldCategory').value, status:$('fieldStatus').value, summary:$('fieldSummary').value, body:$('fieldBody').value }; try{ const d=await fetchJson(`${API}/items/${encodeURIComponent(itemId)}`, {method:'PUT', body:JSON.stringify(payload)}); currentItem=d.item; fillForm(currentItem); $('archiveSaveMsg').textContent='Ficha guardada.'; } catch(e){ $('archiveSaveMsg').textContent=e.message||'No se pudo guardar.'; }});
      $('deleteArchiveItemButton').addEventListener('click', async ()=>{ if(!confirm('¿Borrar esta ficha?')) return; if(!confirm('Última confirmación.')) return; try { await fetchJson(`${API}/items/${encodeURIComponent(itemId)}`, {method:'DELETE'}); window.location.href='/admin/archivo'; } catch(e) { alert(e.message || 'No se pudo borrar.'); }});
      loadItem();
    })();
  </script>
  <style is:global>.gc-archive-cover-preview{display:grid;grid-template-columns:180px 1fr;gap:14px;align-items:center}.gc-archive-cover-preview img{width:100%;aspect-ratio:16/10;object-fit:cover;border:1px solid var(--line)}.gc-archive-media-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:14px}.gc-archive-media-card{display:grid;grid-template-columns:120px 1fr;gap:12px;padding:12px;border:1px solid var(--line);background:rgba(255,255,255,.018)}.gc-archive-media-card img{width:100%;aspect-ratio:1/1;object-fit:cover}.gc-archive-delete-inline{border:1px solid rgba(255,90,90,.45);background:rgba(255,90,90,.1);color:#ffd7d7;padding:12px 18px;font-weight:900}</style>
</AppLayout>

---
export const prerender = false;
import AppLayout from "../../../../layouts/AppLayout.astro";
import AdminSubnav from "../../../../components/AdminSubnav.astro";

const itemId = Astro.params.id;
---

<AppLayout title="Editar ficha | Archivo">
  <link rel="stylesheet" href="/gc-archivo-media-manager-v842.css" />

  <div class="gc-page gc-admin-page-clean gc-archive-editor-v153 gc-archive-editor-simple-v1 is-simple" data-item-id={itemId}>
    <section class="gc-hero gc-hero--compact">
      <div>
        <span class="gc-kicker">Archivo Motorsport</span>
        <h1 class="gc-title">Editar ficha.</h1>
        <p class="gc-subtitle">Editor simplificado por pasos. Los campos avanzados siguen disponibles en modo completo.</p>
      </div>
      <aside class="gc-live-panel">
        <div class="gc-live-panel__title"><span>Estado</span><strong id="archiveEditorState">Cargando</strong></div>
        <div class="gc-status-list">
          <div class="gc-status-row"><span>ID</span><strong>{itemId}</strong></div>
        </div>
      </aside>
    </section>

    <AdminSubnav />

    <div class="gc-archive-editor-topbar">
      <div class="gc-archive-editor-mode" aria-label="Modo de edición">
        <button type="button" data-editor-mode="simple">Modo simple</button>
        <button type="button" data-editor-mode="complete">Modo completo</button>
      </div>
      <nav class="gc-archive-editor-mini-nav" aria-label="Navegación del editor">
        <a href="#editor-basico">Básico</a>
        <a href="#editor-datos">Datos</a>
        <a href="#editor-cierre">Cierre</a>
        <a href="#editor-checklist">Checklist</a>
      </nav>
    </div>

    <section class="gc-section" id="archiveEditorError" hidden>
      <div class="gc-slab">
        <h3>No se pudo cargar la ficha</h3>
        <p id="archiveEditorErrorText">Error desconocido.</p>
        <div class="gc-actions"><a class="gc-btn" href="/admin/archivo">Volver</a></div>
      </div>
    </section>

    <section id="archiveEditorContent" hidden>
      <div class="gc-archive-editor-grid">
        <form class="gc-archive-editor-stack" id="archiveMainForm">
          <details class="gc-archive-editor-panel" id="editor-basico" open>
            <summary>
              <div>
                <h2>1. Básico para publicar</h2>
                <p>Título, estado, categoría, resumen y texto principal. Esta es la zona que más usarás.</p>
              </div>
            </summary>
            <div class="gc-archive-editor-panel__body">
              <div class="gc-archive-editor-form-grid">
                <label class="gc-field gc-field--full"><span>Título</span><input data-field="title" id="fieldTitle" required /></label>
                <label class="gc-field"><span>Slug</span><input data-field="slug" id="fieldSlug" required /></label>
                <label class="gc-field"><span>Estado</span><select data-field="status" id="fieldStatus"><option value="draft">Borrador</option><option value="published">Publicado</option><option value="hidden">Oculto</option></select></label>
                <label class="gc-field"><span>Categoría</span><select data-field="category" id="fieldCategory"><option value="circuitos">Circuito</option><option value="vehiculos">Coche / vehículo</option><option value="pilotos">Piloto</option><option value="glosario">Glosario / concepto</option></select><small>El editor muestra debajo solo los campos útiles para esa categoría.</small></label>
                <label class="gc-field"><span>Periodo / época</span><input data-field="periodo" placeholder="Ej. 1990-2005, era GT2..." /></label>
                <label class="gc-field"><span>País</span><input data-field="pais" /></label>
                <label class="gc-field gc-field--full"><span>Subtítulo</span><input data-field="subtitulo" /></label>
                <label class="gc-field gc-field--full"><span>Resumen</span><textarea data-field="summary" id="fieldSummary" rows="3" placeholder="Entradilla breve de la ficha."></textarea></label>
                <label class="gc-field gc-field--full"><span>Introducción</span><textarea data-field="introduccion" rows="5" placeholder="Texto principal visible en la ficha."></textarea></label>
                <label class="gc-field gc-field--full"><span>Texto largo / cuerpo</span><textarea data-field="body" id="fieldBody" rows="7" placeholder="Contenido más extenso si hace falta."></textarea></label>
              </div>

              <div class="gc-archive-editor-subsection gc-archive-advanced-only">
                <h3>Campos comunes avanzados</h3>
                <div class="gc-archive-editor-form-grid">
                  <label class="gc-field"><span>Región / ciudad</span><input data-field="region" /></label>
                  <label class="gc-field"><span>Disciplina</span><input data-field="disciplina" /></label>
                  <label class="gc-field gc-field--full"><span>Contexto histórico</span><textarea data-field="contexto_historico" rows="5"></textarea></label>
                  <label class="gc-field gc-field--full"><span>Importancia</span><textarea data-field="importancia" rows="4"></textarea></label>
                  <label class="gc-field gc-field--full"><span>Tags</span><input data-field="tags" placeholder="Italia||Ferrari||GT2||Endurance" /></label>
                </div>
              </div>
            </div>
          </details>

          <details class="gc-archive-editor-panel" id="editor-datos" open>
            <summary>
              <div>
                <h2>2. Datos de la ficha</h2>
                <p>Campos específicos según circuito, coche, piloto o concepto. En modo simple solo verás lo más útil.</p>
              </div>
            </summary>
            <div class="gc-archive-editor-panel__body">
              <div class="gc-archive-editor-tabs" aria-label="Secciones de edición">
                <button class="gc-archive-editor-tab" type="button" data-editor-tab="circuitos">Circuito</button>
                <button class="gc-archive-editor-tab" type="button" data-editor-tab="vehiculos">Coche</button>
                <button class="gc-archive-editor-tab" type="button" data-editor-tab="pilotos">Piloto</button>
                <button class="gc-archive-editor-tab" type="button" data-editor-tab="glosario">Concepto</button>
              </div>

              <div class="gc-archive-editor-group" data-category-group="circuitos">
                <div class="gc-archive-editor-form-grid">
                  <label class="gc-field"><span>Ubicación</span><input data-field="ubicacion" /></label>
                  <label class="gc-field"><span>Longitud km</span><input data-field="longitud_km" /></label>
                  <label class="gc-field"><span>Curvas</span><input data-field="curvas" /></label>
                  <label class="gc-field"><span>Sentido</span><input data-field="sentido" /></label>
                  <label class="gc-field gc-field--full"><span>Tipo de trazado</span><input data-field="tipo_trazado" placeholder="Circuito permanente, urbano, temporal..." /></label>
                  <label class="gc-field gc-field--full"><span>Zonas clave</span><textarea data-field="zonas_clave" rows="4" placeholder="San Donato::Frenada principal||Bucine::Salida clave"></textarea><small>Formato recomendado: Nombre::Descripción. Separar con ||.</small></label>
                </div>
                <div class="gc-archive-editor-subsection gc-archive-advanced-only">
                  <h3>Circuito avanzado</h3>
                  <div class="gc-archive-editor-form-grid">
                    <label class="gc-field"><span>Recta principal km</span><input data-field="recta_principal_km" /></label>
                    <label class="gc-field"><span>Fecha apertura</span><input data-field="fecha_apertura" /></label>
                    <label class="gc-field"><span>Arquitecto</span><input data-field="arquitecto" /></label>
                    <label class="gc-field"><span>Desnivel m</span><input data-field="desnivel_m" /></label>
                    <label class="gc-field"><span>Diseñador</span><input data-field="diseniador" /></label>
                    <label class="gc-field"><span>Propietario</span><input data-field="propietario" /></label>
                    <label class="gc-field gc-field--full"><span>Características de conducción</span><textarea data-field="caracteristicas_conduccion" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Características del trazado</span><textarea data-field="caracteristicas_trazado" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Eventos destacados</span><textarea data-field="eventos_destacados" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Referencias de tiempos</span><textarea data-field="referencias_tiempos" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Datos sim racing</span><textarea data-field="datos_sim_racing" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Récords destacados</span><textarea data-field="records_destacados" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Anécdotas</span><textarea data-field="anecdotas" rows="4"></textarea></label>
                  </div>
                </div>
              </div>

              <div class="gc-archive-editor-group" data-category-group="vehiculos">
                <div class="gc-archive-editor-form-grid">
                  <label class="gc-field"><span>Fabricante</span><input data-field="fabricante" /></label>
                  <label class="gc-field"><span>Modelo base</span><input data-field="modelo_base" /></label>
                  <label class="gc-field"><span>Categoría competición</span><input data-field="categoria_competicion" /></label>
                  <label class="gc-field"><span>Años actividad</span><input data-field="anos_actividad" /></label>
                  <label class="gc-field"><span>Motor</span><input data-field="motor" /></label>
                  <label class="gc-field"><span>Potencia</span><input data-field="potencia" /></label>
                  <label class="gc-field"><span>Peso</span><input data-field="peso" /></label>
                  <label class="gc-field"><span>Tracción</span><input data-field="traccion" /></label>
                  <label class="gc-field gc-field--full"><span>Historial deportivo</span><textarea data-field="historial_competicion" rows="5"></textarea></label>
                </div>
                <div class="gc-archive-editor-subsection gc-archive-advanced-only">
                  <h3>Coche avanzado</h3>
                  <div class="gc-archive-editor-form-grid">
                    <label class="gc-field"><span>Constructor</span><input data-field="constructor" /></label>
                    <label class="gc-field"><span>Cilindrada</span><input data-field="cilindrada" /></label>
                    <label class="gc-field"><span>Transmisión</span><input data-field="transmision" /></label>
                    <label class="gc-field gc-field--full"><span>Chasis</span><textarea data-field="chasis" rows="3"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Aerodinámica</span><textarea data-field="aerodinamica" rows="3"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Ficha técnica</span><textarea data-field="ficha_tecnica" rows="4" placeholder="Motor::V8 atmosférico||Arquitectura::Motor central"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Características técnicas</span><textarea data-field="caracteristicas_tecnicas" rows="5" placeholder="Motor::V8 atmosférico||Arquitectura::Motor central"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Desarrollo</span><textarea data-field="desarrollo" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Campeonatos</span><textarea data-field="campeonatos" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Equipos destacados</span><textarea data-field="equipos_destacados" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Victorias / resultados destacados</span><textarea data-field="victorias_destacadas" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Variantes</span><textarea data-field="variantes" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Nota de identificación</span><textarea data-field="nota_identificacion" rows="3"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Anécdotas</span><textarea data-field="anecdotas" rows="4"></textarea></label>
                  </div>
                </div>
              </div>

              <div class="gc-archive-editor-group" data-category-group="pilotos">
                <div class="gc-archive-editor-form-grid">
                  <label class="gc-field"><span>Nombre completo</span><input data-field="nombre_completo" /></label>
                  <label class="gc-field"><span>Nacionalidad</span><input data-field="nacionalidad" /></label>
                  <label class="gc-field"><span>Fecha nacimiento</span><input data-field="fecha_nacimiento" /></label>
                  <label class="gc-field"><span>Años activo</span><input data-field="anos_activo" /></label>
                  <label class="gc-field"><span>Disciplinas</span><input data-field="disciplinas" /></label>
                  <label class="gc-field"><span>Títulos</span><input data-field="titulos" /></label>
                  <label class="gc-field gc-field--full"><span>Biografía</span><textarea data-field="biografia" rows="5"></textarea></label>
                  <label class="gc-field gc-field--full"><span>Trayectoria</span><textarea data-field="trayectoria" rows="5"></textarea></label>
                </div>
                <div class="gc-archive-editor-subsection gc-archive-advanced-only">
                  <h3>Piloto avanzado</h3>
                  <div class="gc-archive-editor-form-grid">
                    <label class="gc-field"><span>Lugar nacimiento</span><input data-field="lugar_nacimiento" /></label>
                    <label class="gc-field"><span>Victorias</span><input data-field="victorias" /></label>
                    <label class="gc-field"><span>Podios</span><input data-field="podios" /></label>
                    <label class="gc-field"><span>Poles</span><input data-field="poles" /></label>
                    <label class="gc-field gc-field--full"><span>Palmarés</span><textarea data-field="palmares" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Momentos clave</span><textarea data-field="momentos_clave" rows="5"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Equipos</span><textarea data-field="equipos" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Campeonatos</span><textarea data-field="campeonatos" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Estilo de pilotaje</span><textarea data-field="estilo_pilotaje" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Estilo de conducción</span><textarea data-field="estilo_conduccion" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Coches asociados</span><textarea data-field="coches_asociados" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Circuitos asociados</span><textarea data-field="circuitos_asociados" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Anécdotas</span><textarea data-field="anecdotas" rows="4"></textarea></label>
                  </div>
                </div>
              </div>

              <div class="gc-archive-editor-group" data-category-group="glosario">
                <div class="gc-archive-editor-form-grid">
                  <label class="gc-field"><span>Área</span><input data-field="area" placeholder="Técnica, pilotaje, estrategia..." /></label>
                  <label class="gc-field"><span>Categoría visible</span><input data-field="categoria" placeholder="Técnica, pilotaje, estrategia..." /></label>
                  <label class="gc-field gc-field--full"><span>Definición</span><textarea data-field="definicion" rows="4"></textarea></label>
                  <label class="gc-field gc-field--full"><span>Uso</span><textarea data-field="uso" rows="4"></textarea></label>
                  <label class="gc-field gc-field--full"><span>Aplicación práctica</span><textarea data-field="aplicacion_practica" rows="4"></textarea></label>
                  <label class="gc-field gc-field--full"><span>Ejemplos</span><textarea data-field="ejemplos" rows="4" placeholder="Curva lenta::Apex tardío||Curva rápida::Apex progresivo"></textarea></label>
                </div>
                <div class="gc-archive-editor-subsection gc-archive-advanced-only">
                  <h3>Concepto avanzado</h3>
                  <div class="gc-archive-editor-form-grid">
                    <label class="gc-field gc-field--full"><span>Errores comunes</span><textarea data-field="errores_comunes" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Relacionados</span><textarea data-field="relacionados" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Datos sim racing</span><textarea data-field="datos_sim_racing" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Datos destacados</span><textarea data-field="datos_destacados" rows="5"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Cronología</span><textarea data-field="cronologia" rows="5"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Referencias</span><textarea data-field="referencias" rows="4"></textarea></label>
                    <label class="gc-field gc-field--full"><span>Anécdotas</span><textarea data-field="anecdotas" rows="4"></textarea></label>
                  </div>
                </div>
              </div>
            </div>
          </details>

          <details class="gc-archive-editor-panel" id="editor-cierre" open>
            <summary>
              <div>
                <h2>3. Cierre, fuentes e imagen</h2>
                <p>Campos de publicación, fuentes, portada manual y SEO. El SEO queda en modo completo.</p>
              </div>
            </summary>
            <div class="gc-archive-editor-panel__body">
              <div class="gc-archive-editor-form-grid">
                <label class="gc-field gc-field--full"><span>Fuentes</span><textarea data-field="fuentes" rows="4" placeholder="Wikipedia::https://...||Sitio oficial::https://..."></textarea><small>Separar fuentes con ||. Formato recomendado: Etiqueta::URL.</small></label>
                <label class="gc-field"><span>Autor texto</span><input data-field="autor" value="Redacción del archivo" /></label>
                <label class="gc-field"><span>Licencia texto</span><input data-field="licencia" value="Texto editorial con fuentes indicadas." /></label>
                <label class="gc-field"><span>Última revisión</span><input data-field="ultima_revision" placeholder="2026-05-29" /></label>
                <label class="gc-field gc-field--full"><span>Imagen URL manual</span><input data-field="imagen_url" placeholder="https://..." /></label>
                <label class="gc-field gc-field--full"><span>Alt imagen manual</span><input data-field="imagen_alt" /></label>
              </div>

              <div class="gc-archive-editor-subsection gc-archive-advanced-only">
                <h3>SEO avanzado</h3>
                <div class="gc-archive-editor-form-grid">
                  <label class="gc-field gc-field--full"><span>SEO title</span><input data-field="seoTitle" /></label>
                  <label class="gc-field gc-field--full"><span>SEO description</span><textarea data-field="seoDescription" rows="3"></textarea></label>
                </div>
              </div>
            </div>
          </details>

          <details class="gc-archive-editor-panel gc-archive-advanced-only">
            <summary>
              <div>
                <h2>4. JSON avanzado</h2>
                <p>Opcional. Para campos especiales que aún no tengan campo visual.</p>
              </div>
            </summary>
            <div class="gc-archive-editor-panel__body">
              <label class="gc-field">
                <span>Datos completos</span>
                <textarea class="gc-archive-editor-json" id="advancedJson" spellcheck="false" placeholder='{"campo_extra":"valor"}'></textarea>
              </label>
            </div>
          </details>

          <details class="gc-archive-editor-panel" id="editor-checklist" open>
            <summary>
              <div>
                <h2>Checklist</h2>
                <p>Estado mínimo de la ficha antes de publicarla.</p>
              </div>
            </summary>
            <div class="gc-archive-editor-panel__body">
              <div class="gc-archive-editor-check-score">
                <strong id="archiveCompletenessScore">0/0</strong>
                <span id="archiveCompletenessLabel">Sin revisar</span>
              </div>
              <div class="gc-archive-editor-checklist" id="archiveCompletenessChecklist"></div>
            </div>
          </details>

          <section class="gc-archive-editor-panel">
            <div class="gc-archive-editor-actions is-sticky">
              <button class="gc-btn gc-btn--primary" type="submit">Guardar ficha</button>
              <a class="gc-btn" id="publicPreviewLink" href="/archivo/" target="_blank" rel="noreferrer">Ver público</a>
              <a class="gc-btn" href="/admin/archivo">Volver</a>
              <button type="button" class="gc-btn gc-archive-editor-danger" id="deleteArchiveItemButton">Borrar ficha</button>
            </div>
            <p class="gc-archive-editor-status" id="archiveSaveMsg"></p>
          </section>
        </form>

        <aside class="gc-archive-editor-stack gc-archive-editor-side">
          
          <section class="gc-archive-editor-panel" open>
            <div class="gc-archive-editor-panel__body">
              <h2>Portada</h2>
              <div class="gc-archive-editor-cover">
                <img id="archiveCoverPreview" src="/og/grasscutters-og.svg" alt="Portada" />
                <div>
                  <strong id="archiveCoverTitle">Sin portada</strong>
                  <p id="archiveCoverText">Añade una imagen desde URL o desde tu PC.</p>
                </div>
              </div>
              <div class="gc-archive-editor-actions">
                <a class="gc-btn gc-btn--primary" id="archiveAddImageLink" href="/admin/archivo/imagen-url" aria-disabled="true">Añadir imagen a esta ficha</a>
              </div>
              <p class="gc-editor-media-hint">Abre el gestor de imágenes con esta ficha ya seleccionada.</p>
            </div>
          </section>
          
          <section class="gc-archive-editor-panel" open>
            <div class="gc-archive-editor-panel__body">
              <h2>Guía rápida</h2>
              <div class="gc-archive-editor-mini-list">
                <p><code>Modo simple</code> muestra lo necesario para publicar sin ruido.</p>
                <p><code>Modo completo</code> muestra todos los campos avanzados.</p>
                <p><code>||</code> separa elementos.</p>
                <p><code>::</code> separa título y descripción.</p>
              </div>
            </div>
          </section>

          
          <section class="gc-archive-editor-panel" open>
            <div class="gc-archive-editor-panel__body">
              <h2>Media de la ficha</h2>
              <div class="gc-archive-media-grid" id="archiveMediaGrid"></div>
            </div>
          </section>
          
        </aside>
      </div>
    </section>
  </div>

  <script is:inline>
    (() => {

      const API = '/api/admin/archive/unified';
      const root = document.querySelector('.gc-archive-editor-simple-v1');
      const fields = [...document.querySelectorAll('[data-field]')];
      const groups = [...document.querySelectorAll('[data-category-group]')];
      const tabs = [...document.querySelectorAll('[data-editor-tab]')];
      const $ = (id) => document.getElementById(id);
      const esc = (v) => String(v ?? '').replace(/[&<>'"]/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));

      let currentItem = null;

      const normalizeCategoryForEditor = (value) => {
        const raw = String(value || '').toLowerCase();
        if (['coches','coche','vehiculo','vehículo','vehiculos','vehículos','vehicle','car'].includes(raw)) return 'vehiculos';
        if (['circuito','circuit','track'].includes(raw)) return 'circuitos';
        if (['piloto','driver','pilot'].includes(raw)) return 'pilotos';
        if (['glosario','concepto','concept','general'].includes(raw)) return 'glosario';
        return raw || 'glosario';
      };

      const publicType = (category) => normalizeCategoryForEditor(category) === 'vehiculos' ? 'coches' : normalizeCategoryForEditor(category);
      const slugify = (value) => String(value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'').replace(/-{2,}/g,'-');
      const setMsg = (text, kind = '') => { const el = $('archiveSaveMsg'); if (el) { el.textContent = text || ''; el.className = `gc-archive-editor-status ${kind}`.trim(); } };

      function fieldValue(name) {
        const field = document.querySelector(`[data-field="${name}"]`);
        return String(field?.value || '').trim();
      }

      function anyField(...names) {
        return names.some((name) => fieldValue(name).length > 0);
      }

      function textMin(name, min) {
        return fieldValue(name).length >= min;
      }

      function mediaReady() {
        const item = currentItem || {};
        const media = Array.isArray(item?.media) ? item.media : [];
        return media.some((entry) => entry?.url || entry?.localUrl) || anyField('imagen_url');
      }

      function rule(label, ok, hint = '') {
        return { label, ok: Boolean(ok), hint };
      }

      function completionRulesFor(category) {
        const normalized = normalizeCategoryForEditor(category);
        const base = [
          rule('Título claro', fieldValue('title').length >= 4, 'Nombre reconocible de la ficha.'),
          rule('Resumen', textMin('summary', 70), 'Mínimo 70 caracteres para la entradilla.'),
          rule('Texto principal', textMin('body', 250) || textMin('introduccion', 180), 'Introducción o cuerpo con contexto real.'),
          rule('Fuentes', anyField('fuentes'), 'Añade al menos una fuente o referencia.'),
          rule('Portada o imagen', mediaReady(), 'Imagen URL, media local o portada manual.'),
        ];

        if (normalized === 'circuitos') {
          return [
            ...base,
            rule('País o ubicación', anyField('pais', 'ubicacion', 'region'), 'Ej. Italia, Toscana, Mugello.'),
            rule('Tipo de trazado', anyField('tipo_trazado'), 'Ej. Circuito permanente, urbano, temporal.'),
            rule('Longitud', anyField('longitud_km'), 'Dato visible en la ficha pública.'),
            rule('Zonas clave', anyField('zonas_clave'), 'Formato recomendado: Nombre::Descripción.'),
          ];
        }

        if (normalized === 'vehiculos') {
          return [
            ...base,
            rule('Fabricante', anyField('fabricante'), 'Marca o constructor principal.'),
            rule('Categoría / periodo', anyField('categoria_competicion', 'anos_actividad', 'periodo'), 'Ej. GT2, 2009-2011.'),
            rule('Motor', anyField('motor'), 'Dato técnico básico.'),
            rule('Historial deportivo', anyField('historial_competicion'), 'Dónde corrió, qué logró o por qué importa.'),
          ];
        }

        if (normalized === 'pilotos') {
          return [
            ...base,
            rule('Nacionalidad', anyField('nacionalidad', 'pais'), 'Dato básico de identificación.'),
            rule('Periodo activo', anyField('anos_activo', 'periodo'), 'Época o años de actividad.'),
            rule('Biografía o trayectoria', anyField('biografia', 'trayectoria'), 'Bloque principal de la ficha.'),
            rule('Palmarés', anyField('titulos', 'victorias', 'palmares', 'campeonatos'), 'Títulos, victorias o resultados destacados.'),
          ];
        }

        return [
          ...base,
          rule('Categoría visible', anyField('categoria', 'disciplina'), 'Área o familia del concepto.'),
          rule('Definición o datos', anyField('datos_destacados', 'referencias', 'cronologia', 'body'), 'Completa el concepto con datos consultables.'),
        ];
      }

      function renderCompletenessChecklist() {
        const target = $('archiveCompletenessChecklist');
        if (!target) return;

        const rules = completionRulesFor($('fieldCategory')?.value || 'glosario');
        const done = rules.filter((item) => item.ok).length;
        const total = rules.length;
        const percent = total ? Math.round((done / total) * 100) : 0;

        const score = $('archiveCompletenessScore');
        const label = $('archiveCompletenessLabel');

        if (score) score.textContent = `${done}/${total}`;
        if (label) {
          label.textContent = percent >= 85 ? 'Lista para revisar' : percent >= 55 ? 'Le falta contenido' : 'Muy incompleta';
          label.dataset.state = percent >= 85 ? 'ready' : percent >= 55 ? 'review' : 'critical';
        }

        target.innerHTML = rules.map((item) => `
          <article class="${item.ok ? 'is-ok' : 'is-missing'}">
            <span>${item.ok ? 'OK' : 'Falta'}</span>
            <div>
              <strong>${esc(item.label)}</strong>
              ${item.hint ? `<small>${esc(item.hint)}</small>` : ''}
            </div>
          </article>
        `).join('');
      }

      function showGroup(value) {
        const category = normalizeCategoryForEditor(value);
        const groupName = ['circuitos','vehiculos','pilotos'].includes(category) ? category : 'glosario';
        groups.forEach((group) => { group.hidden = group.dataset.categoryGroup !== groupName; });
        tabs.forEach((tab) => tab.classList.toggle('is-active', tab.dataset.editorTab === groupName));
        renderCompletenessChecklist();
      }

      function shouldCollectField(field) {
        const group = field.closest('[data-category-group]');
        return !group || group.hidden === false;
      }

      async function fetchJson(url, options = {}) {
        const response = await fetch(url, { credentials:'include', cache:'no-store', headers:{'Content-Type':'application/json'}, ...options });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || data.ok === false) throw new Error(data.message || data.error || `HTTP ${response.status}`);
        return data;
      }

      function setupEditorMode() {
        const buttons = [...document.querySelectorAll('[data-editor-mode]')];
        const stored = localStorage.getItem('gcArchiveEditorMode') || 'simple';

        function setMode(mode) {
          const finalMode = mode === 'complete' ? 'complete' : 'simple';
          root?.classList.toggle('is-simple', finalMode === 'simple');
          root?.classList.toggle('is-complete', finalMode === 'complete');
          buttons.forEach((button) => button.classList.toggle('is-active', button.dataset.editorMode === finalMode));
          localStorage.setItem('gcArchiveEditorMode', finalMode);
        }

        buttons.forEach((button) => button.addEventListener('click', () => setMode(button.dataset.editorMode)));
        setMode(stored);
      }

      function bindCommonEvents() {
        fields.forEach((field) => {
          field.addEventListener('input', renderCompletenessChecklist);
          field.addEventListener('change', renderCompletenessChecklist);
        });

        $('fieldCategory')?.addEventListener('change', () => showGroup($('fieldCategory').value));

        tabs.forEach((tab) => tab.addEventListener('click', () => {
          const target = tab.dataset.editorTab;
          if (target === 'vehiculos') $('fieldCategory').value = 'vehiculos';
          else if (target === 'circuitos') $('fieldCategory').value = 'circuitos';
          else if (target === 'pilotos') $('fieldCategory').value = 'pilotos';
          else $('fieldCategory').value = 'glosario';
          showGroup($('fieldCategory').value);
        }));

        setupEditorMode();
      }

      const itemId = root?.dataset?.itemId;
      let titleTouched = false;

      function getItemValue(item, name) {
        const aliasMap = Object.create(null);
        aliasMap.title = ['title','nombre','name','titulo'];
        aliasMap.summary = ['summary','descripcion_corta','resumen'];
        aliasMap.body = ['body','descripcion_larga','texto','content'];
        aliasMap.category = ['category','categoria_tipo','tipo'];
        const aliases = Array.isArray(aliasMap[name]) ? aliasMap[name] : [name];
        for (const key of aliases) {
          const value = item?.[key];
          if (value !== undefined && value !== null) return value;
        }
        return '';
      }

      function collectPayload() {
        let base = {};
        const advanced = $('advancedJson')?.value?.trim() || '';
        if (advanced) {
          try { base = JSON.parse(advanced); }
          catch { throw new Error('El JSON avanzado no es válido. Corrígelo o vacíalo antes de guardar.'); }
        }

        const payload = { ...base };
        fields.filter(shouldCollectField).forEach((field) => {
          const name = field.dataset.field;
          if (!name) return;
          payload[name] = field.value.trim();
        });

        payload.title = $('fieldTitle').value.trim();
        payload.nombre = payload.title;
        payload.slug = slugify($('fieldSlug').value || payload.title);
        payload.category = normalizeCategoryForEditor($('fieldCategory').value);
        payload.tipo = publicType(payload.category);
        payload.status = $('fieldStatus').value || 'draft';
        payload.summary = $('fieldSummary').value.trim();
        payload.descripcion_corta = payload.summary;
        payload.body = $('fieldBody').value.trim();
        payload.descripcion_larga = payload.body;
        
        payload.updatedAt = new Date().toISOString();
        return payload;
      }

      function updatePreviewLink() {
        const link = $('publicPreviewLink');
        if (!link) return;
        const category = publicType($('fieldCategory').value);
        const slug = slugify($('fieldSlug').value || $('fieldTitle').value);
        link.href = slug ? `/archivo/${category}/${slug}/` : '/archivo/';
      }

      function updateImageLink() {
        const link = $('archiveAddImageLink');
        if (!link) return;
        const id = currentItem?.id || itemId || '';
        const slug = slugify($('fieldSlug')?.value || currentItem?.slug || $('fieldTitle')?.value || '');
        if (id) {
          link.href = `/admin/archivo/imagen-url?item=${encodeURIComponent(id)}`;
          link.removeAttribute('aria-disabled');
          link.classList.remove('is-disabled');
          return;
        }
        if (slug) {
          link.href = `/admin/archivo/imagen-url?slug=${encodeURIComponent(slug)}`;
          link.removeAttribute('aria-disabled');
          link.classList.remove('is-disabled');
          return;
        }
        link.href = '/admin/archivo/imagen-url';
        link.setAttribute('aria-disabled', 'true');
        link.classList.add('is-disabled');
      }

      function renderMedia(item) {
        const media = Array.isArray(item?.media) ? item.media : [];
        const main = media.find((m) => m.isMain || m.isPrimary) || media[0];

        if ($('archiveCoverPreview')) {
          if (main?.url || main?.localUrl || item?.coverUrl || item?.imagen_url) {
            const image = main?.url || main?.localUrl || item.coverUrl || item.imagen_url;
            $('archiveCoverPreview').src = image;
            $('archiveCoverTitle').textContent = main?.alt || item.coverAlt || item.imagen_alt || item.title || item.nombre || 'Portada';
            $('archiveCoverText').textContent = [main?.source, main?.author, main?.license].filter(Boolean).join(' · ') || 'Créditos no indicados.';
          }
        }

        const grid = $('archiveMediaGrid');
        if (!grid) return;

        if (!media.length) {
          grid.innerHTML = '<div class="gc-admin-empty">Todavía no hay imágenes asociadas.</div>';
          return;
        }

        grid.innerHTML = media.map((m) => `
          <article class="gc-archive-media-card">
            <img src="${esc(m.url || m.localUrl)} " alt="${esc(m.alt || '')}" />
            <div>
              <strong>${m.isMain || m.isPrimary ? 'Portada' : 'Imagen'}</strong>
              <p>${esc(m.alt || 'Sin alt')}</p>
              <small>${esc([m.source, m.author, m.license].filter(Boolean).join(' · ') || 'Créditos no indicados')}</small>
            </div>
          </article>
        `).join('');
      }

      function fillForm(item) {
        currentItem = item || {};
        fields.forEach((field) => {
          const name = field.dataset.field;
          let value = getItemValue(currentItem, name);
          if (name === 'category') value = normalizeCategoryForEditor(value || currentItem.category || currentItem.tipo);
          field.value = String(value ?? '');
        });
        if (!$('fieldCategory').value) $('fieldCategory').value = 'circuitos';
        showGroup($('fieldCategory').value);
        if ($('advancedJson')) $('advancedJson').value = JSON.stringify(currentItem, null, 2);
        if ($('archiveEditorContent')) $('archiveEditorContent').hidden = false;
        if ($('archiveEditorError')) $('archiveEditorError').hidden = true;
        if ($('archiveEditorState')) $('archiveEditorState').textContent = currentItem.status || 'OK';
        renderMedia(currentItem);
        updatePreviewLink();
        updateImageLink();
        renderCompletenessChecklist();
      }

      $('fieldTitle')?.addEventListener('input', () => {
        if (!titleTouched) $('fieldSlug').value = slugify($('fieldTitle').value);
        updatePreviewLink();
        updateImageLink();
      });
      $('fieldSlug')?.addEventListener('input', () => { titleTouched = true; updatePreviewLink(); updateImageLink(); });
      $('fieldCategory')?.addEventListener('change', () => { updatePreviewLink(); updateImageLink(); });

      bindCommonEvents();

      
      async function loadItem() {
        try {
          const data = await fetchJson(`${API}/items/${encodeURIComponent(itemId)}`);
          fillForm(data.item);
        } catch (error) {
          $('archiveEditorContent').hidden = true;
          $('archiveEditorError').hidden = false;
          $('archiveEditorErrorText').textContent = error.message || 'No se pudo cargar.';
          $('archiveEditorState').textContent = 'Error';
        }
      }

      $('archiveMainForm').addEventListener('submit', async (event) => {
        event.preventDefault();
        setMsg('Guardando ficha...');
        try {
          const payload = collectPayload();
          const data = await fetchJson(`${API}/items/${encodeURIComponent(itemId)}`, { method:'PUT', body: JSON.stringify(payload) });
          fillForm(data.item);
          setMsg('Ficha guardada.', 'ok');
        } catch (error) {
          setMsg(error.message || 'No se pudo guardar.', 'error');
        }
      });

      $('deleteArchiveItemButton')?.addEventListener('click', async () => {
        if (!confirm('¿Borrar esta ficha?')) return;
        if (!confirm('Última confirmación. Esta acción no se puede deshacer desde el editor.')) return;
        try {
          await fetchJson(`${API}/items/${encodeURIComponent(itemId)}`, { method:'DELETE' });
          window.location.href = '/admin/archivo';
        } catch (error) {
          alert(error.message || 'No se pudo borrar.');
        }
      });

      loadItem();
      
    })();
  </script>


---
import AppLayout from '../../layouts/AppLayout.astro';
import AdminSubnav from '../../components/AdminSubnav.astro';
---
<AppLayout title="Archivo Motorsport | Admin GrassCutters">
  <div class="gc-page gc-admin-page-clean">
    <section class="gc-hero gc-hero--compact">
      <div>
        <span class="gc-kicker">Archivo Motorsport</span>
        <h1 class="gc-title">Archivo editable.</h1>
        <p class="gc-subtitle">Panel unificado MySQL/local para crear, editar, revisar e importar fichas sin rutas antiguas.</p>
      </div>
      <aside class="gc-live-panel">
        <div class="gc-live-panel__title"><span>Fichas</span><strong id="archiveStatusLabel">Cargando</strong></div>
        <div class="gc-status-list">
          <div class="gc-status-row"><span>Total</span><strong id="archiveTotal">...</strong></div>
          <div class="gc-status-row"><span>Publicadas</span><strong id="archivePublished">...</strong></div>
          <div class="gc-status-row"><span>Borradores</span><strong id="archiveDrafts">...</strong></div>
        </div>
      </aside>
    </section>

    <AdminSubnav />

    <section class="gc-section">
      <div class="gc-section-head">
        <div><h2>Gestión del archivo</h2><p>Listado directo desde la API unificada.</p></div>
        <div class="gc-admin-actions">
          <a class="gc-btn gc-btn--primary" href="/admin/archivo/nuevo">Nueva ficha</a>
          <a class="gc-btn" href="/admin/archivo/importar">Importar CSV</a>
          <a class="gc-btn" href="/admin/archivo/imagen-url">Añadir imagen URL</a>
          <button class="gc-btn" id="refreshArchiveBtn" type="button">Recargar</button>
          <button class="gc-btn" id="demoArchiveBtn" type="button">Crear demo</button>
        </div>
      </div>
      <div class="gc-slab" id="archiveNotice" hidden><h3 id="archiveNoticeTitle">Aviso</h3><p id="archiveNoticeText"></p></div>
      <div class="gc-row-list" id="archiveItems"><div class="gc-admin-empty">Cargando fichas...</div></div>
    </section>
  </div>

  <script is:inline>
    (() => {
      const API = '/api/admin/archive/unified';
      const $ = (id) => document.getElementById(id);
      const esc = (v) => String(v ?? '').replace(/[&<>'"]/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));
      const els = { status:$('archiveStatusLabel'), total:$('archiveTotal'), published:$('archivePublished'), drafts:$('archiveDrafts'), items:$('archiveItems'), notice:$('archiveNotice'), noticeTitle:$('archiveNoticeTitle'), noticeText:$('archiveNoticeText'), refresh:$('refreshArchiveBtn'), demo:$('demoArchiveBtn') };
      async function fetchJson(url, options={}) {
        const response = await fetch(url, { credentials:'include', cache:'no-store', headers:{'Content-Type':'application/json'}, ...options });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || data.ok === false) throw new Error(data.message || data.error || `HTTP ${response.status}`);
        return data;
      }
      function showNotice(title, text) { els.notice.hidden = false; els.noticeTitle.textContent = title; els.noticeText.textContent = text; }
      function clearNotice() { els.notice.hidden = true; }
      function cat(item) { return item.category || item.type || 'general'; }
      function statusLabel(item) { return item.status === 'published' ? 'Publicado' : item.status === 'hidden' ? 'Oculto' : 'Borrador'; }
      function render(items) {
        els.status.textContent = 'Operativo';
        els.total.textContent = items.length;
        els.published.textContent = items.filter((i) => i.status === 'published').length;
        els.drafts.textContent = items.filter((i) => i.status !== 'published').length;
        if (!items.length) { els.items.innerHTML = '<div class="gc-admin-empty">Todavía no hay fichas.</div>'; return; }
        els.items.innerHTML = items.map((item, index) => `
          <a class="gc-row-link" href="/admin/archivo/editar/${encodeURIComponent(item.id || item.slug || index)}">
            <span class="gc-row-link__num">${String(index + 1).padStart(2, '0')}</span>
            <span><strong class="gc-row-link__title">${esc(item.title || 'Sin título')}</strong><br><span class="gc-row-link__desc">${esc(cat(item))} · ${esc(statusLabel(item))} · ${esc(item.summary || 'Sin resumen')}</span></span>
            <span class="gc-row-link__cta">Editar</span>
          </a>`).join('');
      }
      async function loadArchive() {
        clearNotice(); els.status.textContent = 'Cargando';
        try { const data = await fetchJson(`${API}/items`); render(Array.isArray(data.items) ? data.items : []); }
        catch (error) { els.status.textContent = 'API error'; els.items.innerHTML = '<div class="gc-admin-empty">No se pudieron cargar fichas.</div>'; showNotice('No se pudo leer el Archivo', error.message || 'Error desconocido'); }
      }
      async function createDemo() {
        clearNotice(); els.demo.disabled = true; els.demo.textContent = 'Creando...';
        try { const data = await fetchJson(`${API}/demo`, { method:'POST' }); await loadArchive(); showNotice('Demo creada', `Creadas ${data.created}, omitidas ${data.skipped}.`); }
        catch (error) { showNotice('No se pudo crear la demo', error.message || 'Error desconocido'); }
        finally { els.demo.disabled = false; els.demo.textContent = 'Crear demo'; }
      }
      els.refresh?.addEventListener('click', loadArchive);
      els.demo?.addEventListener('click', createDemo);
      loadArchive();
    })();
  </script>
</AppLayout>
<script src="/gc-admin-pagination.js" is:inline></script>

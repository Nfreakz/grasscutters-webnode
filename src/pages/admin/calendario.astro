---
import AppLayout from '../../layouts/AppLayout.astro';
import AdminSubnav from '../../components/AdminSubnav.astro';
---
<AppLayout title="Admin calendario | GrassCutters">
  <div class="gc-page gc-admin-page-clean gc-admin-calendar-page">
    <section class="gc-hero gc-hero--compact">
      <div>
        <span class="gc-kicker">Administración</span>
        <h1 class="gc-title">Calendario.</h1>
        <p class="gc-subtitle">Eventos visibles en calendario, combo semanal, carreras LFM, carreras GrassCutters y sincronización ACSM.</p>
        <div class="gc-hero__meta"><span class="gc-chip gc-chip--accent">Eventos</span><span class="gc-chip">ACSM</span><span class="gc-chip">MySQL</span></div>
      </div>
      <aside class="gc-live-panel"><div class="gc-live-panel__title"><span>Calendario</span><strong id="calAdminState">Comprobando</strong></div><div class="gc-status-list"><div class="gc-status-row"><span>Eventos</span><strong id="calAdminCount">...</strong></div><div class="gc-status-row"><span>Visibles</span><strong id="calAdminVisible">...</strong></div><div class="gc-status-row"><span>Última acción</span><strong id="calAdminLast">...</strong></div></div></aside>
    </section>

    <AdminSubnav />

    <section class="gc-section" id="calAdminAccess" hidden><div class="gc-slab"><h3>Acceso restringido</h3><p>Esta página solo funciona con una cuenta administradora.</p><div class="gc-actions"><a class="gc-btn gc-btn--primary" href="/login">Ir a login</a><button class="gc-btn" id="calRetry" type="button">Reintentar</button></div></div></section>

    <section id="calAdminContent" hidden>
      <section class="gc-grid-2">
        <form class="gc-section gc-form gc-calendar-admin-form" id="calendarForm">
          <div class="gc-section-head"><h2 id="calendarFormTitle">Crear evento</h2><p>Solo tipos oficiales del calendario GrassCutters.</p></div>
          <input type="hidden" name="id" />
          <div class="gc-form-grid">
            <label class="gc-field"><span>Tipo</span><select class="gc-select" name="type"><option value="combo">Combo semanal</option><option value="race_lfm">Carrera LFM</option><option value="race_gc">Carrera GrassCutters</option></select></label>
            <label class="gc-field"><span>Título</span><input class="gc-input" name="title" required placeholder="Combo semanal en Sebring" /></label>
            <label class="gc-field"><span>Fecha inicio</span><input class="gc-input" name="startDate" type="date" required /></label>
            <label class="gc-field"><span>Hora inicio</span><input class="gc-input" name="startTime" type="time" /></label>
            <label class="gc-field"><span>Fecha fin</span><input class="gc-input" name="endDate" type="date" /></label>
            <label class="gc-field"><span>Hora fin</span><input class="gc-input" name="endTime" type="time" /></label>
            <label class="gc-field gc-calendar-repeat-until"><span>Repetir hasta</span><input class="gc-input" name="repeatUntil" type="date" /></label>
            <label class="gc-field"><span>Circuito</span><input class="gc-input" name="trackName" placeholder="Sebring" /></label>
            <label class="gc-field"><span>Coches</span><input class="gc-input" name="carNames" placeholder="Oreca 07 LMP2" /></label>
            <label class="gc-field" style="grid-column:1 / -1"><span>Enlace opcional</span><input class="gc-input" name="linkUrl" placeholder="https://..." /></label>
            <label class="gc-field" style="grid-column:1 / -1"><span>Descripción</span><textarea class="gc-input gc-calendar-textarea" name="description" rows="4" placeholder="Briefing, formato, notas o indicaciones."></textarea></label>
          </div>
          <div class="gc-calendar-checks"><label><input type="checkbox" name="visible" checked /> Visible</label><label><input type="checkbox" name="featured" /> Destacado</label><label><input type="checkbox" name="repeatEnabled" /> Repetir cada semana</label></div>
          <p class="gc-calendar-repeat-note">La repetición semanal usa el mismo día y hora del evento inicial.</p>
          <div class="gc-actions"><button class="gc-btn gc-btn--primary" type="submit">Guardar evento</button><button class="gc-btn" type="button" id="calendarReset">Limpiar</button><a class="gc-btn" href="/calendario" target="_blank" rel="noreferrer">Ver calendario</a></div>
          <p class="gc-message" id="calendarMessage"></p>
        </form>

        <aside class="gc-section">
          <div class="gc-section-head"><h2>Sincronización ACSM</h2><p>Importa el combo activo desde Server Manager.</p></div>
          <div class="gc-slab-list" id="acsmRows"><div><span>Estado</span><strong>...</strong></div></div>
          <div class="gc-actions"><button class="gc-btn" id="checkAcsmBtn" type="button">Probar ACSM</button><button class="gc-btn gc-btn--primary" id="syncAcsmBtn" type="button">Sincronizar combo</button></div>
          <p class="gc-message" id="acsmMessage"></p>
        </aside>
      </section>

      <section class="gc-section">
        <div class="gc-section-head"><div><h2>Eventos creados</h2><p id="calendarListMeta">Cargando...</p></div><button class="gc-btn" id="calendarReload" type="button">Recargar</button></div>
        <div class="gc-toolbar"><label class="gc-field"><span>Buscar</span><input class="gc-input" id="calendarSearch" type="search" placeholder="título, circuito, coche..." /></label><label class="gc-field"><span>Tipo</span><select class="gc-select" id="calendarTypeFilter"><option value="all">Todos</option><option value="combo">Combo semanal</option><option value="race_lfm">Carrera LFM</option><option value="race_gc">Carrera GrassCutters</option></select></label></div>
        <div class="gc-calendar-admin-list" id="calendarAdminList">Cargando eventos...</div>
      </section>
    </section>
  </div>

  <style is:global>
    .gc-calendar-admin-form{align-self:start}.gc-calendar-textarea{height:auto;min-height:110px;padding-top:10px;resize:vertical}.gc-calendar-checks{display:flex;flex-wrap:wrap;gap:12px;color:var(--soft)}.gc-calendar-checks label{display:inline-flex;gap:8px;align-items:center;border:1px solid var(--line);padding:9px 12px;background:rgba(255,255,255,.018)}.gc-calendar-repeat-note{margin:-4px 0 0;color:var(--dim);font-size:.86rem}.gc-calendar-repeat-until{transition:opacity .18s ease}.gc-calendar-repeat-until.is-disabled{opacity:.45}.gc-calendar-admin-list{display:grid;gap:10px}.gc-calendar-admin-card{display:grid;gap:10px;padding:14px;border:1px solid var(--line);border-left:3px solid var(--accent);background:rgba(255,255,255,.018)}.gc-calendar-admin-card[data-type="race_lfm"]{border-left-color:#35d3ff}.gc-calendar-admin-card[data-type="race_gc"]{border-left-color:#ffc46b}.gc-calendar-admin-card-head{display:flex;justify-content:space-between;gap:12px;align-items:flex-start}.gc-calendar-admin-card h3{margin:0;color:var(--text);font-size:1.1rem}.gc-calendar-admin-card p{margin:0;color:var(--soft)}.gc-calendar-admin-card small{color:var(--dim)}.gc-calendar-admin-card.is-hidden{opacity:.55}@media(max-width:900px){.gc-admin-calendar-page .gc-grid-2{grid-template-columns:1fr}.gc-calendar-admin-card-head{display:grid}}
  </style>

  <script is:inline>
    (()=>{const $=(id)=>document.getElementById(id);const form=$('calendarForm');const content=$('calAdminContent');const noAccess=$('calAdminAccess');const list=$('calendarAdminList');const message=$('calendarMessage');const state=$('calAdminState');const count=$('calAdminCount');const visibleCount=$('calAdminVisible');const last=$('calAdminLast');const meta=$('calendarListMeta');const search=$('calendarSearch');const typeFilter=$('calendarTypeFilter');const reload=$('calendarReload');const reset=$('calendarReset');const title=$('calendarFormTitle');const retry=$('calRetry');const acsmRows=$('acsmRows');const acsmMessage=$('acsmMessage');const checkAcsmBtn=$('checkAcsmBtn');const syncAcsmBtn=$('syncAcsmBtn');const typeLabels={combo:'Combo semanal',race_lfm:'Carrera LFM',race_gc:'Carrera GrassCutters'};let events=[];const esc=(v)=>String(v??'').replace(/[&<>'"]/g,(c)=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));const setMessage=(text,ok=false)=>{message.textContent=text;message.style.color=ok?'var(--accent)':'var(--soft)'};const dateText=(e)=>[e.startDate,e.startTime].filter(Boolean).join(' · ')||'-';const repeatText=(e)=>{if(!(e.repeatEnabled||e.repeatFrequency==='weekly'))return'';return e.repeatUntil?`Repetición semanal hasta ${e.repeatUntil}`:'Repetición semanal'};async function fetchJson(url,options={}){const r=await fetch(url,{credentials:'include',cache:'no-store',headers:{'Content-Type':'application/json'},...options});const d=await r.json().catch(()=>({}));if(!r.ok||d.ok===false){if(r.status===404)throw new Error('API no encontrada.');throw new Error(d.message||`HTTP ${r.status}`)}return d}async function isAdmin(){try{const s=await fetchJson('/api/admin/status');if(s.authorized===true)return true}catch{}const p=await fetchJson('/api/profile');return p.user?.role==='admin'}function updateRepeatFields(){const enabled=Boolean(form.elements.repeatEnabled?.checked);const field=document.querySelector('.gc-calendar-repeat-until');if(field)field.classList.toggle('is-disabled',!enabled);if(form.elements.repeatUntil)form.elements.repeatUntil.disabled=!enabled}function serializeForm(){const data=Object.fromEntries(new FormData(form));return{id:data.id||undefined,type:['combo','race_lfm','race_gc'].includes(String(data.type))?data.type:'combo',title:String(data.title||'').trim(),startDate:data.startDate,startTime:data.startTime||'',endDate:data.endDate||'',endTime:data.endTime||'',trackName:String(data.trackName||'').trim(),carNames:String(data.carNames||'').trim(),linkUrl:String(data.linkUrl||'').trim(),description:String(data.description||'').trim(),repeatEnabled:form.elements.repeatEnabled.checked,repeatFrequency:form.elements.repeatEnabled.checked?'weekly':'none',repeatUntil:data.repeatUntil||'',visible:form.elements.visible.checked,featured:form.elements.featured.checked}}function resetForm(){form.reset();form.elements.id.value='';form.elements.visible.checked=true;form.elements.featured.checked=false;form.elements.repeatEnabled.checked=false;form.elements.repeatUntil.value='';updateRepeatFields();title.textContent='Crear evento';setMessage('')}function editEvent(e){form.elements.id.value=e.id||'';form.elements.type.value=['combo','race_lfm','race_gc'].includes(String(e.type))?e.type:'combo';form.elements.title.value=e.title||'';form.elements.startDate.value=e.startDate||'';form.elements.startTime.value=e.startTime||'';form.elements.endDate.value=e.endDate||'';form.elements.endTime.value=e.endTime||'';form.elements.trackName.value=e.trackName||'';form.elements.carNames.value=e.carNames||'';form.elements.linkUrl.value=e.linkUrl||'';form.elements.description.value=e.description||'';form.elements.repeatEnabled.checked=Boolean(e.repeatEnabled||e.repeatFrequency==='weekly');form.elements.repeatUntil.value=e.repeatUntil||'';form.elements.visible.checked=e.visible!==false;form.elements.featured.checked=Boolean(e.featured);updateRepeatFields();title.textContent='Editar evento';window.scrollTo({top:0,behavior:'smooth'})}function filteredEvents(){const q=search.value.trim().toLowerCase();const type=typeFilter.value;return events.filter((e)=>{if(type!=='all'&&e.type!==type)return false;const hay=[e.title,e.type,e.trackName,e.carNames,e.description,e.startDate,e.repeatEnabled?'repetición semanal repetir':''].join(' ').toLowerCase();return!q||hay.includes(q)}).sort((a,b)=>String(a.startDate||'').localeCompare(String(b.startDate||''))||String(a.startTime||'').localeCompare(String(b.startTime||'')))}function render(){const rows=filteredEvents();count.textContent=String(events.length);visibleCount.textContent=String(events.filter((e)=>e.visible!==false).length);meta.textContent=`${rows.length} eventos visibles de ${events.length}`;list.innerHTML=rows.length?rows.map((e)=>`<article class="gc-calendar-admin-card ${e.visible===false?'is-hidden':''}" data-type="${esc(e.type||'combo')}"><div class="gc-calendar-admin-card-head"><div><span class="gc-chip ${e.featured?'gc-chip--accent':''}">${esc(typeLabels[e.type]||'Combo semanal')}</span><h3>${esc(e.title||'Evento')}</h3><p>${esc([dateText(e),e.trackName,e.carNames].filter(Boolean).join(' · '))}</p><small>${e.visible===false?'Oculto':'Visible'}${e.featured?' · Destacado':''}${repeatText(e)?' · '+esc(repeatText(e)):''}</small></div><div class="gc-admin-actions"><button class="gc-btn gc-btn--mini" data-action="edit" data-id="${esc(e.id)}">Editar</button><button class="gc-btn gc-btn--mini" data-action="toggle" data-id="${esc(e.id)}">${e.visible===false?'Mostrar':'Ocultar'}</button><button class="gc-btn gc-btn--mini" data-action="delete" data-id="${esc(e.id)}">Borrar</button></div></div>${e.description?`<p>${esc(e.description)}</p>`:''}</article>`).join(''):'<div class="gc-admin-empty">No hay eventos con ese filtro.</div>'}async function loadEvents(){state.textContent='Cargando';const data=await fetchJson('/api/admin/calendar-events');events=(data.events||data.items||[]).filter((e)=>['combo','race_lfm','race_gc'].includes(String(e.type||'combo')));state.textContent='OK';last.textContent=new Date().toLocaleTimeString('es-ES',{hour:'2-digit',minute:'2-digit'});render()}async function checkAcsm(){try{acsmMessage.textContent='Comprobando ACSM...';const d=await fetchJson('/api/admin/acsm/status');acsmRows.innerHTML=`<div><span>Guard</span><strong>${esc(d.source||'-')}</strong></div><div><span>Host</span><strong>${d.config?.hostConfigured?'OK':'Falta'}</strong></div><div><span>User</span><strong>${d.config?.userConfigured?'OK':'Falta'}</strong></div><div><span>Password</span><strong>${d.config?.passwordConfigured?'OK':'Falta'}</strong></div>`;acsmMessage.textContent='ACSM disponible.';acsmMessage.style.color='var(--accent)'}catch(e){acsmRows.innerHTML=`<div><span>Error</span><strong>${esc(e.message||'No disponible')}</strong></div>`;acsmMessage.textContent=e.message||'No se pudo comprobar ACSM.'}}async function syncAcsm(){try{acsmMessage.textContent='Sincronizando combo...';const d=await fetchJson('/api/admin/acsm/sync-current-combo',{method:'POST'});acsmMessage.textContent=`Combo sincronizado. Storage: ${d.source||'-'}.`;acsmMessage.style.color='var(--accent)';await Promise.allSettled([loadEvents(),checkAcsm()])}catch(e){acsmMessage.textContent=e.message||'No se pudo sincronizar ACSM.'}}async function checkAdmin(){try{if(!(await isAdmin()))throw new Error('Sin permisos');content.hidden=false;noAccess.hidden=true;await Promise.allSettled([loadEvents(),checkAcsm()])}catch(e){content.hidden=true;noAccess.hidden=false;state.textContent='Bloqueado'}}form.addEventListener('submit',async(ev)=>{ev.preventDefault();const payload=serializeForm();if(!payload.title||!payload.startDate){setMessage('Título y fecha inicio son obligatorios.');return}try{const id=form.elements.id.value;setMessage('Guardando evento...');await fetchJson(id?`/api/admin/calendar-events/${encodeURIComponent(id)}`:'/api/admin/calendar-events',{method:id?'PUT':'POST',body:JSON.stringify(payload)});setMessage('Evento guardado.',true);resetForm();await loadEvents()}catch(e){setMessage(e.message||'No se pudo guardar.')}});list.addEventListener('click',async(ev)=>{const btn=ev.target.closest('button[data-action]');if(!btn)return;const id=btn.dataset.id;const item=events.find((e)=>e.id===id);if(!item)return;if(btn.dataset.action==='edit'){editEvent(item);return}try{if(btn.dataset.action==='delete'){if(!confirm('¿Borrar este evento del calendario?'))return;await fetchJson(`/api/admin/calendar-events/${encodeURIComponent(id)}`,{method:'DELETE'})}if(btn.dataset.action==='toggle')await fetchJson(`/api/admin/calendar-events/${encodeURIComponent(id)}`,{method:'PUT',body:JSON.stringify({...item,visible:item.visible===false})});await loadEvents()}catch(e){setMessage(e.message||'No se pudo aplicar la acción.')}});[search,typeFilter].forEach((n)=>n.addEventListener('input',render));form.elements.repeatEnabled?.addEventListener('change',updateRepeatFields);reload.addEventListener('click',()=>loadEvents().catch((e)=>setMessage(e.message)));reset.addEventListener('click',resetForm);retry.addEventListener('click',checkAdmin);checkAcsmBtn.addEventListener('click',checkAcsm);syncAcsmBtn.addEventListener('click',syncAcsm);updateRepeatFields();checkAdmin()})();
  </script>
</AppLayout>

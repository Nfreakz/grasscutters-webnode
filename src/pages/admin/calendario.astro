---
import AppLayout from '../../layouts/AppLayout.astro';
import AdminSubnav from '../../components/AdminSubnav.astro';
---
<AppLayout title="Admin calendario | GrassCutters">
  <div class="gc-page gc-admin-calendar-page gc-admin-calendar-v3">
    <section class="gc-hero gc-hero--compact">
      <div>
        <span class="gc-kicker">Administración</span>
        <h1 class="gc-title">Calendario.</h1>
        <p class="gc-subtitle">Gestiona el combo semanal, las carreras LFM y las carreras GrassCutters. La lectura usa fallback público si alguna ruta admin se pone tonta.</p>
        <div class="gc-hero__meta">
          <span class="gc-chip gc-chip--accent">Eventos</span>
          <span class="gc-chip">ACSM</span>
          <span class="gc-chip">MySQL</span>
        </div>
      </div>
      <aside class="gc-live-panel">
        <div class="gc-live-panel__title"><span>Calendario</span><strong id="calAdminState">Comprobando</strong></div>
        <div class="gc-status-list">
          <div class="gc-status-row"><span>Sesión</span><strong id="calAdminSession">...</strong></div>
          <div class="gc-status-row"><span>Eventos</span><strong id="calAdminCount">...</strong></div>
          <div class="gc-status-row"><span>Lectura</span><strong id="calAdminReadMode">...</strong></div>
        </div>
      </aside>
    </section>

    <AdminSubnav active="calendario" />

    <section class="gc-section" id="calAdminAccess" hidden>
      <div class="gc-slab">
        <h3>Acceso restringido</h3>
        <p id="calAccessText">Esta página solo funciona con una cuenta administradora.</p>
        <div class="gc-actions">
          <a class="gc-btn gc-btn--primary" href="/login">Ir a login</a>
          <a class="gc-btn" href="/admin">Volver a admin</a>
          <button class="gc-btn" id="calRetryAuth" type="button">Reintentar</button>
        </div>
      </div>
    </section>

    <section class="gc-grid-2" id="calAdminContent" hidden>
      <form class="gc-form gc-calendar-admin-form" id="calendarForm">
        <div class="gc-section-head">
          <div>
            <h2 id="calendarFormTitle">Crear evento</h2>
            <p>Eventos visibles en la página pública.</p>
          </div>
        </div>
        <input type="hidden" name="id" />
        <div class="gc-form-grid">
          <label class="gc-field"><span>Tipo</span><select class="gc-select" name="type"><option value="combo">Combo semanal</option><option value="race_lfm">Carrera LFM</option><option value="race_gc">Carrera GrassCutters</option></select></label>
          <label class="gc-field"><span>Título</span><input class="gc-input" name="title" required placeholder="Carrera GrassCutters en Suzuka" /></label>
          <label class="gc-field"><span>Fecha inicio</span><input class="gc-input" name="startDate" type="date" required /></label>
          <label class="gc-field"><span>Hora inicio</span><input class="gc-input" name="startTime" type="time" /></label>
          <label class="gc-field"><span>Fecha fin</span><input class="gc-input" name="endDate" type="date" /></label>
          <label class="gc-field"><span>Hora fin</span><input class="gc-input" name="endTime" type="time" /></label>
          <label class="gc-field"><span>Repetir hasta</span><input class="gc-input" name="repeatUntil" type="date" /></label>
          <label class="gc-field"><span>Circuito</span><input class="gc-input" name="trackName" placeholder="Suzuka" /></label>
          <label class="gc-field"><span>Coches</span><input class="gc-input" name="carNames" placeholder="Toyota Supra JGTC 2000" /></label>
          <label class="gc-field" style="grid-column:1 / -1"><span>Enlace opcional</span><input class="gc-input" name="linkUrl" placeholder="https://..." /></label>
          <label class="gc-field" style="grid-column:1 / -1"><span>Descripción</span><textarea class="gc-input gc-calendar-textarea" name="description" rows="4" placeholder="Briefing, formato, notas o indicaciones."></textarea></label>
        </div>
        <div class="gc-calendar-checks">
          <label><input type="checkbox" name="visible" checked /> Visible</label>
          <label><input type="checkbox" name="featured" /> Destacado</label>
          <label><input type="checkbox" name="repeatEnabled" /> Repetir cada semana</label>
        </div>
        <p class="gc-calendar-repeat-note">La repetición semanal usa el mismo día y hora del evento inicial.</p>
        <div class="gc-actions">
          <button class="gc-btn gc-btn--primary" type="submit">Guardar evento</button>
          <button class="gc-btn" type="button" id="calendarReset">Limpiar</button>
          <a class="gc-btn" href="/calendario" target="_blank" rel="noreferrer">Ver calendario</a>
        </div>
        <p class="gc-message" id="calendarMessage"></p>
      </form>

      <aside class="gc-section gc-calendar-acsm-panel">
        <div class="gc-section-head">
          <div>
            <h2>ACSM</h2>
            <p>Combo activo desde Assetto Corsa Server Manager.</p>
          </div>
        </div>
        <div class="gc-slab-list" id="acsmRows">
          <div><span>Estado</span><strong>Comprobando</strong></div>
        </div>
        <div class="gc-actions">
          <button class="gc-btn" id="checkAcsmBtn" type="button">Probar ACSM</button>
          <button class="gc-btn gc-btn--primary" id="syncAcsmBtn" type="button">Sincronizar combo</button>
        </div>
        <p class="gc-message" id="acsmMessage"></p>
      </aside>
    </section>

    <section class="gc-section" id="calendarListSection" hidden>
      <div class="gc-section-head">
        <div>
          <h2>Eventos creados</h2>
          <p id="calendarListMeta">Cargando...</p>
        </div>
        <button class="gc-btn" id="calendarReload" type="button">Recargar</button>
      </div>
      <div class="gc-toolbar">
        <label class="gc-field"><span>Buscar</span><input class="gc-input" id="calendarSearch" type="search" placeholder="título, circuito, coche..." /></label>
        <label class="gc-field"><span>Tipo</span><select class="gc-select" id="calendarTypeFilter"><option value="all">Todos</option><option value="combo">Combo semanal</option><option value="race_lfm">Carrera LFM</option><option value="race_gc">Carrera GrassCutters</option></select></label>
      </div>
      <div class="gc-calendar-admin-list" id="calendarAdminList">Cargando eventos...</div>
    </section>
  </div>

  <style is:global>
    .gc-admin-calendar-v3{display:grid;gap:clamp(22px,3vw,34px)}
    .gc-admin-calendar-v3 [hidden]{display:none!important}
    .gc-calendar-admin-form,.gc-calendar-acsm-panel{align-self:start}
    .gc-calendar-textarea{height:auto;min-height:110px;padding-top:10px;resize:vertical}
    .gc-calendar-checks{display:flex;flex-wrap:wrap;gap:12px;color:var(--soft);margin-top:14px}
    .gc-calendar-checks label{display:inline-flex;gap:8px;align-items:center;border:1px solid var(--line);padding:9px 12px;background:rgba(255,255,255,.018)}
    .gc-calendar-repeat-note{margin:10px 0 0;color:var(--dim);font-size:.86rem}
    .gc-calendar-admin-list{display:grid;gap:10px}
    .gc-calendar-admin-card{display:grid;gap:10px;padding:14px;border:1px solid var(--line);border-left:3px solid var(--accent);background:rgba(255,255,255,.018)}
    .gc-calendar-admin-card[data-type="race_lfm"]{border-left-color:#35d3ff}.gc-calendar-admin-card[data-type="race_gc"]{border-left-color:#ffc46b}
    .gc-calendar-admin-card-head{display:flex;justify-content:space-between;gap:12px;align-items:flex-start}.gc-calendar-admin-card h3{margin:0;color:var(--text);font-size:1.1rem}.gc-calendar-admin-card p{margin:0;color:var(--soft)}.gc-calendar-admin-card small{color:var(--dim)}.gc-calendar-admin-actions{display:flex;gap:8px;flex-wrap:wrap}.gc-calendar-admin-card.is-hidden{opacity:.55}
    @media(max-width:900px){.gc-admin-calendar-v3 .gc-grid-2{grid-template-columns:1fr}.gc-calendar-admin-card-head{display:grid}}
  </style>

  <script is:inline>
    (() => {
      const $ = (id) => document.getElementById(id);
      const form = $('calendarForm');
      const content = $('calAdminContent');
      const noAccess = $('calAdminAccess');
      const listSection = $('calendarListSection');
      const list = $('calendarAdminList');
      const message = $('calendarMessage');
      const state = $('calAdminState');
      const session = $('calAdminSession');
      const count = $('calAdminCount');
      const readMode = $('calAdminReadMode');
      const meta = $('calendarListMeta');
      const search = $('calendarSearch');
      const typeFilter = $('calendarTypeFilter');
      const reload = $('calendarReload');
      const reset = $('calendarReset');
      const title = $('calendarFormTitle');
      const acsmRows = $('acsmRows');
      const acsmMessage = $('acsmMessage');
      const typeLabels = { combo:'Combo semanal', race_lfm:'Carrera LFM', race_gc:'Carrera GrassCutters' };
      let events = [];
      let adminAuthorized = false;
      let adminReadOnly = false;

      const escapeHtml = (value) => String(value ?? '').replace(/[&<>\'\"]/g, (char) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[char]));
      const setMessage = (text, ok = false) => { message.textContent = text || ''; message.style.color = ok ? 'var(--accent)' : 'var(--soft)'; };
      const setAcsmMessage = (text, ok = false) => { acsmMessage.textContent = text || ''; acsmMessage.style.color = ok ? 'var(--accent)' : 'var(--soft)'; };
      const dateText = (event) => [event.startDate, event.startTime].filter(Boolean).join(' · ') || '-';
      const repeatText = (event) => (event.repeatEnabled || event.repeatFrequency === 'weekly') ? (event.repeatUntil ? `Repetición semanal hasta ${event.repeatUntil}` : 'Repetición semanal') : '';

      async function fetchJson(url, options = {}) {
        const response = await fetch(url, { credentials:'include', cache:'no-store', headers:{ 'Content-Type':'application/json' }, ...options });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || data.ok === false) throw new Error(data.message || `HTTP ${response.status}`);
        return data;
      }

      async function getAdminStatus() {
        try {
          const status = await fetchJson('/api/admin/status');
          if (status.authorized === true) return { authorized:true, user: status.currentUser || null, source:'admin-status' };
        } catch {}
        const profile = await fetchJson('/api/profile');
        return { authorized: profile.user?.role === 'admin', user: profile.user || null, source:'profile' };
      }

      async function checkAdmin() {
        state.textContent = 'Comprobando';
        try {
          const status = await getAdminStatus();
          adminAuthorized = status.authorized === true;
          if (!adminAuthorized) throw new Error('Acceso admin requerido.');
          session.textContent = status.user?.displayName || 'Admin';
          state.textContent = 'OK';
          content.hidden = false;
          listSection.hidden = false;
          noAccess.hidden = true;
          await Promise.allSettled([checkAcsm(), loadEvents()]);
        } catch (error) {
          adminAuthorized = false;
          session.textContent = 'No';
          state.textContent = 'Bloqueado';
          content.hidden = true;
          listSection.hidden = true;
          noAccess.hidden = false;
          $('calAccessText').textContent = error.message || 'Acceso admin requerido.';
        }
      }

      function serializeForm() {
        const data = Object.fromEntries(new FormData(form));
        return {
          id: data.id || undefined,
          type: ['combo','race_lfm','race_gc'].includes(String(data.type)) ? data.type : 'combo',
          title: String(data.title || '').trim(),
          startDate: data.startDate,
          startTime: data.startTime || '',
          endDate: data.endDate || '',
          endTime: data.endTime || '',
          trackName: String(data.trackName || '').trim(),
          carNames: String(data.carNames || '').trim(),
          linkUrl: String(data.linkUrl || '').trim(),
          description: String(data.description || '').trim(),
          repeatEnabled: form.elements.repeatEnabled.checked,
          repeatFrequency: form.elements.repeatEnabled.checked ? 'weekly' : 'none',
          repeatUntil: data.repeatUntil || '',
          visible: form.elements.visible.checked,
          featured: form.elements.featured.checked
        };
      }

      function resetForm() {
        form.reset();
        form.elements.id.value = '';
        form.elements.visible.checked = true;
        form.elements.featured.checked = false;
        form.elements.repeatEnabled.checked = false;
        title.textContent = 'Crear evento';
        setMessage('');
      }

      function editEvent(event) {
        form.elements.id.value = event.id || '';
        form.elements.type.value = ['combo','race_lfm','race_gc'].includes(String(event.type)) ? event.type : 'combo';
        form.elements.title.value = event.title || '';
        form.elements.startDate.value = event.startDate || '';
        form.elements.startTime.value = event.startTime || '';
        form.elements.endDate.value = event.endDate || '';
        form.elements.endTime.value = event.endTime || '';
        form.elements.trackName.value = event.trackName || '';
        form.elements.carNames.value = event.carNames || '';
        form.elements.linkUrl.value = event.linkUrl || '';
        form.elements.description.value = event.description || '';
        form.elements.repeatEnabled.checked = Boolean(event.repeatEnabled || event.repeatFrequency === 'weekly');
        form.elements.repeatUntil.value = event.repeatUntil || '';
        form.elements.visible.checked = event.visible !== false;
        form.elements.featured.checked = Boolean(event.featured);
        title.textContent = 'Editar evento';
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      function filteredEvents() {
        const query = search.value.trim().toLowerCase();
        const type = typeFilter.value;
        return events.filter((event) => {
          if (type !== 'all' && event.type !== type) return false;
          const haystack = [event.title, event.type, event.trackName, event.carNames, event.description, event.startDate, event.repeatEnabled ? 'repetición semanal repetir' : ''].join(' ').toLowerCase();
          return !query || haystack.includes(query);
        }).sort((a,b) => String(a.startDate || '').localeCompare(String(b.startDate || '')) || String(a.startTime || '').localeCompare(String(b.startTime || '')));
      }

      function render() {
        const rows = filteredEvents();
        count.textContent = String(events.length);
        readMode.textContent = adminReadOnly ? 'Pública' : 'Admin';
        meta.textContent = `${rows.length} eventos visibles de ${events.length}${adminReadOnly ? ' · lectura fallback' : ''}`;
        if (!rows.length) {
          list.innerHTML = '<div class="gc-slab"><p>No hay eventos con ese filtro.</p></div>';
          return;
        }
        list.innerHTML = rows.map((event) => `<article class="gc-calendar-admin-card ${event.visible === false ? 'is-hidden' : ''}" data-type="${escapeHtml(event.type || 'combo')}"><div class="gc-calendar-admin-card-head"><div><span class="gc-chip ${event.featured ? 'gc-chip--accent' : ''}">${escapeHtml(typeLabels[event.type] || 'Combo semanal')}</span><h3>${escapeHtml(event.title || 'Evento')}</h3><p>${escapeHtml([dateText(event), event.trackName, event.carNames].filter(Boolean).join(' · '))}</p><small>${event.visible === false ? 'Oculto' : 'Visible'}${event.featured ? ' · Destacado' : ''}${repeatText(event) ? ' · ' + escapeHtml(repeatText(event)) : ''}</small></div><div class="gc-calendar-admin-actions"><button class="gc-btn gc-btn--mini" data-action="edit" data-id="${escapeHtml(event.id)}">Editar</button><button class="gc-btn gc-btn--mini" data-action="toggle" data-id="${escapeHtml(event.id)}" ${adminReadOnly ? 'disabled' : ''}>${event.visible === false ? 'Mostrar' : 'Ocultar'}</button><button class="gc-btn gc-btn--mini" data-action="delete" data-id="${escapeHtml(event.id)}" ${adminReadOnly ? 'disabled' : ''}>Borrar</button></div></div>${event.description ? `<p>${escapeHtml(event.description)}</p>` : ''}</article>`).join('');
      }

      function normalizeEventsPayload(data) {
        return (data.events || data.items || data.calendarEvents || []).filter((event) => ['combo','race_lfm','race_gc'].includes(String(event.type || 'combo')));
      }

      async function loadEvents() {
        list.innerHTML = 'Cargando eventos...';
        adminReadOnly = false;
        try {
          const data = await fetchJson('/api/admin/calendar-events');
          events = normalizeEventsPayload(data);
          setMessage('');
        } catch (adminError) {
          try {
            const data = await fetchJson('/api/calendar-events');
            events = normalizeEventsPayload(data);
            adminReadOnly = true;
            setMessage('La API admin de calendario sigue devolviendo acceso restringido. Se usa lectura pública como fallback.', false);
          } catch (publicError) {
            events = [];
            setMessage(publicError.message || adminError.message || 'No se pudieron cargar eventos.');
          }
        }
        render();
      }

      async function checkAcsm() {
        try {
          setAcsmMessage('Comprobando ACSM...');
          const data = await fetchJson('/api/admin/acsm/status');
          acsmRows.innerHTML = `<div><span>Auth</span><strong>${data.authorized ? 'OK' : 'No'}</strong></div><div><span>Ruta</span><strong>${escapeHtml(data.source || '-')}</strong></div><div><span>SFTP</span><strong>${data.config?.hostConfigured && data.config?.userConfigured ? 'OK' : 'Falta'}</strong></div>`;
          setAcsmMessage('ACSM disponible.', true);
        } catch (error) {
          acsmRows.innerHTML = '<div><span>Estado</span><strong>Error</strong></div>';
          setAcsmMessage(error.message || 'No se pudo comprobar ACSM.');
        }
      }

      async function syncAcsm() {
        try {
          setAcsmMessage('Sincronizando combo ACSM...');
          const data = await fetchJson('/api/admin/acsm/sync-current-combo', { method:'POST' });
          setAcsmMessage(`Combo sincronizado en ${data.source || 'storage'}.`, true);
          await loadEvents();
        } catch (error) {
          setAcsmMessage(error.message || 'No se pudo sincronizar ACSM.');
        }
      }

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const payload = serializeForm();
        if (!payload.title || !payload.startDate) { setMessage('Título y fecha inicio son obligatorios.'); return; }
        try {
          const id = form.elements.id.value;
          setMessage('Guardando evento...');
          await fetchJson(id ? `/api/admin/calendar-events/${encodeURIComponent(id)}` : '/api/admin/calendar-events', { method: id ? 'PUT' : 'POST', body: JSON.stringify(payload) });
          setMessage('Evento guardado.', true);
          resetForm();
          await loadEvents();
        } catch (error) {
          setMessage(error.message || 'No se pudo guardar. Si pone acceso admin requerido, falta unificar el guard de las rutas /api/admin/calendar-events.');
        }
      });

      list.addEventListener('click', async (event) => {
        const button = event.target.closest('button[data-action]');
        if (!button) return;
        const id = button.dataset.id;
        const item = events.find((event) => event.id === id);
        if (!item) return;
        if (button.dataset.action === 'edit') { editEvent(item); return; }
        try {
          if (button.dataset.action === 'delete') {
            if (!confirm('¿Borrar este evento del calendario?')) return;
            await fetchJson(`/api/admin/calendar-events/${encodeURIComponent(id)}`, { method:'DELETE' });
          }
          if (button.dataset.action === 'toggle') {
            await fetchJson(`/api/admin/calendar-events/${encodeURIComponent(id)}`, { method:'PUT', body: JSON.stringify({ ...item, visible: item.visible === false }) });
          }
          await loadEvents();
        } catch (error) {
          setMessage(error.message || 'No se pudo aplicar la acción.');
        }
      });

      [search, typeFilter].forEach((node) => node?.addEventListener('input', render));
      reload.addEventListener('click', () => loadEvents());
      reset.addEventListener('click', resetForm);
      $('calRetryAuth')?.addEventListener('click', checkAdmin);
      $('checkAcsmBtn')?.addEventListener('click', checkAcsm);
      $('syncAcsmBtn')?.addEventListener('click', syncAcsm);
      checkAdmin();
    })();
  </script>
</AppLayout>

---
import AppLayout from '../../layouts/AppLayout.astro';
import AdminSubnav from '../../components/AdminSubnav.astro';
---
<AppLayout title="Admin historial | GrassCutters">
  <div class="gc-page gc-admin-page-clean">
    <section class="gc-hero gc-hero--compact">
      <div><span class="gc-kicker">Administración</span><h1 class="gc-title">Historial.</h1><p class="gc-subtitle">Auditoría de acciones sensibles, cambios de nombres y permisos.</p></div>
      <aside class="gc-live-panel"><div class="gc-live-panel__title"><span>Historial</span><strong id="auditState">Cargando</strong></div><div class="gc-status-list"><div class="gc-status-row"><span>Eventos</span><strong id="auditCount">...</strong></div></div></aside>
    </section>
    <AdminSubnav />
    <section class="gc-section" id="adminGate" hidden><div class="gc-section-head"><h2>Acceso restringido</h2><p>Solo administradores</p></div><div class="gc-slab"><p>Inicia sesión con una cuenta administradora.</p><div class="gc-actions"><a class="gc-btn gc-btn--primary" href="/login">Login</a><button class="gc-btn" id="retryAdmin" type="button">Reintentar</button></div></div></section>
    <section class="gc-section" id="adminContent" hidden>
      <div class="gc-section-head"><h2>Historial admin</h2><p id="auditMeta">Últimos cambios</p></div>
      <div class="gc-toolbar"><button class="gc-btn" id="reloadAudit" type="button">Recargar historial</button></div>
      <div class="gc-table-wrap"><table class="gc-table gc-table--compact" id="auditTable"><thead><tr><th>Fecha</th><th>Admin</th><th>Acción</th><th>Entidad</th><th>Detalle</th></tr></thead><tbody><tr><td colspan="5">Cargando historial...</td></tr></tbody></table></div>
      <p class="gc-message" id="auditMessage"></p>
    </section>
  </div>
  <script is:inline>
    (()=>{const $=(id)=>document.getElementById(id);const els={gate:$('adminGate'),content:$('adminContent'),retry:$('retryAdmin'),state:$('auditState'),count:$('auditCount'),meta:$('auditMeta'),table:document.querySelector('#auditTable tbody'),reload:$('reloadAudit'),msg:$('auditMessage')};const esc=(v)=>String(v??'').replace(/[&<>'"]/g,(c)=>({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));const dateText=(v)=>{if(!v)return'-';const d=new Date(v);return Number.isNaN(d.getTime())?'-':d.toLocaleString('es-ES',{dateStyle:'short',timeStyle:'short'})};const detail=(v)=>{if(!v)return'-';try{if(typeof v==='string')return v.slice(0,160);if(v.displayName)return v.displayName;if(v.after?.displayName)return v.after.displayName;if(v.count!==undefined)return `${v.count} cambios`;return JSON.stringify(v).slice(0,160)}catch{return String(v).slice(0,160)}};async function fetchJson(url,options={}){const r=await fetch(url,{credentials:'include',cache:'no-store',headers:{'Content-Type':'application/json'},...options});const d=await r.json().catch(()=>({}));if(!r.ok||d.ok===false)throw new Error(d.message||`HTTP ${r.status}`);return d}async function isAdmin(){try{const s=await fetchJson('/api/admin/status');if(s.authorized===true)return true}catch{}const p=await fetchJson('/api/profile');return p.user?.role==='admin'}function show(m){els.gate.hidden=m!=='gate';els.content.hidden=m!=='content'}async function load(){els.state.textContent='Cargando';const data=await fetchJson('/api/admin/audit-log?limit=120');const items=data.items||[];els.count.textContent=String(items.length);els.meta.textContent=`${items.length} eventos recientes`;els.table.innerHTML=items.length?items.map((i)=>`<tr><td>${esc(dateText(i.createdAt))}</td><td><strong>${esc(i.actorName||i.actorEmail||'Sistema')}</strong><br><span class="gc-muted-text">${esc(i.actorEmail||'')}</span></td><td><span class="gc-chip">${esc(i.action)}</span></td><td>${esc(i.entityType)}<br><span class="gc-muted-text">${esc(i.entityId||'-')}</span></td><td>${esc(detail(i.afterValue||i.beforeValue))}</td></tr>`).join(''):'<tr><td colspan="5">Sin historial todavía.</td></tr>';els.state.textContent='OK';els.msg.textContent=''}async function init(){show('gate');try{if(!(await isAdmin()))return show('gate');show('content');await load()}catch(e){show('gate')}}els.retry.addEventListener('click',init);els.reload.addEventListener('click',()=>load().catch((e)=>els.msg.textContent=e.message||'No se pudo cargar.'));init()})();
  </script>
</AppLayout>

---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import {
  archiveItemHref,
  getArchiveImage,
  getArchiveStats,
  getArchiveSummary,
  normalizeArchiveType as normalizeArchiveTypeRuntime,
  prettifyArchiveType,
} from '../lib/archive/archiveRuntime';

const title = 'GrassCutters Racing | Sim racing, hotlaps y comunidad';
const description = 'GrassCutters Racing: comunidad de sim racing con servidor, combos, hotlaps, noticias, archivo motorsport y herramientas para pilotos.';

const home2ToolLinks = {
  hud: 'https://www.overtake.gg/downloads/grasscutters-lua-hud-lite.84201/',
  android: '/app-android',
  carsDrive: 'https://drive.google.com/drive/folders/1BXJJkPOo7ZuhIKf_VegI5g8serZsJw7W?usp=drive_link',
  tracksDrive: 'https://drive.google.com/drive/folders/1xSrI8aPBLH15wrytkR-IUjMQPWEVyfQw?usp=drive_link',
  profile: '/perfil',
  hotlaps: '/hotlaps',
  combos: '/combos',
  championship: '/campeonato',
};

const archiveStats = await getArchiveStats();
const home2ArchiveSeed = (archiveStats.items || [])
  .filter((item) => ['circuitos', 'coches', 'pilotos', 'glosario'].includes(normalizeArchiveTypeRuntime(item.tipo || item.category || item.type || '')))
  .slice(0, 80)
  .map((item) => ({
    id: item.id || `${item.tipo}-${item.slug}`,
    tipo: normalizeArchiveTypeRuntime(item.tipo || item.category || item.type || ''),
    type: normalizeArchiveTypeRuntime(item.tipo || item.category || item.type || ''),
    category: item.category || item.tipo || '',
    slug: item.slug || '',
    nombre: item.nombre || item.title || '',
    title: item.title || item.nombre || '',
    status: item.status || item.estado || 'published',
    featured: item.featured || item.destacado || item.isFeatured || false,
    href: archiveItemHref(item),
    image: getArchiveImage(item),
    imageUrl: getArchiveImage(item),
    coverUrl: getArchiveImage(item),
    summary: getArchiveSummary(item),
    descripcion_corta: getArchiveSummary(item),
    description: getArchiveSummary(item),
    tipoLabel: prettifyArchiveType(item.tipo || item.category || item.type || ''),
    pais: item.pais || item.país || item.nacionalidad || item.ubicacion || '',
    periodo: item.periodo || item.epoca || item.años_actividad || item.anos_actividad || item.fecha_apertura || '',
    tags: item.tags || '',
    fabricante: item.fabricante || '',
    modelo: item.modelo || item.modelo_base || '',
    motor: item.motor || '',
    disciplina: item.disciplina || '',
    circuitos_asociados: item.circuitos_asociados || '',
    coches_asociados: item.coches_asociados || '',
    pilotos_asociados: item.pilotos_asociados || '',
    search: [
      item.nombre,
      item.title,
      item.slug,
      item.tipo,
      prettifyArchiveType(item.tipo || item.category || item.type || ''),
      getArchiveSummary(item),
      item.pais,
      item.país,
      item.nacionalidad,
      item.ubicacion,
      item.periodo,
      item.epoca,
      item.tags,
      item.fabricante,
      item.modelo,
      item.modelo_base,
      item.motor,
      item.disciplina,
      item.circuitos_asociados,
      item.coches_asociados,
      item.pilotos_asociados,
    ].filter(Boolean).join(' '),
  }));


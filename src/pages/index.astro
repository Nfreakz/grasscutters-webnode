        const comboStandoutsPayload =
          await fetchJson('/api/gc/recent-laps?limit=3000&sort=recent&valid=all') ||
          await fetchJson('/api/gc/leaderboard?scope=activeCombo&valid=all&group=all&limit=3000') ||
          await fetchJson('/api/gc/leaderboard?scope=currentCombo&valid=all&group=all&limit=3000') ||
          await fetchJson('/api/gc/leaderboard?scope=global&valid=all&group=all&limit=3000') ||
          await fetchJson('/api/laps?limit=3000&sort=recent&valid=all') ||
          await fetchJson('/api/hotlaps?limit=3000&sort=recent&valid=all');

        const raceData = diagnostics && (diagnostics.raceData || diagnostics.stats || diagnostics);
        if (raceData) {
          const totalLaps = firstValue(raceData, ['lapsCount', 'validLapsCount', 'totalLaps', 'hotlaps']);
          const drivers = firstValue(raceData, ['driversCount', 'pilotsCount', 'totalDrivers', 'pilots']);
          const active = diagnostics && (diagnostics.health === 'ok' || diagnostics.ok);
          setText('[data-home2-live]', active ? 'LIVE' : 'STATUS');
          setText('[data-home2-server-state]', active ? 'Online' : 'Revisar');
          if (drivers) setText('[data-home2-drivers]', drivers);
          if (totalLaps) setText('[data-home2-laps]', totalLaps);
        }

        const combo = getArray(combosPayload)[0] || combosPayload?.activeCombo || combosPayload?.combo || {};
        const rawTrackName = firstValue(combo, ['canonicalTrackName', 'trackName', 'track', 'circuitName', 'name']) || 'Actualizando';
        const trackHelper = window.GCHomeTrackResolver || null;
        const track = trackHelper?.displayName ? trackHelper.displayName(rawTrackName) : rawTrackName;
        const trackAssetName = trackHelper?.assetName ? trackHelper.assetName(rawTrackName) : rawTrackName;
        const cars = firstValue(combo, ['publicComboCars', 'carNames', 'cars', 'mainVariantAllCars']);
        const carList = Array.isArray(cars) ? cars.map((car) => typeof car === 'string' ? car : firstValue(car, ['name', 'carName', 'displayName'])).filter(Boolean) : String(cars || '').split(',').map((s) => s.trim()).filter(Boolean);
        const totalComboLaps = firstValue(combo, ['totalLaps', 'validLaps', 'lapsCount', 'summary.totalLaps']);
        const comboDrivers = firstValue(combo, ['driversCount', 'pilotsCount', 'summary.driversCount']);
        const bestDriver = firstValue(combo, ['bestDriverName', 'bestPilotName', 'leaderboard.0.driverName', 'best.driverName']) || '--';
        const bestCar = firstValue(combo, ['bestCarName', 'best.carName', 'leaderboard.0.carName']) || carList[0] || '--';
        const bestTime = formatLap(firstValue(combo, ['bestLapTimeFormatted', 'bestLapFormatted', 'bestLapTime', 'bestLap', 'best.time', 'leaderboard.0.lapTime'])) || '--';

        setText('[data-home2-track]', track);
        setText('[data-home2-now-title]', track);
        const inferredCountry = inferTrackCountry(track, combo) || '--';
        setText('[data-home2-track-country]', inferredCountry);
        setText('[data-home2-now-country]', inferredCountry);
        // GC_HOME_TRACK_RESOLVER_V2_DISTANCE
        const rawTrackDistance = firstValue(combo, [
          'trackDistanceKm',
          'distanceKm',
          'track.distanceKm',
          'track.lengthKm',
          'lengthKm',
          'trackLengthKm',
          'trackLength',
          'track.distance',
          'distance'
        ]);
        const directDistance = trackHelper?.formatDistance ? trackHelper.formatDistance(rawTrackDistance) : rawTrackDistance;
        const fallbackDistance = trackHelper?.distance ? (trackHelper.distance(rawTrackName) || trackHelper.distance(track)) : '';
        setText('[data-home2-now-distance]', directDistance || fallbackDistance || '--');
        setText('[data-home2-cars]', carList.slice(0, 3).join(' / ') || 'Sin coches publicados');
        setText('[data-home2-now-cars]', String(carList.length || '--'));
        setText('[data-home2-best-driver]', bestDriver);
        setText('[data-home2-reference-driver]', bestDriver);
        setText('[data-home2-best-car]', bestCar);
        setText('[data-home2-reference-car]', bestCar);
        setText('[data-home2-best-time]', bestTime);
        setText('[data-home2-reference-time]', bestTime);
        if (totalComboLaps) setText('[data-home2-laps]', totalComboLaps);
        if (comboDrivers) setText('[data-home2-drivers]', comboDrivers);

        const bestAvatar = pilotAvatarUrl(combo.best || combo.leaderboard?.[0] || combo);
        $$('[data-home2-best-avatar], [data-home2-reference-avatar]').forEach((img) => img.src = bestAvatar);

        await setTrackImage(trackAssetName || track);
        await setTrackMap(trackAssetName || track);

        const champTrackImageFallback = $('[data-home2-champ-track-image]');
        const heroTrackImage = $('[data-home2-track-image]');
        if (champTrackImageFallback && heroTrackImage && champTrackImageFallback.src.includes('gc-home2-track-fallback')) {
          champTrackImageFallback.src = heroTrackImage.currentSrc || heroTrackImage.src;
        }
        renderRows('[data-home2-recent-laps]', getArray(recentPayload));
        await updateReliableServerPanel(getArray(recentPayload), combo, raceData || {});



        const boardCandidates = [
          ...getArray(leaderboardPayload),
          ...getArray(combo.leaderboard),
          ...getArray(combo.bestLaps),
          ...getArray(combo.laps),
          ...getArray(recentPayload)
        ];

        renderComboRanking(boardCandidates, trackAssetName || rawTrackName || track, carList);

        renderRaceStandoutsV1([
          ...getArray(comboStandoutsPayload),
          ...getArray(leaderboardPayload),
          ...getArray(combo.laps),
          ...getArray(combo.bestLaps),
          ...getArray(combo.leaderboard),
          ...getArray(recentPayload)
        ], trackAssetName || rawTrackName || track, carList);

        await Promise.all([
          renderChampionship(),
          renderNews(),
          renderArchive(track, carList)
        ]);
      };

      init();
    })();
  </script>
</MarketingLayout>

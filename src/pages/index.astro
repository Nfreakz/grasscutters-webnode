          '/api/gc/recent-laps?limit=1&order=asc&valid=all',
          '/api/laps?limit=1&sort=oldest&valid=all',
          '/api/laps?limit=1&order=asc&valid=all',
          '/api/hotlaps?limit=1&sort=oldest',

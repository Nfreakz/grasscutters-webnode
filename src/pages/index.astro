---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="GrassCutters Platform">
  <main class="gc-shell">
    <section class="gc-hero">
      <div class="gc-hero__glow gc-hero__glow--a"></div>
      <div class="gc-hero__glow gc-hero__glow--b"></div>

      <div class="gc-hero__content">
        <span class="gc-kicker">GrassCutters Platform</span>
        <h1>Una nueva centralita para la comunidad GC.</h1>
        <p>
          Web Astro, servidor Node único, API propia, Discord bot, stracker.db3 y futura área de pilotos.
        </p>

        <div class="gc-actions">
          <a href="/pilotos" class="gc-button gc-button--primary">Área pilotos</a>
          <a href="/hotlaps" class="gc-button">Hotlaps</a>
        </div>
      </div>
    </section>

    <section class="gc-grid" aria-label="Módulos principales">
      <article class="gc-card">
        <span>01</span>
        <h2>Web Astro</h2>
        <p>Home, eventos, rankings, calendario, comunidad y páginas públicas.</p>
      </article>

      <article class="gc-card">
        <span>02</span>
        <h2>API Node</h2>
        <p>Rutas centralizadas para pilotos, estadísticas, Discord, eventos y autenticación.</p>
      </article>

      <article class="gc-card">
        <span>03</span>
        <h2>stracker.db3</h2>
        <p>Lectura de vueltas, coches, circuitos, sectores, historial y datos de rendimiento.</p>
      </article>

      <article class="gc-card">
        <span>04</span>
        <h2>Discord Bot</h2>
        <p>Bot integrado en el mismo Node para anuncios, estado, eventos y futuras automatizaciones.</p>
      </article>
    </section>
  </main>
</BaseLayout>

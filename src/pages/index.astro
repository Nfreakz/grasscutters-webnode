</style>

  <script is:inline src="/js/gc-track-images.js"></script>
  <script is:inline>
    const gcSetText = (id, value) => {
      const el = document.getElementById(id);
      if (el) el.textContent = String(value ?? '0');
    };

    const gcEscape = (value) => String(value ?? '').replace(/[&<>'"]/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      "'": '&#39;',
      '"': '&quot;'
    }[char]));

    const gcText = (value) => {
      if (value == null) return '';
      if (typeof value === 'string' || typeof value === 'number') return String(value).trim();
      if (Array.isArray(value)) return value.map(gcText).filter(Boolean).join(' ');
      if (typeof value === 'object') {
        return gcText(
          value.displayName ??
          value.name ??
          value.Name ??
          value.uiName ??
          value.uiCarName ??
          value.uiTrackName ??
          value.carName ??
          value.trackName ??
          value.driverName ??
          value.playerName ??
          value.code ??
          value.id ??
          value.ID ??
          value.car ??
          value.track
        );
      }
      return String(value).trim();
    };

    const gcFormatMs = (value) => {
      const ms = Number(value);
      if (!Number.isFinite(ms) || ms <= 0) return '--';
      const minutes = Math.floor(ms / 60000);
      const seconds = Math.floor((ms % 60000) / 1000);
      const millis = Math.floor(ms % 1000);
      return `${minutes}:${String(seconds).padStart(2, '0')}.${String(millis).padStart(3, '0')}`;
    };

    const gcNumber = (value, fallback = 0) => {
      const n = Number(value);
      return Number.isFinite(n) ? n : fallback;
    };

    const gcAnimateNumber = (id, value) => {
      const el = document.getElementById(id);
      const end = Math.max(0, Math.round(gcNumber(value, 0)));
      if (!el) return;
      const duration = 850;
      const start = performance.now();
      const step = (now) => {
        const progress = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.round(end * eased).toLocaleString('es-ES');
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };

    const gcPickList = (data) => {
      if (!data) return [];
      return (
        data.items ||
        data.combos ||
        data.stats ||
        data.results ||
        data.data ||
        []
      );
    };

    const gcPickTotal = (data, candidates = []) => {
      if (!data) return 0;
      for (const key of candidates) {
        const n = Number(data?.[key]);
        if (Number.isFinite(n)) return n;
      }
      const list = gcPickList(data);
      return Array.isArray(list) ? list.length : 0;
    };

    const gcCarName = (car) => gcText(
      car?.displayName ??
      car?.uiCarName ??
      car?.uiName ??
      car?.carName ??
      car?.name ??
      car?.Car ??
      car?.code ??
      car
    );

    const gcExtractCars = (combo) => {
      const raw = (
        combo?.cars ||
        combo?.carList ||
        combo?.carNames ||
        combo?.availableCars ||
        combo?.comboCars ||
        combo?.members?.cars ||
        []
      );

      let cars = Array.isArray(raw) ? raw : [];
      if (!cars.length && typeof raw === 'string') {
        cars = raw.split(/[,|;]/g);
      }

      if (!cars.length && combo?.carName) cars = [combo.carName];
      if (!cars.length && combo?.car?.name) cars = [combo.car];

      const seen = new Set();
      return cars
        .map(gcCarName)
        .filter(Boolean)
        .filter((name) => {
          const key = name.toLowerCase();
          if (seen.has(key)) return false;
          seen.add(key);
          return true;
        });
    };

    const gcComboTime = (combo) => {
      const best = combo?.bestLap || combo?.best || combo?.fastestLap || combo?.leader || combo?.topLap || {};
      return (
        gcText(combo?.bestLapTimeFormatted) ||
        gcText(combo?.bestTimeFormatted) ||
        gcText(combo?.bestLapFormatted) ||
        gcText(best?.lapTimeFormatted) ||
        gcText(best?.lapTime) ||
        gcFormatMs(
          combo?.bestLapTimeMs ??
          combo?.bestTimeMs ??
          combo?.bestLapMs ??
          best?.lapTimeMs ??
          best?.LapTime ??
          best?.lapTime
        )
      );
    };

    const gcComboBestParts = (combo) => {
      const best = combo?.bestLap || combo?.best || combo?.fastestLap || combo?.leader || combo?.topLap || {};
      const driver = gcText(
        combo?.bestDriverName ??
        combo?.fastestDriverName ??
        combo?.leaderName ??
        best?.driverName ??
        best?.playerName ??
        best?.name ??
        best?.driver ??
        best?.player
      );

      const car = gcText(
        combo?.bestCarName ??
        combo?.fastestCarName ??
        best?.carName ??
        best?.uiCarName ??
        best?.car?.displayName ??
        best?.car?.name ??
        best?.car
      );

      return {
        driver: driver || 'Piloto pendiente',
        car: car || 'Coche por confirmar'
      };
    };

    const gcComboDate = (combo) => {
      const raw = combo?.lastActivityIso || combo?.lastSeenAt || combo?.latestLapAt || combo?.updatedAt || combo?.lastActivity || combo?.timestampIso || combo?.timestamp;
      if (!raw) return 0;
      if (typeof raw === 'number') return raw > 20000000000 ? raw : raw * 1000;
      const parsed = Date.parse(String(raw));
      return Number.isFinite(parsed) ? parsed : 0;
    };

    const gcComboId = (combo) => combo?.canonicalComboId ?? combo?.comboId ?? combo?.id ?? combo?.ComboId;

    const gcTrackName = (combo) => gcText(
      combo?.__canonicalTrack ??
      combo?.canonicalTrack ??
      combo?.trackName ??
      combo?.track?.displayName ??
      combo?.track?.name ??
      combo?.track?.id ??
      combo?.uiTrackName ??
      combo?.circuitName ??
      combo?.trackCode ??
      combo?.track
    ) || 'Combo activo';

    const gcSlug = (value) => String(value || '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '_')
      .replace(/^_+|_+$/g, '');

    const gcTrackImageCandidates = (trackName) => {
      const raw = gcText(trackName);
      const slug = gcSlug(raw);
      const slugs = new Set();

      const add = (value) => {
        const item = gcSlug(value);
        if (!item || item === 'object_object') return;

        slugs.add(item);
        slugs.add(item.replace(/^ks_/, ''));
        slugs.add(item.replace(/^rt_/, ''));
        slugs.add(item.replace(/^nrms_/, ''));
        slugs.add(item.replace(/^acu_/, ''));
        slugs.add(item.replace(/^actk_/, ''));
        slugs.add(item.replace(/_online$/, ''));
        slugs.add(item.replace(/_offline$/, ''));
        slugs.add(item.replace(/(?:_|-)?(?:19|20)\d{2}(?:_|-)?/g, '_').replace(/^_+|_+$/g, ''));
      };

      add(slug);
      raw.split(/[\/|,; ]+/).forEach(add);

      if (slug.includes('mugello')) slugs.add('mugello');
      if (slug.includes('zolder')) slugs.add('zolder');
      if (slug.includes('sebring')) slugs.add('sebring');
      if (slug.includes('hockenheim')) slugs.add('hockenheim');
      if (slug.includes('phillip') || slug.includes('philip')) slugs.add('phillip_island');

      const helper = window.GCTrackImages;
      const helperUrls = helper?.candidates
        ? helper.candidates(raw).filter((url) => !url.includes('object_object'))
        : [];

      const urls = [...helperUrls];

      [...slugs].forEach((item) => {
        if (!item) return;

        ['webp','jpg','jpeg','png','avif'].forEach((ext) => {
          urls.push(`/images/tracks/${item}.${ext}`);
          urls.push(`/imagenes/tracks/${item}.${ext}`);
        });
      });

      return [...new Set(urls)];
    };

    const gcFindFirstImage = (urls) => {
      const list = Array.isArray(urls) ? urls.filter(Boolean) : [];

      return new Promise((resolve) => {
        let index = 0;

        const testNext = () => {
          const url = list[index];
          if (!url) {
            resolve('');
            return;
          }

          const image = new Image();
          image.onload = () => resolve(url);
          image.onerror = () => {
            index += 1;
            testNext();
          };
          image.src = url;
        };

        testNext();
      });
    };

    const gcSetWeekComboImage = async (trackName) => {
      const figure = document.getElementById('gcWeekComboImage');
      const img = document.getElementById('gcWeekComboImageImg');
      if (!figure || !img || !trackName) return;

      const candidates = gcTrackImageCandidates(trackName);
      const found = await gcFindFirstImage(candidates);

      console.info('[GC home hero spacing v7.4]', {
        trackName,
        found,
        firstCandidates: candidates.slice(0, 12)
      });

      if (!found) {
        figure.hidden = true;
        return;
      }

      img.alt = `Imagen del circuito ${trackName}`;
      img.onerror = null;
      img.onload = () => {
        img.style.display = '';
        figure.hidden = false;
      };
      img.src = found;
    };

    async function gcLoadComboWeek() {
      const card = document.getElementById('gcWeekCombo');
      try {
        const res = await fetch('/api/combos/stats', { cache: 'no-store' });
        if (!res.ok) throw new Error(String(res.status));
        const data = await res.json();
        const combos = gcPickList(data)
          .filter(Boolean)
          .sort((a, b) => gcComboDate(b) - gcComboDate(a));

        const combo = combos.find((item) => gcNumber(item.totalLaps ?? item.laps ?? item.lapCount, 0) > 0) || combos[0];
        if (!combo) throw new Error('Sin combos');

        const comboId = gcComboId(combo);
        const cars = gcExtractCars(combo);
        const laps = gcNumber(combo.totalLaps ?? combo.laps ?? combo.lapCount ?? combo.visibleLaps, 0);
        const drivers = gcNumber(combo.driversCount ?? combo.pilotsCount ?? combo.playersCount ?? combo.uniqueDrivers ?? combo.totalDrivers, 0);
        const bestTime = gcComboTime(combo);
        const bestParts = gcComboBestParts(combo);
        const trackName = gcTrackName(combo);

        gcSetText('gcWeekComboTitle', trackName);
        gcSetText('gcWeekComboLaps', laps.toLocaleString('es-ES'));
        gcSetText('gcWeekComboDrivers', drivers.toLocaleString('es-ES'));
        gcSetText('gcWeekComboBest', bestTime || '--');
        gcSetText('gcWeekComboBestDriver', bestParts.driver);
        gcSetText('gcWeekComboBestCar', bestParts.car);
        await gcSetWeekComboImage(trackName);

        const state = document.getElementById('gcWeekComboState');
        if (state && combo.mergedCombosCount > 1) {
          state.textContent = `Familia de ${combo.mergedCombosCount} combos`;
        }

        const carsEl = document.getElementById('gcWeekComboCars');
        if (carsEl) {
          carsEl.innerHTML = cars.length
            ? cars.map((name) => `<span class="gc-week-combo__chip">${gcEscape(name)}</span>`).join('')
            : '<span class="gc-week-combo__chip">Coches por confirmar</span>';
        }

        const open = document.getElementById('gcWeekComboOpen');
        if (open && comboId != null) open.href = `/combos/${encodeURIComponent(comboId)}`;

        card?.removeAttribute('data-loading');

        console.info('[GC home hero spacing v7.4]', { trackName });
      } catch (error) {
        gcSetText('gcWeekComboTitle', 'Combo activo');
        gcSetText('gcWeekComboBestDriver', 'Piloto pendiente');
        gcSetText('gcWeekComboBestCar', 'Abre Combo Center para ver la actividad actual');
        document.getElementById('gcWeekComboCars').innerHTML = '<span class="gc-week-combo__chip">Datos no disponibles</span>';
        card?.setAttribute('data-error', 'true');
      }
    }

    async function gcLoadLandingMetrics() {
      const [overviewResult, hotlapsResult, pilotsResult] = await Promise.allSettled([
        fetch('/api/stats/overview', { cache: 'no-store' }).then((res) => res.ok ? res.json() : null),
        fetch('/api/hotlaps?limit=5000', { cache: 'no-store' }).then((res) => res.ok ? res.json() : null),
        fetch('/api/pilots?limit=1', { cache: 'no-store' }).then((res) => res.ok ? res.json() : null),
      ]);

      const overview = overviewResult.status === 'fulfilled' ? overviewResult.value : null;
      const hotlaps = hotlapsResult.status === 'fulfilled' ? hotlapsResult.value : null;
      const pilots = pilotsResult.status === 'fulfilled' ? pilotsResult.value : null;
      const stats = overview?.stats || overview?.overview || overview || {};

      const totalLaps = (
        stats.totalLaps ??
        stats.laps ??
        stats.lapCount ??
        gcPickTotal(hotlaps, ['totalLaps', 'total', 'count'])
      );

      const hotlapItems = gcPickList(hotlaps);
      const hotlapTotal = (
        hotlaps?.total ??
        hotlaps?.count ??
        hotlaps?.totalItems ??
        hotlaps?.visibleTotal ??
        hotlaps?.totalVisible ??
        stats.totalHotlaps ??
        stats.hotlaps ??
        (Array.isArray(hotlapItems) && hotlapItems.length > 1 ? hotlapItems.length : totalLaps)
      );

      const pilotsTotal = (
        pilots?.total ??
        pilots?.count ??
        pilots?.totalItems ??
        stats.totalDrivers ??
        stats.drivers ??
        stats.players ??
        gcPickTotal(pilots)
      );

      gcAnimateNumber('gcMkLaps', hotlapTotal);
      gcAnimateNumber('gcMkDrivers', pilotsTotal);
      gcAnimateNumber('gcMkTotalLaps', totalLaps);
    }

    gcLoadComboWeek();
    gcLoadLandingMetrics();
  </script>

  <script is:inline>
    (() => {
      const logo = document.querySelector('[data-gc-hero-logo]');
      if (!logo || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const clamp = (value, min, max) => Math.max(min, Math.min(max, value));
      const state = {
        tx: 0, ty: 0, rx: 0, ry: 0,
        x: 0, y: 0, crx: 0, cry: 0,
        active: false,
        raf: 0
      };

      const setLogoVars = () => {
        state.x += (state.tx - state.x) * 0.16;
        state.y += (state.ty - state.y) * 0.16;
        state.crx += (state.rx - state.crx) * 0.16;
        state.cry += (state.ry - state.cry) * 0.16;

        logo.style.setProperty('--gc-logo-x', `${state.x.toFixed(2)}px`);
        logo.style.setProperty('--gc-logo-y', `${state.y.toFixed(2)}px`);
        logo.style.setProperty('--gc-logo-rx', `${state.crx.toFixed(2)}deg`);
        logo.style.setProperty('--gc-logo-ry', `${state.cry.toFixed(2)}deg`);

        const stillMoving =
          Math.abs(state.tx - state.x) > 0.08 ||
          Math.abs(state.ty - state.y) > 0.08 ||
          Math.abs(state.rx - state.crx) > 0.05 ||
          Math.abs(state.ry - state.cry) > 0.05;

        if (state.active || stillMoving) {
          state.raf = requestAnimationFrame(setLogoVars);
        } else {
          state.raf = 0;
          logo.classList.remove('is-settling');
        }
      };

      const startRaf = () => {
        if (!state.raf) state.raf = requestAnimationFrame(setLogoVars);
      };

      const updateFromPointer = (event) => {
        const rect = logo.getBoundingClientRect();
        const nx = clamp(((event.clientX - rect.left) / rect.width) - 0.5, -0.65, 0.65);
        const ny = clamp(((event.clientY - rect.top) / rect.height) - 0.5, -0.65, 0.65);

        state.tx = nx * 20;
        state.ty = ny * 14;
        state.rx = -ny * 5.5;
        state.ry = nx * 7.5;

        logo.style.setProperty('--gc-logo-glow-x', `${((nx + 0.5) * 100).toFixed(1)}%`);
        logo.style.setProperty('--gc-logo-glow-y', `${((ny + 0.5) * 100).toFixed(1)}%`);
        startRaf();
      };

      const reset = () => {
        state.active = false;
        state.tx = 0;
        state.ty = 0;
        state.rx = 0;
        state.ry = 0;
        logo.classList.remove('is-magnetic');
        logo.classList.add('is-settling');
        logo.style.setProperty('--gc-logo-glow-x', '50%');
        logo.style.setProperty('--gc-logo-glow-y', '50%');
        startRaf();
      };

      logo.addEventListener('pointerenter', (event) => {
        state.active = true;
        logo.classList.add('is-magnetic');
        logo.classList.remove('is-settling');
        updateFromPointer(event);
      });

      logo.addEventListener('pointermove', updateFromPointer);
      logo.addEventListener('pointerleave', reset);
      logo.addEventListener('pointercancel', reset);
      window.addEventListener('blur', reset);

      console.info('[GC home hero spacing v7.4]');
    })();
  </script>

</MarketingLayout>

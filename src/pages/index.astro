---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import '../styles/landing-combo-week-polish.css';

const discordUrl = 'https://discord.gg/jA4yuuH5T';
const whatsappUrl = 'https://chat.whatsapp.com/JMXKRF4XnG73D4xLzzrlHa';
const instagramUrl = 'https://www.instagram.com/grasscutters_ac/';
const carsDriveUrl = 'https://drive.google.com/drive/folders/1BXJJkPOo7ZuhIKf_VegI5g8serZsJw7W?usp=drive_link';
const tracksDriveUrl = 'https://drive.google.com/drive/folders/1xSrI8aPBLH15wrytkR-IUjMQPWEVyfQw?usp=drive_link';
const serverJoinUrl = 'https://acstuff.ru/s/q:race/online/join?httpPort=8381&ip=185.216.144.78';
---
<MarketingLayout title="GrassCutters Racing | Comunidad sim racing" description="GrassCutters Racing: comunidad de Assetto Corsa con Discord, WhatsApp, rankings, perfiles de piloto y herramientas para seguir la actividad del servidor.">
  <section class="gc-hero gc-landing-hero gc-home-hero-video">
    <video
      class="gc-home-hero-bg-video"
      src="/videos/04061.mp4"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
    ></video>
    <div class="gc-home-hero-scrim"></div>

    <div class="gc-page gc-home-hero-inner">
      <div>
        <span class="gc-kicker">GrassCutters Racing</span>
        <h1 class="gc-title">Corre, compara y vuelve al box.</h1>
        <p class="gc-lead">Una comunidad de sim racing con Discord, rankings, perfiles de piloto y herramientas para seguir la actividad del servidor.</p>

        <div class="gc-actions gc-secondary-actions gc-secondary-actions--hero">
          <a class="gc-btn gc-home-cta gc-home-cta--android" href="/app-android" aria-label="App Android">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.1 8.2h9.8a1.7 1.7 0 0 1 1.7 1.7v6.3a1.7 1.7 0 0 1-1.7 1.7H7.1a1.7 1.7 0 0 1-1.7-1.7V9.9a1.7 1.7 0 0 1 1.7-1.7Zm-3.6 1.9c.55 0 1 .45 1 1v4.3a1 1 0 0 1-2 0v-4.3c0-.55.45-1 1-1Zm17 0c.55 0 1 .45 1 1v4.3a1 1 0 0 1-2 0v-4.3c0-.55.45-1 1-1ZM8.1 18.7h1.8v2.1a.9.9 0 1 1-1.8 0v-2.1Zm6 0h1.8v2.1a.9.9 0 1 1-1.8 0v-2.1ZM8.35 5.05 7.3 3.25a.45.45 0 0 1 .78-.45l1.1 1.9a7.4 7.4 0 0 1 5.64 0l1.1-1.9a.45.45 0 0 1 .78.45l-1.05 1.8A6.55 6.55 0 0 1 18 7.35H6a6.55 6.55 0 0 1 2.35-2.3Zm.9 1.25a.55.55 0 1 0 0-1.1.55.55 0 0 0 0 1.1Zm5.5 0a.55.55 0 1 0 0-1.1.55.55 0 0 0 0 1.1Z"/></svg>
            <span>APP ANDROID</span>
          </a>
          <a class="gc-btn gc-home-cta gc-home-cta--platform" href="/app" aria-label="Entrar a la plataforma">
            <img src="/images/newlogo.png" alt="" loading="lazy" />
            <span>PLATAFORMA</span>
          </a>
          <a class="gc-btn gc-home-cta gc-home-cta--combo" href="#combo-semana" aria-label="Ir al combo de la semana">
            <svg class="gc-home-cta-trophy" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7 4h10v2h3a1 1 0 0 1 1 1v2.2c0 2.64-1.94 4.83-4.47 5.2A5.55 5.55 0 0 1 13 17.9V20h3v2H8v-2h3v-2.1a5.55 5.55 0 0 1-3.53-3.5A5.25 5.25 0 0 1 3 9.2V7a1 1 0 0 1 1-1h3V4Zm10 4v3.95A3.25 3.25 0 0 0 19 9.2V8h-2ZM5 8v1.2a3.25 3.25 0 0 0 2 2.75V8H5Zm4-2v6.45a3 3 0 0 0 6 0V6H9Z"/>
            </svg>
            <span>COMBO SEMANA</span>
          </a>
        </div>
      </div>

      <aside class="gc-home-floating-logo-absolute" aria-label="GrassCutters Racing" data-gc-hero-logo>
        <span class="gc-home-floating-logo-absolute__glow" aria-hidden="true"></span>
        <span class="gc-home-floating-logo-absolute__orbit" aria-hidden="true"></span>
        <img src="/images/newlogo.png" alt="GrassCutters Racing" class="gc-home-floating-logo-absolute__img" />
      </aside>
    </div>
  

    <section class="gc-metrics gc-metrics--home-v68" aria-label="Métricas públicas">
        <div class="gc-metric"><span>Servidor</span><strong>Live</strong><small>Servidor activo</small></div>
        <div class="gc-metric"><span>Hotlaps</span><strong id="gcMkLaps">...</strong><small>Referencias registradas</small></div>
        <div class="gc-metric"><span>Pilotos</span><strong id="gcMkDrivers">...</strong><small>Pilotos de la comunidad</small></div>
        <div class="gc-metric"><span>Vueltas totales</span><strong id="gcMkTotalLaps">...</strong><small>Actividad del servidor</small></div>
      </section>
  </section>
  <section id="combo-semana" class="gc-page gc-week-combo-section gc-week-combo-section--v61" aria-labelledby="gcWeekComboTitle">
    <article class="gc-week-combo gc-week-combo--v61" id="gcWeekCombo" data-loading="true">
      <div class="gc-week-combo__top-v61">
        <div class="gc-week-combo__badges">
          <span class="gc-week-combo__tag">Combo de la semana</span>
          <span class="gc-week-combo__state" id="gcWeekComboState">Último activo</span>
        </div>

        <div class="gc-week-combo__summary-v61" aria-label="Resumen del combo activo">
          <article class="gc-week-combo__leader-v61">
            <span class="gc-week-combo__leader-label">Mejor referencia</span>
            <strong><span id="gcWeekComboBestDriver">Pendiente</span> · <span id="gcWeekComboBest">--</span></strong>
            <small id="gcWeekComboBestCar">Coche por confirmar</small>
          </article>

          <article class="gc-week-combo__mini-stat-v61">
            <span>Vueltas totales</span>
            <strong id="gcWeekComboLaps">--</strong>
          </article>

          <article class="gc-week-combo__mini-stat-v61">
            <span>Pilotos</span>
            <strong id="gcWeekComboDrivers">--</strong>
          </article>
        </div>
      </div>

      <figure class="gc-week-combo__image gc-week-combo__image--wide-v61" id="gcWeekComboImage" hidden>
        <img id="gcWeekComboImageImg" src="" alt="" loading="lazy" />
      </figure>

      <div class="gc-week-combo__body-v61">
        <div class="gc-week-combo__main">
          <h2 id="gcWeekComboTitle">Cargando combo...</h2>

          <div class="gc-week-combo__cars" id="gcWeekComboCars">
            <span class="gc-week-combo__chip">Coches por confirmar</span>
          </div>

          <div class="gc-week-combo__actions">
            <a class="gc-btn gc-btn-primary" href={carsDriveUrl} target="_blank" rel="noreferrer">Descargar coches</a>
            <a class="gc-btn gc-btn-primary" href={tracksDriveUrl} target="_blank" rel="noreferrer">Descargar circuito</a>
            <a class="gc-btn gc-btn-primary" id="gcWeekComboOpen" href="/combos">Abrir combo</a>
          </div>
        </div>

        <div class="gc-week-combo__join-block-v61">
          <a class="gc-btn gc-week-combo__join" href={serverJoinUrl} target="_blank" rel="noreferrer">Unirse al servidor</a>
          <small>Abre el servidor directamente desde Content Manager.</small>
        </div>
      </div>
    </article>
  </section>

  <section class="gc-page">
    <div class="gc-section-head">
      <span class="gc-section-kicker">Bienvenida</span>
      <h2 class="gc-section-title">Todo empieza en pista.</h2>
      <p class="gc-section-lead">Un punto de entrada para conocer la comunidad, consultar la actividad y encontrar el servidor, Discord y las herramientas principales.</p>
    </div>
    <div class="gc-grid-3">
      <article class="gc-card">
        <code>01</code>
        <h3>Discord</h3>
        <p>Anuncios, eventos, votaciones, briefing de carrera y punto de encuentro para pilotos nuevos.</p>
        <a class="gc-feature-link" href={discordUrl} target="_blank" rel="noreferrer">Abrir Discord</a>
      </article>
      <article class="gc-card">
        <code>02</code>
        <h3>Plataforma</h3>
        <p>Hotlaps, combos, perfiles públicos y herramientas de piloto.</p>
        <a class="gc-feature-link" href="/app">Abrir plataforma</a>
      </article>
      <article class="gc-card">
        <code>03</code>
        <h3>App Android</h3>
        <p>Acceso móvil para seguir la comunidad y consultar la actividad principal.</p>
        <a class="gc-feature-link" href="/app-android">Ver app</a>
      </article>
    </div>
  </section>

  <section class="gc-page">
    <div class="gc-split">
      <div class="gc-copy">
        <span class="gc-kicker">La parte racing</span>
        <h2 class="gc-section-title">Tiempos, combos y pilotos.</h2>
        <p>La plataforma ordena la actividad del servidor en rankings, perfiles, combos y referencias claras para la comunidad.</p>
        <div class="gc-actions">
          <a class="gc-btn gc-btn-primary" href="/hotlaps">Ver hotlaps</a>
          <a class="gc-btn" href="/combos">Combo Center</a>
          <a class="gc-btn" href="/pilotos">Pilotos</a>
        </div>
      </div>
      <div class="gc-rows">
        <a class="gc-row" href="/hotlaps"><span class="gc-row-num">HL</span><span><strong class="gc-row-title">Hotlaps</strong><br><span class="gc-row-desc">Leaderboard con tiempos y enlaces a pilotos.</span></span><span class="gc-row-cta">Ver</span></a>
        <a class="gc-row" href="/combos"><span class="gc-row-num">CB</span><span><strong class="gc-row-title">Combos</strong><br><span class="gc-row-desc">Circuitos y paquetes de coches agrupados de forma útil.</span></span><span class="gc-row-cta">Ver</span></a>
        <a class="gc-row" href="/pilotos"><span class="gc-row-num">PI</span><span><strong class="gc-row-title">Pilotos</strong><br><span class="gc-row-desc">Fichas públicas, garaje, circuitos y actividad.</span></span><span class="gc-row-cta">Ver</span></a>
      </div>
    </div>
  </section>

  <style is:global>
    .gc-secondary-actions--hero{
      display:flex;
      flex-wrap:wrap;
      gap:12px;
      align-items:center;
    }

    .gc-home-cta{
      min-height:52px;
      padding:0 20px!important;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      border-radius:999px!important;
      color:#fff!important;
      font-weight:950;
      letter-spacing:.065em;
      text-transform:uppercase;
      line-height:1;
      border:1px solid rgba(255,255,255,.14)!important;
      box-shadow:0 16px 46px rgba(0,0,0,.28);
      transition:transform .18s ease, filter .18s ease, box-shadow .18s ease;
    }

    .gc-home-cta:hover{
      transform:translateY(-2px);
      filter:brightness(1.06);
      box-shadow:0 20px 58px rgba(0,0,0,.34);
    }

    .gc-home-cta svg{
      width:22px;
      height:22px;
      display:block;
      fill:currentColor;
      color:#fff!important;
      flex:0 0 auto;
    }

    .gc-home-cta img{
      width:24px;
      height:24px;
      object-fit:contain;
      display:block;
      flex:0 0 auto;
      filter:drop-shadow(0 0 8px rgba(255,255,255,.24));
    }

    .gc-home-cta span{
      color:#fff!important;
      line-height:1;
      white-space:nowrap;
    }


    .gc-week-combo--v59{
      display:grid!important;
      grid-template-columns:1fr!important;
      gap:clamp(18px,2vw,26px)!important;
      align-items:stretch!important;
    }

    .gc-week-combo__top-v59{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:14px;
    }

    .gc-week-combo__image--wide-v59{
      position:relative;
      overflow:hidden;
      width:100%;
      margin:0!important;
      border:1px solid rgba(255,255,255,.12);
      border-radius:24px;
      background:rgba(0,0,0,.2);
      box-shadow:0 24px 90px rgba(0,0,0,.24);
    }

    .gc-week-combo__image--wide-v59[hidden]{
      display:none;
    }

    .gc-week-combo__image--wide-v59 img{
      display:block;
      width:100%;
      aspect-ratio:21/7;
      object-fit:cover;
      opacity:.94;
      filter:saturate(1.05) contrast(1.03);
    }

    .gc-week-combo__image--wide-v59::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(180deg,rgba(0,0,0,.04),rgba(0,0,0,.34)),
        radial-gradient(circle at 10% 0%,rgba(135,255,42,.16),transparent 34rem);
      pointer-events:none;
    }

    .gc-week-combo__body-v59{
      display:grid;
      grid-template-columns:minmax(0,1.15fr) minmax(300px,.85fr);
      gap:clamp(20px,3vw,44px);
      align-items:end;
    }

    .gc-week-combo__side--compact-v59{
      display:grid;
      align-content:end;
      gap:18px;
      min-height:auto!important;
    }

    .gc-week-combo__stats-v59{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:0;
      border:1px solid rgba(255,255,255,.1);
      border-radius:18px;
      overflow:hidden;
      background:rgba(0,0,0,.12);
    }

    .gc-week-combo__stats-v59 .gc-week-combo__stat{
      padding:16px 18px;
      border-right:1px solid rgba(255,255,255,.1);
    }

    .gc-week-combo__stats-v59 .gc-week-combo__stat:last-child{
      border-right:0;
    }

    @media(max-width:760px){
      .gc-home-cta{
        min-height:48px;
        padding-inline:16px!important;
        font-size:.82rem;
      }

      .gc-home-cta svg{
        width:20px;
        height:20px;
      }

      .gc-home-cta img{
        width:22px;
        height:22px;
      }

      .gc-week-combo__body-v59{
        grid-template-columns:1fr;
        align-items:start;
      }

      .gc-week-combo__stats-v59{
        grid-template-columns:1fr;
      }

      .gc-week-combo__stats-v59 .gc-week-combo__stat{
        border-right:0;
        border-bottom:1px solid rgba(255,255,255,.1);
      }

      .gc-week-combo__stats-v59 .gc-week-combo__stat:last-child{
        border-bottom:0;
      }

      .gc-week-combo__image--wide-v59 img{
        aspect-ratio:16/9;
      }
    }

    .gc-secondary-actions--hero{
      display:flex;
      flex-wrap:wrap;
      gap:12px;
      align-items:center;
    }

    .gc-secondary-actions--hero .gc-home-cta{
      background:var(--gc-btn-bg, rgba(255,255,255,.045))!important;
      color:var(--text)!important;
      border-color:var(--line)!important;
      box-shadow:none!important;
    }

    .gc-secondary-actions--hero .gc-home-cta span,
    .gc-secondary-actions--hero .gc-home-cta svg{
      color:var(--text)!important;
      fill:currentColor;
    }

    .gc-secondary-actions--hero .gc-home-cta img{
      filter:none!important;
    }

    .gc-metrics{
      margin-bottom:clamp(30px,4vw,58px)!important;
    }

    .gc-week-combo-section--v61{
      margin-top:clamp(22px,3.2vw,46px)!important;
    }

    .gc-week-combo--v61{
      display:grid!important;
      grid-template-columns:1fr!important;
      gap:clamp(20px,2.4vw,30px)!important;
      align-items:stretch!important;
    }

    .gc-week-combo__top-v61{
      display:grid;
      grid-template-columns:minmax(180px,.45fr) minmax(0,1.55fr);
      gap:clamp(18px,2.5vw,34px);
      align-items:start;
    }

    .gc-week-combo__summary-v61{
      display:grid;
      grid-template-columns:minmax(0,1.4fr) minmax(150px,.55fr) minmax(150px,.55fr);
      gap:0;
      border:1px solid rgba(255,255,255,.12);
      border-radius:20px;
      overflow:hidden;
      background:linear-gradient(135deg,rgba(255,255,255,.065),rgba(255,255,255,.018));
      box-shadow:0 18px 60px rgba(0,0,0,.18);
    }

    .gc-week-combo__leader-v61,
    .gc-week-combo__mini-stat-v61{
      display:grid;
      align-content:center;
      min-height:104px;
      padding:18px 20px;
      border-right:1px solid rgba(255,255,255,.1);
    }

    .gc-week-combo__mini-stat-v61:last-child{
      border-right:0;
    }

    .gc-week-combo__leader-v61 span,
    .gc-week-combo__mini-stat-v61 span{
      color:var(--dim);
      font-weight:950;
      letter-spacing:.105em;
      text-transform:uppercase;
      font-size:.72rem;
    }

    .gc-week-combo__leader-v61 strong{
      margin-top:7px;
      color:var(--text);
      font-size:clamp(1.15rem,1.7vw,1.55rem);
      line-height:1.18;
    }

    .gc-week-combo__leader-v61 strong span{
      color:inherit;
      letter-spacing:inherit;
      text-transform:none;
      font-size:inherit;
      font-weight:inherit;
    }

    .gc-week-combo__leader-v61 small{
      margin-top:6px;
      color:var(--muted);
      font-size:.96rem;
    }

    .gc-week-combo__mini-stat-v61 strong{
      margin-top:7px;
      color:var(--text);
      font-size:clamp(2rem,3.1vw,3rem);
      line-height:.95;
      letter-spacing:-.04em;
    }

    .gc-week-combo__image--wide-v61{
      position:relative;
      overflow:hidden;
      width:100%;
      margin:0!important;
      border:1px solid rgba(255,255,255,.12);
      border-radius:24px;
      background:rgba(0,0,0,.2);
      box-shadow:0 24px 90px rgba(0,0,0,.24);
    }

    .gc-week-combo__image--wide-v61[hidden]{
      display:none;
    }

    .gc-week-combo__image--wide-v61 img{
      display:block;
      width:100%;
      aspect-ratio:23/7;
      object-fit:cover;
      opacity:.94;
      filter:saturate(1.05) contrast(1.03);
    }

    .gc-week-combo__image--wide-v61::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(180deg,rgba(0,0,0,.04),rgba(0,0,0,.34)),
        radial-gradient(circle at 10% 0%,rgba(135,255,42,.16),transparent 34rem);
      pointer-events:none;
    }

    .gc-week-combo__body-v61{
      display:grid;
      grid-template-columns:minmax(0,1.15fr) minmax(300px,.85fr);
      gap:clamp(20px,3vw,44px);
      align-items:center;
    }

    .gc-week-combo__join-block-v61{
      display:grid;
      justify-items:center;
      gap:10px;
      align-self:center;
    }

    .gc-week-combo__join-block-v61 .gc-week-combo__join{
      width:min(100%,420px);
    }

    .gc-week-combo__join-block-v61 small{
      color:var(--muted);
      text-align:center;
    }

    .gc-week-combo__stats-v59{
      display:none!important;
    }

    @media(max-width:980px){
      .gc-week-combo__top-v61,
      .gc-week-combo__body-v61{
        grid-template-columns:1fr;
      }

      .gc-week-combo__summary-v61{
        grid-template-columns:1fr;
      }

      .gc-week-combo__leader-v61,
      .gc-week-combo__mini-stat-v61{
        border-right:0;
        border-bottom:1px solid rgba(255,255,255,.1);
      }

      .gc-week-combo__mini-stat-v61:last-child{
        border-bottom:0;
      }

      .gc-week-combo__image--wide-v61 img{
        aspect-ratio:16/8;
      }
    }


    .gc-home-hero-video{
      position:relative;
      overflow:hidden;
      margin-bottom:0!important;
    }

    .gc-home-hero-video::after{
      content:"";
      position:absolute;
      left:0;
      right:0;
      bottom:-1px;
      height:clamp(82px,9vw,140px);
      z-index:2;
      pointer-events:none;
      background:
        linear-gradient(180deg,
          rgba(1,7,4,0) 0%,
          rgba(1,7,4,.42) 45%,
          var(--bg,#020804) 100%
        );
    }

    .gc-home-hero-inner{
      position:relative;
      z-index:4;
    }

    .gc-metrics--home-v68,
    .gc-metrics--home-v68{
      position:relative;
      z-index:5;
      margin-top:clamp(34px,4.8vw,72px)!important;
      margin-bottom:clamp(34px,4.6vw,62px)!important;
    }

    @media(max-width:860px){
      .gc-metrics--home-v68,
      .gc-metrics--home-v68{
        margin-top:clamp(28px,8vw,54px)!important;
      }

      .gc-home-hero-video::after{
        height:clamp(70px,18vw,118px);
      }
    }

  
    /* v6.5: smooth bridge outside the hero to hide the video/content cut */
    .gc-home-hero-video{
      position:relative;
      overflow:hidden;
      margin-bottom:0!important;
      isolation:isolate;
    }

    .gc-home-hero-video::before{
      content:"";
      position:absolute;
      left:0;
      right:0;
      bottom:0;
      height:clamp(190px,18vw,330px);
      z-index:2;
      pointer-events:none;
      background:
        linear-gradient(180deg,
          rgba(1,7,4,0) 0%,
          rgba(1,7,4,.20) 30%,
          rgba(1,7,4,.68) 70%,
          var(--bg,#020804) 100%
        );
    }

    .gc-home-hero-video::after{
      content:"";
      position:absolute;
      left:50%;
      bottom:-92px;
      width:min(980px,90vw);
      height:220px;
      transform:translateX(-50%);
      z-index:3;
      pointer-events:none;
      background:radial-gradient(ellipse at center, rgba(121,255,37,.13), transparent 66%);
      filter:blur(34px);

      const totalServerDriversFromHomeLogic = (payload) => {
        if (!payload) return null;

        return serverMetricFromPayload(payload, [
          'driversCount',
          'pilotsCount',
          'totalDrivers',
          'pilots',
          'drivers',
          'totalServerDrivers',
          'serverTotalDrivers',
          'serverDrivers',
          'totalRegisteredDrivers',
          'registeredDrivers',
          'totalDriversAll',
          'allDrivers',
          'driversTotal',
          'totalDriverCount',
          'uniqueDrivers',
          'totalUniqueDrivers',
          'playersTotal',
          'pilotsTotal',
          'usersTotal'
        ]);
      };

      const updateReliableServerPanel = async (recentRows = [], comboInfo = {}, raceInfo = {}) => {
        const rows = getArray(recentRows);
        const lastDates = rows
          .map((row) => lapDateFromRow(row))
          .filter(Boolean)
          .sort((a, b) => b.getTime() - a.getTime());

        const lastLap = lastDates[0];

        const { payload: summaryPayload } = await fetchJsonFirstWithSource([
          '/api/gc/diagnostics',
          '/api/stats/overview',
          '/api/status',
          '/api/gc/server-summary',
          '/api/gc/server-summary.json',
          '/api/gc/server-stats',
          '/api/gc/server-stats.json',
          '/api/gc/stats',
          '/api/gc/stats.json',
          '/api/gc/summary',
          '/api/gc/summary.json',
          '/api/gc/overview',
          '/api/gc/overview.json'
        ]);

        const summaryRaceData = summaryPayload && (summaryPayload.raceData || summaryPayload.stats || summaryPayload);

        // Misma idea que la home actual:
        // Hotlaps, Pilotos y Vueltas totales salen de raceData / stats / diagnostics,
        // no de los datos del combo activo.
        const totalServerLaps =
          totalServerLapsFromHomeLogic(summaryRaceData) ??
          totalServerLapsFromHomeLogic(summaryPayload) ??
          totalServerLapsFromHomeLogic(raceInfo);

        const totalHotlaps =
          totalHotlapsFromHomeLogic(summaryRaceData) ??
          totalHotlapsFromHomeLogic(summaryPayload) ??
          totalHotlapsFromHomeLogic(raceInfo);

        const totalServerDrivers =
          totalServerDriversFromHomeLogic(summaryRaceData) ??
          totalServerDriversFromHomeLogic(summaryPayload) ??
          totalServerDriversFromHomeLogic(raceInfo);

        const firstLapDate =
          findDeepDateServerV5(summaryRaceData, [
            'firstLapDate',
            'firstLapAt',
            'first_lap_date',
            'first_lap_at',
            'oldestLapDate',
            'oldestLapAt',
            'serverFirstLapDate',

      const renderArchive = async (activeTrack = '', activeCars = []) => {
        const serverSeed = Array.isArray(window.__GC_HOME2_ARCHIVE__) ? window.__GC_HOME2_ARCHIVE__ : [];

        const endpoints = [
          '/api/archive/items.json?limit=100',
          '/api/archive/items.json?limit=100&status=published',
          '/api/archive/items.json?featured=1&limit=100',
          '/api/archive/items?limit=100',
          '/api/archive/items?featured=1&limit=100',
          '/api/archive',
          '/api/archivo',
          '/data/archive/items.json',
          '/data/app/motorsport-archive.json'
        ];

        let items = getArray(serverSeed);

        // En producción el Archivo público no depende de esos endpoints: /archivo usa archiveRuntime server-side.
        // Por eso home2 debe usar primero el seed SSR y solo probar endpoints si no existe seed.
        if (!items.length) {
          let payload = null;
          for (const endpoint of endpoints) {
            payload = await fetchJson(endpoint);
            items = getArray(payload);
            if (items.length) break;
          }
        }

        const wanted = [activeTrack, ...activeCars].filter(Boolean).map((value) => slugify(value));
        const activeTrackSlug = slugify(activeTrack).replace(/^(ks_|rt_|mx_|nrms_|fn_)/, '');

        const visiblePool = items
          .filter((item) => {
            const status = String(firstValue(item, ['status', 'estado']) || 'published').toLowerCase();
            return !['draft', 'borrador', 'trash', 'deleted'].includes(status);
          })
          .map((item, index) => {
            const title = firstValue(item, ['title', 'nombre', 'name']) || '';
            const slug = firstValue(item, ['slug', 'seoSlug', 'seo_slug']) || '';
            const type = firstValue(item, ['tipo', 'type', 'category', 'categoria', 'kind']) || '';
            const normalizedType = normalizeArchiveType(type);
            const searchText = [
              title,
              slug,
              type,
              firstValue(item, ['tipoLabel', 'label', 'categoryLabel']),
              firstValue(item, ['search', 'descripcion_corta', 'summary', 'description', 'descripcion', 'subtitle', 'subtitulo']),
              firstValue(item, ['pais', 'país', 'country', 'nacionalidad', 'ubicacion', 'ubicación']),
              firstValue(item, ['periodo', 'epoca', 'año', 'year']),
              firstValue(item, ['tags', 'fabricante', 'modelo', 'modelo_base', 'motor', 'disciplina']),
              firstValue(item, ['circuitos_asociados', 'coches_asociados', 'pilotos_asociados'])
            ].filter(Boolean).join(' ');

            const compact = slugify(searchText);

            let score = 0;

            wanted.forEach((needle) => {
              if (!needle) return;
              const shortNeedle = needle.replace(/^(ks_|rt_|mx_|nrms_|fn_)/, '');
              if (compact.includes(needle) || needle.includes(compact)) score += 120;
              if (shortNeedle && compact.includes(shortNeedle)) score += 90;
              if (slugify(title).includes(shortNeedle) || slugify(slug).includes(shortNeedle)) score += 80;
            });

            // Preferir un circuito activo, luego coches del combo, luego pilotos/glosario destacados.
            if (activeTrackSlug && normalizedType === 'circuitos' && compact.includes(activeTrackSlug)) score += 140;
            if (activeTrackSlug && normalizedType !== 'circuitos' && compact.includes(activeTrackSlug)) score += 25;

            if (String(firstValue(item, ['featured', 'destacado', 'isFeatured', 'is_featured'])).toLowerCase() === 'true') score += 20;
            if (normalizedType === 'circuitos') score += 8;
            if (normalizedType === 'coches') score += 6;
            if (normalizedType === 'pilotos') score += 4;
            score += Math.max(0, 10 - index);

            return { item, score, index, type: normalizedType };
          })
          .sort((a, b) => b.score - a.score || a.index - b.index);

        const picked = [];
        const usedKeys = new Set();

        const pushUnique = (entry) => {
          if (!entry || !entry.item) return;
          const key = `${normalizeArchiveType(firstValue(entry.item, ['tipo', 'type', 'category']) || '')}:${firstValue(entry.item, ['slug', 'title', 'nombre'])}`;
          if (usedKeys.has(key)) return;
          usedKeys.add(key);
          picked.push(entry.item);
        };

        // Primero circuito activo si existe.
        pushUnique(visiblePool.find((entry) => entry.type === 'circuitos' && activeTrackSlug && slugify([firstValue(entry.item, ['title', 'nombre']), firstValue(entry.item, ['slug']), firstValue(entry.item, ['search'])].join(' ')).includes(activeTrackSlug)));

        // Luego mejores coches/pilotos relacionados.
        visiblePool.forEach((entry) => {
          if (picked.length < 6) pushUnique(entry);
        });

        const visible = picked.slice(0, 6);

        const host = $('[data-home2-archive]');
        if (!host || !visible.length) return;

        host.innerHTML = visible.map((item, index) => {
          const title = firstValue(item, ['title', 'nombre', 'name']) || 'Ficha';
          const type = firstValue(item, ['tipoLabel', 'label']) || firstValue(item, ['tipo', 'type', 'category', 'categoria', 'kind']) || 'Archivo';
          const summary = firstValue(item, ['descripcion_corta', 'summary', 'description', 'descripcion', 'subtitle', 'subtitulo']) || 'Ficha técnica e histórica.';
          const imageAttrs = archiveImageAttrs(item, index);
          const finalHref = archiveHref(item);
          return `
            <a class="gc-home2-archive-card" href="${finalHref}">
              <img ${imageAttrs} alt="" width="340" height="190" loading="lazy" decoding="async" />
              <span class="gc-home2-archive-card__tag">${type}</span>
              <strong>${title}</strong>
              <small>${summary}</small>
              <em>Ver ficha →</em>
            </a>
          `;
        }).join('');
      };


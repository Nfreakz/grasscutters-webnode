---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="Panel | GrassCutters Platform">
  <div class="gc-page">
    <section class="gc-hero">
      <div>
        <span class="gc-kicker">GC Platform</span>
        <h1 class="gc-title">Panel de mando GrassCutters.</h1>
        <p class="gc-subtitle">La zona de trabajo de los pilotos: hotlaps reales, combos, perfiles, tracker y herramientas para seguir la actividad del servidor.</p>
        <div class="gc-actions">
          <a class="gc-btn gc-btn--primary" href="/hotlaps">Ver leaderboard</a>
          <a class="gc-btn" href="/combos">Combo Center</a>
          <a class="gc-btn gc-btn--ghost" href="/perfil">Mi perfil</a>
        </div>
        <div class="gc-hero__meta">
          <span class="gc-chip gc-chip--accent"><span class="gc-live-dot"></span> Datos activos</span>
          <span class="gc-chip">Hotlaps</span>
          <span class="gc-chip">Perfiles</span>
        </div>
      </div>

      <aside class="gc-live-panel">
        <div class="gc-live-panel__title"><span>Estado plataforma</span><strong id="homeHealth">ONLINE</strong></div>
        <div class="gc-status-list">
          <div class="gc-status-row"><span>Web</span><strong>Activa</strong></div>
          <div class="gc-status-row"><span>API</span><strong id="apiStatus">Comprobando</strong></div>
          <div class="gc-status-row"><span>Tracker</span><strong id="trackerStatus">Lectura real</strong></div>
          <div class="gc-status-row"><span>Servidor</span><strong id="syncStatus">Sincronizado</strong></div>
        </div>
      </aside>
    </section>

    <section class="gc-metrics" id="overviewMetrics" aria-label="Métricas generales">
      <div class="gc-metric"><span>Pilotos</span><strong>...</strong><small>Detectados</small></div>
      <div class="gc-metric"><span>Vueltas</span><strong>...</strong><small>Registradas</small></div>
      <div class="gc-metric"><span>Coches</span><strong>...</strong><small>Usados</small></div>
      <div class="gc-metric"><span>Circuitos</span><strong class="is-accent">...</strong><small>Visitados</small></div>
    </section>

    <section class="gc-command-strip" aria-label="Resumen rápido">
      <div class="gc-command-item"><span>Leaderboard</span><strong>Hotlaps</strong><p>Tiempos reales, deltas y enlaces directos a fichas de piloto.</p></div>
      <div class="gc-command-item"><span>Actividad</span><strong>Combos</strong><p>Circuitos y paquetes de coches agrupados para leer el servidor sin ruido.</p></div>
      <div class="gc-command-item"><span>Pilotos</span><strong>Perfil</strong><p>Área privada, ficha pública y datos personales de pista.</p></div>
    </section>

    <section class="gc-grid-2">
      <div class="gc-section">
        <div class="gc-section-head"><h2>Centro de plataforma</h2><p>Secciones principales</p></div>
        <div class="gc-row-list">
          <a class="gc-row-link" href="/hotlaps"><span class="gc-row-link__num">01</span><span><strong class="gc-row-link__title">Leaderboard</strong><br><span class="gc-row-link__desc">Tiempos reales con filtros rápidos.</span></span><span class="gc-row-link__cta">Abrir</span></a>
          <a class="gc-row-link" href="/combos"><span class="gc-row-link__num">02</span><span><strong class="gc-row-link__title">Combos</strong><br><span class="gc-row-link__desc">Actividad por circuito y paquete de coches.</span></span><span class="gc-row-link__cta">Abrir</span></a>
          <a class="gc-row-link" href="/pilotos"><span class="gc-row-link__num">03</span><span><strong class="gc-row-link__title">Pilotos</strong><br><span class="gc-row-link__desc">Directorio, fichas públicas y actividad.</span></span><span class="gc-row-link__cta">Abrir</span></a>
          <a class="gc-row-link" href="/perfil"><span class="gc-row-link__num">04</span><span><strong class="gc-row-link__title">Área piloto</strong><br><span class="gc-row-link__desc">Perfil privado, vínculo de piloto y métricas personales.</span></span><span class="gc-row-link__cta">Entrar</span></a>
        </div>
      </div>

      <aside class="gc-section">
        <div class="gc-section-head"><h2>Últimas referencias</h2><p>Top hotlaps</p></div>
        <div class="gc-table-meta"><span id="homeHotlapsCount">Cargando datos</span><span id="homeHotlapsUpdated">...</span></div>
        <div class="gc-table-wrap">
          <table class="gc-table gc-table--compact">
            <thead><tr><th>Piloto</th><th>Coche</th><th>Tiempo</th></tr></thead>
            <tbody id="homeHotlaps"><tr><td colspan="3">Cargando...</td></tr></tbody>
          </table>
        </div>
      </aside>
    </section>
  </div>

  <script>
    const $ = (selector) => document.querySelector(selector);
    const escapeHtml = (value) => String(value ?? '-').replace(/[&<>'"]/g, (char) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[char]));
    const fmtMs = (ms) => {
      const n = Number(ms);
      if (!Number.isFinite(n)) return '-';
      const m = Math.floor(n / 60000);
      const s = Math.floor((n % 60000) / 1000);
      const x = String(Math.floor(n % 1000)).padStart(3, '0');
      return `${m}:${String(s).padStart(2, '0')}.${x}`;
    };
    async function json(url) {
      const res = await fetch(url);
      if (!res.ok) throw new Error(url);
      return res.json();
    }

    json('/api/stats/overview').then((data) => {
      const stats = data.stats || data.overview || data;
      const vals = [
        stats.totalDrivers || stats.drivers || stats.players || 0,
        stats.totalLaps || stats.laps || 0,
        stats.totalCars || stats.cars || 0,
        stats.totalTracks || stats.tracks || 0
      ];
      document.querySelectorAll('#overviewMetrics strong').forEach((el, index) => {
        el.textContent = String(vals[index] ?? 0);
      });
      $('#apiStatus').textContent = 'OK';
    }).catch(() => {
      $('#apiStatus').textContent = 'Sin respuesta';
      $('#apiStatus').style.color = 'var(--warn)';
    });

    json('/api/hotlaps?limit=6').then((data) => {
      const rows = data.items || data.hotlaps || data.laps || [];
      $('#homeHotlapsCount').textContent = `${rows.length} referencias`;
      $('#homeHotlapsUpdated').textContent = new Date().toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });
      $('#homeHotlaps').innerHTML = rows.slice(0, 6).map((row) => `
        <tr>
          <td><strong>${escapeHtml(row.driverName || row.playerName || row.name)}</strong></td>
          <td>${escapeHtml(row.carName || row.car || row.uiCarName)}</td>
          <td><strong>${escapeHtml(row.lapTimeFormatted || fmtMs(row.lapTimeMs || row.LapTime || row.lapTime))}</strong></td>
        </tr>
      `).join('') || '<tr><td colspan="3">Sin datos todavía</td></tr>';
    }).catch(() => {
      $('#homeHotlapsCount').textContent = 'Hotlaps no disponibles';
      $('#homeHotlaps').innerHTML = '<tr><td colspan="3">No se pudo leer el endpoint.</td></tr>';
    });
  </script>
</AppLayout>

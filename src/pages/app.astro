  <script is:inline>
    /* GC_APP_SINGLE_RENDERER_V1_8_START */
    (() => {
      const CONFIG = { refreshMs: 30000, firstDelayMs: 350, secondDelayMs: 1500 };
      const state = {
        version: 'v1.8',
        mode: 'single-renderer',
        lastRunAt: null,
        lastOkAt: null,
        lastError: null,
        diagnostics: null,
        combo: null,
        recent: null,
        leaderboard: null
      };

      const byId = (id) => document.getElementById(id);
      const setText = (id, value) => {
        const node = byId(id);
        if (node) node.textContent = String(value ?? '--');
      };
      const escapeHtml = (value) => String(value ?? '').replace(/[&<>'"]/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        "'": '&#39;',
        '"': '&quot;'
      }[char]));
      const number = (value, fallback = 0) => {
        const parsed = Number(value);
        return Number.isFinite(parsed) ? parsed : fallback;
      };
      const formatNumber = (value) => Math.max(0, Math.round(number(value, 0))).toLocaleString('es-ES');

      const valueAt = (source, path) => {
        if (!source || typeof source !== 'object') return undefined;
        if (Object.prototype.hasOwnProperty.call(source, path)) return source[path];
        return String(path).split('.').reduce((acc, part) => acc == null ? undefined : acc[part], source);
      };

      const pick = (source, paths) => {
        for (const path of paths) {
          const value = valueAt(source, path);
          if (value !== undefined && value !== null && value !== '') return value;
        }
        return undefined;
      };

      const text = (value, fallback = '') => {
        if (value == null || value === '') return fallback;
        if (Array.isArray(value)) return value.length ? text(value[0], fallback) : fallback;
        if (typeof value === 'object') {
          return text(
            value.displayName ?? value.visibleName ?? value.cleanName ?? value.display_name ??
            value.uiName ?? value.uiCarName ?? value.uiTrackName ??
            value.name ?? value.Name ?? value.driverName ?? value.playerName ?? value.code,
            fallback
          );
        }
        return String(value).replace(/_/g, ' ').replace(/\s+/g, ' ').trim() || fallback;
      };

      const items = (data) => {
        if (Array.isArray(data)) return data;
        if (!data || typeof data !== 'object') return [];
        return data.items || data.data?.items || data.data?.leaderboard || data.data?.laps ||
          data.leaderboard || data.laps || data.recentLaps || data.hotlaps ||
          data.combos || data.results || [];
      };

      const dateMs = (value) => {
        if (!value) return 0;
        if (typeof value === 'number') return value > 20000000000 ? value : value * 1000;
        const parsed = Date.parse(String(value));
        return Number.isFinite(parsed) ? parsed : 0;
      };

      const dateText = (value) => {
        const ms = typeof value === 'object' ? lapDate(value) : dateMs(value);
        if (!ms) return '--';
        return new Date(ms).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'short' });
      };

      const timeText = (value) => {
        const raw = text(value, '');
        if (raw && /[:.]/.test(raw) && !/^\d+$/.test(raw)) return raw;
        const ms = number(value, 0);
        if (!ms) return '--';
        const minutes = Math.floor(ms / 60000);
        const seconds = Math.floor((ms % 60000) / 1000);
        const millis = Math.floor(ms % 1000);
        return minutes + ':' + String(seconds).padStart(2, '0') + '.' + String(millis).padStart(3, '0');
      };

      const lapDate = (row) => dateMs(pick(row, [
        'timestampIso',
        'dateIso',
        'createdAt',
        'updatedAt',
        'lastSeenAt',
        'latestLapAt',
        'timestamp',
        'Timestamp'
      ]));

      const lapTime = (row) => text(pick(row, [
        'lapTimeFormatted',
        'timeFormatted',
        'bestLapTime',
        'bestLap',
        'lapTime'
      ]), '') || timeText(pick(row, [
        'lapTimeMs',
        'bestLapMs',
        'timeMs',
        'LapTime'
      ]));

      const driverName = (row) => text(pick(row, [
        'driverName',
        'playerName',
        'pilotName',
        'name',
        'driver.displayName',
        'driver.visibleName',
        'driver.name',
        'player.displayName',
        'player.name'
      ]), 'Piloto');

      const carName = (row) => text(pick(row, [
        'carName',
        'uiCarName',
        'car.displayName',
        'car.visibleName',
        'car.name',
        'car'
      ]), 'Coche');

      const trackName = (row) => text(pick(row, [
        'trackName',
        'uiTrackName',
        'track.displayName',
        'track.visibleName',
        'track.name',
        'track'
      ]), 'Circuito');

      const speed = (row) => {
        const raw = pick(row, ['maxSpeedKmh', 'maxSpeed', 'speedKmh', 'MaxSpeed_KMH']);
        const parsed = Number(raw);
        return Number.isFinite(parsed) && parsed > 0 ? Math.round(parsed) + ' km/h' : '';
      };

      const fetchJson = async (url) => {
        const controller = new AbortController();
        const timeout = window.setTimeout(() => controller.abort(), 10000);
        try {
          const response = await fetch(url, { credentials: 'include', cache: 'no-store', signal: controller.signal });
          const data = await response.json().catch(() => null);
          if (!response.ok || !data) throw new Error(url + ' ' + response.status);
          return data;
        } finally {
          window.clearTimeout(timeout);
        }
      };

      function globalStatsFromDiagnostics(data) {
        const race = data?.raceData || data?.stracker?.raceData || data?.stats || data?.overview || {};
        return {
          totalLaps: number(
            pick(race, ['lapsCount', 'totalLaps', 'laps', 'lapCount']) ??
            pick(data, ['raceData.lapsCount', 'totalLaps', 'lapsCount']),
            0
          ),
          driversCount: number(
            pick(race, ['driversCount', 'totalDrivers', 'pilotsCount']) ??
            pick(data, ['raceData.driversCount', 'driversCount', 'totalDrivers']),
            0
          ),
          combosCount: number(
            pick(race, ['activeCombosCount', 'combosCount', 'totalCombos']) ??
            pick(data, ['raceData.activeCombosCount', 'activeCombosCount', 'combosCount', 'totalCombos']),
            0
          ),
          latestLapAt:
            pick(race, ['latestLapAt', 'lastSeenAt', 'latestActivityAt']) ||
            pick(data, ['raceData.latestLapAt', 'latestLapAt']),
          firstSeenAt:
            pick(race, ['oldestLapAt', 'firstSeenAt', 'startedAt']) ||
            pick(data, ['raceData.oldestLapAt', 'oldestLapAt', 'firstSeenAt']),
          generatedAt: data?.generatedAt
        };
      }

      function comboCars(combo) {
        const raw = pick(combo, [
          'publicComboCars',
          'carNames',
          'carList',
          'cars',
          'availableCars',
          'comboCars',
          'mainVariantAllCars'
        ]);
        const arr = Array.isArray(raw) ? raw : (typeof raw === 'string' ? raw.split(/[,|;]/g) : []);
        const seen = new Set();
        return arr.map((car) => text(car, '')).filter(Boolean).filter((name) => {
          const key = name.toLowerCase();
          if (seen.has(key)) return false;
          seen.add(key);
          return true;
        });
      }

      function comboId(combo) {
        return pick(combo, ['comboId', 'canonicalComboId', 'id']);
      }

      function comboUrl(combo) {
        const id = comboId(combo);
        return combo?.url || (id !== undefined && id !== null ? '/combos/' + encodeURIComponent(String(id)) : '/combos');
      }

      function comboBestLap(combo, leaderboard) {
        return (
          pick(combo, ['bestLap', 'summary.bestLap']) ||
          (Array.isArray(combo?.leaderboard) ? combo.leaderboard[0] : null) ||
          leaderboard[0] ||
          {}
        );
      }

      function comboState(combo) {
        const hiddenCars = number(pick(combo, ['hiddenLowLapCarsCount', 'summary.hiddenLowLapCarsCount']), 0);
        const variants = number(pick(combo, ['variantsCount', 'summary.variantsCount']), 0);
        if (hiddenCars > 0) return 'Filtrado';
        if (variants > 1) return 'Canónico';
        return 'Activo';
      }

      function ensureBadge(stateName, label) {
        let badge = byId('gcAppCoreBadge');
        if (!badge) {
          const host = document.querySelector('.gc-live-panel__title') || document.querySelector('.gc-hero') || document.body;
          badge = document.createElement('span');
          badge.id = 'gcAppCoreBadge';
          badge.style.cssText = 'display:inline-flex;align-items:center;min-height:24px;padding:4px 8px;border:1px solid rgba(122,255,144,.35);border-radius:999px;color:var(--accent,#7aff90);font-size:.68rem;font-weight:900;letter-spacing:.08em;text-transform:uppercase;background:rgba(122,255,144,.08);margin-left:8px';
          host.appendChild(badge);
        }
        badge.textContent = label;
        badge.dataset.state = stateName;
        badge.style.borderColor = stateName === 'error' ? 'rgba(255,94,94,.45)' : stateName === 'warn' ? 'rgba(255,207,90,.45)' : 'rgba(122,255,144,.35)';
        badge.style.color = stateName === 'error' ? '#ff6b6b' : stateName === 'warn' ? '#ffcf5a' : 'var(--accent,#7aff90)';
      }

      function gcAppSessionUserFromV1_10(identityData, adminData) {
        const candidates = [
          identityData?.user,
          identityData?.currentUser,
          identityData?.account,
          identityData?.profile?.user,
          identityData?.session?.user,
          identityData?.auth?.user,
          identityData?.data?.user,
          adminData?.user,
          adminData?.currentUser,
          adminData?.account,
          adminData?.profile?.user,
          adminData?.session?.user,
          adminData?.auth?.user,
          adminData?.data?.user
        ].filter(Boolean);

        return candidates[0] || {};
      }

      function gcAppSessionPilotFromV1_10(identityData, adminData, user) {
        const candidates = [
          identityData?.pilot,
          identityData?.linkedPilot,
          identityData?.pilotLink,
          identityData?.linked,
          identityData?.profile?.pilot,
          identityData?.profile?.pilotLink,
          identityData?.data?.pilot,
          identityData?.data?.pilotLink,
          adminData?.pilot,
          adminData?.linkedPilot,
          adminData?.pilotLink,
          adminData?.profile?.pilot,
          adminData?.profile?.pilotLink,
          user?.pilot,
          user?.pilotLink,
          user?.linkedPilot
        ].filter(Boolean);

        return candidates[0] || {};
      }

      function gcAppSessionIsLoggedV1_10(identityData, adminData, user) {
        return Boolean(
          identityData?.authenticated === true ||
          identityData?.loggedIn === true ||
          identityData?.isAuthenticated === true ||
          identityData?.ok === true ||
          adminData?.authenticated === true ||
          adminData?.loggedIn === true ||
          adminData?.isAuthenticated === true ||
          adminData?.ok === true ||
          user?.id ||
          user?.email ||
          user?.name ||
          user?.displayName ||
          user?.role
        );
      }

      function renderSession(identityData, adminData) {
        const user = gcAppSessionUserFromV1_10(identityData, adminData);
        const pilot = gcAppSessionPilotFromV1_10(identityData, adminData, user);
        const logged = gcAppSessionIsLoggedV1_10(identityData, adminData, user);

        const accountName = text(
          user.displayName ??
          user.display_name ??
          user.username ??
          user.name ??
          user.email ??
          identityData?.displayName ??
          identityData?.name ??
          adminData?.displayName ??
          adminData?.name,
          logged ? 'Admin Local' : 'Invitado'
        );

        const role = text(
          user.role ??
          user.userRole ??
          user.accountRole ??
          identityData?.role ??
          identityData?.user?.role ??
          adminData?.role ??
          adminData?.user?.role,
          logged ? 'pilot' : '-'
        );

        const pilotName = text(
          pilot.displayName ??
          pilot.display_name ??
          pilot.driverName ??
          pilot.strackerName ??
          pilot.name ??
          identityData?.pilotName ??
          identityData?.driverName ??
          user?.strackerName,
          pilot && Object.keys(pilot).length ? 'Vinculado' : accountName
        );

        setText('gcAppSessionState', logged ? 'Conectado' : 'Invitado');
        setText('gcAppSessionUser', accountName);
        setText('gcAppSessionRole', role);
        setText('gcAppSessionPilot', pilotName);

        document.documentElement.dataset.gcAppSessionRenderer = 'v1.10';
      }

      function renderGlobal(diagnostics) {
        const stats = globalStatsFromDiagnostics(diagnostics);
        if (stats.driversCount) setText('gcMetricDrivers', formatNumber(stats.driversCount));
        if (stats.totalLaps) {
          setText('gcMetricLaps', formatNumber(stats.totalLaps));
          setText('gcQuickRefs', formatNumber(stats.totalLaps));
        }
        if (stats.combosCount) setText('gcMetricCombos', formatNumber(stats.combosCount));
        if (stats.latestLapAt) setText('gcMetricLastActivity', dateText(stats.latestLapAt).split(',')[0]);

        if (stats.firstSeenAt) {
          const firstMs = dateMs(stats.firstSeenAt);
          if (firstMs) {
            const days = Math.max(1, Math.ceil((Date.now() - firstMs) / 86400000));
            setText('gcServerUptimeDays', days + ' días');
            setText('gcServerUptimeMeta', 'desde ' + dateText(stats.firstSeenAt).split(',')[0]);
          }
        }

        setText('gcQuickDb', 'Activo');
        setText('gcQuickDbMeta', stats.generatedAt ? 'Data Core · ' + dateText(stats.generatedAt) : 'Data Core');

        return stats;
      }

      function renderCombo(combo, leaderboard, recent) {
        if (!combo) return;

        const cars = comboCars(combo);
        const best = comboBestLap(combo, leaderboard);
        const latest = recent[0] || best || {};
        const track = text(pick(combo, [
          'canonicalTrackName',
          'displayTrackName',
          'track.displayName',
          'track.name',
          'trackName'
        ]), trackName(latest));

        setText('gcAppComboChip', track || 'Combo');
        setText('gcComboTrack', track || 'Sin combo');
        setText('gcComboHint', pick(combo, ['lastSeenAt', 'summary.lastSeenAt'])
          ? 'Última actividad · ' + dateText(pick(combo, ['lastSeenAt', 'summary.lastSeenAt']))
          : 'Combo canónico cargado.');
        setText('gcComboBest', best ? lapTime(best) : '--');
        setText('gcComboBestMeta', best ? [driverName(best), carName(best)].filter(Boolean).join(' · ') : 'Mejor vuelta del combo');
        setText('gcComboLaps', formatNumber(pick(combo, ['totalLaps', 'summary.totalLaps', 'laps'])));
        setText('gcComboDrivers', formatNumber(pick(combo, ['driversCount', 'summary.driversCount', 'pilotsCount'])));
        setText('gcComboFamily', comboState(combo));

        const link = byId('gcComboLink');
        if (link) link.href = comboUrl(combo);

        const carsNode = byId('gcComboCars');
        if (carsNode) {
          carsNode.innerHTML = cars.length
            ? cars.map((name) => '<span class="gc-chip">' + escapeHtml(name) + '</span>').join('')
            : '<span class="gc-chip">Coches por confirmar</span>';
        }

        const comboCard = document.querySelector('.gc-app-combo-v3');
        if (comboCard && track) {
          comboCard.dataset.trackName = track;
          window.GCTrackImages?.applyAll?.(document);
        }

        if (best && Object.keys(best).length) {
          setText('gcTopDriverName', driverName(best));
          setText('gcTopDriverTime', lapTime(best));
          setText('gcTopDriverMeta', [carName(best), trackName(best), speed(best)].filter(Boolean).join(' · '));

          const avatar = byId('gcTopDriverAvatar');
          const playerId = pick(best, ['playerId', 'driverId', 'pilotId', 'id', 'driver.id', 'player.id', 'pilot.id']);
          if (avatar && playerId) {
            avatar.src = '/api/pilot-avatar/' + encodeURIComponent(String(playerId));
            avatar.alt = 'Avatar de ' + driverName(best);
            avatar.onerror = () => {
              avatar.onerror = null;
              avatar.src = '/images/pilot-avatar-default.png';
            };
          }
        }
      }

      function renderRecentTable(recent, leaderboard) {
        const rows = recent.length ? recent : leaderboard;
        const table = byId('gcRefsTable');
        if (table) {
          table.innerHTML = rows.length
            ? rows.slice(0, 10).map((lap) => `
                <tr>
                  <td><strong>${escapeHtml(driverName(lap))}</strong></td>
                  <td>${escapeHtml(carName(lap))}</td>
                  <td>${escapeHtml(trackName(lap))}</td>
                  <td><strong>${escapeHtml(lapTime(lap))}</strong></td>
                  <td>${escapeHtml(dateText(lap))}</td>
                </tr>
              `).join('')
            : '<tr><td colspan="5">Sin vueltas recientes.</td></tr>';
        }

        const latest = rows.slice().sort((a, b) => lapDate(b) - lapDate(a))[0] || null;
        setText('gcQuickLast', latest ? lapTime(latest) : '--');
        setText('gcQuickLastMeta', latest ? [driverName(latest), trackName(latest), dateText(latest)].filter(Boolean).join(' · ') : 'sin datos');
        setText('gcRefsMeta', formatNumber(recent.length) + ' vueltas recientes · Data Core single renderer');
      }

      async function render() {
        state.lastRunAt = new Date().toISOString();

        try {
          ensureBadge('warn', 'Data Core loading');

          const [diagnostics, combosData, recentData, leaderboardData, identityData, adminData] = await Promise.all([
            fetchJson('/api/gc/diagnostics'),
            fetchJson('/api/gc/combos?limit=1&sort=recent'),
            fetchJson('/api/gc/recent-laps?limit=12&sort=recent&valid=all').catch(() => null),
            fetchJson('/api/gc/leaderboard?scope=activeCombo&limit=20').catch(() => null),
            fetchJson('/api/gc/identity/me').catch(() => null),
            fetchJson('/api/admin/status').catch(() => null)
          ]);

          const combo = items(combosData)[0] || null;
          const recent = items(recentData);
          const leaderboard = items(leaderboardData);

          renderSession(identityData, adminData);

          const globalStats = renderGlobal(diagnostics);
          renderCombo(combo, leaderboard, recent);
          renderRecentTable(recent, leaderboard);

          document.documentElement.dataset.gcAppDataCore = 'primary';
          document.documentElement.dataset.gcAppDataCoreVersion = 'v1.8-single';
          document.documentElement.dataset.gcAppSingleRenderer = 'v1.8';

          ensureBadge('ok', 'Data Core single');

          state.lastOkAt = new Date().toISOString();
          state.lastError = null;
          state.diagnostics = diagnostics;
          state.combo = combo;
          state.recent = recentData;
          state.leaderboard = leaderboardData;

          window.GCAppDataCorePrimary = {
            status: 'ok',
            mode: 'single-renderer',
            diagnostics,
            combos: combosData,
            recent: recentData,
            leaderboard: leaderboardData,
            identity: identityData,
            admin: adminData,
            renderedAt: state.lastOkAt
          };

          window.GCAppSingleRendererStatus = () => ({ ...state });

          console.info('[GC /app Single Renderer v1.8]', {
            totalLaps: globalStats.totalLaps,
            drivers: globalStats.driversCount,
            combos: globalStats.combosCount,
            combo: combo?.trackName || combo?.canonicalTrackName,
            cars: comboCars(combo || {}).length
          });
        } catch (error) {
          state.lastError = error?.message || String(error);
          document.documentElement.dataset.gcAppDataCore = 'single-error';
          ensureBadge('error', 'Data Core error');
          window.GCAppSingleRendererStatus = () => ({ ...state });
          console.warn('[GC /app Single Renderer v1.8] failed:', error);
        }
      }

      const start = () => {
        window.setTimeout(render, CONFIG.firstDelayMs);
        window.setTimeout(render, CONFIG.secondDelayMs);
        window.clearInterval(window.GCAppSingleRendererTimer);
        window.GCAppSingleRendererTimer = window.setInterval(render, CONFIG.refreshMs);
      };

      window.GCAppSingleRendererReload = render;

      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', start, { once: true });
      else start();
    })();
    /* GC_APP_SINGLE_RENDERER_V1_8_END */
  </script>


  <script is:inline>
    /* GC_APP_SINGLE_RENDERER_SESSION_FIX_V1_10_MARKER */
    (() => {
      document.documentElement.dataset.gcAppSessionFix = 'v1.10';
    })();
  </script>

</AppLayout>


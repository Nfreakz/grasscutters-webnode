---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="Panel | GrassCutters">
  <div class="gc-page gc-app-dashboard-v3">
    <section class="gc-hero gc-hero--compact gc-app-hero-v3">
      <div>
        <span class="gc-kicker">GrassCutters Platform</span>
        <h1 class="gc-title">Panel de pista.</h1>
        <p class="gc-subtitle">Resumen ligero del combo activo, estado del servidor y cambios recientes de la plataforma.</p>
        <div class="gc-hero__meta">
          <span class="gc-chip gc-chip--accent" id="gcAppStatusChip">Panel listo</span>
          <span class="gc-chip" id="gcAppComboChip">Combo activo</span>
          <span class="gc-chip" id="gcAppClock">--:--</span>
        </div>
      </div>

      <aside class="gc-live-panel gc-app-session-v3" aria-label="Estado de sesión">
        <div class="gc-live-panel__title"><span>Sesión</span><strong id="gcAppSessionState">Comprobando</strong></div>
        <div class="gc-status-list">
          <div class="gc-status-row"><span>Cuenta</span><strong id="gcAppSessionUser">...</strong></div>
          <div class="gc-status-row"><span>Rol</span><strong id="gcAppSessionRole">...</strong></div>
          <div class="gc-status-row"><span>Piloto</span><strong id="gcAppSessionPilot">...</strong></div>
        </div>
      </aside>
    </section>

    <section class="gc-metrics gc-app-metrics-v3" aria-label="Métricas rápidas">
      <div class="gc-metric"><span>Pilotos</span><strong id="gcMetricDrivers">...</strong><small>detectados</small></div>
      <div class="gc-metric"><span>Vueltas</span><strong id="gcMetricLaps">...</strong><small>actividad total</small></div>
      <div class="gc-metric"><span>Coches</span><strong id="gcMetricCars">...</strong><small>catálogo</small></div>
      <div class="gc-metric"><span>Circuitos</span><strong id="gcMetricTracks">...</strong><small>registrados</small></div>
    </section>

    <section class="gc-app-top-grid-v3" aria-label="Resumen principal">
      <article class="gc-section gc-app-combo-v3">
        <div class="gc-section-head gc-app-card-head-v3">
          <div>
            <h2>Combo activo</h2>
            <p id="gcComboHint">Última lectura del servidor.</p>
          </div>
          <a class="gc-feature-link" href="/combos" id="gcComboLink">Abrir combo</a>
        </div>

        <div class="gc-app-combo-body-v3">
          <div>
            <span class="gc-app-label-v3">Circuito</span>
            <h3 id="gcComboTrack">Cargando...</h3>
            <div class="gc-app-chip-list-v3" id="gcComboCars">
              <span class="gc-chip">Leyendo coches</span>
            </div>
          </div>

          <div class="gc-app-best-v3">
            <span>Mejor referencia</span>
            <strong id="gcComboBest">--</strong>
            <small id="gcComboBestMeta">Pendiente de datos</small>
          </div>
        </div>

        <div class="gc-app-mini-stats-v3">
          <div><span>Vueltas</span><strong id="gcComboLaps">--</strong></div>
          <div><span>Pilotos</span><strong id="gcComboDrivers">--</strong></div>
          <div><span>Familia</span><strong id="gcComboFamily">--</strong></div>
        </div>
      </article>

      <article class="gc-section gc-app-readout-card-v3">
        <div class="gc-section-head gc-app-card-head-v3">
          <div>
            <h2>Lectura rápida</h2>
            <p>Datos útiles del último refresco.</p>
          </div>
          <span class="gc-chip" id="gcApiState">API</span>
        </div>

        <div class="gc-app-readout-grid-v3">
          <div class="gc-app-readout-v3"><span>Últimas referencias</span><strong id="gcQuickRefs">--</strong><small>cargadas en esta vista</small></div>
          <div class="gc-app-readout-v3"><span>Top actual</span><strong id="gcQuickTop">--</strong><small id="gcQuickTopMeta">sin datos</small></div>
          <div class="gc-app-readout-v3"><span>Última vuelta</span><strong id="gcQuickLast">--</strong><small id="gcQuickLastMeta">sin datos</small></div>
          <div class="gc-app-readout-v3"><span>Stracker</span><strong id="gcQuickDb">--</strong><small id="gcQuickDbMeta">comprobando</small></div>
        </div>
      </article>
    </section>

    <section class="gc-section gc-app-references-v3">
      <div class="gc-section-head gc-app-card-head-v3">
        <div>
          <h2>Últimas referencias</h2>
          <p id="gcRefsMeta">Cargando referencias recientes...</p>
        </div>
        <a class="gc-feature-link" href="/hotlaps">Ver leaderboard</a>
      </div>
      <div class="gc-table-wrap gc-app-table-wrap-v3">
        <table class="gc-table gc-app-table-v3">
          <thead>
            <tr>
              <th>Piloto</th>
              <th>Coche</th>
              <th>Tiempo</th>
              <th>Fecha</th>
            </tr>
          </thead>
          <tbody id="gcRefsTable">
            <tr><td colspan="4">Leyendo hotlaps...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="gc-section gc-app-webchanges-v3">
      <div class="gc-section-head gc-app-card-head-v3">
        <div>
          <h2>Últimos cambios web</h2>
          <p>Registro de mejoras recientes aplicadas a la plataforma.</p>
        </div>
        <span class="gc-chip gc-chip--accent">Web update</span>
      </div>

      <div class="gc-app-webchange-list-v3">
        <article class="gc-app-webchange-v3">
          <span>01</span>
          <div>
            <strong>Admin visible solo para administradores</strong>
            <p>El acceso de administración queda oculto para invitados y pilotos. El enlace solo aparece cuando la sesión tiene rol admin.</p>
          </div>
        </article>
        <article class="gc-app-webchange-v3">
          <span>02</span>
          <div>
            <strong>Login y logout más consistentes</strong>
            <p>El header centraliza el estado de sesión, muestra perfil al estar conectado y limpia la sesión al salir.</p>
          </div>
        </article>
        <article class="gc-app-webchange-v3">
          <span>03</span>
          <div>
            <strong>Landing con botón directo al servidor</strong>
            <p>El combo de la semana incluye acceso directo al servidor desde Content Manager, junto a descargas y ficha del combo.</p>
          </div>
        </article>
        <article class="gc-app-webchange-v3">
          <span>04</span>
          <div>
            <strong>Panel /app aligerado</strong>
            <p>Se eliminan accesos duplicados y la home interna prioriza combo activo, lectura rápida, referencias y cambios de plataforma.</p>
          </div>
        </article>
      </div>
    </section>
  </div>

  <style>
    .gc-app-dashboard-v3{
      display:grid;
      gap:clamp(22px,3vw,34px);
    }

    .gc-app-hero-v3,
    .gc-app-metrics-v3{
      margin:0;
    }

    .gc-app-session-v3 .gc-live-panel__title strong{
      color:var(--accent);
    }

    .gc-app-top-grid-v3{
      display:grid;
      grid-template-columns:minmax(0,1.15fr) minmax(340px,.85fr);
      gap:clamp(18px,2.2vw,30px);
      align-items:stretch;
    }

    .gc-app-card-head-v3{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:18px;
      margin-bottom:18px;
    }

    .gc-app-card-head-v3 h2{
      margin:0;
    }

    .gc-app-card-head-v3 p{
      margin:.35rem 0 0;
    }

    .gc-app-combo-body-v3{
      display:grid;
      grid-template-columns:minmax(0,1fr) minmax(210px,.36fr);
      gap:clamp(18px,2vw,28px);
      align-items:stretch;
    }

    .gc-app-label-v3,
    .gc-app-best-v3 span,
    .gc-app-mini-stats-v3 span,
    .gc-app-readout-v3 span{
      display:block;
      color:var(--soft);
      font-size:.72rem;
      font-weight:950;
      text-transform:uppercase;
      letter-spacing:.13em;
    }

    .gc-app-combo-body-v3 h3{
      margin:8px 0 16px;
      color:var(--text);
      font-size:clamp(2.1rem,4.5vw,4rem);
      line-height:.92;
      letter-spacing:-.07em;
    }

    .gc-app-chip-list-v3{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
    }

    .gc-app-best-v3{
      display:grid;
      align-content:center;
      gap:8px;
      padding:18px;
      border:1px solid var(--line);
      border-radius:22px;
      background:linear-gradient(135deg,rgba(255,255,255,.06),rgba(255,255,255,.025));
    }

    .gc-app-best-v3 strong{
      color:var(--text);
      font-size:clamp(1.75rem,3vw,2.65rem);
      line-height:1;
      letter-spacing:-.05em;
    }

    .gc-app-best-v3 small,
    .gc-app-readout-v3 small{
      color:var(--muted);
      line-height:1.45;
    }

    .gc-app-mini-stats-v3{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:10px;
      margin-top:18px;
    }

    .gc-app-mini-stats-v3 div,
    .gc-app-readout-v3{
      padding:14px;
      border:1px solid var(--line);
      border-radius:16px;
      background:rgba(255,255,255,.025);
    }

    .gc-app-mini-stats-v3 strong{
      display:block;
      margin-top:6px;
      color:var(--text);
      font-size:1.42rem;
      line-height:1;
    }

    .gc-app-readout-grid-v3{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:12px;
    }

    .gc-app-readout-v3{
      min-height:126px;
      display:grid;
      align-content:space-between;
      gap:10px;
    }

    .gc-app-readout-v3 strong{
      color:var(--text);
      font-size:clamp(1.25rem,2.4vw,1.95rem);
      line-height:1;
      letter-spacing:-.04em;
      word-break:break-word;
    }

    .gc-app-table-wrap-v3{
      max-height:420px;
      overflow:auto;
    }

    .gc-app-table-v3 td,
    .gc-app-table-v3 th{
      white-space:nowrap;
    }

    .gc-app-table-v3 td:nth-child(2){
      min-width:250px;
    }

    .gc-app-webchange-list-v3{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:12px;
    }

    .gc-app-webchange-v3{
      display:grid;
      grid-template-columns:48px minmax(0,1fr);
      gap:14px;
      padding:16px;
      border:1px solid var(--line);
      border-radius:18px;
      background:linear-gradient(135deg,rgba(255,255,255,.045),rgba(255,255,255,.018));
    }

    .gc-app-webchange-v3 > span{
      width:42px;
      height:42px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:999px;
      color:#07110a;
      background:linear-gradient(135deg,var(--accent),var(--accent2));
      font-size:.72rem;
      font-weight:1000;
      letter-spacing:.05em;
    }

    .gc-app-webchange-v3 strong{
      display:block;
      color:var(--text);
      font-size:1.02rem;
      line-height:1.2;
    }

    .gc-app-webchange-v3 p{
      margin:.35rem 0 0;
      color:var(--muted);
      line-height:1.5;
    }

    @media(max-width:1100px){
      .gc-app-top-grid-v3,
      .gc-app-combo-body-v3,
      .gc-app-webchange-list-v3{
        grid-template-columns:1fr;
      }
    }

    @media(max-width:720px){
      .gc-app-card-head-v3{
        flex-direction:column;
        align-items:flex-start;
      }

      .gc-app-readout-grid-v3,
      .gc-app-mini-stats-v3{
        grid-template-columns:1fr;
      }

      .gc-app-table-wrap-v3{
        max-height:none;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const byId = (id) => document.getElementById(id);
      const setText = (id, value) => {
        const node = byId(id);
        if (node) node.textContent = String(value ?? '--');
      };
      const escapeHtml = (value) => String(value ?? '').replace(/[&<>'"]/g, (char) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;'
      }[char]));
      const asNumber = (value, fallback = 0) => {
        const number = Number(value);
        return Number.isFinite(number) ? number : fallback;
      };
      const formatNumber = (value) => Math.max(0, Math.round(asNumber(value, 0))).toLocaleString('es-ES');
      const text = (value) => {
        if (value == null) return '';
        if (typeof value === 'string' || typeof value === 'number') return String(value).trim();
        if (typeof value === 'object') {
          return text(value.displayName ?? value.name ?? value.uiName ?? value.uiCarName ?? value.uiTrackName ?? value.carName ?? value.trackName ?? value.driverName ?? value.playerName ?? value.code ?? value.car ?? value.track);
        }
        return String(value).trim();
      };
      const items = (data) => {
        if (Array.isArray(data)) return data;
        const candidates = [data?.items, data?.data, data?.results, data?.hotlaps, data?.laps, data?.combos];
        for (const candidate of candidates) {
          if (Array.isArray(candidate)) return candidate;
        }
        return [];
      };
      const dateMs = (value) => {
        if (!value) return 0;
        if (typeof value === 'number') return value > 20000000000 ? value : value * 1000;
        const parsed = Date.parse(String(value));
        return Number.isFinite(parsed) ? parsed : 0;
      };
      const dateText = (value) => {
        const ms = dateMs(value);
        if (!ms) return '--';
        return new Date(ms).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'short' });
      };
      const timeText = (value) => {
        const raw = text(value);
        if (raw && /[:.]/.test(raw) && !/^\d+$/.test(raw)) return raw;
        const ms = asNumber(value, 0);
        if (!ms) return '--';
        const minutes = Math.floor(ms / 60000);
        const seconds = Math.floor((ms % 60000) / 1000);
        const millis = Math.floor(ms % 1000);
        return `${minutes}:${String(seconds).padStart(2, '0')}.${String(millis).padStart(3, '0')}`;
      };
      const fetchJson = async (url) => {
        const controller = new AbortController();
        const timeout = window.setTimeout(() => controller.abort(), 8000);
        try {
          const response = await fetch(url, { credentials: 'include', cache: 'no-store', signal: controller.signal });
          if (!response.ok) throw new Error(`${url} ${response.status}`);
          return await response.json();
        } finally {
          window.clearTimeout(timeout);
        }
      };
      const firstUser = (data) => data?.user || data?.currentUser || data?.account || data?.profile?.user || data?.session?.user || data?.auth?.user || null;
      const isLogged = (data) => Boolean(data?.authenticated === true || data?.loggedIn === true || data?.isAuthenticated === true || firstUser(data));
      const driverName = (lap) => text(lap?.driverName ?? lap?.playerName ?? lap?.pilotName ?? lap?.name ?? lap?.player?.name ?? lap?.driver ?? lap?.player);
      const carName = (value) => text(value?.carName ?? value?.uiCarName ?? value?.car?.displayName ?? value?.car?.name ?? value?.car ?? value?.Car ?? value);
      const lapDate = (lap) => dateMs(lap?.timestampIso || lap?.dateIso || lap?.createdAt || lap?.updatedAt || lap?.timestamp || lap?.Timestamp || lap?.lastSeenAt);
      const lapTime = (lap) => text(lap?.lapTimeFormatted) || text(lap?.timeFormatted) || text(lap?.bestLap) || timeText(lap?.lapTimeMs ?? lap?.LapTime ?? lap?.lapTime ?? lap?.timeMs ?? lap?.time);

      function renderClock() {
        setText('gcAppClock', new Date().toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }));
      }

      function renderAuth(auth) {
        const user = firstUser(auth) || {};
        if (isLogged(auth)) {
          setText('gcAppSessionState', 'Conectado');
          setText('gcAppSessionUser', text(user.displayName ?? user.display_name ?? user.name ?? user.email) || 'Mi perfil');
          setText('gcAppSessionRole', text(user.role) || 'pilot');
          setText('gcAppSessionPilot', text(user.pilotLink?.strackerName ?? user.pilot_stracker_name ?? auth?.pilot?.name) || 'Sin vincular');
        } else {
          setText('gcAppSessionState', 'Invitado');
          setText('gcAppSessionUser', 'Sin login');
          setText('gcAppSessionRole', '-');
          setText('gcAppSessionPilot', '-');
        }
      }

      function renderMetrics(overview, pilots, hotlaps) {
        const stats = overview?.stats || overview?.overview || overview || {};
        setText('gcMetricDrivers', formatNumber(stats.totalDrivers ?? stats.drivers ?? stats.players ?? pilots?.total ?? pilots?.count ?? items(pilots).length));
        setText('gcMetricLaps', formatNumber(stats.totalLaps ?? stats.laps ?? stats.lapCount ?? hotlaps?.total ?? hotlaps?.count ?? items(hotlaps).length));
        setText('gcMetricCars', formatNumber(stats.totalCars ?? stats.cars ?? stats.carCount ?? overview?.carsCount ?? 0));
        setText('gcMetricTracks', formatNumber(stats.totalTracks ?? stats.tracks ?? stats.trackCount ?? overview?.tracksCount ?? 0));
      }

      function renderCombo(combosData) {
        const combos = items(combosData).filter(Boolean);
        const combo = combos.find((entry) => asNumber(entry.totalLaps ?? entry.laps ?? entry.lapCount, 0) > 0) || combos[0];
        if (!combo) {
          setText('gcComboTrack', 'Combo activo');
          setText('gcComboHint', 'Sin datos de combo disponibles.');
          return;
        }

        const track = text(combo.trackName ?? combo.track?.displayName ?? combo.track?.name ?? combo.uiTrackName ?? combo.circuitName ?? combo.trackCode ?? combo.track) || 'Combo activo';
        const id = combo.canonicalComboId ?? combo.comboId ?? combo.id ?? combo.ComboId;
        const rawCars = Array.isArray(combo.cars) ? combo.cars : Array.isArray(combo.carList) ? combo.carList : Array.isArray(combo.carNames) ? combo.carNames : [];
        const cars = rawCars.map(carName).filter(Boolean).slice(0, 8);
        const best = combo.bestLap || combo.best || combo.fastestLap || combo.leader || combo.topLap || {};
        const bestTime = text(combo.bestLapTimeFormatted) || text(combo.bestTimeFormatted) || text(best.lapTimeFormatted) || timeText(combo.bestLapTimeMs ?? combo.bestTimeMs ?? best.lapTimeMs ?? best.LapTime ?? best.lapTime);
        const bestDriver = text(combo.bestDriverName ?? combo.fastestDriverName ?? combo.leaderName ?? best.driverName ?? best.playerName ?? best.name ?? best.driver ?? best.player);
        const bestCar = text(combo.bestCarName ?? combo.fastestCarName ?? best.carName ?? best.uiCarName ?? best.car?.displayName ?? best.car?.name ?? best.car);

        setText('gcComboTrack', track);
        setText('gcAppComboChip', track);
        setText('gcComboHint', 'Última lectura del servidor.');
        setText('gcComboBest', bestTime || '--');
        setText('gcComboBestMeta', [bestDriver, bestCar].filter(Boolean).join(' · ') || 'Mejor vuelta del combo');
        setText('gcComboLaps', formatNumber(combo.totalLaps ?? combo.laps ?? combo.lapCount ?? combo.visibleLaps ?? 0));
        setText('gcComboDrivers', formatNumber(combo.driversCount ?? combo.pilotsCount ?? combo.playersCount ?? combo.uniqueDrivers ?? combo.totalDrivers ?? 0));
        setText('gcComboFamily', asNumber(combo.mergedCombosCount ?? combo.memberComboIds?.length, 1) > 1 ? `${combo.mergedCombosCount ?? combo.memberComboIds?.length} combos` : '1 combo');

        const link = byId('gcComboLink');
        if (link && id != null) link.href = `/combos/${encodeURIComponent(id)}`;
        const carsNode = byId('gcComboCars');
        if (carsNode) {
          carsNode.innerHTML = cars.length
            ? cars.map((name) => `<span class="gc-chip">${escapeHtml(name)}</span>`).join('')
            : '<span class="gc-chip">Coches por confirmar</span>';
        }
      }

      function renderHotlaps(hotlapsData) {
        const laps = items(hotlapsData).filter(Boolean).slice(0, 12);
        setText('gcQuickRefs', formatNumber(hotlapsData?.total ?? hotlapsData?.count ?? laps.length));
        setText('gcRefsMeta', `${formatNumber(hotlapsData?.total ?? hotlapsData?.count ?? laps.length)} referencias · últimas cargadas`);

        const top = laps.find((lap) => lap?.isBest || lap?.rank === 1) || laps[0];
        const last = laps[0];
        setText('gcQuickTop', top ? lapTime(top) : '--');
        setText('gcQuickTopMeta', top ? [driverName(top), carName(top)].filter(Boolean).join(' · ') : 'sin datos');
        setText('gcQuickLast', last ? lapTime(last) : '--');
        setText('gcQuickLastMeta', last ? [driverName(last), dateText(lapDate(last))].filter(Boolean).join(' · ') : 'sin datos');

        const table = byId('gcRefsTable');
        if (table) {
          table.innerHTML = laps.length
            ? laps.slice(0, 8).map((lap) => `
              <tr>
                <td><strong>${escapeHtml(driverName(lap) || 'Piloto')}</strong></td>
                <td>${escapeHtml(carName(lap) || 'Coche')}</td>
                <td><strong>${escapeHtml(lapTime(lap))}</strong></td>
                <td>${escapeHtml(dateText(lapDate(lap)))}</td>
              </tr>
            `).join('')
            : '<tr><td colspan="4">Sin referencias recientes.</td></tr>';
        }
      }

      function renderStracker(data) {
        const db = data?.database || data?.stracker || data || {};
        const ok = Boolean(db.exists);
        setText('gcQuickDb', ok ? 'OK' : 'Pendiente');
        setText('gcQuickDbMeta', ok ? `SQLite ${db.validSQLite === false ? 'por revisar' : 'válido'}` : 'sin lectura');
        setText('gcApiState', ok ? 'API OK' : 'API parcial');
      }

      async function loadDashboard() {
        renderClock();
        const [auth, overview, combos, hotlaps, pilots, stracker] = await Promise.all([
          fetchJson('/api/auth/status').catch(() => null),
          fetchJson('/api/stats/overview').catch(() => null),
          fetchJson('/api/combos/stats').catch(() => null),
          fetchJson('/api/hotlaps?limit=12').catch(() => null),
          fetchJson('/api/pilots?limit=1').catch(() => null),
          fetchJson('/api/stracker/status').catch(() => null)
        ]);

        renderAuth(auth);
        renderMetrics(overview, pilots, hotlaps);
        renderCombo(combos);
        renderHotlaps(hotlaps);
        renderStracker(stracker);
        setText('gcAppStatusChip', 'Live');
      }

      loadDashboard().catch((error) => {
        console.warn('[GC] Error cargando /app:', error);
        setText('gcAppStatusChip', 'API parcial');
        setText('gcApiState', 'Revisar API');
      });
    })();
  </script>
</AppLayout>

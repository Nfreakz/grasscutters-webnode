---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="Herramientas | GrassCutters">
  <div class="gc-page">
    <section class="gc-hero gc-hero--compact">
      <div>
        <span class="gc-kicker">Tools</span>
        <h1 class="gc-title">Herramientas de pilotos.</h1>
        <p class="gc-subtitle">Comparativas, consistencia, filtros avanzados y diagnósticos. Primero dejamos el shell visual fino; luego cada herramienta entrará como módulo enchufable, sin desmontar media web cada vez.</p>
        <div class="gc-hero__meta">
          <span class="gc-chip gc-chip--accent">Módulos futuros</span>
          <span class="gc-chip">Datos tracker</span>
          <span class="gc-chip">Análisis piloto</span>
        </div>
      </div>
      <aside class="gc-live-panel">
        <div class="gc-live-panel__title"><span>Estado</span><strong>Preparado</strong></div>
        <div class="gc-status-list">
          <div class="gc-status-row"><span>Leaderboard</span><strong>Activo</strong></div>
          <div class="gc-status-row"><span>Comparativas</span><strong>Roadmap</strong></div>
          <div class="gc-status-row"><span>Consistencia</span><strong>Roadmap</strong></div>
        </div>
      </aside>
    </section>

    <section class="gc-row-list">
      <a class="gc-row-link" href="/hotlaps"><span class="gc-row-link__num">01</span><span><strong class="gc-row-link__title">Leaderboard</strong><br><span class="gc-row-link__desc">Referencia de tiempos, filtros rápidos, vueltas válidas y lectura directa de stracker.</span></span><span class="gc-row-link__cta">Abrir</span></a>
      <a class="gc-row-link" href="/perfil"><span class="gc-row-link__num">02</span><span><strong class="gc-row-link__title">Perfil Pro</strong><br><span class="gc-row-link__desc">Métricas personales del piloto vinculado, últimas vueltas y progreso.</span></span><span class="gc-row-link__cta">Abrir</span></a>
      <a class="gc-row-link" href="/tracker"><span class="gc-row-link__num">03</span><span><strong class="gc-row-link__title">Diagnóstico tracker</strong><br><span class="gc-row-link__desc">Estado de base de datos, SQLite, tamaño y sync GTX.</span></span><span class="gc-row-link__cta">Abrir</span></a>
      <a class="gc-row-link" href="/pilotos"><span class="gc-row-link__num">04</span><span><strong class="gc-row-link__title">Directorio pilotos</strong><br><span class="gc-row-link__desc">Listado real de pilotos detectados para futura vinculación y perfiles públicos.</span></span><span class="gc-row-link__cta">Abrir</span></a>
    </section>

    <section class="gc-command-strip">
      <div class="gc-command-item"><span>Comparativa</span><strong>Piloto vs piloto</strong><p>Preparada para escoger coche, circuito y delta.</p></div>
      <div class="gc-command-item"><span>Consistencia</span><strong>Ritmo real</strong><p>Promedios, desviación y vueltas válidas.</p></div>
      <div class="gc-command-item"><span>Filtros</span><strong>Nombres limpios</strong><p>Mapeos de coches y circuitos para evitar nombres internos feos.</p></div>
    </section>
  </div>
</AppLayout>

---
export const prerender = false;
import MarketingLayout from '../../../layouts/MarketingLayout.astro';
import { ARCHIVE_PUBLIC_CATEGORIES, findPublishedArchiveItem, getArchiveCoverAlt, getArchiveCoverUrl, getArchiveItemUrl, getPublishedArchiveItems, normalizeArchiveCategory } from '../../../lib/motorsport-archive/public-data';

const categoryParam = String(Astro.params.category || '').replace(/\/$/, '');
const slugParam = String(Astro.params.slug || '').replace(/\/$/, '');

const item = await findPublishedArchiveItem(categoryParam, slugParam);

if (!item) {
  return Astro.redirect('/archivo');
}

const title = item.title;
const summary = item.summary || '';
const body = item.body || '';
const facts = Array.isArray(item.facts) ? item.facts : [];
const media = Array.isArray(item.media) ? item.media : [];
const hero = media[0];
const published = await getPublishedArchiveItems();
const relatedItems = published
  .filter((entry) => entry.id !== item.id && normalizeArchiveCategory(entry.category || entry.type) === normalizeArchiveCategory(item.category || item.type))
  .slice(0, 4);
const categoryLabel = ARCHIVE_PUBLIC_CATEGORIES.find((category) => category.key === item.category)?.label || item.category;
---
<MarketingLayout title={`${title} | Archivo Motorsport`} description={summary || `Ficha del Archivo Motorsport: ${title}`} canonicalPath={`/archivo/${categoryParam}/${slugParam}/`}>
  <link rel="stylesheet" href="/gc-archivo-share-v832.css" />

  <section class="gc-page archivo-detail-hero">
    <div class="archivo-detail-copy">
      <nav class="archivo-breadcrumbs" aria-label="Breadcrumbs">
        <a href="/archivo">Archivo Motorsport</a>
        <span>/</span>
        <a href={`/archivo/${categoryParam}/`}>{categoryLabel}</a>
        <span>/</span>
        <strong>{title}</strong>
      </nav>
      <span class="gc-kicker">Archivo Motorsport</span>
      <h1 class="gc-title">{title}</h1>
      {summary ? <p class="gc-lead">{summary}</p> : null}
      {facts.length ? (
        <ul class="archivo-facts">
          {facts.slice(0, 8).map((fact) => <li><strong>{fact.label}</strong><span>{fact.value}</span></li>)}
        </ul>
      ) : null}
    </div>
    <div class="archivo-media-card">
      <img id="archivoHeroImage" src={getArchiveCoverUrl(item)} alt={getArchiveCoverAlt(item)} loading="eager" />
      {hero ? (
        <div class="archivo-media-credit">
          <strong>{hero.alt || title}</strong>
          {hero.source || hero.author || hero.license ? <span>{[hero.source, hero.author, hero.license].filter(Boolean).join(' · ')}</span> : null}
        </div>
      ) : null}
    </div>
  </section>

  {media.length > 1 ? (
    <section class="gc-page archivo-gallery-wrap">
      <div class="archivo-section-head">
        <h2>Galería</h2>
        <p>{media.length} imágenes asociadas a esta ficha.</p>
      </div>
      <div class="archivo-gallery" data-archivo-gallery>
        {media.map((image, index) => (
          <button type="button" class:list={["archivo-gallery-thumb", { 'is-active': index === 0 }]} data-gallery-src={image.url} data-gallery-alt={image.alt}>
            <img src={image.url} alt={image.alt} loading="lazy" />
            <span>{image.isPrimary || image.isMain ? 'Portada' : `Imagen ${index + 1}`}</span>
          </button>
        ))}
      </div>
    </section>
  ) : null}

  <section class="gc-page archivo-content-grid">
    <article class="archivo-panel archivo-panel-main">
      <h2>Ficha</h2>
      {body ? <div class="archivo-body" set:html={body.replace(/\n/g, '<br />')} /> : <p>Esta ficha todavía no tiene texto largo.</p>}
    </article>

    <aside class="archivo-panel">
      <h2>Créditos de imagen</h2>
      {media.length ? (
        <div class="archivo-credits-list">
          {media.map((image) => (
            <div class="archivo-credit-item">
              <strong>{image.alt || title}</strong>
              {image.author ? <span>Autor: {image.author}</span> : null}
              {image.license ? <span>Licencia: {image.license}</span> : null}
              {image.sourceUrl ? <a href={image.sourceUrl} target="_blank" rel="noreferrer">Ver fuente</a> : null}
            </div>
          ))}
        </div>
      ) : <p>Sin imágenes asociadas.</p>}
    </aside>
  </section>

  <div class="gc-page" data-archive-detail-share></div>

  {relatedItems.length ? (
    <section class="gc-page archivo-related-wrap">
      <div class="archivo-section-head">
        <h2>Relacionados</h2>
        <p>Más fichas de la misma categoría.</p>
      </div>
      <div class="archivo-related-grid">
        {relatedItems.map((entry) => (
          <a class="archivo-related-card" href={getArchiveItemUrl(entry)}>
            <img src={getArchiveCoverUrl(entry)} alt={entry.title} loading="lazy" />
            <div>
              <strong>{entry.title}</strong>
              <span>{entry.summary || entry.category}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  ) : null}

  <script is:inline>
    (() => {
      const hero = document.getElementById('archivoHeroImage');
      const buttons = document.querySelectorAll('[data-gallery-src]');
      if (!hero || !buttons.length) return;
      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          buttons.forEach((b) => b.classList.remove('is-active'));
          button.classList.add('is-active');
          hero.src = button.getAttribute('data-gallery-src') || hero.src;
          hero.alt = button.getAttribute('data-gallery-alt') || hero.alt;
        });
      });
    })();
  </script>

  <style is:global>
    .archivo-detail-hero{display:grid;grid-template-columns:minmax(0,1fr) minmax(320px,.82fr);gap:1.4rem;align-items:start}.archivo-breadcrumbs{display:flex;gap:.5rem;flex-wrap:wrap;opacity:.75;margin-bottom:.75rem}.archivo-breadcrumbs a{text-decoration:none;color:inherit}.archivo-media-card{padding:.75rem;border-radius:26px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08)}.archivo-media-card>img{width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:20px;background:#101810}.archivo-media-credit{display:grid;gap:.2rem;margin-top:.7rem;font-size:.92rem}.archivo-media-credit span{opacity:.76}.archivo-facts{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.7rem;list-style:none;padding:0;margin:1rem 0 0}.archivo-facts li{padding:.75rem .9rem;border-radius:18px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08)}.archivo-facts strong{display:block;font-size:.78rem;opacity:.7;margin-bottom:.15rem}.archivo-gallery-wrap,.archivo-content-grid,.archivo-related-wrap{padding-top:0}.archivo-section-head{margin-bottom:1rem}.archivo-section-head h2{margin:0 0 .2rem}.archivo-section-head p{margin:0;opacity:.76}.archivo-gallery{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:.75rem}.archivo-gallery-thumb{padding:.55rem;border-radius:18px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.04);color:inherit;text-align:left;cursor:pointer}.archivo-gallery-thumb.is-active{border-color:rgba(137,195,92,.6);background:rgba(137,195,92,.12)}.archivo-gallery-thumb img{width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:13px;background:#101810}.archivo-gallery-thumb span{display:block;margin-top:.4rem;font-size:.82rem;opacity:.8}.archivo-content-grid{display:grid;grid-template-columns:minmax(0,1.15fr) minmax(280px,.85fr);gap:1rem}.archivo-panel{padding:1rem;border-radius:24px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08)}.archivo-body{line-height:1.75;color:rgba(255,255,255,.86)}.archivo-credits-list{display:grid;gap:.75rem}.archivo-credit-item{display:grid;gap:.25rem;padding:.75rem;border-radius:16px;background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.06)}.archivo-credit-item span,.archivo-credit-item a{font-size:.9rem;opacity:.82}.archivo-related-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem}.archivo-related-card{display:grid;grid-template-columns:100px 1fr;gap:.8rem;padding:.8rem;border-radius:20px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);color:inherit;text-decoration:none}.archivo-related-card img{width:100%;aspect-ratio:1/1;object-fit:cover;border-radius:14px;background:#101810}.archivo-related-card strong{display:block;margin-bottom:.25rem}.archivo-related-card span{opacity:.74}@media(max-width:980px){.archivo-detail-hero,.archivo-content-grid{grid-template-columns:1fr}.archivo-gallery{grid-template-columns:repeat(3,minmax(0,1fr))}.archivo-related-grid{grid-template-columns:1fr}}@media(max-width:620px){.archivo-facts,.archivo-gallery{grid-template-columns:1fr}.archivo-related-card{grid-template-columns:1fr}}
  </style>

  <script src="/gc-archivo-share-v832.js" is:inline></script>
</MarketingLayout>

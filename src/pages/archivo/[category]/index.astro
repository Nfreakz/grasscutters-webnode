---
import MarketingLayout from '../../../layouts/MarketingLayout.astro';
import { getArchiveCategoryBySlug, getArchiveCoverAlt, getArchiveCoverUrl, getArchiveItemUrl, getPublishedArchiveItemsByCategory } from '../../../lib/motorsport-archive/public';

export const prerender = false;

const categorySlug = String(Astro.params.category || '');
const category = getArchiveCategoryBySlug(categorySlug);
if (!category) return Astro.redirect('/archivo');
const items = getPublishedArchiveItemsByCategory(category.key);
---
<MarketingLayout title={`${category.label} | Archivo Motorsport`} description={category.intro} canonicalPath={`/archivo/${category.slug}/`}>
  <section class="gc-page archive-list-hero">
    <span class="gc-kicker">Archivo Motorsport</span>
    <h1 class="gc-title">{category.label}</h1>
    <p class="gc-lead">{category.intro}</p>
    <p><a href="/archivo">← Volver al archivo</a></p>
  </section>

  <section class="gc-page archive-list">
    {items.length ? items.map((item) => (
      <a class="archive-list-card" href={getArchiveItemUrl(item)}>
        <img src={getArchiveCoverUrl(item)} alt={getArchiveCoverAlt(item)} loading="lazy" onerror="this.onerror=null;this.src='/images/biblia-placeholder.svg';" />
        <div>
          <h2>{item.title}</h2>
          <p>{item.summary || 'Ficha publicada en el Archivo Motorsport.'}</p>
        </div>
      </a>
    )) : (
      <div class="archive-empty"><h2>Sin fichas publicadas</h2><p>Publica una ficha de esta categoría desde el admin.</p></div>
    )}
  </section>

  <style is:global>
    .archive-list{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem}.archive-list-card{display:grid;grid-template-columns:120px 1fr;gap:1rem;padding:1rem;border-radius:22px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);text-decoration:none;color:inherit}.archive-list-card img{width:100%;aspect-ratio:1/1;object-fit:cover;border-radius:16px;background:#101810}.archive-list-card h2{font-size:1.08rem;margin:.1rem 0 .35rem}.archive-list-card p{margin:0;opacity:.78}@media(max-width:1000px){.archive-list{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:680px){.archive-list{grid-template-columns:1fr}.archive-list-card{grid-template-columns:1fr}.archive-list-card img{aspect-ratio:16/9}}
  </style>
</MarketingLayout>

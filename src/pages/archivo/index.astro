---
export const prerender = false;

import MarketingLayout from '../../layouts/MarketingLayout.astro';
import {
  archiveItemHref,
  archiveTypeHref,
  getArchiveCountry,
  getArchiveImage,
  getArchivePeriod,
  getArchiveStats,
  getArchiveSummary,
  prettifyArchiveType,
  singularArchiveType,
} from '../../lib/archive/archiveRuntime';

const stats = await getArchiveStats();
const items = stats.items || [];
const types = (stats.types || []).filter((type) => ['circuitos', 'coches', 'pilotos', 'glosario'].includes(type.tipo));

const itemsWithImage = items.filter((item) => getArchiveImage(item));
const featured = itemsWithImage[0] || items[0] || null;
const latest = items.slice(0, 12);

const heroImage = featured ? getArchiveImage(featured) : '';
const heroStyle = heroImage ? `--archive-hero-image:url('${String(heroImage).replace(/'/g, '%27')}');` : '';

const typeIntros = {
  circuitos: 'Trazados, datos técnicos, zonas clave y contexto de conducción.',
  coches: 'Modelos, versiones de competición, mecánica e historial deportivo.',
  pilotos: 'Trayectorias, palmarés, estilo de pilotaje y etapas clave.',
  glosario: 'Conceptos de pilotaje, técnica, competición y cultura motorsport.',
};

const pageTitle = 'Archivo GrassCutters | Circuitos, coches, pilotos y glosario';
const pageDescription = 'Archivo visual y editorial de GrassCutters con fichas de circuitos, coches, pilotos y conceptos técnicos del motorsport.';
---

<MarketingLayout
  bodyClass="gc-archive-public"
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/archivo/"
  ogImage="/og/archivo-og.png"
  ogImageAlt="Archivo GrassCutters Racing"
>
  <main class="gc-archive-home" data-archive-home>
    <section class={`gc-archive-home__hero ${heroImage ? 'has-image' : ''}`} style={heroStyle}>
      <div class="gc-archive-home__hero-copy">
        <span class="gc-archive-home__eyebrow">Archivo GrassCutters</span>
        <h1>Archivo motorsport.</h1>
        <p>
          Circuitos, coches, pilotos y conceptos. Fichas claras, datos útiles e imágenes para consultar rápido.
        </p>

        <form class="gc-archive-home__search" role="search" aria-label="Buscar en el archivo">
          <label for="archiveHomeSearch">Buscar en el archivo</label>
          <div>
            <input
              id="archiveHomeSearch"
              type="search"
              placeholder="Busca Mugello, GT2, piloto, motor, trazado..."
              data-archive-search-input
              autocomplete="off"
            />
            <button type="button" data-archive-clear>Limpiar</button>
          </div>
          <small><span data-archive-result-count>{items.length}</span> fichas visibles</small>
        </form>

        <div class="gc-archive-home__actions">
          <a href="#archivo-catalogo">Explorar catálogo</a>
          <a href={featured ? archiveItemHref(featured) : '/archivo/circuitos/'}>{featured ? 'Abrir destacado' : 'Ver circuitos'}</a>
        </div>
      </div>

      <aside class="gc-archive-home__command-card" aria-label="Resumen del archivo">
        <span>Índice actual</span>
        <strong>{items.length}</strong>
        <p>fichas publicadas</p>

        <div>
          {types.map((type) => (
            <a href={archiveTypeHref(type.tipo)}>
              <span>{type.label}</span>
              <strong>{type.count}</strong>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="gc-archive-home__types" aria-label="Categorías principales">
      {types.map((type) => (
        <a href={archiveTypeHref(type.tipo)} data-home-type-card={type.tipo}>
          <span>{type.singular}</span>
          <strong>{type.label}</strong>
          <p>{typeIntros[type.tipo] || 'Fichas del archivo.'}</p>
          <small>{type.count} ficha{type.count === 1 ? '' : 's'}</small>
        </a>
      ))}
    </section>

    {featured && (
      <section class="gc-archive-home__spotlight">
        <article>
          <div class="gc-archive-home__spotlight-copy">
            <span class="gc-archive-home__eyebrow">Dossier destacado</span>
            <h2>{featured.nombre}</h2>
            <p>{getArchiveSummary(featured) || 'Ficha destacada del archivo.'}</p>

            <dl>
              <div>
                <dt>Ficha</dt>
                <dd>{singularArchiveType(featured.tipo)}</dd>
              </div>
              {getArchiveCountry(featured) && (
                <div>
                  <dt>Origen</dt>
                  <dd>{getArchiveCountry(featured)}</dd>
                </div>
              )}
              {getArchivePeriod(featured) && (
                <div>
                  <dt>Periodo</dt>
                  <dd>{getArchivePeriod(featured)}</dd>
                </div>
              )}
            </dl>

            <a href={archiveItemHref(featured)}>Abrir dossier</a>
          </div>

          {getArchiveImage(featured) ? (
            <figure>
              <img src={getArchiveImage(featured)} alt={featured.coverAlt || featured.imagen_alt || featured.nombre} loading="eager" />
            </figure>
          ) : (
            <div class="gc-archive-home__visual-mark">
              <span>{singularArchiveType(featured.tipo)}</span>
              <strong>{featured.nombre}</strong>
            </div>
          )}
        </article>
      </section>
    )}

    <section class="gc-archive-home__catalogue" id="archivo-catalogo">
      <div class="gc-archive-home__section-head">
        <div>
          <span class="gc-archive-home__eyebrow">Catálogo</span>
          <h2>Todas las fichas.</h2>
        </div>
        <p>Filtra por categoría o busca por título, país, época, motor, equipo, trazado o concepto.</p>
      </div>

      <div class="gc-archive-home__filters" aria-label="Filtros del archivo">
        <button type="button" class="is-active" data-archive-type="all">Todo</button>
        {types.map((type) => (
          <button type="button" data-archive-type={type.tipo}>{type.label}</button>
        ))}
      </div>

      {latest.length ? (
        <div class="gc-archive-home__grid" data-archive-results>
          {items.map((item) => (
            <a
              class="gc-archive-home__card"
              href={archiveItemHref(item)}
              data-archive-card
              data-type={item.tipo}
              data-search={`${item.nombre} ${item.slug} ${item.tipo} ${prettifyArchiveType(item.tipo)} ${getArchiveSummary(item)} ${getArchiveCountry(item)} ${getArchivePeriod(item)} ${item.tags || ''} ${item.fabricante || ''} ${item.motor || ''} ${item.disciplina || ''}`}
            >
              {getArchiveImage(item) ? (
                <img src={getArchiveImage(item)} alt={item.coverAlt || item.imagen_alt || item.nombre} loading="lazy" />
              ) : (
                <span class="gc-archive-home__card-mark">{singularArchiveType(item.tipo)}</span>
              )}

              <div>
                <small>{prettifyArchiveType(item.tipo)}</small>
                <strong>{item.nombre}</strong>
                <p>{getArchiveSummary(item) || 'Ficha del archivo.'}</p>
                <footer>
                  {getArchiveCountry(item) && <em>{getArchiveCountry(item)}</em>}
                  {getArchivePeriod(item) && <em>{getArchivePeriod(item)}</em>}
                  <b>Abrir</b>
                </footer>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="gc-archive-home__empty">
          <strong>Aún no hay fichas publicadas.</strong>
          <p>Cuando publiques fichas desde el admin aparecerán aquí automáticamente.</p>
        </div>
      )}

      <div class="gc-archive-home__empty" data-archive-empty hidden>
        <strong>No hay resultados.</strong>
        <p>Prueba con otro término o limpia los filtros.</p>
      </div>
    </section>
  </main>

  <script>
    const root = document.querySelector('[data-archive-home]');
    const input = root?.querySelector('[data-archive-search-input]');
    const clearBtn = root?.querySelector('[data-archive-clear]');
    const cards = [...root?.querySelectorAll('[data-archive-card]') || []];
    const count = root?.querySelector('[data-archive-result-count]');
    const empty = root?.querySelector('[data-archive-empty]');
    const typeButtons = [...root?.querySelectorAll('button[data-archive-type]') || []];

    let activeType = 'all';

    function normalize(value) {
      return String(value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    }

    function setActiveType(value) {
      activeType = value;
      typeButtons.forEach((button) => {
        const selected = button.dataset.archiveType === value;
        button.classList.toggle('is-active', selected);
        button.setAttribute('aria-pressed', selected ? 'true' : 'false');
      });
    }

    function applyFilters() {
      const query = normalize(input?.value || '');
      let visible = 0;

      cards.forEach((card) => {
        const typeOk = activeType === 'all' || card.dataset.type === activeType;
        const textOk = !query || normalize(card.dataset.search).includes(query);
        const show = typeOk && textOk;
        card.hidden = !show;
        if (show) visible += 1;
      });

      if (count) count.textContent = String(visible);
      if (empty) empty.hidden = visible !== 0;
    }

    typeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        setActiveType(button.dataset.archiveType || 'all');
        applyFilters();
      });
    });

    input?.addEventListener('input', applyFilters);

    clearBtn?.addEventListener('click', () => {
      if (input) input.value = '';
      setActiveType('all');
      applyFilters();
      input?.focus();
    });

    applyFilters();
  </script>

  <style is:global>
    .gc-archive-home{
      --archive-line:rgba(202,255,188,.13);
      --archive-line-strong:rgba(156,255,63,.28);
      --archive-accent:var(--accent,#9cff3f);
      width:min(100%,1460px);
      margin:0 auto;
      padding:clamp(22px,3.8vw,50px) clamp(14px,3vw,34px) clamp(64px,7vw,110px);
      color:var(--text,#f2f7ef);
    }

    .gc-archive-home *,
    .gc-archive-home *::before,
    .gc-archive-home *::after{box-sizing:border-box}

    .gc-archive-home a{color:inherit}

    .gc-archive-home__hero{
      position:relative;
      display:grid;
      grid-template-columns:minmax(0,1fr) minmax(260px,.34fr);
      gap:clamp(18px,3vw,36px);
      align-items:center;
      min-height:clamp(340px,42vh,500px);
      padding:clamp(20px,3.2vw,38px);
      border:1px solid var(--archive-line);
      border-radius:24px;
      overflow:hidden;
      background:
        radial-gradient(circle at 16% 6%, rgba(156,255,63,.18), transparent 34%),
        radial-gradient(circle at 86% 10%, rgba(37,214,230,.10), transparent 34%),
        radial-gradient(circle at 50% 100%, rgba(255,255,255,.06), transparent 48%),
        linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.012));
      box-shadow:0 40px 130px rgba(0,0,0,.32);
    }

    .gc-archive-home__hero.has-image::before{
      content:"";
      position:absolute;
      inset:-1px;
      background:
        linear-gradient(90deg, rgba(0,9,4,.93) 0%, rgba(0,9,4,.78) 50%, rgba(0,9,4,.38) 100%),
        var(--archive-hero-image);
      background-size:cover;
      background-position:center;
      opacity:.26;
      filter:saturate(.9) contrast(1.08);
      pointer-events:none;
    }

    .gc-archive-home__hero::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(rgba(255,255,255,.033) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.026) 1px, transparent 1px);
      background-size:56px 56px;
      mask-image:linear-gradient(90deg, rgba(0,0,0,.82), transparent 86%);
      pointer-events:none;
    }

    .gc-archive-home__hero-copy,
    .gc-archive-home__command-card{
      position:relative;
      z-index:1;
    }

    .gc-archive-home__hero-copy{
      display:grid;
      align-content:center;
      min-width:0;
      max-width:820px;
    }

    .gc-archive-home__eyebrow{
      display:inline-flex;
      color:var(--archive-accent);
      font-size:.75rem;
      font-weight:950;
      letter-spacing:.22em;
      text-transform:uppercase;
    }

    .gc-archive-home h1{
      max-width:1020px;
      margin:.25rem 0 .65rem;
      font-size:clamp(3.2rem,6vw,6.4rem);
      line-height:.86;
      letter-spacing:-.075em;
    }

    .gc-archive-home__hero-copy > p{
      max-width:650px;
      margin:0;
      color:var(--soft,#b6c5b8);
      font-size:clamp(1rem,1.25vw,1.18rem);
      line-height:1.5;
    }

    .gc-archive-home__search{
      width:min(100%,760px);
      margin-top:clamp(18px,2.4vw,28px);
      padding:12px;
      border:1px solid var(--archive-line);
      border-radius:24px;
      background:rgba(0,0,0,.30);
      backdrop-filter:blur(14px);
    }

    .gc-archive-home__search label{
      display:block;
      margin:2px 0 9px 4px;
      color:var(--archive-accent);
      font-size:.72rem;
      font-weight:950;
      letter-spacing:.18em;
      text-transform:uppercase;
    }

    .gc-archive-home__search div{
      display:grid;
      grid-template-columns:1fr auto;
      gap:10px;
    }

    .gc-archive-home__search input{
      width:100%;
      min-height:52px;
      padding:0 18px;
      border:1px solid rgba(255,255,255,.12);
      border-radius:17px;
      background:rgba(2,6,4,.78);
      color:#fff;
      font:inherit;
      outline:none;
    }

    .gc-archive-home__search button,
    .gc-archive-home__filters button{
      min-height:42px;
      padding:0 16px;
      border:1px solid rgba(255,255,255,.12);
      border-radius:999px;
      background:rgba(255,255,255,.045);
      color:var(--text,#f2f7ef);
      font-weight:950;
      letter-spacing:.08em;
      text-transform:uppercase;
      cursor:pointer;
    }

    .gc-archive-home__search small{
      display:block;
      margin:10px 0 0 4px;
      color:var(--muted,#7f9184);
    }

    .gc-archive-home__actions{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin-top:18px;
    }

    .gc-archive-home__actions a,
    .gc-archive-home__spotlight a{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:46px;
      padding:0 18px;
      border-radius:999px;
      background:linear-gradient(135deg,var(--archive-accent),#45f1db);
      color:#061006;
      text-decoration:none;
      font-weight:950;
    }

    .gc-archive-home__actions a + a{
      color:#fff;
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.13);
    }

    .gc-archive-home__command-card{
      display:grid;
      align-content:center;
      gap:12px;
      padding:clamp(18px,2vw,24px);
      border:1px solid rgba(255,255,255,.10);
      border-radius:30px;
      background:linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.020));
      backdrop-filter:blur(16px);
    }

    .gc-archive-home__command-card > span{
      color:var(--archive-accent);
      font-size:.74rem;
      font-weight:950;
      letter-spacing:.16em;
      text-transform:uppercase;
    }

    .gc-archive-home__command-card > strong{
      font-size:clamp(3.4rem,5.4vw,5.5rem);
      line-height:.78;
      letter-spacing:-.09em;
    }

    .gc-archive-home__command-card > p{
      margin:-10px 0 8px;
      color:var(--soft,#b6c5b8);
    }

    .gc-archive-home__command-card div{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
    }

    .gc-archive-home__command-card a{
      min-height:64px;
      display:grid;
      gap:8px;
      padding:13px;
      border:1px solid rgba(255,255,255,.08);
      border-radius:18px;
      background:rgba(0,0,0,.18);
      text-decoration:none;
      transition:border-color .16s ease, background .16s ease, transform .16s ease;
    }

    .gc-archive-home__command-card a:hover{
      transform:translateY(-1px);
      border-color:var(--archive-line-strong);
      background:rgba(255,255,255,.034);
    }

    .gc-archive-home__command-card a span{
      color:var(--muted,#7f9184);
      font-size:.72rem;
      font-weight:900;
      letter-spacing:.12em;
      text-transform:uppercase;
    }

    .gc-archive-home__command-card a strong{
      font-size:2rem;
      line-height:1;
    }

    .gc-archive-home__types{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:12px;
      margin:16px 0 clamp(24px,3vw,42px);
    }

    .gc-archive-home__types a{
      min-height:160px;
      display:grid;
      align-content:end;
      gap:9px;
      padding:20px;
      border:1px solid var(--archive-line);
      border-radius:26px;
      background:
        radial-gradient(circle at 90% 15%, rgba(156,255,63,.10), transparent 38%),
        linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.014));
      text-decoration:none;
      transition:transform .16s ease,border-color .16s ease,background .16s ease;
    }

    .gc-archive-home__types a:hover{
      transform:translateY(-2px);
      border-color:var(--archive-line-strong);
      background:
        radial-gradient(circle at 90% 15%, rgba(156,255,63,.15), transparent 38%),
        linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.018));
    }

    .gc-archive-home__types span,
    .gc-archive-home__card small,
    .gc-archive-home__routes-grid small,
    .gc-archive-home__route-mark{
      color:var(--archive-accent);
      font-size:.72rem;
      font-weight:950;
      letter-spacing:.14em;
      text-transform:uppercase;
    }

    .gc-archive-home__types strong{
      font-size:clamp(1.55rem,2.5vw,2.25rem);
      line-height:.96;
      letter-spacing:-.055em;
    }

    .gc-archive-home__types p,
    .gc-archive-home__types small{
      color:var(--soft,#b6c5b8);
      line-height:1.45;
    }

    .gc-archive-home__types p{
      margin:0;
    }

    .gc-archive-home__spotlight,
    .gc-archive-home__routes,
    .gc-archive-home__catalogue{
      margin-top:clamp(28px,4vw,62px);
    }

    .gc-archive-home__spotlight article{
      display:grid;
      grid-template-columns:minmax(0,1fr) minmax(320px,.46fr);
      overflow:hidden;
      border:1px solid var(--archive-line);
      border-radius:34px;
      background:
        radial-gradient(circle at 14% 0%, rgba(156,255,63,.10), transparent 34%),
        linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.014));
    }

    .gc-archive-home__spotlight-copy{
      padding:clamp(26px,4vw,48px);
    }

    .gc-archive-home__spotlight h2,
    .gc-archive-home__section-head h2{
      margin:.35rem 0 .8rem;
      font-size:clamp(2.6rem,5.2vw,5.9rem);
      line-height:.84;
      letter-spacing:-.09em;
    }

    .gc-archive-home__spotlight p,
    .gc-archive-home__section-head p,
    .gc-archive-home__card p,
    .gc-archive-home__routes-grid p{
      color:var(--soft,#b6c5b8);
      line-height:1.6;
    }

    .gc-archive-home__spotlight dl{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:10px;
      margin:24px 0;
    }

    .gc-archive-home__spotlight dl div{
      padding:12px;
      border:1px solid rgba(255,255,255,.08);
      border-radius:15px;
      background:rgba(0,0,0,.16);
    }

    .gc-archive-home__spotlight dt{
      color:var(--muted,#7f9184);
      font-size:.72rem;
      font-weight:900;
      letter-spacing:.12em;
      text-transform:uppercase;
    }

    .gc-archive-home__spotlight dd{
      margin:6px 0 0;
    }

    .gc-archive-home__spotlight figure{
      margin:0;
      min-height:100%;
    }

    .gc-archive-home__spotlight img{
      width:100%;
      height:100%;
      min-height:340px;
      object-fit:cover;
      display:block;
    }

    .gc-archive-home__visual-mark{
      min-height:340px;
      display:grid;
      place-content:center;
      gap:10px;
      text-align:center;
      padding:24px;
      background:
        linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
      background-size:42px 42px;
    }

    .gc-archive-home__visual-mark span{
      color:var(--archive-accent);
      font-size:.78rem;
      font-weight:950;
      letter-spacing:.18em;
      text-transform:uppercase;
    }

    .gc-archive-home__visual-mark strong{
      font-size:clamp(1.8rem,3vw,3rem);
      line-height:.95;
      letter-spacing:-.06em;
    }

    .gc-archive-home__section-head{
      display:flex;
      justify-content:space-between;
      gap:18px;
      align-items:end;
      margin-bottom:18px;
    }

    .gc-archive-home__section-head p{
      max-width:560px;
      margin:0;
    }

    .gc-archive-home__routes-grid{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:14px;
    }

    .gc-archive-home__routes-grid a{
      display:grid;
      grid-template-rows:auto 1fr;
      overflow:hidden;
      min-height:360px;
      border:1px solid var(--archive-line);
      border-radius:26px;
      background:linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.014));
      text-decoration:none;
      transition:transform .16s ease,border-color .16s ease,background .16s ease;
    }

    .gc-archive-home__routes-grid a:hover{
      transform:translateY(-2px);
      border-color:var(--archive-line-strong);
      background:rgba(255,255,255,.032);
    }

    .gc-archive-home__routes-grid img,
    .gc-archive-home__route-mark{
      width:100%;
      aspect-ratio:16/9;
      object-fit:cover;
      display:grid;
      place-items:center;
      background:rgba(255,255,255,.035);
    }

    .gc-archive-home__routes-grid div{
      display:grid;
      align-content:end;
      gap:8px;
      padding:18px;
    }

    .gc-archive-home__routes-grid strong{
      font-size:1.35rem;
      line-height:1.05;
      letter-spacing:-.04em;
    }

    .gc-archive-home__catalogue{
      padding:clamp(20px,3vw,30px);
      border:1px solid var(--archive-line);
      border-radius:32px;
      background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.014));
    }

    .gc-archive-home__filters{
      display:flex;
      flex-wrap:wrap;

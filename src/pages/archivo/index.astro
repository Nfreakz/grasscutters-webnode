---
export const prerender = false;

import MarketingLayout from '../../layouts/MarketingLayout.astro';
import '../../styles/home2.css';
import '../../styles/archive-home2-polish.css';
import {
  archiveItemHref,
  archiveTypeHref,
  getArchiveCountry,
  getArchiveImage,
  getArchivePeriod,
  getArchiveStats,
  getArchiveSummary,
  prettifyArchiveType,
  singularArchiveType,
} from '../../lib/archive/archiveRuntime';

const stats = await getArchiveStats();
const items = stats.items || [];
const types = (stats.types || []).filter((type) => ['circuitos', 'coches', 'pilotos', 'glosario'].includes(type.tipo));

const itemsWithImage = items.filter((item) => getArchiveImage(item));
const featured = itemsWithImage[0] || items[0] || null;

const heroImage = featured ? getArchiveImage(featured) : '';
const heroStyle = heroImage ? `--archive-hero-image:url('${String(heroImage).replace(/'/g, '%27')}');` : '';

const typeIntros = {
  circuitos: 'Trazados, historia, características, eventos y contexto dentro del motorsport.',
  coches: 'Modelos de competición, versiones, técnica, categorías e historial deportivo.',
  pilotos: 'Trayectorias, palmarés, etapas clave, equipos y estilo dentro de la competición.',
  glosario: 'Conceptos técnicos, términos de pilotaje, cultura racing y vocabulario del motor.',
};

const pageTitle = 'Archivo GrassCutters | Base de datos de motorsport';
const pageDescription = 'Base de datos editorial de motorsport con fichas de circuitos, coches, pilotos, conceptos técnicos, historia y cultura racing.';
---

<MarketingLayout
  bodyClass="gc-archive-public"
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/archivo/"
  ogImage="/og/archivo-og.png"
  ogImageAlt="Archivo GrassCutters Racing"
>
  <main class="gc-archive-home2" data-archive-home>
    <section class={`gc-archive-race-hero ${heroImage ? 'has-image' : ''}`} style={heroStyle}>
      <div class="gc-archive-shell gc-archive-race-hero__grid">
        <div>
          <p class="gc-archive-kicker">GRASSCUTTERS DATABASE</p>
          <h1>Archivo</h1>
          <p class="gc-archive-race-hero__lead">
            Base de datos editorial sobre motorsport: circuitos, coches, pilotos, conceptos técnicos, historia y cultura racing organizada para consultar y ampliar contexto.
          </p>

          <div class="gc-archive-statusline">
            <span class="gc-archive-badge">Motorsport database</span>
            <span class="gc-archive-badge">Fichas editoriales</span>
            <span class="gc-archive-badge">Historia y técnica</span>
          </div>

          <form class="gc-archive-search" role="search" aria-label="Buscar en el archivo">
            <label for="archiveHomeSearch">Buscar en el archivo</label>
            <div>
              <input
                id="archiveHomeSearch"
                type="search"
                placeholder="Mugello, GT2, piloto, motor, trazado..."
                data-archive-search-input
                autocomplete="off"
              />
              <button type="button" data-archive-clear>Limpiar</button>
            </div>
            <small><span data-archive-result-count>{items.length}</span> fichas visibles</small>
          </form>
        </div>

        <aside class="gc-archive-command-card" aria-label="Resumen del archivo">
          <span>Base de datos</span>
          <strong>{items.length}</strong>
          <small>fichas publicadas</small>

          <div class="gc-archive-command-grid">
            {types.map((type) => (
              <a href={archiveTypeHref(type.tipo)}>
                <small>{type.label}</small>
                <strong>{type.count}</strong>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </section>

    <section class="gc-archive-shell gc-archive-section" aria-label="Categorías principales">
      <div class="gc-archive-type-grid">
        {types.map((type) => (
          <a class="gc-archive-type-card" href={archiveTypeHref(type.tipo)} data-home-type-card={type.tipo}>
            <small>{type.singular}</small>
            <strong>{type.label}</strong>
            <p>{typeIntros[type.tipo] || 'Fichas editoriales del archivo motorsport.'}</p>
            <small>{type.count} ficha{type.count === 1 ? '' : 's'}</small>
          </a>
        ))}
      </div>
    </section>

    {featured && (
      <section class="gc-archive-shell gc-archive-section">
        <article class="gc-archive-spotlight">
          <div class="gc-archive-spotlight__copy">
            <span class="gc-archive-panel__eyebrow">Ficha destacada</span>
            <h2>{featured.nombre}</h2>
            <p>{getArchiveSummary(featured) || 'Entrada destacada de la base de datos motorsport.'}</p>

            <dl>
              <div>
                <dt>Ficha</dt>
                <dd>{singularArchiveType(featured.tipo)}</dd>
              </div>
              {getArchiveCountry(featured) && (
                <div>
                  <dt>Origen</dt>
                  <dd>{getArchiveCountry(featured)}</dd>
                </div>
              )}
              {getArchivePeriod(featured) && (
                <div>
                  <dt>Periodo</dt>
                  <dd>{getArchivePeriod(featured)}</dd>
                </div>
              )}
            </dl>

            <a href={archiveItemHref(featured)}>Abrir ficha</a>
          </div>

          {getArchiveImage(featured) ? (
            <figure>
              <img src={getArchiveImage(featured)} alt={featured.coverAlt || featured.imagen_alt || featured.nombre} loading="eager" />
            </figure>
          ) : (
            <div class="gc-archive-spotlight__mark">
              <span>{singularArchiveType(featured.tipo)}</span>
              <strong>{featured.nombre}</strong>
            </div>
          )}
        </article>
      </section>
    )}

    <section class="gc-archive-shell gc-archive-section gc-archive-section--panel" id="archivo-catalogo">
      <div class="gc-archive-section-head">
        <div>
          <span>Catálogo</span>
          <h2>Todas las fichas</h2>
        </div>
        <p>Explora la base de datos por categoría o busca por título, país, época, motor, equipo, trazado, piloto o concepto técnico.</p>
      </div>

      <div class="gc-archive-filter-row" aria-label="Filtros del archivo">
        <button type="button" class="is-active" data-archive-type="all">Todo</button>
        {types.map((type) => (
          <button type="button" data-archive-type={type.tipo}>{type.label}</button>
        ))}
      </div>

      {items.length ? (
        <div class="gc-archive-grid" data-archive-results>
          {items.map((item) => (
            <a
              class="gc-archive-card"
              href={archiveItemHref(item)}
              data-archive-card
              data-type={item.tipo}
              data-search={`${item.nombre} ${item.slug} ${item.tipo} ${prettifyArchiveType(item.tipo)} ${getArchiveSummary(item)} ${getArchiveCountry(item)} ${getArchivePeriod(item)} ${item.tags || ''} ${item.fabricante || ''} ${item.motor || ''} ${item.disciplina || ''}`}
            >
              {getArchiveImage(item) ? (
                <img src={getArchiveImage(item)} alt={item.coverAlt || item.imagen_alt || item.nombre} loading="lazy" />
              ) : (
                <span class="gc-archive-card__mark">{singularArchiveType(item.tipo)}</span>
              )}

              <div>
                <small>{prettifyArchiveType(item.tipo)}</small>
                <strong>{item.nombre}</strong>
                <p>{getArchiveSummary(item) || 'Ficha editorial de la base de datos motorsport.'}</p>
                <footer>
                  {getArchiveCountry(item) && <em>{getArchiveCountry(item)}</em>}
                  {getArchivePeriod(item) && <em>{getArchivePeriod(item)}</em>}
                  <b>Abrir</b>
                </footer>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="gc-archive-empty">
          <strong>Aún no hay fichas publicadas.</strong>
          <p>Cuando publiques fichas desde el admin aparecerán aquí automáticamente.</p>
        </div>
      )}

      <div class="gc-archive-empty" data-archive-empty hidden>
        <strong>No hay resultados.</strong>
        <p>Prueba con otro término o limpia los filtros.</p>
      </div>
    </section>
  </main>

  <script>
    const root = document.querySelector('[data-archive-home]');
    const input = root?.querySelector('[data-archive-search-input]');
    const clearBtn = root?.querySelector('[data-archive-clear]');
    const cards = [...root?.querySelectorAll('[data-archive-card]') || []];
    const count = root?.querySelector('[data-archive-result-count]');
    const empty = root?.querySelector('[data-archive-empty]');
    const typeButtons = [...root?.querySelectorAll('button[data-archive-type]') || []];

    let activeType = 'all';

    function normalize(value) {
      return String(value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    }

    function setActiveType(value) {
      activeType = value;
      typeButtons.forEach((button) => {
        const selected = button.dataset.archiveType === value;
        button.classList.toggle('is-active', selected);
        button.setAttribute('aria-pressed', selected ? 'true' : 'false');
      });
    }

    function applyFilters() {
      const query = normalize(input?.value || '');
      let visible = 0;

      cards.forEach((card) => {
        const typeOk = activeType === 'all' || card.dataset.type === activeType;
        const textOk = !query || normalize(card.dataset.search).includes(query);
        const show = typeOk && textOk;
        card.hidden = !show;
        if (show) visible += 1;
      });

      if (count) count.textContent = String(visible);
      if (empty) empty.hidden = visible !== 0;
    }

    typeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        setActiveType(button.dataset.archiveType || 'all');
        applyFilters();
      });
    });

    input?.addEventListener('input', applyFilters);

    clearBtn?.addEventListener('click', () => {
      if (input) input.value = '';
      setActiveType('all');
      applyFilters();
      input?.focus();
    });

    applyFilters();
  </script>
</MarketingLayout>

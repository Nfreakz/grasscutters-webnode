---
export const prerender = false;
import AppLayout from '../../layouts/AppLayout.astro';

const serverJoinUrl = 'https://acstuff.ru/s/q:race/online/join?httpPort=8381&ip=185.216.144.78';
const carsDriveUrl = 'https://drive.google.com/drive/folders/1BXJJkPOo7ZuhIKf_VegI5g8serZsJw7W?usp=drive_link';
const tracksDriveUrl = 'https://drive.google.com/drive/folders/1xSrI8aPBLH15wrytkR-IUjMQPWEVyfQw?usp=drive_link';
---
<AppLayout title="Combo | GrassCutters">
  <div class="gc-page gc-combo-detail-page gc-combo-detail-v7" data-combo-detail>
    <section class="gc-combo-hero-v7">
      <div class="gc-combo-hero-v7__main">
        <span class="gc-kicker">Ficha de combo</span>
        <h1 class="gc-title" id="comboTitle">Cargando combo...</h1>
        <p class="gc-subtitle" id="comboSubtitle">Ficha del circuito, paquete de coches permitido, mejores vueltas y actividad reciente.</p>

        <figure class="gc-combo-track-figure-v52" id="comboTrackFigure" hidden>
          <img id="comboTrackImage" src="" alt="" loading="lazy" />
        </figure>

        <div class="gc-combo-actions-v7" aria-label="Acciones del combo">
          <a class="gc-btn" href="/combos">Volver a combos</a>
          <a class="gc-btn" href="/hotlaps">Ver hotlaps</a>
          <a class="gc-btn gc-btn--primary" href={serverJoinUrl} target="_blank" rel="noreferrer">Unirse al servidor</a>
          <a class="gc-btn" href={carsDriveUrl} target="_blank" rel="noreferrer">Coches</a>
          <a class="gc-btn" href={tracksDriveUrl} target="_blank" rel="noreferrer">Circuito</a>
          <span class="gc-chip gc-chip--accent" id="comboKey">Combo lógico</span>
        </div>
      </div>

      <aside class="gc-combo-summary-v7 gc-combo-summary-v53" aria-label="Resumen del combo">
        <div class="gc-combo-summary-v7__title">
          <span>Resumen</span>
          <strong id="comboStatus">...</strong>
        </div>
        <div class="gc-combo-reference-v53">
          <span>Mejor referencia</span>
          <strong id="comboQuickBest">...</strong>
          <small id="comboQuickBestMeta">...</small>
        </div>
        <div class="gc-combo-summary-v7__grid">
          <div><span>Vueltas</span><strong id="comboLaps">...</strong></div>
          <div><span>Pilotos</span><strong id="comboDrivers">...</strong></div>
          <div><span>Coches</span><strong id="comboCars">...</strong></div>
        </div>
      </aside>
    </section>

    <section class="gc-combo-garage-panel-v54" aria-label="Garaje y referencia del combo">
      <div class="gc-combo-garage-head-v54">
        <div>
          <span class="gc-kicker">Paquete de coches</span>
          <h2 id="comboCarsTitle">...</h2>
          <p id="comboCarsSub">Referencia principal del combo.</p>
        </div>
        <div class="gc-combo-car-tags gc-combo-car-tags-v54" id="comboCarTags"></div>
      </div>

      <div class="gc-combo-garage-stats-v54">
        <article>
          <span>Mejor vuelta</span>
          <strong id="metricBest">...</strong>
          <small id="metricBestDriver">Piloto</small>
        </article>
        <article>
          <span>Velocidad máxima</span>
          <strong id="metricSpeed">...</strong>
          <small>Máxima registrada</small>
        </article>
        <article>
          <span>Media Top 10</span>
          <strong id="metricTop10">...</strong>
          <small>Vueltas válidas</small>
        </article>
        <article>
          <span>Última actividad</span>
          <strong id="metricRecent">...</strong>
          <small>Última vuelta registrada</small>
        </article>
      </div>
    </section>

    <section class="gc-section-block gc-combo-table-section-v7">
      <div class="gc-section-head">
        <div>
          <span class="gc-kicker">Leaderboard</span>
          <h2>Mejores pilotos del combo</h2>
        </div>
        <span class="gc-chip" id="comboLeaderboardCount">Cargando</span>
      </div>
      <div class="gc-table-wrap gc-combo-table-wrap-v7">
        <table class="gc-table">
          <thead>
            <tr><th>#</th><th>Piloto</th><th>Coche</th><th>Tiempo</th><th>Delta</th><th>Vmax</th><th>Cortes</th><th>Fecha</th></tr>
          </thead>
          <tbody id="leaderboardRows"><tr><td colspan="8">Cargando...</td></tr></tbody>
        </table>
      </div>
    </section>

    <section class="gc-section-block gc-combo-table-section-v7">
      <div class="gc-section-head">
        <div>
          <span class="gc-kicker">Actividad</span>
          <h2>Últimas vueltas</h2>
        </div>
        <span class="gc-chip" id="comboRecentCount">Cargando</span>
      </div>
      <div class="gc-table-wrap gc-combo-table-wrap-v7">
        <table class="gc-table">
          <thead>
            <tr><th>Piloto</th><th>Coche</th><th>Tiempo</th><th>Estado</th><th>Vmax</th><th>Cortes</th><th>Fecha</th></tr>
          </thead>
          <tbody id="recentRows"><tr><td colspan="7">Cargando...</td></tr></tbody>
        </table>
      </div>
    </section>
  </div>

  <style is:global>
    .gc-combo-detail-v7{
      display:grid;
      gap:clamp(18px,2.3vw,28px);
    }

    .gc-combo-hero-v7{
      display:grid;
      grid-template-columns:minmax(0,1fr) minmax(280px,360px);
      gap:clamp(16px,2vw,26px);
      align-items:start;
      padding:clamp(20px,3vw,34px) 0 clamp(18px,2.4vw,26px);
      border-bottom:1px solid var(--line);
    }

    .gc-combo-hero-v7 .gc-title{
      font-size:clamp(3rem,7vw,6.25rem);
      line-height:.86;
      letter-spacing:-.075em;
      margin:8px 0 12px;
    }

    .gc-combo-hero-v7 .gc-subtitle{
      max-width:920px;
      margin:0;
    }


    .gc-combo-track-figure-v52{
      margin:16px 0 0;
      border:1px solid var(--line);
      border-radius:20px;
      overflow:hidden;
      background:rgba(0,0,0,.2);
      box-shadow:0 18px 60px rgba(0,0,0,.18);
    }

    .gc-combo-track-figure-v52[hidden]{
      display:none;
    }

    .gc-combo-track-figure-v52 img{
      display:block;
      width:100%;
      aspect-ratio:16/6;
      object-fit:cover;
      opacity:.95;
      filter:saturate(1.04) contrast(1.03);
    }

    @media(min-width:981px){
      .gc-combo-summary-v53{
        margin-top:clamp(158px,13vw,212px);
      }
    }

    .gc-combo-garage-panel-v54{
      display:grid;
      gap:18px;
      padding:clamp(18px,2.2vw,26px);
      border:1px solid var(--line);
      border-top:2px solid var(--accent);
      background:
        radial-gradient(circle at 5% 0%,rgba(133,255,85,.085),transparent 26rem),
        linear-gradient(135deg,rgba(255,255,255,.052),rgba(255,255,255,.014));
      box-shadow:0 18px 70px rgba(0,0,0,.16);
    }

    .gc-combo-garage-head-v54{
      display:grid;
      grid-template-columns:minmax(250px,.58fr) minmax(0,1.42fr);
      gap:clamp(16px,2.2vw,28px);
      align-items:start;
    }

    .gc-combo-garage-head-v54 h2{
      margin:.28rem 0 .5rem;
      color:var(--text);
      font-size:clamp(2.1rem,4.4vw,4.7rem);
      line-height:.9;
      letter-spacing:-.065em;
      max-width:520px;
    }

    .gc-combo-garage-head-v54 p{
      margin:0;
      max-width:560px;
      color:var(--muted);
      line-height:1.48;
    }

    .gc-combo-car-tags-v54{
      justify-content:flex-end;
      align-content:flex-start;
      max-height:none;
      overflow:visible;
      padding:0;
    }

    .gc-combo-garage-stats-v54{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:0;
      border:1px solid color-mix(in srgb,var(--line) 82%,transparent);
      background:rgba(0,0,0,.12);
    }

    .gc-combo-garage-stats-v54 article{
      min-height:112px;
      display:grid;
      align-content:start;
      gap:9px;
      padding:15px;
      border-right:1px solid color-mix(in srgb,var(--line) 82%,transparent);
    }

    .gc-combo-garage-stats-v54 article:last-child{
      border-right:0;
    }

    .gc-combo-garage-stats-v54 span{
      color:var(--dim);
      text-transform:uppercase;
      letter-spacing:.105em;
      font-size:.7rem;
      font-weight:950;
    }

    .gc-combo-garage-stats-v54 strong{
      display:block;
      color:var(--text);
      font-size:clamp(1.55rem,2.55vw,2.35rem);
      line-height:.95;
      letter-spacing:-.04em;
    }

    .gc-combo-garage-stats-v54 small{
      color:var(--muted);
      line-height:1.35;
    }

    .gc-combo-package-note-v54{
      display:grid;
      gap:6px;
      margin-top:10px;
      padding-top:10px;
      border-top:1px solid color-mix(in srgb,var(--line) 70%,transparent);
    }

    .gc-combo-package-note-v54 span{
      color:var(--accent);
      font-size:.68rem;
      font-weight:950;
      letter-spacing:.09em;
      text-transform:uppercase;
    }

    .gc-combo-package-note-v54 strong{
      color:var(--text);
      font-size:.98rem;
      line-height:1.28;
    }

    .gc-combo-car-panel-v7 h2{
      font-size:clamp(2rem,4.4vw,4.6rem);
      line-height:.92;
      letter-spacing:-.06em;
    }

    .gc-combo-actions-v7{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-top:16px;
      align-items:center;
    }

    .gc-combo-actions-v7 .gc-btn,
    .gc-combo-actions-v7 .gc-chip{
      min-height:36px;
    }

    .gc-combo-summary-v7{
      align-self:start;
      display:grid;
      align-content:start;
      gap:14px;
      padding:16px;
      border:1px solid var(--line);
      border-top:2px solid var(--accent);
      background:linear-gradient(135deg,rgba(255,255,255,.05),rgba(255,255,255,.018));
      box-shadow:0 18px 70px rgba(0,0,0,.18);
    }

    .gc-combo-summary-v7__title{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding-bottom:12px;
      border-bottom:1px solid var(--line);
    }

    .gc-combo-summary-v7__title span,
    .gc-combo-summary-v7__grid span,
    .gc-combo-metrics-v7 span{
      color:var(--dim);
      text-transform:uppercase;
      letter-spacing:.105em;
      font-size:.7rem;
      font-weight:950;
    }

    .gc-combo-summary-v7__title strong{
      color:var(--accent);
      text-transform:uppercase;
      letter-spacing:.08em;
      font-size:.82rem;
    }

    .gc-combo-summary-v7__grid{
      display:grid;
      gap:8px;
    }

    .gc-combo-summary-v7__grid div{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      padding:10px 0;
      border-bottom:1px solid color-mix(in srgb,var(--line) 64%,transparent);
    }

    .gc-combo-summary-v7__grid div:last-child{
      border-bottom:0;
    }

    .gc-combo-summary-v7__grid strong{
      color:var(--text);
      font-size:1.15rem;
      line-height:1;
    }

    .gc-combo-overview-v7{
      display:grid;
      grid-template-columns:minmax(0,1fr) minmax(340px,.82fr);
      gap:clamp(14px,2vw,22px);
      align-items:stretch;
    }

    .gc-combo-car-panel-v7{
      min-width:0;
      display:grid;
      grid-template-columns:minmax(250px,.72fr) minmax(0,1.28fr);
      gap:clamp(14px,1.8vw,22px);
      align-items:start;
      padding:clamp(16px,2vw,22px);
      border:1px solid var(--line);
      background:linear-gradient(135deg,rgba(255,255,255,.045),rgba(255,255,255,.014));
    }

    .gc-combo-car-panel-v7 h2{
      margin:.25rem 0 .45rem;
      color:var(--text);
      font-size:clamp(1.8rem,3.2vw,3.1rem);
      line-height:1;
      letter-spacing:-.055em;
    }

    .gc-combo-car-panel-v7 p{
      margin:0;
      color:var(--muted);
      line-height:1.45;
    }

    .gc-combo-car-tags{
      display:flex;
      gap:.45rem;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-content:flex-start;
      max-height:132px;
      overflow:auto;
      padding-right:2px;
    }

    .gc-combo-car-tag{
      border:1px solid var(--line);
      padding:.42rem .62rem;
      color:var(--text);
      background:color-mix(in srgb,var(--surface),transparent 22%);
      font-size:.82rem;
      font-weight:850;
      line-height:1.1;
    }

    .gc-combo-metrics-v7{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:10px;
    }

    .gc-combo-metrics-v7 article{
      min-height:112px;
      display:grid;
      align-content:start;
      gap:10px;
      padding:14px;
      border:1px solid var(--line);
      background:linear-gradient(135deg,rgba(255,255,255,.05),rgba(255,255,255,.016));
    }

    .gc-combo-metrics-v7 strong{
      display:block;
      color:var(--text);
      font-size:clamp(1.55rem,2.7vw,2.4rem);
      line-height:.95;
      letter-spacing:-.04em;
    }

    .gc-combo-metrics-v7 small{
      color:var(--muted);
      line-height:1.35;
    }

    .gc-combo-table-section-v7{
      margin:0;
    }

    .gc-combo-table-section-v7 .gc-section-head{
      margin-bottom:12px;
    }

    .gc-combo-table-wrap-v7{
      max-height:520px;
      overflow:auto;
    }

    .gc-combo-table-wrap-v7 td,
    .gc-combo-table-wrap-v7 th{
      white-space:nowrap;
    }

    .gc-combo-table-wrap-v7 td:nth-child(2),
    .gc-combo-table-wrap-v7 td:nth-child(3){
      white-space:normal;
      min-width:180px;
    }

    .gc-driver-link{
      font-weight:950;
      color:var(--text);
    }

    .gc-driver-link:hover{
      color:var(--accent);
    }


    .gc-combo-summary-v53{
      align-self:start;
      align-content:start;
      min-height:auto;
    }

    .gc-combo-reference-v53{
      display:grid;
      gap:5px;
      padding:14px;
      border:1px solid color-mix(in srgb,var(--line) 78%,transparent);
      background:rgba(255,255,255,.026);
    }

    .gc-combo-reference-v53 span{
      color:var(--accent);
      text-transform:uppercase;
      letter-spacing:.1em;
      font-size:.68rem;
      font-weight:950;
    }

    .gc-combo-reference-v53 strong{
      color:var(--text);
      font-size:1.08rem;
      line-height:1.16;
      letter-spacing:-.02em;
    }

    .gc-combo-reference-v53 small{
      color:var(--muted);
      line-height:1.35;
    }

    .gc-combo-package-note-v53{
      display:grid;
      gap:6px;
      margin-top:10px;
      padding-top:10px;
      border-top:1px solid color-mix(in srgb,var(--line) 70%,transparent);
    }

    .gc-combo-package-note-v53 span{
      color:var(--accent);
      font-size:.68rem;
      font-weight:950;
      letter-spacing:.09em;
      text-transform:uppercase;
    }

    .gc-combo-package-note-v53 strong{
      color:var(--text);
      font-size:.96rem;
      line-height:1.28;
    }

    @media(max-width:1180px){
      .gc-combo-overview-v7{
        grid-template-columns:1fr;
      }

      .gc-combo-metrics-v7{
        grid-template-columns:repeat(4,minmax(0,1fr));
      }
    }

    @media(max-width:980px){
      .gc-combo-hero-v7{
        grid-template-columns:1fr;
      }

      .gc-combo-car-panel-v7,
      .gc-combo-garage-head-v54{
        grid-template-columns:1fr;
      }

      .gc-combo-car-tags,
      .gc-combo-car-tags-v54{
        justify-content:flex-start;
      }

      .gc-combo-metrics-v7,
      .gc-combo-garage-stats-v54{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }

      .gc-combo-garage-stats-v54 article:nth-child(2){
        border-right:0;
      }

      .gc-combo-garage-stats-v54 article:nth-child(1),
      .gc-combo-garage-stats-v54 article:nth-child(2){
        border-bottom:1px solid color-mix(in srgb,var(--line) 82%,transparent);
      }
    }

    @media(max-width:640px){
      .gc-combo-metrics-v7,
      .gc-combo-garage-stats-v54{
        grid-template-columns:1fr;
      }

      .gc-combo-garage-stats-v54 article{
        border-right:0;
        border-bottom:1px solid color-mix(in srgb,var(--line) 82%,transparent);
      }

      .gc-combo-garage-stats-v54 article:last-child{
        border-bottom:0;
      }

      .gc-combo-actions-v7 .gc-btn,
      .gc-combo-actions-v7 .gc-chip{
        width:100%;
        justify-content:center;
      }

      .gc-combo-table-wrap-v7{
        max-height:none;
      }
    }
  
/* GC_COMBO_DETAIL_VISUAL_POLISH_V55_START */
    .gc-combo-detail-v7{
      width:100%;
      max-width:1480px;
      margin-inline:auto;
      padding-inline:clamp(8px,1.2vw,18px);
      box-sizing:border-box;
    }

    .gc-combo-hero-v7{
      position:relative;
      overflow:hidden;
      align-items:center;
      margin:0;
      padding:clamp(26px,3.4vw,40px)!important;
      border:1px solid color-mix(in srgb,var(--accent,#9dff00) 30%,var(--line));
      border-radius:28px;
      background:
        linear-gradient(120deg,rgba(255,255,255,.07),rgba(255,255,255,.018)),
        radial-gradient(circle at 82% 12%, color-mix(in srgb,var(--accent2,#35d3ff) 10%,transparent), transparent 22rem),
        radial-gradient(circle at 8% 18%, color-mix(in srgb,var(--accent,#9dff00) 12%,transparent), transparent 20rem);
      box-shadow:0 18px 70px rgba(0,0,0,.20), inset 0 0 0 1px rgba(255,255,255,.035);
    }

    .gc-combo-hero-v7::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background:
        linear-gradient(90deg,rgba(255,255,255,.045) 1px,transparent 1px),
        linear-gradient(0deg,rgba(255,255,255,.026) 1px,transparent 1px);
      background-size:42px 42px;
      opacity:.28;
      mask-image:linear-gradient(90deg,rgba(0,0,0,.48),transparent 72%);
    }

    .gc-combo-hero-v7 > *{
      position:relative;
      z-index:1;
    }

    .gc-combo-hero-v7 .gc-title{
      text-transform:uppercase;
      font-size:clamp(3.2rem,7vw,6.4rem);
      line-height:.86;
      letter-spacing:-.08em;
      margin:8px 0 12px;
    }

    .gc-combo-track-figure-v52{
      margin:16px 0 0;
      border-radius:22px;
      border:1px solid rgba(255,255,255,.1);
      box-shadow:0 20px 70px rgba(0,0,0,.24);
    }

    .gc-combo-track-figure-v52 img{
      aspect-ratio:16/6;
      opacity:.98;
      filter:saturate(1.02) contrast(1.04);
    }

    @media(min-width:981px){
      .gc-combo-summary-v53{
        margin-top:clamp(112px,10vw,168px);
      }
    }

    .gc-combo-summary-v7{
      padding:0;
      overflow:hidden;
      border:1px solid color-mix(in srgb,var(--accent,#9dff00) 18%,var(--line));
      border-top:2px solid var(--accent);
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb,var(--accent,#9dff00) 16%,transparent), transparent 10rem),
        rgba(0,0,0,.18);
      box-shadow:inset 0 0 0 1px rgba(255,255,255,.035);
    }

    .gc-combo-summary-v7__title{
      padding:14px 16px;
      border-bottom:1px solid rgba(255,255,255,.08);
      background:rgba(0,0,0,.14);
    }

    .gc-combo-reference-v53{
      border-width:0 0 1px;
      padding:14px 16px;
      background:rgba(0,0,0,.08);
    }

    .gc-combo-summary-v7__grid{
      gap:0;
    }

    .gc-combo-summary-v7__grid div{
      padding:13px 16px;
      border-bottom:1px solid rgba(255,255,255,.08);
      background:rgba(0,0,0,.08);
    }

    .gc-combo-summary-v7__grid div:last-child{
      border-bottom:0;
    }

    .gc-combo-garage-panel-v54{
      border-radius:28px;
      border:1px solid rgba(255,255,255,.08);
      border-top:2px solid var(--accent);
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb,var(--accent,#9dff00) 7%,transparent), transparent 16rem),
        linear-gradient(135deg,rgba(255,255,255,.045),rgba(255,255,255,.014));
      box-shadow:0 18px 70px rgba(0,0,0,.16);
    }

    .gc-combo-garage-stats-v54{
      border:1px solid color-mix(in srgb,var(--accent,#9dff00) 18%,var(--line));
      border-radius:0;
      overflow:hidden;
      background:rgba(255,255,255,.018);
    }

    .gc-combo-garage-stats-v54 article{

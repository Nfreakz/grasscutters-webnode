  </style>

  <script is:inline src="/js/gc-track-images.js"></script>
  <script>
    const escapeHtml = (value) => String(value ?? '-').replace(/[&<>'"]/g, (char) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[char]));
    const fmtSpeed = (value) => Number.isFinite(Number(value)) && Number(value) > 0 ? `${Math.round(Number(value))} km/h` : '--';
    const fmtNumber = (value) => Math.max(0, Math.round(Number(value) || 0)).toLocaleString('es-ES');
    const fmtDate = (value) => {
      if (value === undefined || value === null || value === '') return '--';

      let ms = 0;

      if (typeof value === 'number') {
        ms = value > 20000000000 ? value : value * 1000;
      } else {
        const raw = String(value).trim();

        if (/^\d+$/.test(raw)) {
          const numberValue = Number(raw);
          ms = numberValue > 20000000000 ? numberValue : numberValue * 1000;
        } else {
          ms = new Date(raw).getTime();

          if (!Number.isFinite(ms)) {
            ms = new Date(raw.replace(' ', 'T')).getTime();
          }

          if (!Number.isFinite(ms)) {
            const slash = raw.match(/^(\d{1,2})[\/-](\d{1,2})[\/-](\d{2,4})(?:[,\s]+(\d{1,2}):(\d{2}))?/);
            if (slash) {
              const day = Number(slash[1]);
              const month = Number(slash[2]) - 1;
              const yearRaw = Number(slash[3]);
              const year = yearRaw < 100 ? 2000 + yearRaw : yearRaw;
              const hour = Number(slash[4] || 0);
              const minute = Number(slash[5] || 0);
              ms = new Date(year, month, day, hour, minute).getTime();
            }
          }
        }
      }

      if (!Number.isFinite(ms) || ms <= 0) return '--';

      return new Date(ms).toLocaleString('es-ES', {
        day:'2-digit',
        month:'2-digit',
        hour:'2-digit',
        minute:'2-digit'
      });
    };

    const els = {
      title: document.getElementById('comboTitle'),
      subtitle: document.getElementById('comboSubtitle'),
      key: document.getElementById('comboKey'),
      status: document.getElementById('comboStatus'),
      laps: document.getElementById('comboLaps'),
      drivers: document.getElementById('comboDrivers'),
      cars: document.getElementById('comboCars'),
      quickBest: document.getElementById('comboQuickBest'),
      quickBestMeta: document.getElementById('comboQuickBestMeta'),
      carsTitle: document.getElementById('comboCarsTitle'),
      carsSub: document.getElementById('comboCarsSub'),
      carTags: document.getElementById('comboCarTags'),
      best: document.getElementById('metricBest'),
      bestDriver: document.getElementById('metricBestDriver'),
      speed: document.getElementById('metricSpeed'),
      top10: document.getElementById('metricTop10'),
      recent: document.getElementById('metricRecent'),
      leaderboard: document.getElementById('leaderboardRows'),
      recentRows: document.getElementById('recentRows'),
      leaderboardCount: document.getElementById('comboLeaderboardCount'),
      recentCount: document.getElementById('comboRecentCount'),
      trackFigure: document.getElementById('comboTrackFigure'),
      trackImage: document.getElementById('comboTrackImage')
    };

    function pathComboId() {
      const parts = window.location.pathname.split('/').filter(Boolean);
      return parts[1];
    }

    function lapStatus(row) {
      return row.valid === false || row.isValid === false
        ? '<span class="gc-chip gc-chip--danger">No válida</span>'
        : '<span class="gc-chip gc-chip--accent">Válida</span>';
    }

    function renderDriver(row) {
      const id = row.playerId || row.driverId;
      const driver = escapeHtml(row.driverName || row.playerName || '-');
      return id ? `<a class="gc-driver-link" href="/pilotos/${encodeURIComponent(id)}">${driver}</a>` : driver;
    }


    function cleanTrackText(value) {
      if (value === undefined || value === null) return '';
      if (typeof value === 'string' || typeof value === 'number') {
        const text = String(value).trim();
        return text === '[object Object]' ? '' : text;
      }
      if (typeof value === 'object') {
        return cleanTrackText(value.name || value.Name || value.trackName || value.TrackName || value.track || value.Track || value.id || value.ID || '');
      }
      return '';
    }

    function renderTrackImage(trackName) {
      const clean = cleanTrackText(trackName);
      const candidates = window.GCTrackImages?.candidates
        ? window.GCTrackImages.candidates(clean).filter((url) => !url.includes('object_object'))
        : [`/images/tracks/${clean.toLowerCase().replace(/[^a-z0-9]+/g, '_')}.webp`, `/images/tracks/${clean.toLowerCase().replace(/[^a-z0-9]+/g, '_')}.jpg`];

      if (!clean || !candidates.length || !els.trackImage || !els.trackFigure) {
        if (els.trackFigure) els.trackFigure.hidden = true;
        return;
      }

      els.trackFigure.hidden = false;
      els.trackImage.style.display = '';
      els.trackImage.alt = clean;
      els.trackImage.dataset.fallbacks = candidates.slice(1).join('|');
      els.trackImage.dataset.fallbackIndex = '0';
      els.trackImage.onerror = function () {
        const list = (this.dataset.fallbacks || '').split('|').filter(Boolean);
        const index = Number(this.dataset.fallbackIndex || 0);
        if (list[index]) {
          this.dataset.fallbackIndex = String(index + 1);
          this.src = list[index];
          return;
        }
        this.closest('figure')?.setAttribute('hidden', '');
        this.style.display = 'none';
      };
      els.trackImage.src = candidates[0];
    }

    function cleanCarName(car) {
      if (!car) return '';
      if (typeof car === 'string') return car;
      return car.name || car.Name || car.code || car.Code || car.model || car.Model || '';
    }

    function bestLapCarName(summary, leaderboard) {
      const best = summary.bestLap || {};
      return best.carName || best.car?.name || best.car || best.carModel || best.model || leaderboard?.[0]?.carName || leaderboard?.[0]?.car?.name || '';
    }

    function renderCarTags(cars) {
      if (!cars.length) return '<span class="gc-combo-car-tag">Sin coches</span>';
      return cars.map((car) => `<span class="gc-combo-car-tag">${escapeHtml(cleanCarName(car) || '-')}</span>`).join('');
    }

    function carPackageCountLine(cars, summary) {
      const count = cars.length || summary.usedCarsCount || 0;
      return `${count} ${count === 1 ? 'coche permitido' : 'coches permitidos'}`;
    }

    async function load() {
      const comboId = pathComboId();

      try {
        const response = await fetch(`/api/combos/${encodeURIComponent(comboId)}`, { credentials:'same-origin', cache:'no-store' });
        const data = await response.json();
        if (!data.ok || !data.item) throw new Error(data.message || 'Combo no encontrado');

        const item = data.item;
        const summary = item.summary || {};
        const track = item.track || summary.track || {};
        const cars = Array.isArray(item.cars || summary.cars) ? (item.cars || summary.cars) : [];
        const carSummary = item.carSummary || summary.carSummary || 'Sin coches detectados';
        const memberIds = Array.isArray(item.memberComboIds) ? item.memberComboIds : [];
        const memberCount = memberIds.length || 1;
        const idText = memberCount > 1 ? `Familia ${item.comboId} · IDs ${memberIds.join(', ')}` : `Combo ID ${item.comboId}`;
        const leaderboard = Array.isArray(item.leaderboard) ? item.leaderboard : [];
        const recentLaps = Array.isArray(item.recentLaps) ? item.recentLaps : [];

        const trackName = cleanTrackText(track.name || track.id || track || summary.track || item.trackName || item.trackId) || 'Circuito';
        const fastestDriver = summary.bestLap?.driverName || summary.bestLap?.playerName || leaderboard[0]?.driverName || leaderboard[0]?.playerName || '';
        const fastestCar = bestLapCarName(summary, leaderboard);
        const fastestTime = summary.bestLapTime || summary.bestLap?.lapTime || leaderboard[0]?.lapTime || '--';

        els.title.textContent = trackName;
        els.subtitle.textContent = `${cars.length || summary.usedCarsCount || 0} coches - ${summary.totalLaps || 0} vueltas - mejor referencia: ${fastestDriver || 'sin piloto'}${fastestCar ? ` - ${fastestCar}` : ''} - ${fastestTime}`;
        renderTrackImage(trackName);

        els.key.textContent = memberCount > 1 ? `Familia ${item.comboId}` : `Combo ${item.comboId}`;
        els.status.textContent = memberCount > 1 ? 'Agrupado' : 'Activo';
        if (els.quickBest) els.quickBest.textContent = `${fastestDriver || 'Sin piloto'} - ${fastestTime}`;
        if (els.quickBestMeta) els.quickBestMeta.textContent = fastestCar || 'Coche sin identificar';

        els.laps.textContent = fmtNumber(summary.totalLaps || 0);
        els.drivers.textContent = fmtNumber(summary.driversCount || 0);
        els.cars.textContent = fmtNumber(cars.length || summary.usedCarsCount || 0);

        els.carsTitle.textContent = carPackageCountLine(cars, summary);
        els.carsSub.innerHTML = `<span class="gc-combo-package-note-v54"><span>Mejor referencia</span><strong>${escapeHtml(fastestDriver || 'Sin piloto')}${fastestCar ? ` · ${escapeHtml(fastestCar)}` : ''} · ${escapeHtml(fastestTime)}</strong></span>`;
        els.carTags.innerHTML = renderCarTags(cars);

        els.best.textContent = summary.bestLapTime || summary.bestLap?.lapTime || '--';
        els.bestDriver.textContent = summary.bestLap?.driverName || summary.bestLap?.playerName || 'Sin piloto';
        els.speed.textContent = fmtSpeed(summary.maxSpeedKmh);
        els.top10.textContent = summary.best10Average || '--';
        els.recent.textContent = fmtDate(summary.lastSeenAt || summary.lastActivityAt || summary.latestLapAt || summary.lastLapAt || item.lastActivityAt || item.updatedAt || recentLaps[0]?.timestampIso);

        els.leaderboardCount.textContent = `${leaderboard.length} pilotos`;
        els.recentCount.textContent = `${recentLaps.length} vueltas`;

        els.leaderboard.innerHTML = leaderboard.map((row) => {
          return `<tr><td>${escapeHtml(row.position)}</td><td>${renderDriver(row)}</td><td>${escapeHtml(row.carName || row.car?.name || '-')}</td><td><strong>${escapeHtml(row.lapTime || '--')}</strong></td><td>${escapeHtml(row.delta || '--')}</td><td>${escapeHtml(fmtSpeed(row.maxSpeedKmh))}</td><td>${escapeHtml(row.cuts || 0)}</td><td>${escapeHtml(fmtDate(row.timestampIso))}</td></tr>`;
        }).join('') || '<tr><td colspan="8">Sin leaderboard para este combo.</td></tr>';

        els.recentRows.innerHTML = recentLaps.map((row) => {
          return `<tr><td>${renderDriver(row)}</td><td>${escapeHtml(row.carName || row.car?.name || '-')}</td><td><strong>${escapeHtml(row.lapTime || '--')}</strong></td><td>${lapStatus(row)}</td><td>${escapeHtml(fmtSpeed(row.maxSpeedKmh))}</td><td>${escapeHtml(row.cuts || 0)}</td><td>${escapeHtml(fmtDate(row.timestampIso))}</td></tr>`;
        }).join('') || '<tr><td colspan="7">Sin vueltas recientes.</td></tr>';

        console.info('[GC combo detail layout v5.4]', {
          comboId: item.comboId,
          memberCount,
          cars: cars.length,
          leaderboard: leaderboard.length,
          recentLaps: recentLaps.length
        });
      } catch (error) {
        els.title.textContent = 'Combo no disponible';
        els.subtitle.textContent = 'No se pudo cargar la ficha del combo. Vuelve a intentarlo en unos segundos.';
        els.status.textContent = 'Error';
        els.leaderboardCount.textContent = 'Error';
        els.recentCount.textContent = 'Error';
        els.leaderboard.innerHTML = '<tr><td colspan="8">No se pudo cargar el combo.</td></tr>';
        els.recentRows.innerHTML = '<tr><td colspan="7">No se pudo cargar actividad reciente.</td></tr>';
        console.warn('[GC combo detail layout v5.4] Error', error);
      }
    }

    load();
  </script>
</AppLayout>

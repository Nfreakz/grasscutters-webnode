      background:color-mix(in srgb,var(--accent) 10%,transparent);
    }

    .gc-pilot-status-pill-v20.is-invalid{
      color:var(--danger,#ff5d73);
      border-color:color-mix(in srgb,var(--danger,#ff5d73) 40%,transparent);
      background:rgba(255,93,115,.08);
    }

    .gc-pilot-empty-v20{
      color:var(--muted);
      padding:16px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.018);
    }

    @media(max-width:1180px){
      .gc-pilot-top-grid-v20,
      .gc-pilot-grid-2-v20{
        grid-template-columns:1fr;
      }
    }

    @media(max-width:900px){
      .gc-pilot-hero-v20{
        grid-template-columns:1fr;
      }

      .gc-pilot-table-wrap-v20{
        max-height:none;
      }
    }

    @media(max-width:640px){
      .gc-pilot-actions-v20 .gc-btn{
        width:100%;
      }

      .gc-pilot-identity-v20__title,
      .gc-pilot-identity-v20__row,
      .gc-pilot-list-row-v20{
        grid-template-columns:1fr;
      }

      .gc-pilot-list-value-v20{
        justify-self:start;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-pilot-page]');
      if (!root) return;

      const playerId = root.dataset.playerId || '';

      const statusEl = document.getElementById('pilotStatus');
      const contentEl = document.getElementById('pilotContent');
      const titleEl = document.getElementById('pilotTitle');
      const subtitleEl = document.getElementById('pilotSubtitle');
      const guidEl = document.getElementById('pilotGuidValue');
      const metricsEl = document.getElementById('pilotMetrics');
      const combosBody = document.getElementById('combosBody');
      const recentBody = document.getElementById('recentBody');
      const garageRows = document.getElementById('garageRows');
      const trackRows = document.getElementById('trackRows');
      const combosCountEl = document.getElementById('pilotCombosCount');
      const recentCountEl = document.getElementById('pilotRecentCount');
      const garageCountEl = document.getElementById('pilotGarageCount');
      const tracksCountEl = document.getElementById('pilotTracksCount');

      const escapeHtml = (input) => String(input ?? '').replace(/[&<>'"]/g, (char) => ({
        '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#039;'
      }[char]));

      const valueAt = (source, path) => {
        if (!source || typeof source !== 'object') return undefined;
        if (Object.prototype.hasOwnProperty.call(source, path)) return source[path];
        return String(path).split('.').reduce((acc, part) => acc == null ? undefined : acc[part], source);
      };

      const firstValue = (...items) => {
        for (const item of items) {
          if (item !== undefined && item !== null && item !== '') return item;
        }
        return null;
      };

      const firstPath = (source, paths) => {
        for (const path of paths) {
          const value = valueAt(source, path);
          if (value !== undefined && value !== null && value !== '') return value;
        }
        return '';
      };

      const cleanName = (value, fallback = '--') => {
        if (value === undefined || value === null || value === '') return fallback;
        if (Array.isArray(value)) return value.length ? cleanName(value[0], fallback) : fallback;
        if (typeof value === 'object') {
          return cleanName(
            value.displayName ??
            value.visibleName ??
            value.cleanName ??
            value.display_name ??
            value.uiName ??
            value.uiCarName ??
            value.uiTrackName ??
            value.name ??
            value.Name ??
            value.driverName ??
            value.playerName ??
            value.code,
            fallback
          );
        }
        return String(value).replace(/_/g,' ').replace(/\s+/g,' ').trim() || fallback;
      };

      const arr = (...items) => {
        for (const item of items) if (Array.isArray(item)) return item;
        return [];
      };

      const fmt = (input, fallback = '--') => firstValue(input) ?? fallback;

      const fmtNumber = (input, fallback = '--') => {
        const n = Number(input);
        return Number.isFinite(n) ? n.toLocaleString('es-ES') : fallback;
      };

      const fmtPercent = (input) => {
        const n = Number(input);
        return Number.isFinite(n) ? `${n.toFixed(1)}%` : '--';
      };

      const fmtSpeed = (input) => {
        const n = Number(input);
        return Number.isFinite(n) && n > 0 ? `${Math.round(n)} km/h` : '--';
      };

      const fmtDate = (input) => {
        const raw = firstValue(input);
        if (!raw) return '--';
        const date = new Date(raw);
        if (Number.isNaN(date.getTime())) return '--';
        return date.toLocaleString('es-ES', { dateStyle:'short', timeStyle:'short' });
      };

      const lapTime = (row) => fmt(firstValue(row?.lapTimeFormatted, row?.lapTime, row?.bestLapTimeFormatted, row?.bestLap, row?.bestTime));
      const carName = (row) => cleanName(firstPath(row, ['carDisplayName','carVisibleName','carName','car.displayName','car.visibleName','car.cleanName','uiCarName','car.uiName','car.uiCarName','car.name','carCode','car']));
      const trackName = (row) => cleanName(firstPath(row, ['trackDisplayName','trackVisibleName','trackName','track.displayName','track.visibleName','track.cleanName','uiTrackName','track.uiName','track.uiTrackName','track.name','trackCode','track']));
      const pilotName = (pilot, data) => cleanName(firstPath(pilot, ['displayName','visibleName','cleanName','name','driverName','playerName']) || data?.pilotLink?.strackerName || `Piloto #${playerId}`);
      const isValid = (row) => row?.valid === true || row?.isValid === true || row?.valid === 1 || row?.Valid === 1;

      const showStatus = (html, bad = false) => {
        statusEl.innerHTML = html;
        statusEl.style.borderColor = bad ? 'var(--danger, #ff5d73)' : '';
      };

      function renderMetrics(data) {
        const s = data.summary || {};
        const best = firstValue(s.bestLap, data.bestLap);
        const rank = firstValue(s.bestRank, data.bestRank, s.ranking, data.ranking);
        const rankValue = typeof rank === 'object' ? firstValue(rank.position, rank.rank, rank.globalRank) : rank;
        const vmax = firstValue(s.maxSpeedKmh, s.maxSpeed, best?.maxSpeedKmh, data.maxSpeedKmh);

        const metrics = [
          ['Mejor vuelta', best ? lapTime(best) : '--', 'referencia'],
          ['Ranking global', rankValue ? `#${rankValue}` : '--', 'posición'],
          ['Vueltas válidas', fmtNumber(s.validLaps), 'limpias'],
          ['Limpieza', fmtPercent(s.validityRate), 'ratio'],
          ['Coches', fmtNumber(s.carsCount), 'garaje'],
          ['Circuitos', fmtNumber(s.tracksCount), 'pistas'],
          ['Combos', fmtNumber(s.combosCount), 'detectados'],
          ['Vmax', fmtSpeed(vmax), 'máxima']
        ];

        metricsEl.innerHTML = metrics.map(([label, value, sub]) => `
          <div class="gc-metric">
            <span>${escapeHtml(label)}</span>
            <strong>${escapeHtml(value)}</strong>
            <small>${escapeHtml(sub)}</small>
          </div>
        `).join('');
      }

      function renderCombos(data) {
        const rows = arr(data.bestCombos, data.combos, data.summary?.bestCombos, data.summary?.combos);
        combosCountEl.textContent = `${rows.length} combos`;

        combosBody.innerHTML = rows.length
          ? rows.slice(0,12).map((row) => `
            <tr>
              <td>${escapeHtml(trackName(row))}</td>
              <td>${escapeHtml(carName(row))}</td>
              <td><strong>${escapeHtml(lapTime(row))}</strong></td>
              <td>${escapeHtml(fmtNumber(firstValue(row.totalLaps,row.laps,row.lapCount)))}</td>
              <td>${escapeHtml(fmtNumber(firstValue(row.validLaps,row.cleanLaps)))}</td>
              <td>${escapeHtml(fmtDate(firstValue(row.latestAt,row.lastSeenAt,row.timestampIso,row.lastLapAt)))}</td>
            </tr>
          `).join('')
          : '<tr><td colspan="6"><div class="gc-pilot-empty-v20">Sin combos suficientes todavía.</div></td></tr>';
      }

      function renderRecent(data) {
        const rows = arr(data.latestLaps, data.recentLaps, data.summary?.latestLaps, data.summary?.recentLaps);
        recentCountEl.textContent = `${rows.length} vueltas`;

        recentBody.innerHTML = rows.length
          ? rows.slice(0,20).map((row) => `
            <tr>
              <td>${escapeHtml(fmtDate(firstValue(row.timestampIso,row.date,row.createdAt)))}</td>
              <td>${escapeHtml(trackName(row))}</td>
              <td>${escapeHtml(carName(row))}</td>
              <td><strong>${escapeHtml(lapTime(row))}</strong></td>
              <td><span class="gc-pilot-status-pill-v20 ${isValid(row) ? 'is-valid' : 'is-invalid'}">${isValid(row) ? 'Válida' : 'No válida'}</span></td>
              <td>${escapeHtml(fmtSpeed(row.maxSpeedKmh))}</td>
            </tr>
          `).join('')
          : '<tr><td colspan="6"><div class="gc-pilot-empty-v20">No hay vueltas recientes para mostrar.</div></td></tr>';
      }

      function renderList(container, countEl, rows, config) {
        countEl.textContent = `${rows.length}`;
        if (!rows.length) {
          container.innerHTML = '<div class="gc-pilot-empty-v20">Sin datos disponibles.</div>';
          return;
        }

        container.innerHTML = rows.slice(0,12).map((row,index) => `
          <div class="gc-pilot-list-row-v20">
            <div class="gc-pilot-list-index-v20">${index + 1}</div>
            <div>
              <span class="gc-pilot-list-title-v20">${escapeHtml(config.title(row))}</span>
              <span class="gc-pilot-list-meta-v20">${escapeHtml(config.meta(row))}</span>
            </div>
            <strong class="gc-pilot-list-value-v20">${escapeHtml(config.value(row))}</strong>
          </div>
        `).join('');
      }

      function renderGarage(data) {
        const rows = arr(data.garage, data.cars, data.summary?.garage, data.summary?.cars);
        renderList(garageRows, garageCountEl, rows, {
          title: (row) => carName(row),
          meta: (row) => `${fmtNumber(firstValue(row.totalLaps,row.laps,row.lapCount))} vueltas · ${fmtNumber(firstValue(row.tracksCount,row.trackCount))} circuitos`,
          value: (row) => lapTime(row)
        });
      }

      function renderTracks(data) {
        const rows = arr(data.tracks, data.circuits, data.summary?.tracks, data.summary?.circuits);
        renderList(trackRows, tracksCountEl, rows, {
          title: (row) => trackName(row),
          meta: (row) => `${fmtNumber(firstValue(row.totalLaps,row.laps,row.lapCount))} vueltas · ${fmtNumber(firstValue(row.carsCount,row.carCount))} coches`,
          value: (row) => lapTime(row)
        });
      }

      function render(data) {
        const pilot = firstValue(data.pilot, data.driver) || {};
        const summary = data.summary || {};
        const name = pilotName(pilot, data);
        const guid = firstValue(pilot.steamGuid, pilot.guid, data.pilotLink?.steamGuid);
        const latest = firstValue(summary.latestLap, data.latestLap);

        titleEl.textContent = name;
        subtitleEl.textContent = latest
          ? `Última actividad: ${fmtDate(latest.timestampIso)} · datos generados desde stracker.db3.`
          : `Ficha pública del piloto #${playerId}. Datos generados desde stracker.db3.`;

        guidEl.textContent = guid ? `${String(guid).slice(0,18)}...${String(guid).slice(-8)}` : '--';
        guidEl.title = guid || '';

        renderMetrics(data);
        renderCombos(data);
        renderGarage(data);
        renderTracks(data);
        renderRecent(data);

        statusEl.classList.add('is-hidden');
        contentEl.classList.remove('is-hidden');

        console.info('[GC pilot detail v2.0]', {
          playerId,
          combos: arr(data.bestCombos, data.combos, data.summary?.bestCombos, data.summary?.combos).length,
          recent: arr(data.latestLaps, data.recentLaps, data.summary?.latestLaps, data.summary?.recentLaps).length
        });
      }

      async function load() {
        if (!playerId || !/^\d+$/.test(playerId)) {
          showStatus(`<strong>Player ID no válido</strong><p>${escapeHtml(playerId)}</p>`, true);
          return;
        }

        try {
          const response = await fetch(`/api/pilots/${encodeURIComponent(playerId)}/profile`, {
            credentials:'include',
            cache:'no-store'
          });
          const data = await response.json();

          if (!response.ok || !data?.ok) {
            showStatus(`<strong>No se pudo cargar la ficha</strong><p>${escapeHtml(data?.message || response.statusText)}</p>`, true);
            return;
          }

          render(data);
        } catch (error) {
          showStatus(`<strong>Error cargando la ficha pública</strong><p>${escapeHtml(error?.message || error)}</p>`, true);
          console.warn('[GC pilot detail v2.0] Error', error);
        }
      }

      load();
    })();
  </script>
</AppLayout>

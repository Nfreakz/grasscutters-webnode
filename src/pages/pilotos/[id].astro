    }

    .gc-pilot-content-v20{
      display:grid;
      gap:clamp(18px,2.3vw,28px);
    }

    .gc-pilot-metrics-v20{
      margin:0;
    }

    .gc-pilot-top-grid-v20{
      display:grid;
      grid-template-columns:minmax(0,1fr) minmax(0,1fr);
      gap:clamp(16px,2vw,24px);

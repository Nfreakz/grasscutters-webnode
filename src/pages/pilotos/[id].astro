        <article class="gc-section gc-pilot-section-v20">
          <div class="gc-section-head">
            <div>
              <span class="gc-kicker">Últimas vueltas</span>
              <h2>Actividad reciente</h2>
            </div>
            <span class="gc-chip" id="pilotRecentCount">Cargando</span>
          </div>

          <div class="gc-table-wrap gc-pilot-table-wrap-v20">
            <table class="gc-table gc-pilot-table-v20">
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Circuito</th>

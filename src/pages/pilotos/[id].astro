    }

    .gc-pilot-grid-2-v20{
      display:grid;
      grid-template-columns:minmax(0,1fr) minmax(0,1fr);
      gap:clamp(16px,2vw,24px);
      align-items:start;
    }

    .gc-pilot-section-v20{
      margin:0;
      min-width:0;
    }

    .gc-pilot-section-v20 .gc-section-head{

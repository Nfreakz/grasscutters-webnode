    }

    .gc-pilot-list-row-v20{
      display:grid;
      grid-template-columns:38px minmax(0,1fr) auto;
      gap:12px;
      align-items:center;
      padding:12px;
      border:1px solid var(--line);
      border-radius:14px;
      background:linear-gradient(135deg,rgba(255,255,255,.04),rgba(255,255,255,.014));
    }

    .gc-pilot-list-index-v20{
      width:32px;
      height:32px;
      display:grid;
      place-items:center;
      border:1px solid var(--line);
      color:var(--soft);
      font-weight:950;
      background:rgba(255,255,255,.025);
    }

    .gc-pilot-list-title-v20{

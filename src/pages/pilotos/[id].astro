      color:var(--text);
      font-weight:950;
      line-height:1.15;
      overflow-wrap:anywhere;
    }

    .gc-pilot-list-meta-v20{
      display:block;
      margin-top:4px;
      color:var(--muted);
      font-size:.72rem;
      text-transform:uppercase;
      letter-spacing:.08em;
    }

    .gc-pilot-list-value-v20{
      color:var(--accent);
      font-weight:950;
      white-space:nowrap;
    }

    .gc-pilot-status-pill-v20{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:28px;
      padding:0 9px;
      border:1px solid var(--line);
      color:var(--soft);
      font-size:.68rem;
      font-weight:950;
      text-transform:uppercase;
      letter-spacing:.08em;
      white-space:nowrap;

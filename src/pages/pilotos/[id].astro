    <section id="pilotContent" class="gc-pilot-content-v20 is-hidden" aria-live="polite">
      <section class="gc-metrics gc-pilot-metrics-v20" id="pilotMetrics"></section>

      <section class="gc-pilot-top-grid-v20">
        <article class="gc-section gc-pilot-section-v20">
          <div class="gc-section-head">
            <div>
              <span class="gc-kicker">Mejores combos</span>

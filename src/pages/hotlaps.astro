---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="Hotlaps | GrassCutters">
  <div class="gc-page gc-hotlaps-page">
    <section class="gc-hero gc-hero--compact">
      <div>
        <span class="gc-kicker">Leaderboard</span>
        <h1 class="gc-title">Hotlaps reales de stracker.</h1>
        <p class="gc-subtitle">Tabla pro con nombres corregidos, piloto, coche, circuito, tiempo, delta, Vmax, cortes y fecha.</p>
        <div class="gc-hero__meta">
          <span class="gc-chip gc-chip--accent">Nombres corregidos</span>
          <span class="gc-chip">Fuente: stracker.db3</span>
          <span class="gc-chip">Perfil público enlazado</span>
        </div>
      </div>
      <aside class="gc-live-panel">
        <div class="gc-live-panel__title"><span>Leaderboard</span><strong id="hotlapSource">...</strong></div>
        <div class="gc-status-list">
          <div class="gc-status-row"><span>Cargadas</span><strong id="hotlapLoaded">...</strong></div>
          <div class="gc-status-row"><span>Visibles</span><strong id="hotlapVisible">...</strong></div>
          <div class="gc-status-row"><span>Actualizado</span><strong id="hotlapUpdated">...</strong></div>
        </div>
      </aside>
    </section>

    <section class="gc-toolbar" aria-label="Filtros del leaderboard">
      <div class="gc-field">
        <label for="driverFilter">Piloto</label>
        <select class="gc-select" id="driverFilter">
          <option value="all">Todos los pilotos</option>
        </select>
      </div>
      <div class="gc-field">
        <label for="carFilter">Coche</label>
        <select class="gc-select" id="carFilter">
          <option value="all">Todos los coches</option>
        </select>
      </div>
      <div class="gc-field">
        <label for="trackFilter">Circuito</label>
        <select class="gc-select" id="trackFilter">
          <option value="all">Todos los circuitos</option>
        </select>
      </div>
      <div class="gc-field">
        <label for="validFilter">Estado</label>
        <select class="gc-select" id="validFilter"><option value="all">Todas</option><option value="valid">Válidas</option><option value="invalid">No válidas</option></select>
      </div>
      <button class="gc-btn gc-btn--primary" id="reloadHotlaps" type="button">Actualizar</button>
      <button class="gc-btn" id="clearFilters" type="button">Limpiar</button>
    </section>

    <div class="gc-table-meta">
      <span id="leaderboardHint">Cargando leaderboard...</span>
      <span>Ordenado por fecha reciente</span>
    </div>

    <section class="gc-table-wrap">
      <table class="gc-table gc-table--leaderboard">
        <thead>
          <tr>
            <th>#</th>
            <th>Piloto</th>
            <th>Coche</th>
            <th>Circuito</th>
            <th>Tiempo</th>
            <th>Delta</th>
            <th>Vmax</th>
            <th>Cortes</th>
            <th>Fecha</th>
            <th>Estado</th>
          </tr>
        </thead>
        <tbody id="hotlapRows"><tr><td colspan="10">Cargando...</td></tr></tbody>
      </table>
    </section>
  </div>

  <style is:global>
    .gc-table--leaderboard td:nth-child(5),.gc-table--leaderboard td:nth-child(6),.gc-table--leaderboard td:nth-child(7){white-space:nowrap;font-variant-numeric:tabular-nums}
    .gc-driver-link{color:var(--text);text-decoration:none;font-weight:900}
    .gc-driver-link:hover{color:var(--accent)}
    .gc-leaderboard-sub{display:block;margin-top:.18rem;color:var(--muted);font-size:.72rem;letter-spacing:.04em;text-transform:uppercase}
    .gc-hotlaps-page .gc-toolbar .gc-select{min-width:190px}
    .gc-table-meta span:last-child{color:var(--muted)}
  </style>

  <script is:inline>
    (() => {
      const els = {
        driver: document.getElementById('driverFilter'), car: document.getElementById('carFilter'), track: document.getElementById('trackFilter'), valid: document.getElementById('validFilter'),
        reload: document.getElementById('reloadHotlaps'), clear: document.getElementById('clearFilters'), rows: document.getElementById('hotlapRows'), loaded: document.getElementById('hotlapLoaded'),
        visible: document.getElementById('hotlapVisible'), updated: document.getElementById('hotlapUpdated'), hint: document.getElementById('leaderboardHint'), source: document.getElementById('hotlapSource')
      };
      let cache = [];
      const escapeHtml = (value) => String(value ?? '-').replace(/[&<>'"]/g, (char) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[char]));
      const valueAt = (source, path) => {
        if (!source || typeof source !== 'object') return undefined;
        if (Object.prototype.hasOwnProperty.call(source, path)) return source[path];
        return String(path).split('.').reduce((acc, part) => acc == null ? undefined : acc[part], source);
      };
      const firstValue = (row, paths) => {
        for (const path of paths) {
          const value = valueAt(row, path);
          if (value !== undefined && value !== null && value !== '') return value;
        }
        return '';
      };
      const textValue = (value, fallback = '-') => {
        if (value === undefined || value === null || value === '') return fallback;
        if (Array.isArray(value)) return value.length ? textValue(value[0], fallback) : fallback;
        if (typeof value === 'object') return String(value.displayName ?? value.visibleName ?? value.cleanName ?? value.display_name ?? value.uiName ?? value.uiCarName ?? value.uiTrackName ?? value.name ?? value.Name ?? value.label ?? value.code ?? fallback).trim();
        return String(value).trim() || fallback;
      };
      const cleanFallbackName = (value, fallback = '-') => {
        const raw = textValue(value, fallback);
        if (raw === fallback) return fallback;
        return raw.replace(/_/g, ' ').replace(/\s+/g, ' ').trim();
      };
      const normalizeFilterValue = (value) => cleanFallbackName(value, '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
      const displayFrom = (row, paths, fallback = '-') => cleanFallbackName(firstValue(row, paths), fallback);
      const fmtMs = (ms) => {
        const n = Number(ms);
        if (!Number.isFinite(n) || n <= 0) return '--';
        const m = Math.floor(n / 60000); const s = Math.floor((n % 60000) / 1000); const x = String(Math.floor(n % 1000)).padStart(3, '0');
        return `${m}:${String(s).padStart(2, '0')}.${x}`;
      };
      const fmtDelta = (ms) => { const n = Number(ms); return !Number.isFinite(n) || n <= 0 ? '+0.000' : `+${(n / 1000).toFixed(3)}`; };
      const fmtDate = (value) => {
        if (!value) return '--'; const date = new Date(value); if (Number.isNaN(date.getTime())) return '--';
        return date.toLocaleString('es-ES', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
      };
      const fmtSpeed = (value) => Number.isFinite(Number(value)) && Number(value) > 0 ? `${Math.round(Number(value))} km/h` : '--';
      const playerId = (row) => firstValue(row, ['playerId','driverId','PlayerId','driver.id','driver.playerId','pilot.id']);
      const driverName = (row) => displayFrom(row, ['driverDisplayName','driverVisibleName','displayName','driverName','playerName','pilotName','name','Name','driver.displayName','driver.visibleName','driver.name','player.displayName','player.name','driver'], 'Piloto');
      const carName = (row) => displayFrom(row, ['carDisplayName','carVisibleName','displayCarName','carName','uiCarName','car.displayName','car.visibleName','car.cleanName','car.uiName','car.uiCarName','car.name','Car','car'], 'Coche');
      const trackName = (row) => displayFrom(row, ['trackDisplayName','trackVisibleName','displayTrackName','trackName','uiTrackName','track.displayName','track.visibleName','track.cleanName','track.uiName','track.uiTrackName','track.name','Track','track'], 'Circuito');
      const lapDisplay = (row) => textValue(firstValue(row, ['lapTimeFormatted','lapTimeText','lapTime']), '') || fmtMs(firstValue(row, ['lapTimeMs','LapTime']));
      const lapMs = (row) => Number(firstValue(row, ['lapTimeMs','LapTime'])) || null;
      const lapDate = (row) => firstValue(row, ['timestampIso','dateIso','createdAt','session.endTimeIso','session.startTimeIso']);
      const comboUrl = (row) => {
        const comboId = firstValue(row, ['comboId','session.comboId','ComboId']);
        if (comboId) return `/combos/${encodeURIComponent(comboId)}`;
        const trackId = firstValue(row, ['trackId','track.id']); const carId = firstValue(row, ['carId','car.id']);
        return trackId && carId ? `/combos/${encodeURIComponent(trackId)}/${encodeURIComponent(carId)}` : '';
      };
      const isInvalid = (row) => { const value = firstValue(row, ['valid','Valid','isValid']); return value === 0 || value === false || value === '0' || value === 'false' || value === 'no'; };

      const lapTimestamp = (row) => {
        const raw = lapDate(row);
        if (!raw) return 0;
        const time = new Date(raw).getTime();
        return Number.isFinite(time) ? time : 0;
      };
      const populateSelect = (select, rows, getter, allLabel) => {
        if (!select) return;
        const current = select.value || 'all';
        const map = new Map();
        rows.forEach((row) => {
          const label = getter(row);
          const value = normalizeFilterValue(label);
          if (!value || value === '-') return;
          if (!map.has(value)) map.set(value, label);
        });
        const options = [...map.entries()].sort((a, b) => a[1].localeCompare(b[1], 'es', { sensitivity:'base' }));
        select.innerHTML = '<option value="all">' + escapeHtml(allLabel) + '</option>' + options.map(([value, label]) => '<option value="' + escapeHtml(value) + '">' + escapeHtml(label) + '</option>').join('');
        select.value = map.has(current) ? current : 'all';
      };
      function populateFilterOptions() {
        populateSelect(els.driver, cache, driverName, 'Todos los pilotos');
        populateSelect(els.car, cache, carName, 'Todos los coches');
        populateSelect(els.track, cache, trackName, 'Todos los circuitos');
      }
      function draw() {
        const driver = els.driver.value || 'all';
        const car = els.car.value || 'all';
        const track = els.track.value || 'all';
        const valid = els.valid.value;
        const rows = cache.filter((row) => {
          if (driver !== 'all' && normalizeFilterValue(driverName(row)) !== driver) return false;
          if (car !== 'all' && normalizeFilterValue(carName(row)) !== car) return false;
          if (track !== 'all' && normalizeFilterValue(trackName(row)) !== track) return false;
          if (valid === 'valid' && isInvalid(row)) return false;
          if (valid === 'invalid' && !isInvalid(row)) return false;
          return true;
        }).sort((a, b) => lapTimestamp(b) - lapTimestamp(a) || (lapMs(a) || 999999999) - (lapMs(b) || 999999999));
        const best = Math.min(...rows.map(lapMs).filter((value) => Number.isFinite(value)));
        els.visible.textContent = String(rows.length);
        els.hint.textContent = rows.length ? `${rows.length} vueltas visibles de ${cache.length}` : 'No hay resultados con esos filtros';
        els.rows.innerHTML = rows.map((row, index) => {
          const id = playerId(row); const name = escapeHtml(driverName(row));
          const link = id ? `<a class="gc-driver-link" href="/pilotos/${encodeURIComponent(id)}">${name}</a><span class="gc-leaderboard-sub">Perfil público</span>` : `<strong>${name}</strong>`;
          const delta = Number.isFinite(best) ? fmtDelta((lapMs(row) || best) - best) : '--'; const combo = comboUrl(row);
          return `<tr><td>${index + 1}</td><td>${link}</td><td>${combo ? `<a href="${escapeHtml(combo)}">${escapeHtml(carName(row))}</a>` : escapeHtml(carName(row))}</td><td>${combo ? `<a href="${escapeHtml(combo)}">${escapeHtml(trackName(row))}</a>` : escapeHtml(trackName(row))}</td><td><strong>${escapeHtml(lapDisplay(row))}</strong></td><td>${escapeHtml(delta)}</td><td>${escapeHtml(fmtSpeed(firstValue(row, ['maxSpeedKmh','MaxSpeed_KMH'])))}</td><td>${escapeHtml(firstValue(row, ['cuts','Cuts']) || 0)}</td><td>${escapeHtml(fmtDate(lapDate(row)))}</td><td>${isInvalid(row) ? '<span class="gc-chip gc-chip--danger">No válida</span>' : '<span class="gc-chip gc-chip--accent">Válida</span>'}</td></tr>`;
        }).join('') || '<tr><td colspan="10">Sin resultados</td></tr>';
      }
      async function load() {
        els.rows.innerHTML = '<tr><td colspan="10">Cargando...</td></tr>'; els.reload.disabled = true;
        try {
          const res = await fetch('/api/hotlaps?limit=1000', { cache:'no-store', credentials:'include' });
          if (!res.ok) throw new Error('Endpoint no disponible'); const json = await res.json();
          cache = json.items || json.hotlaps || json.laps || json.data || [];
          populateFilterOptions();
          els.loaded.textContent = String(cache.length); els.updated.textContent = new Date().toLocaleTimeString('es-ES', { hour:'2-digit', minute:'2-digit' }); els.source.textContent = 'OK'; els.source.style.color = ''; draw();
        } catch (error) {
          els.source.textContent = 'Error'; els.source.style.color = 'var(--warn)'; els.hint.textContent = 'No se pudo cargar /api/hotlaps'; els.rows.innerHTML = '<tr><td colspan="10">Error cargando hotlaps. Revisa que el endpoint esté activo.</td></tr>';
        } finally { els.reload.disabled = false; }
      }
      [els.driver, els.car, els.track, els.valid].forEach((input) => input.addEventListener('input', draw));
      els.reload.addEventListener('click', load); els.clear.addEventListener('click', () => { els.driver.value='all'; els.car.value='all'; els.track.value='all'; els.valid.value='all'; draw(); });
      load();
    })();
  </script>
</AppLayout>

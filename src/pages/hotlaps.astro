---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout
  title="Hotlaps | GrassCutters Racing"
  description="Leaderboard de GrassCutters Racing con tiempos de referencia, filtros por piloto, coche, circuito y vueltas válidas."
  canonicalPath="/hotlaps"
  ogImage="/og/hotlaps-og-v1531.png"
  ogImageAlt="Hotlaps GrassCutters Racing"
>
  <div class="gc-page gc-hotlaps-page gc-hotlaps-v8">
    <section class="gc-hero gc-hero--compact gc-hotlaps-hero-v8">
      <div>
        <span class="gc-kicker">Leaderboard</span>
        <h1 class="gc-title">Hotlaps.</h1>
        <p class="gc-subtitle">Tiempos de referencia desde stracker, con filtros rápidos por piloto, coche, circuito y estado.</p>
        <div class="gc-hero__meta">
          <span class="gc-chip gc-chip--accent">stracker.db3</span>
          <span class="gc-chip">Nombres corregidos</span>
          <span class="gc-chip">Combos enlazados</span>
        </div>
      </div>

      <aside class="gc-live-panel gc-hotlaps-status-v8">
        <div class="gc-live-panel__title"><span>Leaderboard</span><strong id="hotlapSource">...</strong></div>
        <div class="gc-status-list">
          <div class="gc-status-row"><span>Cargadas</span><strong id="hotlapLoaded">...</strong></div>
          <div class="gc-status-row"><span>Visibles</span><strong id="hotlapVisible">...</strong></div>
          <div class="gc-status-row"><span>Actualizado</span><strong id="hotlapUpdated">...</strong></div>
        </div>
      </aside>
    </section>

    <section class="gc-metrics gc-hotlaps-metrics-v8" aria-label="Resumen de hotlaps">
      <div class="gc-metric"><span>Mejor vuelta</span><strong id="hotlapMetricBest">...</strong><small id="hotlapMetricBestMeta">cargando</small></div>
      <div class="gc-metric"><span>Pilotos</span><strong id="hotlapMetricDrivers">...</strong><small>visibles</small></div>
      <div class="gc-metric"><span>Coches</span><strong id="hotlapMetricCars">...</strong><small>visibles</small></div>
      <div class="gc-metric"><span>Circuitos</span><strong id="hotlapMetricTracks">...</strong><small>visibles</small></div>
    </section>

    <section class="gc-toolbar gc-hotlaps-toolbar-v8" aria-label="Filtros del leaderboard">
      <div class="gc-field gc-hotlaps-search-v8">
        <label for="hotlapSearch">Buscar</label>
        <input class="gc-input" id="hotlapSearch" placeholder="Piloto, coche o circuito" autocomplete="off" />
      </div>

      <div class="gc-field">
        <label for="driverFilter">Piloto</label>
        <select class="gc-select" id="driverFilter">
          <option value="all">Todos los pilotos</option>
        </select>
      </div>

      <div class="gc-field">
        <label for="carFilter">Coche</label>
        <select class="gc-select" id="carFilter">
          <option value="all">Todos los coches</option>
        </select>
      </div>

      <div class="gc-field">
        <label for="trackFilter">Circuito</label>
        <select class="gc-select" id="trackFilter">
          <option value="all">Todos los circuitos</option>
        </select>
      </div>

      <div class="gc-field">
        <label for="validFilter">Estado</label>
        <select class="gc-select" id="validFilter">
          <option value="all">Todas</option>
          <option value="valid">Válidas</option>
          <option value="invalid">No válidas</option>
        </select>
      </div>

      <div class="gc-field">
        <label for="sortFilter">Orden</label>
        <select class="gc-select" id="sortFilter">
          <option value="fastest">Mejor tiempo</option>
          <option value="recent">Recientes</option>
          <option value="driver">Piloto</option>
          <option value="car">Coche</option>
          <option value="track">Circuito</option>
          <option value="speed">Vmax</option>
        </select>
      </div>

      <button class="gc-btn gc-btn--primary" id="reloadHotlaps" type="button">Actualizar</button>
      <button class="gc-btn" id="clearFilters" type="button">Limpiar</button>
    </section>

    <div class="gc-table-meta gc-hotlaps-meta-v8">
      <span id="leaderboardHint">Cargando leaderboard...</span>
      <span id="leaderboardOrder">Ordenado por mejor tiempo</span>
    </div>

    <section class="gc-table-wrap gc-hotlaps-table-wrap-v8">
      <table class="gc-table gc-table--leaderboard gc-hotlaps-table-v8">
        <thead>
          <tr>
            <th>#</th>
            <th>Piloto</th>
            <th>Coche</th>
            <th>Circuito</th>
            <th>Tiempo</th>
            <th>Delta</th>
            <th>Vmax</th>
            <th>Cortes</th>
            <th>Fecha</th>
            <th>Estado</th>
          </tr>
        </thead>
        <tbody id="hotlapRows"><tr><td colspan="10">Cargando...</td></tr></tbody>
      </table>
    </section>
  </div>

  <style is:global>
    .gc-hotlaps-v8{
      display:grid;
      gap:clamp(18px,2.3vw,28px);
    }

    .gc-hotlaps-hero-v8{
      padding-block:clamp(22px,3vw,34px)!important;
      margin:0;
    }

    .gc-hotlaps-hero-v8 .gc-title{
      font-size:clamp(3.2rem,7vw,6rem);
      line-height:.86;
      letter-spacing:-.075em;
      margin:8px 0 12px;
    }

    .gc-hotlaps-hero-v8 .gc-subtitle{
      max-width:760px;
    }

    .gc-hotlaps-metrics-v8{
      margin:0;
    }

    .gc-hotlaps-toolbar-v8{
      align-items:end;
      gap:10px;
      margin:0;
    }

    .gc-hotlaps-toolbar-v8 .gc-field{
      flex:1 1 170px;
    }

    .gc-hotlaps-toolbar-v8 .gc-hotlaps-search-v8{
      flex:1.6 1 260px;
    }

    .gc-hotlaps-toolbar-v8 .gc-select,
    .gc-hotlaps-toolbar-v8 .gc-input{
      min-width:0;
      width:100%;
    }

    .gc-hotlaps-meta-v8{
      margin:0;
      padding:12px 0;
      border-top:1px solid var(--line);
      border-bottom:1px solid var(--line);
    }

    .gc-hotlaps-meta-v8 span:last-child{
      color:var(--muted);
    }

    .gc-hotlaps-table-wrap-v8{
      max-height:calc(100vh - 260px);
      min-height:360px;
      overflow:auto;
    }

    .gc-hotlaps-table-v8{
      min-width:1180px;
    }

    .gc-hotlaps-table-v8 thead th{
      position:sticky;
      top:0;
      z-index:2;
      background:color-mix(in srgb,var(--bg) 92%,black);
      backdrop-filter:blur(12px);
    }

    .gc-hotlaps-table-v8 td:nth-child(2),
    .gc-hotlaps-table-v8 td:nth-child(3),
    .gc-hotlaps-table-v8 td:nth-child(4){
      min-width:170px;
      white-space:normal;
    }

    .gc-hotlaps-table-v8 td:nth-child(5),
    .gc-hotlaps-table-v8 td:nth-child(6),
    .gc-hotlaps-table-v8 td:nth-child(7),
    .gc-hotlaps-table-v8 td:nth-child(8),
    .gc-hotlaps-table-v8 td:nth-child(9){
      white-space:nowrap;
      font-variant-numeric:tabular-nums;
    }

    .gc-hotlap-rank{
      display:inline-flex;
      min-width:32px;
      height:28px;
      align-items:center;
      justify-content:center;
      border:1px solid var(--line);
      font-weight:950;
      color:var(--soft);
      background:rgba(255,255,255,.025);
    }

    .gc-hotlap-rank.is-podium{
      color:#07110a;
      border-color:transparent;
      background:linear-gradient(135deg,var(--accent),var(--accent2));
    }

    .gc-driver-link{
      color:var(--text);
      text-decoration:none;
      font-weight:950;
    }

    .gc-driver-link:hover{
      color:var(--accent);
    }

    .gc-leaderboard-sub{
      display:block;
      margin-top:.18rem;
      color:var(--muted);
      font-size:.72rem;
      letter-spacing:.04em;
      text-transform:uppercase;
    }

    .gc-hotlaps-table-v8 a{
      color:var(--text);
      font-weight:850;
    }

    .gc-hotlaps-table-v8 a:hover{
      color:var(--accent);
    }

    @media(max-width:900px){
      .gc-hotlaps-table-wrap-v8{
        max-height:none;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const els = {
        search: document.getElementById('hotlapSearch'),
        driver: document.getElementById('driverFilter'),
        car: document.getElementById('carFilter'),
        track: document.getElementById('trackFilter'),
        valid: document.getElementById('validFilter'),
        sort: document.getElementById('sortFilter'),
        reload: document.getElementById('reloadHotlaps'),
        clear: document.getElementById('clearFilters'),
        rows: document.getElementById('hotlapRows'),
        loaded: document.getElementById('hotlapLoaded'),
        visible: document.getElementById('hotlapVisible'),
        updated: document.getElementById('hotlapUpdated'),
        hint: document.getElementById('leaderboardHint'),
        order: document.getElementById('leaderboardOrder'),
        source: document.getElementById('hotlapSource'),
        metricBest: document.getElementById('hotlapMetricBest'),
        metricBestMeta: document.getElementById('hotlapMetricBestMeta'),
        metricDrivers: document.getElementById('hotlapMetricDrivers'),
        metricCars: document.getElementById('hotlapMetricCars'),
        metricTracks: document.getElementById('hotlapMetricTracks')
      };

      let cache = [];

      const escapeHtml = (value) => String(value ?? '-').replace(/[&<>'"]/g, (char) => ({
        '&':'&amp;', '<':'&lt;', '>':'&gt;', "'":'&#39;', '"':'&quot;'
      }[char]));

      const valueAt = (source, path) => {
        if (!source || typeof source !== 'object') return undefined;
        if (Object.prototype.hasOwnProperty.call(source, path)) return source[path];
        return String(path).split('.').reduce((acc, part) => acc == null ? undefined : acc[part], source);
      };

      const firstValue = (row, paths) => {
        for (const path of paths) {
          const value = valueAt(row, path);
          if (value !== undefined && value !== null && value !== '') return value;
        }
        return '';
      };

      const textValue = (value, fallback = '-') => {
        if (value === undefined || value === null || value === '') return fallback;
        if (Array.isArray(value)) return value.length ? textValue(value[0], fallback) : fallback;
        if (typeof value === 'object') {
          return String(
            value.displayName ??
            value.visibleName ??
            value.cleanName ??
            value.display_name ??
            value.uiName ??
            value.uiCarName ??
            value.uiTrackName ??
            value.name ??
            value.Name ??
            value.label ??
            value.code ??
            fallback
          ).trim();
        }
        return String(value).trim() || fallback;
      };

      const cleanFallbackName = (value, fallback = '-') => {
        const raw = textValue(value, fallback);
        if (raw === fallback) return fallback;
        return raw.replace(/_/g, ' ').replace(/\s+/g, ' ').trim();
      };

      const normalizeFilterValue = (value) => cleanFallbackName(value, '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
      const displayFrom = (row, paths, fallback = '-') => cleanFallbackName(firstValue(row, paths), fallback);

      const fmtMs = (ms) => {
        const n = Number(ms);
        if (!Number.isFinite(n) || n <= 0) return '--';
        const m = Math.floor(n / 60000);
        const s = Math.floor((n % 60000) / 1000);
        const x = String(Math.floor(n % 1000)).padStart(3, '0');
        return `${m}:${String(s).padStart(2, '0')}.${x}`;
      };

      const fmtDelta = (ms) => {
        const n = Number(ms);
        return !Number.isFinite(n) || n <= 0 ? '+0.000' : `+${(n / 1000).toFixed(3)}`;
      };

      const fmtDate = (value) => {
        if (!value) return '--';
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return '--';
        return date.toLocaleString('es-ES', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
      };

      const fmtSpeed = (value) => Number.isFinite(Number(value)) && Number(value) > 0 ? `${Math.round(Number(value))} km/h` : '--';

      const playerId = (row) => firstValue(row, ['playerId','driverId','PlayerId','driver.id','driver.playerId','pilot.id']);
      const driverName = (row) => displayFrom(row, ['driverDisplayName','driverVisibleName','displayName','driverName','playerName','pilotName','name','Name','driver.displayName','driver.visibleName','driver.name','player.displayName','player.name','driver'], 'Piloto');
      const carName = (row) => displayFrom(row, ['carDisplayName','carVisibleName','displayCarName','carName','uiCarName','car.displayName','car.visibleName','car.cleanName','car.uiName','car.uiCarName','car.name','Car','car'], 'Coche');
      const trackName = (row) => displayFrom(row, ['trackDisplayName','trackVisibleName','displayTrackName','trackName','uiTrackName','track.displayName','track.visibleName','track.cleanName','track.uiName','track.uiTrackName','track.name','Track','track'], 'Circuito');
      const lapDisplay = (row) => textValue(firstValue(row, ['lapTimeFormatted','lapTimeText','lapTime']), '') || fmtMs(firstValue(row, ['lapTimeMs','LapTime']));
      const lapMs = (row) => Number(firstValue(row, ['lapTimeMs','LapTime'])) || null;
      const speedValue = (row) => Number(firstValue(row, ['maxSpeedKmh','MaxSpeed_KMH'])) || 0;
      const lapDate = (row) => firstValue(row, ['timestampIso','dateIso','createdAt','session.endTimeIso','session.startTimeIso']);

      const lapTimestamp = (row) => {
        const raw = lapDate(row);
        if (!raw) return 0;
        const time = new Date(raw).getTime();
        return Number.isFinite(time) ? time : 0;
      };

      const comboUrl = (row) => {
        const comboId = firstValue(row, ['comboId','session.comboId','ComboId']);
        if (comboId) return `/combos/${encodeURIComponent(comboId)}`;
        const trackId = firstValue(row, ['trackId','track.id']);
        const carId = firstValue(row, ['carId','car.id']);
        return trackId && carId ? `/combos/${encodeURIComponent(trackId)}/${encodeURIComponent(carId)}` : '';
      };

      const isInvalid = (row) => {
        const value = firstValue(row, ['valid','Valid','isValid']);
        return value === 0 || value === false || value === '0' || value === 'false' || value === 'no';
      };

      const populateSelect = (select, rows, getter, allLabel) => {
        if (!select) return;
        const current = select.value || 'all';
        const map = new Map();

        rows.forEach((row) => {
          const label = getter(row);
          const value = normalizeFilterValue(label);
          if (!value || value === '-') return;
          if (!map.has(value)) map.set(value, label);
        });

        const options = [...map.entries()].sort((a, b) => a[1].localeCompare(b[1], 'es', { sensitivity:'base' }));
        select.innerHTML = `<option value="all">${escapeHtml(allLabel)}</option>` + options.map(([value, label]) => `<option value="${escapeHtml(value)}">${escapeHtml(label)}</option>`).join('');
        select.value = map.has(current) ? current : 'all';
      };

      function populateFilterOptions() {
        populateSelect(els.driver, cache, driverName, 'Todos los pilotos');
        populateSelect(els.car, cache, carName, 'Todos los coches');
        populateSelect(els.track, cache, trackName, 'Todos los circuitos');
      }

      function baseFilteredRows() {
        const query = normalizeFilterValue(els.search.value || '');
        const driver = els.driver.value || 'all';
        const car = els.car.value || 'all';
        const track = els.track.value || 'all';
        const valid = els.valid.value;

        return cache.filter((row) => {
          const haystack = normalizeFilterValue(`${driverName(row)} ${carName(row)} ${trackName(row)}`);
          if (query && !haystack.includes(query)) return false;
          if (driver !== 'all' && normalizeFilterValue(driverName(row)) !== driver) return false;
          if (car !== 'all' && normalizeFilterValue(carName(row)) !== car) return false;
          if (track !== 'all' && normalizeFilterValue(trackName(row)) !== track) return false;
          if (valid === 'valid' && isInvalid(row)) return false;
          if (valid === 'invalid' && !isInvalid(row)) return false;
          return true;
        });
      }

      function sortRows(rows) {
        const sort = els.sort.value;
        const sorted = [...rows];

        sorted.sort((a, b) => {
          if (sort === 'recent') return lapTimestamp(b) - lapTimestamp(a) || (lapMs(a) || 999999999) - (lapMs(b) || 999999999);
          if (sort === 'driver') return driverName(a).localeCompare(driverName(b), 'es', { sensitivity:'base' }) || (lapMs(a) || 999999999) - (lapMs(b) || 999999999);
          if (sort === 'car') return carName(a).localeCompare(carName(b), 'es', { sensitivity:'base' }) || (lapMs(a) || 999999999) - (lapMs(b) || 999999999);
          if (sort === 'track') return trackName(a).localeCompare(trackName(b), 'es', { sensitivity:'base' }) || (lapMs(a) || 999999999) - (lapMs(b) || 999999999);
          if (sort === 'speed') return speedValue(b) - speedValue(a);
          return (lapMs(a) || 999999999) - (lapMs(b) || 999999999);
        });

        return sorted;
      }

      function updateMetrics(rows) {
        const validRows = rows.filter((row) => !isInvalid(row));
        const best = validRows.slice().sort((a, b) => (lapMs(a) || 999999999) - (lapMs(b) || 999999999))[0] || rows[0];
        const drivers = new Set();
        const cars = new Set();
        const tracks = new Set();

        rows.forEach((row) => {
          drivers.add(normalizeFilterValue(driverName(row)));
          cars.add(normalizeFilterValue(carName(row)));
          tracks.add(normalizeFilterValue(trackName(row)));
        });

        els.metricBest.textContent = best ? lapDisplay(best) : '--';
        els.metricBestMeta.textContent = best ? driverName(best) : 'sin datos';
        els.metricDrivers.textContent = String([...drivers].filter(Boolean).length);
        els.metricCars.textContent = String([...cars].filter(Boolean).length);
        els.metricTracks.textContent = String([...tracks].filter(Boolean).length);
      }

      function orderLabel() {
        const option = els.sort.options[els.sort.selectedIndex];
        return `Ordenado por ${option ? option.textContent.toLowerCase() : 'mejor tiempo'}`;
      }

      function draw() {
        const filtered = baseFilteredRows();
        const rows = sortRows(filtered);
        const best = Math.min(...filtered.map(lapMs).filter((value) => Number.isFinite(value)));

        updateMetrics(filtered);

        els.visible.textContent = String(rows.length);
        els.hint.textContent = rows.length ? `${rows.length} vueltas visibles de ${cache.length}` : 'No hay resultados con esos filtros';
        els.order.textContent = orderLabel();

        els.rows.innerHTML = rows.map((row, index) => {
          const id = playerId(row);
          const name = escapeHtml(driverName(row));
          const rankClass = index < 3 ? 'gc-hotlap-rank is-podium' : 'gc-hotlap-rank';
          const link = id
            ? `<a class="gc-driver-link" href="/pilotos/${encodeURIComponent(id)}">${name}</a><span class="gc-leaderboard-sub">Perfil público</span>`
            : `<strong>${name}</strong>`;

          const delta = Number.isFinite(best) ? fmtDelta((lapMs(row) || best) - best) : '--';
          const combo = comboUrl(row);

          return `
            <tr>
              <td><span class="${rankClass}">${index + 1}</span></td>
              <td>${link}</td>
              <td>${combo ? `<a href="${escapeHtml(combo)}">${escapeHtml(carName(row))}</a>` : escapeHtml(carName(row))}</td>
              <td>${combo ? `<a href="${escapeHtml(combo)}">${escapeHtml(trackName(row))}</a>` : escapeHtml(trackName(row))}</td>
              <td><strong>${escapeHtml(lapDisplay(row))}</strong></td>
              <td>${escapeHtml(delta)}</td>
              <td>${escapeHtml(fmtSpeed(speedValue(row)))}</td>
              <td>${escapeHtml(firstValue(row, ['cuts','Cuts']) || 0)}</td>
              <td>${escapeHtml(fmtDate(lapDate(row)))}</td>
              <td>${isInvalid(row) ? '<span class="gc-chip gc-chip--danger">No válida</span>' : '<span class="gc-chip gc-chip--accent">Válida</span>'}</td>
            </tr>
          `;
        }).join('') || '<tr><td colspan="10">Sin resultados</td></tr>';

        console.info('[GC hotlaps v1.8]', {
          loaded: cache.length,
          visible: rows.length,
          sort: els.sort.value
        });
      }

      async function load() {
        els.rows.innerHTML = '<tr><td colspan="10">Cargando...</td></tr>';
        els.reload.disabled = true;

        try {
          const res = await fetch('/api/hotlaps?limit=1000', { cache:'no-store', credentials:'include' });
          if (!res.ok) throw new Error('Endpoint no disponible');

          const json = await res.json();
          cache = json.items || json.hotlaps || json.laps || json.data || [];

          populateFilterOptions();

          els.loaded.textContent = String(cache.length);
          els.updated.textContent = new Date().toLocaleTimeString('es-ES', { hour:'2-digit', minute:'2-digit' });
          els.source.textContent = 'OK';
          els.source.style.color = '';

          draw();
        } catch (error) {
          els.source.textContent = 'Error';
          els.source.style.color = 'var(--warn)';
          els.hint.textContent = 'No se pudo cargar /api/hotlaps';
          els.rows.innerHTML = '<tr><td colspan="10">Error cargando hotlaps. Revisa que el endpoint esté activo.</td></tr>';
          console.warn('[GC hotlaps v1.8] Error', error);
        } finally {
          els.reload.disabled = false;
        }
      }

      [els.search, els.driver, els.car, els.track, els.valid, els.sort].forEach((input) => {
        input.addEventListener('input', draw);
        input.addEventListener('change', draw);
      });

      els.reload.addEventListener('click', load);

      els.clear.addEventListener('click', () => {
        els.search.value = '';
        els.driver.value = 'all';
        els.car.value = 'all';
        els.track.value = 'all';
        els.valid.value = 'all';
        els.sort.value = 'fastest';
        draw();
      });

      load();
    })();
  </script>
</AppLayout>

---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import '../styles/home2.css';
import '../styles/archive-home2-polish.css';

const pageTitle = 'Noticias | GrassCutters Newsroom';
const pageDescription = 'Canal de noticias sobre GrassCutters, sim racing y motorsport: novedades de la comunidad, herramientas, carreras, campeonatos y temas relevantes del mundo del motor.';

const categories = [
  { key: 'Update', label: 'Update', intro: 'Cambios, mejoras y novedades técnicas del ecosistema GrassCutters.' },
  { key: 'Sim racing', label: 'Sim racing', intro: 'Actualidad, cultura y temas relevantes del mundo del sim racing.' },
  { key: 'Motorsport', label: 'Motorsport', intro: 'Noticias y contexto del motor, competición y cultura racing.' },
  { key: 'Herramientas', label: 'Herramientas', intro: 'HUDs, apps, recursos y utilidades para pilotos y comunidad.' },
  { key: 'GrassCutters', label: 'GrassCutters', intro: 'Comunidad, servidores, eventos, proyectos y actividad interna de GC.' },
];
---

<MarketingLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/noticias/"
  ogImage="/og/grasscutters-social-card-v1531.png"
  ogImageAlt="GrassCutters Newsroom"
>
  <main class="gc-archive-home2 gc-news-archive-style-v2" data-news-page>
    <section class="gc-archive-race-hero">
      <div class="gc-archive-shell gc-archive-race-hero__grid">
        <div>
          <p class="gc-archive-kicker">GRASSCUTTERS NEWSROOM</p>
          <h1>Noticias</h1>
          <p class="gc-archive-race-hero__lead">
            Canal de noticias sobre GrassCutters, sim racing y motorsport: novedades de la comunidad, herramientas, carreras, campeonatos y temas relevantes del mundo del motor.
          </p>

          <div class="gc-archive-statusline">
            <span class="gc-archive-badge">Newsroom</span>
            <span class="gc-archive-badge">GC Racing</span>
            <span class="gc-archive-badge">Sim racing</span>
            <span class="gc-archive-badge">Motorsport</span>
          </div>

          <form class="gc-archive-search gc-news-search-hero-v2" role="search" aria-label="Buscar noticias">
            <label for="newsSearch">Buscar en noticias</label>
            <div>
              <input
                id="newsSearch"
                type="search"
                placeholder="GC, sim racing, motorsport, herramientas..."
                data-news-search-input
                autocomplete="off"
              />
              <button type="button" data-news-clear>Limpiar</button>
            </div>
            <small><span data-news-result-count>--</span> publicaciones visibles</small>
          </form>
        </div>

        <aside class="gc-archive-command-card" aria-label="Resumen del canal de noticias">
          <span>Canal editorial</span>
          <strong data-news-total>--</strong>
          <small>publicaciones</small>

          <div class="gc-archive-command-grid" data-news-command-categories>
            {categories.slice(0, 4).map((category) => (
              <button type="button" data-news-category={category.key}>
                <small>{category.label}</small>
                <strong data-news-count={category.key}>0</strong>
              </button>
            ))}
          </div>
        </aside>
      </div>
    </section>

    <section class="gc-archive-shell gc-archive-section" aria-label="Categorías de noticias">
      <div class="gc-archive-type-grid gc-news-category-grid-v2">
        {categories.map((category) => (
          <button class="gc-archive-type-card" type="button" data-news-category={category.key}>
            <small>Noticias</small>
            <strong>{category.label}</strong>
            <p>{category.intro}</p>
            <small><span data-news-count={category.key}>0</span> publicación<span data-news-plural={category.key}>es</span></small>
          </button>
        ))}
      </div>
    </section>

    <section class="gc-archive-shell gc-archive-section" aria-label="Noticia destacada">
      <article class="gc-archive-spotlight gc-news-spotlight-v2" data-news-feature>
        <div class="gc-archive-spotlight__copy">
          <span class="gc-archive-panel__eyebrow">Noticia destacada</span>
          <h2>Cargando newsroom</h2>
          <p>Esperando noticias publicadas desde el sistema de contenidos.</p>

          <dl>
            <div>
              <dt>Categoría</dt>
              <dd>Newsroom</dd>
            </div>
            <div>
              <dt>Fecha</dt>
              <dd>Actualizando</dd>
            </div>
            <div>
              <dt>Canal</dt>
              <dd>GC News</dd>
            </div>
          </dl>

          <a href="/noticias/">Leer noticia</a>
        </div>

        <figure>
          <img src="/ui/home2/gc-home2-news-sim.svg" alt="" loading="lazy" />
        </figure>
      </article>
    </section>

    <section class="gc-archive-shell gc-archive-section gc-archive-section--panel gc-news-catalog-panel-v2" id="noticias-catalogo">
      <div class="gc-archive-section-head gc-news-catalog-head-v2">
        <div>
          <span>Catálogo</span>
          <h2>Todas las noticias</h2>
        </div>
        <p>Explora publicaciones por categoría o busca por título, tema, herramienta, comunidad, sim racing o motorsport.</p>
      </div>

      <div class="gc-archive-filter-row" aria-label="Filtros de noticias">
        <button type="button" class="is-active" data-news-category="all">Todo</button>
        {categories.map((category) => (
          <button type="button" data-news-category={category.key}>{category.label}</button>
        ))}
      </div>

      <div class="gc-archive-grid gc-news-grid-v2" data-news-list>
        <article class="gc-archive-card">
          <span class="gc-archive-card__mark">Newsroom</span>
          <div>
            <small>Noticias</small>
            <strong>Cargando publicaciones</strong>
            <p>Esperando datos del sistema persistente.</p>
            <footer>
              <em>GC News</em>
              <b>Abrir</b>
            </footer>
          </div>
        </article>
      </div>

      <div class="gc-archive-empty" data-news-empty hidden>
        <strong>No hay resultados.</strong>
        <p>Prueba con otro término o limpia los filtros.</p>
      </div>
    </section>
  </main>

  <style is:global>
    .gc-news-archive-style-v2 {
      padding-bottom: 34px;
    }

    .gc-news-archive-style-v2 .gc-archive-race-hero {
      min-height: 470px;
    }

    .gc-news-archive-style-v2 .gc-archive-race-hero h1 {
      max-width: 620px;
    }

    .gc-news-search-hero-v2 {
      max-width: 760px;
    }

    .gc-news-archive-style-v2 .gc-archive-command-grid button,
    .gc-news-category-grid-v2 .gc-archive-type-card {
      cursor: pointer;
      appearance: none;
      font: inherit;
      color: inherit;
    }

    .gc-news-archive-style-v2 .gc-archive-command-grid button.is-active,
    .gc-news-category-grid-v2 .gc-archive-type-card.is-active {
      border-color: rgba(150,255,47,.55);
      background:
        radial-gradient(circle at 88% 0%, rgba(150,255,47,.12), transparent 9rem),
        linear-gradient(180deg, rgba(10,18,12,.94), rgba(4,7,5,.98));
    }

    .gc-news-archive-style-v2 .gc-archive-command-grid button strong {
      color: var(--text);
    }

    .gc-news-category-grid-v2 {
      grid-template-columns: repeat(5, minmax(0,1fr));
    }

    .gc-news-category-grid-v2 .gc-archive-type-card {
      text-align: left;
    }

    .gc-news-category-grid-v2 .gc-archive-type-card strong {
      font-size: clamp(18px, 2vw, 27px);
    }

    .gc-news-category-grid-v2 .gc-archive-type-card p {
      min-height: 62px;
      font-size: 12px;
    }

    /* Spotlight alineado con Archivo: misma proporción, mismo aire, mismos radios y altura visual */
    .gc-news-spotlight-v2 {
      grid-template-columns: minmax(0, 1fr) minmax(320px, .55fr);
      min-height: 300px;
      overflow: hidden;
    }

    .gc-news-spotlight-v2 .gc-archive-spotlight__copy {
      padding: clamp(20px, 3vw, 34px);
      align-self: end;
    }

    .gc-news-spotlight-v2 h2 {
      margin: 7px 0 9px;
      font-size: clamp(26px, 3.05vw, 40px);
      line-height: .94;
      letter-spacing: -.04em;
      text-transform: uppercase;
      max-width: 760px;
    }

    .gc-news-spotlight-v2 p {
      max-width: 720px;
    }

    .gc-news-spotlight-v2 dl {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      max-width: 760px;
    }

    .gc-news-spotlight-v2 figure {
      margin: 0;
      min-height: 100%;
      max-height: 360px;
      background:
        radial-gradient(circle at 50% 42%, rgba(150,255,47,.12), transparent 42%),
        linear-gradient(180deg, rgba(8,14,10,.72), rgba(4,8,5,.8)),
        url("/ui/home2/gc-home2-grid.svg");
      background-size: cover;
    }

    .gc-news-spotlight-v2 img {
      width: 100%;
      height: 100%;
      min-height: 300px;
      object-fit: cover;
      filter: saturate(.88) brightness(.74);
    }

    /* Catálogo: evitar que "Todas las noticias" parta en desktop */
    .gc-news-catalog-head-v2 {
      grid-template-columns: minmax(0, auto) minmax(360px, 520px);
    }

    .gc-news-catalog-head-v2 h2 {
      font-size: clamp(28px, 3.45vw, 42px);
      line-height: .94;
      letter-spacing: -.04em;
      white-space: nowrap;
    }

    .gc-news-catalog-head-v2 p {
      align-self: center;
    }

    .gc-news-grid-v2 .gc-archive-card {
      min-height: 100%;
    }

    .gc-news-grid-v2 .gc-archive-card img,
    .gc-news-grid-v2 .gc-archive-card__mark {
      aspect-ratio: 16 / 9;
      min-height: 0;
    }

    .gc-news-grid-v2 .gc-archive-card__mark {
      color: var(--green);
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: .12em;
      text-transform: uppercase;
    }

    .gc-news-grid-v2 .gc-archive-card p {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      min-height: 61px;
    }

    .gc-news-grid-v2 .gc-archive-card footer b {
      color: var(--green);
      font-family: var(--mono);
      text-transform: uppercase;
    }

    @media (max-width: 1120px) {
      .gc-news-category-grid-v2 {
        grid-template-columns: repeat(2, minmax(0,1fr));
      }

      .gc-news-spotlight-v2 {
        grid-template-columns: 1fr;
      }

      .gc-news-catalog-head-v2 h2 {
        white-space: normal;
      }
    }

    @media (max-width: 720px) {
      .gc-news-category-grid-v2 {
        grid-template-columns: 1fr;
      }

      .gc-news-spotlight-v2 .gc-archive-spotlight__copy {
        padding: 18px;
      }

      .gc-news-spotlight-v2 h2 {
        font-size: clamp(25px, 8.8vw, 36px);
      }

      .gc-news-spotlight-v2 dl {
        grid-template-columns: 1fr;
      }

      .gc-news-catalog-head-v2 h2 {
        font-size: clamp(26px, 9vw, 38px);
      }
    }
  </style>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-news-page]');
      const input = root?.querySelector('[data-news-search-input]');
      const clearBtn = root?.querySelector('[data-news-clear]');
      const list = root?.querySelector('[data-news-list]');
      const empty = root?.querySelector('[data-news-empty]');
      const feature = root?.querySelector('[data-news-feature]');
      const totalNode = root?.querySelector('[data-news-total]');
      const resultCount = root?.querySelector('[data-news-result-count]');
      const categoryButtons = [...root?.querySelectorAll('[data-news-category]') || []];

      const PUBLIC_CATEGORIES = ['Update', 'Sim racing', 'Motorsport', 'Herramientas', 'GrassCutters'];
      const fallbackImage = '/ui/home2/gc-home2-news-sim.svg';

      let posts = [];
      let activeCategory = 'all';
      let query = '';

      const esc = (value) => String(value ?? '').replace(/[&<>'"]/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        "'": '&#39;',
        '"': '&quot;',
      }[char]));

      const normalize = (value) => String(value || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '');

      const publicCategory = (value) => {
        const raw = String(value || '').trim();
        const found = PUBLIC_CATEGORIES.find((category) => normalize(category) === normalize(raw));
        return found || 'Update';
      };

      const postHref = (post) => post.href || `/noticias/${post.slug}`;

      const filteredPosts = () => {
        const q = normalize(query);

        return posts.filter((post) => {
          const category = publicCategory(post.category);
          const categoryOk = activeCategory === 'all' || normalize(category) === normalize(activeCategory);
          const textOk = !q || normalize([post.title, post.excerpt, category, post.category, post.body].join(' ')).includes(q);

          return categoryOk && textOk;
        });
      };

      const setActiveButtons = () => {
        categoryButtons.forEach((button) => {
          const selected = normalize(button.dataset.newsCategory || 'all') === normalize(activeCategory);
          button.classList.toggle('is-active', selected);
          button.setAttribute('aria-pressed', selected ? 'true' : 'false');
        });
      };

      const updateCounts = () => {
        const counts = new Map(PUBLIC_CATEGORIES.map((category) => [category, 0]));

        posts.forEach((post) => {
          const category = publicCategory(post.category);
          counts.set(category, (counts.get(category) || 0) + 1);
        });

        if (totalNode) totalNode.textContent = String(posts.length);

        root?.querySelectorAll('[data-news-count]').forEach((node) => {
          const category = node.getAttribute('data-news-count') || '';
          node.textContent = String(counts.get(category) || 0);
        });

        root?.querySelectorAll('[data-news-plural]').forEach((node) => {
          const category = node.getAttribute('data-news-plural') || '';
          node.textContent = (counts.get(category) || 0) === 1 ? '' : 'es';
        });
      };

      const renderFeature = () => {
        if (!feature) return;

        const selected = filteredPosts()[0] || posts[0];

        if (!selected) {
          feature.innerHTML = `
            <div class="gc-archive-spotlight__copy">
              <span class="gc-archive-panel__eyebrow">Noticia destacada</span>
              <h2>No hay noticias todavía</h2>
              <p>Publica una entrada desde /admin/noticias para verla aquí.</p>
              <dl>
                <div><dt>Categoría</dt><dd>Update</dd></div>
                <div><dt>Fecha</dt><dd>Preparado</dd></div>
                <div><dt>Canal</dt><dd>GC News</dd></div>
              </dl>
              <a href="/admin/noticias">Ir al admin</a>
            </div>
            <figure>
              <img src="${fallbackImage}" alt="" loading="lazy" />
            </figure>
          `;
          return;
        }

        const category = publicCategory(selected.category);

        feature.innerHTML = `
          <div class="gc-archive-spotlight__copy">
            <span class="gc-archive-panel__eyebrow">Noticia destacada</span>
            <h2>${esc(selected.title || 'Noticia')}</h2>
            <p>${esc(selected.excerpt || 'Publicación del newsroom GrassCutters.')}</p>
            <dl>
              <div><dt>Categoría</dt><dd>${esc(category)}</dd></div>
              <div><dt>Fecha</dt><dd>${esc(selected.date || 'Publicado')}</dd></div>
              <div><dt>Canal</dt><dd>GC News</dd></div>
            </dl>
            <a href="${esc(postHref(selected))}">Leer noticia</a>
          </div>

          <figure>
            <img src="${esc(selected.image || fallbackImage)}" alt="${esc(selected.imageAlt || selected.title || '')}" loading="lazy" />
          </figure>
        `;
      };

      const cardHtml = (post) => {
        const category = publicCategory(post.category);

        return `
          <a
            class="gc-archive-card"
            href="${esc(postHref(post))}"
            data-news-card
            data-category="${esc(category)}"
            data-search="${esc([post.title, post.excerpt, post.body, category, post.category].join(' '))}"
          >
            ${post.image
              ? `<img src="${esc(post.image)}" alt="${esc(post.imageAlt || post.title || '')}" loading="lazy" />`
              : `<span class="gc-archive-card__mark">Newsroom</span>`
            }

            <div>
              <small>${esc(category)}</small>
              <strong>${esc(post.title || 'Noticia')}</strong>
              <p>${esc(post.excerpt || 'Publicación del newsroom GrassCutters.')}</p>
              <footer>
                ${post.date ? `<em>${esc(post.date)}</em>` : '<em>GC News</em>'}
                <b>Abrir</b>
              </footer>
            </div>
          </a>
        `;
      };

      const renderList = () => {
        if (!list) return;

        const visible = filteredPosts();
        const selectedFeature = visible[0] || posts[0];
        const rest = visible.filter((post) => !selectedFeature || post.id !== selectedFeature.id);

        if (resultCount) resultCount.textContent = String(visible.length);

        list.innerHTML = rest.length
          ? rest.map(cardHtml).join('')
          : `
            <article class="gc-archive-empty">
              <strong>Sin más resultados.</strong>
              <p>No hay más noticias que coincidan con la búsqueda o categoría actual.</p>
            </article>
          `;

        if (empty) empty.hidden = true;
      };

      const render = () => {
        setActiveButtons();
        updateCounts();
        renderFeature();
        renderList();
      };

      categoryButtons.forEach((button) => {
        button.addEventListener('click', () => {
          activeCategory = button.dataset.newsCategory || 'all';
          render();
        });
      });

      input?.addEventListener('input', () => {
        query = input.value || '';
        render();
      });

      clearBtn?.addEventListener('click', () => {
        query = '';
        activeCategory = 'all';
        if (input) input.value = '';
        render();
        input?.focus();
      });

      fetch('/api/noticias?limit=72', { cache: 'no-store' })
        .then((response) => response.ok ? response.json() : Promise.reject(new Error(`HTTP ${response.status}`)))
        .then((data) => {
          posts = Array.isArray(data.posts) ? data.posts : [];
          render();
        })
        .catch((error) => {
          posts = [];
          render();

          if (list) {
            list.innerHTML = `
              <article class="gc-archive-empty">
                <strong>No se pudieron cargar las noticias.</strong>
                <p>${esc(error.message || 'Error desconocido')}</p>
              </article>
            `;
          }
        });
    })();
  </script>
</MarketingLayout>

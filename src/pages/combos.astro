---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout
  title="Combos | GrassCutters Racing"
  description="Centro de combos de GrassCutters Racing con circuitos, coches, actividad real y referencias para decidir dónde rodar."
  canonicalPath="/combos"
  ogImage="/og/combos-og.png"
  ogImageAlt="Combos GrassCutters Racing"
>
  <div class="gc-page gc-combos-page-v42">
    <section class="gc-hero gc-hero--compact gc-combos-hero-v42">
      <div>
        <span class="gc-kicker">Centro de combos</span>
        <h1 class="gc-title">Combos.</h1>
        <p class="gc-subtitle">Circuitos, paquetes de coches, actividad real y referencias rápidas para decidir dónde rodar.</p>
        <div class="gc-hero__meta">
          <span class="gc-chip gc-chip--accent">Circuitos agrupados</span>
          <span class="gc-chip">Actividad real</span>
          <span class="gc-chip">Ficha por combo</span>
        </div>
      </div>

      <aside class="gc-hero-sidecard gc-combos-sidecard-v42">
        <div><span>Combos</span><strong id="comboTotal">--</strong></div>
        <div><span>Visibles</span><strong id="comboVisible">--</strong></div>
        <div><span>Orden</span><strong id="comboSortLabel">Actividad reciente</strong></div>
        <div><span>Actualizado</span><strong id="comboUpdated">--:--</strong></div>
      </aside>
    </section>

    <section class="gc-metrics gc-combos-metrics-v42">
      <article class="gc-metric-card"><span>Combos</span><strong id="metricCombos">--</strong><small>detectados</small></article>
      <article class="gc-metric-card"><span>Con vueltas</span><strong id="metricActive">--</strong><small>actividad real</small></article>
      <article class="gc-metric-card"><span>Vueltas</span><strong id="metricLaps">--</strong><small>total agrupado</small></article>
      <article class="gc-metric-card"><span>Coches</span><strong id="metricCars">--</strong><small>únicos visibles</small></article>
    </section>

    <section class="gc-toolbar gc-combos-toolbar-v42" aria-label="Filtros de combos">
      <div class="gc-field gc-combos-search-v42">
        <label for="comboSearch">Buscar combo</label>
        <input class="gc-input" id="comboSearch" placeholder="Circuito, coche, marca o Combo ID" autocomplete="off" />
      </div>

      <div class="gc-field">
        <label for="comboActivity">Actividad</label>
        <select class="gc-select" id="comboActivity">
          <option value="all">Todos</option>
          <option value="active">Con vueltas</option>
          <option value="7">Últimos 7 días</option>
          <option value="30">Últimos 30 días</option>
        </select>
      </div>

      <div class="gc-field">
        <label for="comboSort">Orden</label>
        <select class="gc-select" id="comboSort">
          <option value="recent">Actividad reciente</option>
          <option value="laps">Más vueltas</option>
          <option value="drivers">Más pilotos</option>
          <option value="clean">Mayor limpieza</option>
          <option value="fastest">Mejor tiempo</option>
          <option value="cars">Más coches</option>
        </select>
      </div>

      <button class="gc-btn gc-btn--primary" id="reloadCombos" type="button">Actualizar</button>
      <button class="gc-btn" id="clearCombos" type="button">Limpiar</button>
    </section>

    <section class="gc-combo-feature-grid-v42">
      <article class="gc-combo-feature-v42" id="comboFeatureRecent"></article>
      <article class="gc-combo-feature-v42" id="comboFeatureLaps"></article>
      <article class="gc-combo-feature-v42" id="comboFeatureClean"></article>
    </section>

    <section class="gc-section-head gc-combos-section-head-v42">
      <div>
        <span class="gc-kicker">Selección rápida</span>
        <h2>Combos destacados</h2>
        <p id="cardsMeta">Cargando combos...</p>
      </div>
      <a href="/hotlaps" class="gc-btn">Ver hotlaps</a>
    </section>

    <section class="gc-combo-grid-v42" id="comboCards">
      <article class="gc-combo-card-v42"><p>Cargando combos...</p></article>
    </section>

    <section class="gc-section-head gc-combos-section-head-v42 gc-combos-table-head-v42">
      <div>
        <span class="gc-kicker">Listado</span>
        <h2>Vista compacta</h2>
        <p>Resumen limpio con circuitos agrupados y variantes unificadas.</p>
      </div>
    </section>

    <section class="gc-combo-table-shell-v42">
      <table class="gc-combo-table-v42">
        <thead>
          <tr>
            <th>Circuito</th>
            <th>Coches</th>
            <th>Vueltas</th>
            <th>Pilotos</th>
            <th>Limpieza</th>
            <th>Mejor vuelta</th>
            <th>Última actividad</th>
          </tr>
        </thead>
        <tbody id="comboTableBody">
          <tr><td colspan="7">Cargando combos...</td></tr>
        </tbody>
      </table>
    </section>
  </div>

  <style is:global>
    .gc-combos-page-v42{
      display:grid;
      gap:20px;
    }

    .gc-combos-hero-v42{
      display:grid;
      grid-template-columns:minmax(0,1fr) 290px;
      gap:18px;
      align-items:end;
    }

    .gc-combos-sidecard-v42{
      display:grid;
      gap:0;
      border:1px solid var(--line);
      border-top:2px solid var(--accent);
      background:linear-gradient(180deg, rgba(22,33,22,.82), rgba(8,15,8,.9));
    }

    .gc-combos-sidecard-v42 div{
      display:flex;
      justify-content:space-between;
      gap:12px;
      padding:14px 16px;
      border-bottom:1px solid var(--line);
    }

    .gc-combos-sidecard-v42 div:last-child{ border-bottom:0; }
    .gc-combos-sidecard-v42 span{
      color:var(--muted);
      text-transform:uppercase;
      font-size:11px;
      letter-spacing:.08em;
      font-weight:800;
    }
    .gc-combos-sidecard-v42 strong{ color:var(--text); }

    .gc-combos-metrics-v42{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:0;
      border:1px solid var(--line);
    }

    .gc-metric-card{
      padding:16px;
      border-right:1px solid var(--line);
      min-height:102px;
      display:grid;
      align-content:start;
      gap:4px;
      background:linear-gradient(180deg, rgba(8,18,8,.72), rgba(5,12,5,.82));
    }
    .gc-metric-card:last-child{ border-right:0; }
    .gc-metric-card span{
      color:var(--muted);
      text-transform:uppercase;
      font-size:11px;
      letter-spacing:.08em;
      font-weight:800;
    }
    .gc-metric-card strong{
      font-size:28px;
      line-height:1;
      color:var(--text);
    }
    .gc-metric-card small{
      color:var(--muted-2, var(--muted));
      text-transform:uppercase;
      font-size:10px;
      letter-spacing:.08em;
    }

    .gc-combos-toolbar-v42{
      display:grid;
      grid-template-columns:minmax(0,1.6fr) repeat(2,minmax(180px,.9fr)) auto auto;
      gap:10px;
      align-items:end;
    }
    .gc-combos-search-v42{ min-width:0; }

    .gc-combo-feature-grid-v42{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:12px;
    }

    .gc-combo-feature-v42,
    .gc-combo-card-v42{
      position:relative;
      overflow:hidden;
      border:1px solid var(--line);
      border-top:2px solid var(--accent);
      background:linear-gradient(180deg, rgba(8,18,8,.72), rgba(5,12,5,.88));
    }

    .gc-combo-feature-v42{
      min-height:280px;
      display:grid;
      align-content:space-between;
    }

    .gc-combo-card-v42{
      min-height:240px;
      display:grid;
      align-content:space-between;
    }

    .gc-track-banner-v42{
      position:relative;
      height:148px;
      overflow:hidden;
      border-bottom:1px solid var(--line);
      background:#091309;
    }
    .gc-combo-card-v42 .gc-track-banner-v42{ height:118px; }

    .gc-track-banner-v42 img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
      opacity:.92;
      transform:scale(1.01);
    }
    .gc-track-banner-v42::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(180deg, rgba(0,0,0,.08) 0%, rgba(0,0,0,.28) 55%, rgba(0,0,0,.68) 100%),
        radial-gradient(circle at top left, rgba(134,255,56,.18), transparent 34%);
      pointer-events:none;
    }

    .gc-track-banner-tag-v42{
      position:absolute;
      top:10px;
      left:10px;
      z-index:2;
      padding:4px 8px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(4,10,4,.58);
      color:#d7ffbd;
      font-size:10px;
      letter-spacing:.08em;
      font-weight:800;
      text-transform:uppercase;
      backdrop-filter:blur(4px);
    }

    .gc-feature-body-v42,
    .gc-card-body-v42{
      padding:14px;
      display:grid;
      gap:10px;
    }
    .gc-feature-body-v42 h3,
    .gc-card-body-v42 h3{
      margin:0;
      color:var(--text);
      line-height:.95;
      letter-spacing:-.04em;
      text-transform:uppercase;
      font-weight:900;
    }
    .gc-feature-body-v42 h3{ font-size:clamp(28px,3vw,38px); }
    .gc-card-body-v42 h3{ font-size:clamp(22px,2.2vw,30px); }

    .gc-feature-meta-v42,
    .gc-card-meta-v42{
      color:var(--muted);
      font-size:12px;
      line-height:1.45;
      min-height:34px;
    }


    .gc-fastest-line-v52{
      display:grid;
      gap:3px;
      margin:0;
      padding:10px 0 8px;
      border-top:1px solid color-mix(in srgb,var(--line) 70%,transparent);
      border-bottom:1px solid color-mix(in srgb,var(--line) 70%,transparent);
    }

    .gc-fastest-line-v52 span{
      color:var(--accent);
      font-size:10px;
      font-weight:900;
      letter-spacing:.08em;
      text-transform:uppercase;
    }

    .gc-fastest-line-v52 strong{
      color:var(--text);
      font-size:13px;
      line-height:1.25;
      font-weight:850;
    }

    .gc-car-summary-line-v52{
      margin:0;
      color:var(--muted);
      font-size:12px;
      line-height:1.4;
    }

    .gc-card-body-v42,
    .gc-feature-body-v42{
      position:relative;
    }

    .gc-combo-card-v42 .gc-kicker,
    .gc-combo-feature-v42 .gc-kicker{
      color:var(--accent);
      letter-spacing:.09em;
    }

    .gc-pill-row-v42{
      display:flex;
      flex-wrap:wrap;
      gap:6px;
    }
    .gc-pill-v42{
      display:inline-flex;
      align-items:center;
      min-height:22px;
      padding:0 7px;
      border:1px solid var(--line);
      color:#cde8c3;
      background:rgba(255,255,255,.03);
      font-size:10px;
      text-transform:uppercase;
      letter-spacing:.06em;
      font-weight:700;
    }
    .gc-pill-v42--muted{ color:var(--muted); }

    .gc-stats-row-v42{
      display:flex;
      flex-wrap:wrap;
      gap:6px;
    }

    .gc-stat-badge-v42{
      display:inline-flex;
      align-items:center;
      gap:6px;
      min-height:24px;
      padding:0 8px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.03);
      color:var(--text);
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:.05em;
      font-weight:800;
    }
    .gc-stat-badge-v42 span{ color:var(--muted); }

    .gc-combo-grid-v42{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:12px;
    }

    .gc-combos-section-head-v42{
      display:flex;
      justify-content:space-between;
      align-items:end;
      gap:12px;
      padding-top:2px;
      border-top:1px solid var(--line);
    }
    .gc-combos-section-head-v42 h2{
      margin:.25rem 0 .15rem;
      font-size:32px;
      letter-spacing:-.04em;
      text-transform:uppercase;
    }
    .gc-combos-section-head-v42 p{ color:var(--muted); margin:0; }

    .gc-combo-table-shell-v42{
      overflow:auto;
      border:1px solid var(--line);
      background:linear-gradient(180deg, rgba(8,18,8,.72), rgba(5,12,5,.88));
    }

    .gc-combo-table-v42{
      width:100%;
      border-collapse:collapse;
      min-width:900px;
    }
    .gc-combo-table-v42 th,
    .gc-combo-table-v42 td{
      padding:12px 14px;
      border-bottom:1px solid var(--line);
      vertical-align:top;
      text-align:left;
    }
    .gc-combo-table-v42 th{
      color:var(--muted);
      font-size:11px;
      letter-spacing:.08em;
      text-transform:uppercase;
      font-weight:800;
      background:rgba(255,255,255,.02);
    }
    .gc-combo-table-v42 td{
      color:var(--text);
      font-size:14px;
    }
    .gc-combo-table-v42 small{
      color:var(--muted);
      display:block;
      margin-top:4px;
      font-size:11px;
    }

    .gc-empty-card-v42{
      padding:18px;
      color:var(--muted);
    }

    @media (max-width: 1180px){
      .gc-combos-hero-v42,
      .gc-combo-feature-grid-v42,
      .gc-combo-grid-v42{
        grid-template-columns:1fr;
      }
      .gc-combos-toolbar-v42{
        grid-template-columns:1fr 1fr;
      }
      .gc-combos-toolbar-v42 .gc-combos-search-v42{ grid-column:1 / -1; }
    }

    @media (max-width: 860px){
      .gc-combos-metrics-v42{ grid-template-columns:repeat(2,minmax(0,1fr)); }
      .gc-metric-card:nth-child(2){ border-right:0; }
      .gc-metric-card:nth-child(1),
      .gc-metric-card:nth-child(2){ border-bottom:1px solid var(--line); }
      .gc-combos-toolbar-v42{ grid-template-columns:1fr; }
      .gc-combos-section-head-v42{ align-items:start; flex-direction:column; }
      .gc-track-banner-v42{ height:136px; }
      .gc-combo-card-v42 .gc-track-banner-v42{ height:110px; }
    }
  </style>

  <script is:inline src="/js/gc-track-images.js"></script>
  <script is:inline>
    (() => {
      const els = {
        total: document.getElementById('comboTotal'),
        visible: document.getElementById('comboVisible'),
        sortLabel: document.getElementById('comboSortLabel'),
        updated: document.getElementById('comboUpdated'),

        metricCombos: document.getElementById('metricCombos'),
        metricActive: document.getElementById('metricActive'),
        metricLaps: document.getElementById('metricLaps'),
        metricCars: document.getElementById('metricCars'),

        search: document.getElementById('comboSearch'),
        activity: document.getElementById('comboActivity'),
        sort: document.getElementById('comboSort'),
        reload: document.getElementById('reloadCombos'),
        clear: document.getElementById('clearCombos'),

        cardsMeta: document.getElementById('cardsMeta'),
        cards: document.getElementById('comboCards'),
        table: document.getElementById('comboTableBody'),

        recent: document.getElementById('comboFeatureRecent'),
        laps: document.getElementById('comboFeatureLaps'),
        clean: document.getElementById('comboFeatureClean'),
      };

      const MIN_LAPS = 50;
      let rawCombos = [];
      let groupedCombos = [];

      const pick = (obj, keys, fallback = null) => {
        for (const key of keys) {
          const value = key.split('.').reduce((acc, part) => acc && typeof acc === 'object' ? acc[part] : undefined, obj);
          if (value !== undefined && value !== null && value !== '') return value;
        }
        return fallback;
      };

      const num = (value, fallback = 0) => {
        const n = Number(value);
        return Number.isFinite(n) ? n : fallback;
      };

      const escapeHtml = (value) => String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

      const slugify = (value) => String(value || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '_')
        .replace(/^_+|_+$/g, '');

      const cleanObjectText = (value) => {
        if (value === undefined || value === null) return '';

        if (typeof value === 'string' || typeof value === 'number') {
          const text = String(value).trim();
          return text === '[object Object]' ? '' : text;
        }

        if (Array.isArray(value)) {
          return value.map(cleanObjectText).filter(Boolean).join(' ');
        }

        if (typeof value === 'object') {
          return cleanObjectText(
            value.name ??
            value.Name ??
            value.trackName ??
            value.TrackName ??
            value.track ??
            value.Track ??
            value.code ??
            value.Code ??
            value.id ??
            value.ID ??
            value.slug ??
            value.Slug ??
            ''
          );
        }

        return '';
      };

      const aliasMap = (() => {
        const groups = {
          zolder: ['zolder','rt_zolder','nrms_zolder','zolder2017','zolder_2017','circuit_zolder','terlaemen'],
          sebring: ['sebring','rt_sebring','sebring2021','sebring_2021','sebring_international','sebring_international_raceway'],
          phillip_island: ['phillip_island','philip_island','phillip_island_2013','philip_island_2013','vr_phillip_island','vr_phillip_island_2013'],
          mugello: ['mugello','ks_mugello','autodromo_internazionale_del_mugello'],
          spa: ['spa','ks_spa','spa_francorchamps','circuit_de_spa_francorchamps'],
          monza: ['monza','ks_monza66','autodromo_nazionale_monza'],
          imola: ['imola','ks_imola','autodromo_enzo_e_dino_ferrari'],
          barcelona: ['barcelona','ks_barcelona','circuit_de_barcelona_catalunya'],
          brands_hatch: ['brands_hatch','ks_brands_hatch'],
          nurburgring: ['nurburgring','ks_nurburgring'],
          nordschleife: ['nordschleife','ks_nordschleife','nurburgring_nordschleife'],
          silverstone: ['silverstone','ks_silverstone'],
          zandvoort: ['zandvoort','ks_zandvoort'],
          red_bull_ring: ['red_bull_ring','ks_red_bull_ring','spielberg'],
          vallelunga: ['vallelunga','ks_vallelunga'],
          laguna_seca: ['laguna_seca','ks_laguna_seca','weathertech_raceway_laguna_seca'],
          bathurst: ['bathurst','mount_panorama'],
          donington: ['donington','donington_park'],
          road_america: ['road_america'],
          road_atlanta: ['road_atlanta'],
          watkins_glen: ['watkins_glen'],
          daytona: ['daytona'],
          vir: ['vir','virginia','virginia_international_raceway'],
          mosport: ['mosport','ctmp','canadian_tire_motorsport_park'],
          interlagos: ['interlagos'],
          suzuka: ['suzuka'],
          fuji: ['fuji'],
          okayama: ['okayama'],
          tsukuba: ['tsukuba'],
          paul_ricard: ['paul_ricard','ricard','le_castellet','circuit_paul_ricard'],
          le_mans: ['le_mans','lemans','la_sarthe','circuit_de_la_sarthe'],
          hockenheim: ['hockenheim','hockenheimring'],
          hungaroring: ['hungaroring'],
          brno: ['brno'],
          most: ['most'],
          misano: ['misano'],
          jerez: ['jerez'],
          jarama: ['jarama'],
          portimao: ['portimao','algarve']
        };

        const map = new Map();
        Object.entries(groups).forEach(([canonical, aliases]) => {
          aliases.forEach((alias) => map.set(slugify(alias), canonical));
        });
        return map;
      })();

      const rawTrackName = (combo) => {
        const direct = pick(combo, [
          'trackName',
          'displayTrackName',
          'track.name',
          'track.Name',
          'track.id',
          'track.ID',
          'track',
          'trackCode',
          'track_id',
          'Track',
          'TrackName',
          'name'
        ], '');

        const text = cleanObjectText(direct);
        if (text) return text;

        // Último recurso: buscar algo que parezca track en el objeto completo.
        const fallback = cleanObjectText(combo?.track) || cleanObjectText(combo?.Track);
        return fallback || 'unknown_track';
      };

      const canonicalTrack = (combo) => {
        const raw = rawTrackName(combo);
        const base = slugify(raw).replace(/(?:_|-)?(?:19|20)\d{2}(?:_|-)?/g, '_').replace(/^_+|_+$/g, '');
        const variants = new Set([base]);

        base.split('_').forEach((part) => {
          if (part && !['rt','nrms','ks','acu','actk','vr','online','offline','gp','full','layout','track','circuit'].includes(part)) {
            variants.add(part);
          }
        });

        for (const item of variants) {
          if (aliasMap.has(item)) return aliasMap.get(item);
        }

        const compactBase = base.replace(/_/g, '');
        for (const [alias, canonical] of aliasMap.entries()) {
          const compactAlias = alias.replace(/_/g, '');
          if (compactAlias.length >= 5 && compactBase.includes(compactAlias)) return canonical;
        }

        return base || 'unknown_track';
      };

      const displayTrack = (combo) => {
        const canonical = combo.__canonicalTrack || canonicalTrack(combo);
        return canonical.replace(/_/g, ' ').replace(/\b\w/g, (ch) => ch.toUpperCase());
      };

      const carList = (combo) => {
        const direct = pick(combo, ['carNames','cars','carList','carModels'], []);
        if (Array.isArray(direct)) {
          return [...new Set(direct.map((item) => {
            if (typeof item === 'string') return item.trim();
            return cleanObjectText(item);
          }).filter(Boolean))];
        }

        const summary = cleanObjectText(pick(combo, ['carSummary','carsSummary','summaryCars'], ''));
        return summary ? summary.split('+').map((item) => item.trim()).filter(Boolean) : [];
      };

      const comboId = (combo) => pick(combo, ['comboId','id','ComboId'], null);
      const totalLaps = (combo) => num(pick(combo, ['totalLaps','laps','lapCount','TotalLaps'], 0), 0);
      const validLaps = (combo) => num(pick(combo, ['validLaps','validLapCount','cleanLaps'], 0), 0);
      const driversCount = (combo) => num(pick(combo, ['driversCount','driverCount','pilots','Pilots'], 0), 0);
      const dateRaw = (combo) => pick(combo, ['lastActivityIso','lastDate','lastActivity','updatedAt','date','LastDate'], '');

      const dateMs = (value) => {
        const ms = value ? new Date(value).getTime() : 0;
        return Number.isFinite(ms) ? ms : 0;
      };

      const bestTimeTextRaw = (combo) => cleanObjectText(pick(combo, [
        'bestLapTimeFormatted','bestTimeFormatted','bestLapFormatted','bestLapTime','bestTime','bestLap.lapTimeFormatted','bestLap.lapTime'
      ], ''));

      const bestTimeMs = (combo) => {
        const direct = num(pick(combo, ['bestLapTimeMs','bestTimeMs','bestLapMs','bestLap.lapTimeMs','bestLap.LapTime'], NaN), NaN);
        if (Number.isFinite(direct) && direct > 0) return direct;

        const text = bestTimeTextRaw(combo).trim();
        const match = text.match(/^(?:(\d+):)?(\d{1,2})(?:[.,](\d{1,3}))?$/);
        if (!match) return Infinity;
        const minutes = Number(match[1] || 0);
        const seconds = Number(match[2] || 0);
        const ms = Number(String(match[3] || '0').padEnd(3, '0').slice(0, 3));
        return minutes * 60000 + seconds * 1000 + ms;
      };

      const formatTimeMs = (ms) => {
        if (!Number.isFinite(ms) || ms <= 0 || ms === Infinity) return '--';
        const minutes = Math.floor(ms / 60000);
        const seconds = Math.floor((ms % 60000) / 1000);
        const millis = Math.floor(ms % 1000);
        return `${minutes}:${String(seconds).padStart(2, '0')}.${String(millis).padStart(3, '0')}`;
      };

      const bestTimeText = (combo) => bestTimeTextRaw(combo) || formatTimeMs(bestTimeMs(combo));

      const bestDriver = (combo) => cleanObjectText(pick(combo, [
        'bestDriverName','fastestDriverName','leaderName','bestLap.driverName','bestLap.playerName','bestLap.name'
      ], ''));

      const bestCarName = (combo) => cleanObjectText(pick(combo, [
        'bestCarName',
        'fastestCarName',
        'bestLap.carName',
        'bestLap.car.name',
        'bestLap.car',
        'bestLap.carModel',
        'bestLap.model',
        'carName'
      ], ''));

      const fastestSummary = (combo) => {
        const driver = bestDriver(combo) || 'Sin piloto';
        const car = bestCarName(combo) || carList(combo)[0] || 'Coche sin identificar';
        const time = bestTimeText(combo) || '--';
        return `${driver} - ${car} - ${time}`;
      };

      const carPackageLine = (combo) => {
        const cars = carList(combo);
        if (!cars.length) return 'Paquete de coches por confirmar';
        const shown = cars.slice(0, 2).join(' + ');
        const rest = cars.length > 2 ? ` + ${cars.length - 2} más` : '';
        return `${cars.length} ${cars.length === 1 ? 'coche' : 'coches'} - ${shown}${rest}`;
      };

      const carPackageCountLine = (combo) => {
        const cars = carList(combo);
        const count = cars.length;
        const laps = totalLaps(combo);
        const drivers = driversCount(combo);
        return `${count || 0} ${count === 1 ? 'coche permitido' : 'coches permitidos'} · ${formatNumber(laps)} vueltas · ${formatNumber(drivers)} pilotos`;
      };

      const cleanPct = (combo) => totalLaps(combo) ? (validLaps(combo) / totalLaps(combo)) * 100 : 0;
      const formatNumber = (value) => new Intl.NumberFormat('es-ES').format(num(value, 0));

      const formatDate = (value) => {
        const date = value ? new Date(value) : null;
        if (!date || Number.isNaN(date.getTime())) return 'Sin fecha';
        return date.toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' });
      };

      const comboUrl = (combo) => {
        const id = combo.canonicalComboId ?? combo.comboId ?? combo.id;
        return id !== null && id !== undefined && id !== '' ? `/combos/${encodeURIComponent(id)}` : '/combos';
      };

      const searchText = (combo) => [
        displayTrack(combo),
        rawTrackName(combo),
        ...(combo.__rawTrackNames || []),
        ...carList(combo),
        comboId(combo)
      ].join(' ').toLowerCase();

      const mergeCombos = (rows) => {
        const groups = new Map();

        rows.forEach((combo) => {
          const canonical = canonicalTrack(combo);
          const id = comboId(combo);

          if (!groups.has(canonical)) {
            groups.set(canonical, {
              ...combo,
              __canonicalTrack: canonical,
              __rawTrackNames: [rawTrackName(combo)].filter(Boolean),
              __variantCount: 1,
              totalLaps: totalLaps(combo),
              validLaps: validLaps(combo),
              driversCount: driversCount(combo),
              bestLapTimeMs: bestTimeMs(combo),
              bestLapTimeFormatted: bestTimeText(combo),
              bestDriverName: bestDriver(combo),
              bestCarName: bestCarName(combo),
              cars: carList(combo),
              lastActivityIso: dateRaw(combo),
              canonicalComboId: id,
              comboId: id,
              id: id,
            });
            return;
          }

          const current = groups.get(canonical);
          current.__variantCount += 1;
          current.__rawTrackNames = [...new Set([...current.__rawTrackNames, rawTrackName(combo)].filter(Boolean))];
          current.totalLaps += totalLaps(combo);
          current.validLaps += validLaps(combo);
          current.driversCount = Math.max(current.driversCount, driversCount(combo));
          current.cars = [...new Set([...(current.cars || []), ...carList(combo)])];

          const comboBest = bestTimeMs(combo);
          if (comboBest < current.bestLapTimeMs) {
            current.bestLapTimeMs = comboBest;
            current.bestLapTimeFormatted = bestTimeText(combo);
            current.bestDriverName = bestDriver(combo);
            current.bestCarName = bestCarName(combo);
          }

          if (dateMs(dateRaw(combo)) > dateMs(current.lastActivityIso)) {
            current.lastActivityIso = dateRaw(combo);
            current.canonicalComboId = id ?? current.canonicalComboId;
            current.comboId = id ?? current.comboId;
            current.id = id ?? current.id;
          }
        });

        return [...groups.values()];
      };

      const imageCandidates = (combo) => {
        const canonical = combo.__canonicalTrack || canonicalTrack(combo);
        const helper = window.GCTrackImages;
        if (helper?.candidates) {
          return helper.candidates(canonical).filter((url) => !url.includes('object_object'));
        }

        return [
          `/images/tracks/${canonical}.webp`,
          `/images/tracks/${canonical}.jpg`,
          `/images/tracks/${canonical}.png`,
          `/imagenes/tracks/${canonical}.webp`,
          `/imagenes/tracks/${canonical}.jpg`,
        ];
      };

      const renderBanner = (combo, label) => {
        const candidates = imageCandidates(combo);
        const primary = candidates[0] || '';
        const fallbackList = candidates.slice(1).map((item) => escapeHtml(item)).join('|');

        return `
          <div class="gc-track-banner-v42">
            <span class="gc-track-banner-tag-v42">${escapeHtml(label)}</span>
            <img src="${escapeHtml(primary)}" alt="${escapeHtml(displayTrack(combo))}" loading="lazy" data-fallbacks="${fallbackList}" data-fallback-index="0"
              onerror="const list=(this.dataset.fallbacks||'').split('|').filter(Boolean); const i=Number(this.dataset.fallbackIndex||0); if(list[i]){this.dataset.fallbackIndex=String(i+1); this.src=list[i];} else { this.style.display='none'; }" />
          </div>
        `;
      };

      const renderFeatureCard = (combo, label, target) => {
        if (!combo) {
          target.innerHTML = `<div class="gc-empty-card-v42">Sin datos suficientes.</div>`;
          return;
        }

        target.innerHTML = `
          ${renderBanner(combo, label)}
          <div class="gc-feature-body-v42">
            <div>
              <h3>${escapeHtml(displayTrack(combo))}</h3>
              <p class="gc-fastest-line-v52">
                <span>Mejor referencia</span>
                <strong>${escapeHtml(fastestSummary(combo))}</strong>
              </p>
              <p class="gc-car-summary-line-v52">${escapeHtml(carPackageCountLine(combo))}</p>
            </div>
            <div>
              <div class="gc-stats-row-v42">
                <span class="gc-stat-badge-v42"><span>Vueltas</span>${escapeHtml(formatNumber(totalLaps(combo)))}</span>
                <span class="gc-stat-badge-v42"><span>Pilotos</span>${escapeHtml(formatNumber(driversCount(combo)))}</span>
                <span class="gc-stat-badge-v42"><span>Variantes</span>${escapeHtml(String(combo.__variantCount || 1))}</span>
              </div>
              <div class="gc-stats-row-v42" style="margin-top:8px">
                <a class="gc-btn gc-btn--primary" href="${escapeHtml(comboUrl(combo))}">Abrir ficha</a>
              </div>
            </div>
          </div>
        `;
      };

      const renderCard = (combo, index) => {
        return `
          <article class="gc-combo-card-v42">
            ${renderBanner(combo, `Combo ${index + 1}`)}
            <div class="gc-card-body-v42">
              <div>
                <span class="gc-kicker">Combo ${index + 1}</span>
                <h3>${escapeHtml(displayTrack(combo))}</h3>
                <p class="gc-fastest-line-v52">
                  <span>Más rápido</span>
                  <strong>${escapeHtml(fastestSummary(combo))}</strong>
                </p>
                <p class="gc-car-summary-line-v52">${escapeHtml(carPackageCountLine(combo))}</p>
              </div>
              <div>
                <div class="gc-stats-row-v42">
                  <span class="gc-stat-badge-v42"><span>Vueltas</span>${escapeHtml(formatNumber(totalLaps(combo)))}</span>
                  <span class="gc-stat-badge-v42"><span>Pilotos</span>${escapeHtml(formatNumber(driversCount(combo)))}</span>
                  <span class="gc-stat-badge-v42"><span>Variantes</span>${escapeHtml(String(combo.__variantCount || 1))}</span>
                </div>
                <div class="gc-stats-row-v42" style="margin-top:8px">
                  <a class="gc-btn gc-btn--primary" href="${escapeHtml(comboUrl(combo))}">Abrir ficha</a>
                </div>
              </div>
            </div>
          </article>
        `;
      };

      const sortRows = (rows) => {
        const copy = [...rows];
        switch (els.sort.value) {
          case 'laps': return copy.sort((a, b) => totalLaps(b) - totalLaps(a));
          case 'drivers': return copy.sort((a, b) => driversCount(b) - driversCount(a));
          case 'clean': return copy.sort((a, b) => cleanPct(b) - cleanPct(a));
          case 'fastest': return copy.sort((a, b) => bestTimeMs(a) - bestTimeMs(b));
          case 'cars': return copy.sort((a, b) => carList(b).length - carList(a).length);
          case 'recent':
          default: return copy.sort((a, b) => dateMs(dateRaw(b)) - dateMs(dateRaw(a)));
        }
      };

      const passesActivity = (combo) => {
        if (els.activity.value === 'all') return true;
        if (els.activity.value === 'active') return totalLaps(combo) > 0;
        const days = Number(els.activity.value);
        if (!Number.isFinite(days)) return true;
        return dateMs(dateRaw(combo)) >= (Date.now() - days * 24 * 60 * 60 * 1000);
      };

      const currentRows = () => {
        const query = els.search.value.trim().toLowerCase();
        return sortRows(groupedCombos.filter((combo) => {
          if (totalLaps(combo) < MIN_LAPS) return false;
          if (!passesActivity(combo)) return false;
          if (query && !searchText(combo).includes(query)) return false;
          return true;
        }));
      };

      const renderMetrics = (rows) => {
        const active = groupedCombos.filter((combo) => totalLaps(combo) > 0).length;
        const laps = groupedCombos.reduce((sum, combo) => sum + totalLaps(combo), 0);
        const uniqueCars = new Set();
        rows.forEach((combo) => carList(combo).forEach((car) => uniqueCars.add(car.toLowerCase())));

        els.metricCombos.textContent = formatNumber(groupedCombos.length);
        els.metricActive.textContent = formatNumber(active);
        els.metricLaps.textContent = formatNumber(laps);
        els.metricCars.textContent = formatNumber(uniqueCars.size);

        els.total.textContent = formatNumber(rawCombos.length);
        els.visible.textContent = `${formatNumber(rows.length)} / ${formatNumber(groupedCombos.length)}`;
        els.sortLabel.textContent = els.sort.options[els.sort.selectedIndex]?.textContent || 'Actividad reciente';
        els.updated.textContent = new Date().toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });
      };

      const renderFeatures = (rows) => {
        const active = rows.filter((combo) => totalLaps(combo) > 0);
        const recent = active[0] || rows[0] || null;
        const mostLaps = [...active].sort((a, b) => totalLaps(b) - totalLaps(a))[0] || recent;
        const clean = [...active].sort((a, b) => cleanPct(b) - cleanPct(a))[0] || recent;

        renderFeatureCard(recent, 'Combo activo', els.recent);
        renderFeatureCard(mostLaps, 'Más rodado', els.laps);
        renderFeatureCard(clean, 'Más limpio', els.clean);
      };

      const renderCards = (rows) => {
        const shown = rows.slice(0, 6);
        els.cardsMeta.textContent = shown.length ? `${shown.length} destacados de ${rows.length} visibles` : 'Sin combos visibles con los filtros actuales.';
        els.cards.innerHTML = shown.length
          ? shown.map((combo, index) => renderCard(combo, index)).join('')
          : `<article class="gc-combo-card-v42"><div class="gc-empty-card-v42">Sin combos visibles. Prueba a limpiar filtros.</div></article>`;
      };

      const renderTable = (rows) => {
        els.table.innerHTML = rows.length ? rows.map((combo) => `
          <tr>
            <td>
              <strong>${escapeHtml(displayTrack(combo))}</strong>
              <small>${escapeHtml(rawTrackName(combo) || displayTrack(combo))}</small>
            </td>
            <td>${escapeHtml(carList(combo).slice(0, 3).join(' + ') || 'Sin coches')}${carList(combo).length > 3 ? `<small>+${carList(combo).length - 3} más</small>` : ''}</td>
            <td>${escapeHtml(formatNumber(totalLaps(combo)))}</td>
            <td>${escapeHtml(formatNumber(driversCount(combo)))}</td>
            <td>${escapeHtml(cleanPct(combo).toFixed(1))}%</td>
            <td>${escapeHtml(bestTimeText(combo))}${bestDriver(combo) ? `<small>${escapeHtml(bestDriver(combo))}</small>` : ''}</td>
            <td>${escapeHtml(formatDate(dateRaw(combo)))}<small>${escapeHtml(String(combo.__variantCount || 1))} variantes</small></td>
          </tr>
        `).join('') : `<tr><td colspan="7">No hay combos visibles con la política actual.</td></tr>`;
      };

      const draw = () => {
        const rows = currentRows();
        renderMetrics(rows);
        renderFeatures(rows);
        renderCards(rows);
        renderTable(rows);

        console.info('[GC combos polished cards v5.3]', {
          raw: rawCombos.length,
          grouped: groupedCombos.length,
          visible: rows.length,
          minLaps: MIN_LAPS,
          sort: els.sort.value,
          tracks: rows.slice(0, 8).map((combo) => ({
            raw: rawTrackName(combo),
            canonical: combo.__canonicalTrack,
            firstCandidate: imageCandidates(combo)[0]
          }))
        });
      };

      const load = async () => {
        try {
          const response = await fetch('/api/combos/stats?limit=300&sort=recent', { cache: 'no-store' });
          const data = await response.json();
          const source = Array.isArray(data) ? data : (data.rows || data.combos || data.items || data.results || data.data || []);
          rawCombos = Array.isArray(source) ? source.filter(Boolean) : [];
          groupedCombos = mergeCombos(rawCombos);
          draw();
        } catch (error) {
          console.error('[GC combos polished cards v5.3] error', error);
          els.cards.innerHTML = `<article class="gc-combo-card-v42"><div class="gc-empty-card-v42">Error cargando combos. Revisa /api/combos/stats.</div></article>`;
          els.table.innerHTML = `<tr><td colspan="7">Error cargando combos.</td></tr>`;
          [els.recent, els.laps, els.clean].forEach((node) => node.innerHTML = `<div class="gc-empty-card-v42">Sin datos.</div>`);
        }
      };

      [els.search, els.activity, els.sort].forEach((input) => {
        input.addEventListener('input', draw);
        input.addEventListener('change', draw);
      });

      els.reload.addEventListener('click', load);
      els.clear.addEventListener('click', () => {
        els.search.value = '';
        els.activity.value = 'all';
        els.sort.value = 'recent';
        draw();
      });

      load();
    })();
  </script>
</AppLayout>

---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---
<MarketingLayout title="Calendario | GrassCutters Racing" description="Calendario mensual de GrassCutters Racing con combo semanal, carreras LFM y carreras GrassCutters.">
  <section class="gc-public-shell gc-public-page-hero gc-calendar-page" data-calendar-page>
    <div class="gc-public-page-hero__grid">
      <div class="gc-public-page-hero__main">
        <span class="gc-public-kicker">Calendario GC</span>
        <h1 class="gc-public-title">Calendario de pista.</h1>
        <p class="gc-public-description">Consulta el combo semanal, las carreras LFM y las carreras GrassCutters programadas.</p>
        <div class="gc-actions">
          <a class="gc-public-btn gc-public-btn-primary" href="/app">Entrar a la plataforma</a>
          <a class="gc-public-btn gc-public-btn-secondary" href="/comunidad">Ver comunidad</a>
        </div>
      </div>
    </div>
  </section>

  <section class="gc-public-shell gc-public-section gc-calendar-shell" aria-label="Calendario mensual">
    <div class="gc-calendar-top">
      <div>
        <span class="gc-public-kicker">Vista mensual</span>
        <h2 id="gcCalendarTitle">Calendario</h2>
        <p id="gcCalendarMeta">Cargando calendario...</p>
      </div>
      <div class="gc-calendar-controls">
        <button class="gc-public-btn gc-public-btn-secondary" type="button" id="gcCalendarPrev">Mes anterior</button>
        <button class="gc-public-btn gc-public-btn-primary" type="button" id="gcCalendarToday">Hoy</button>
        <button class="gc-public-btn gc-public-btn-secondary" type="button" id="gcCalendarNext">Mes siguiente</button>
      </div>
    </div>

    <div class="gc-calendar-legend" aria-label="Tipos de evento">
      <span data-type="combo">Combo semanal</span>
      <span data-type="race_lfm">Carrera LFM</span>
      <span data-type="race_gc">Carrera GrassCutters</span>
      <span data-type="range">Evento varios días</span>
    </div>

    <div class="gc-calendar-grid" id="gcCalendarGrid" aria-live="polite"></div>
  </section>

  <section class="gc-public-shell gc-public-section gc-calendar-list-section">
    <div class="gc-public-section-head">
      <span class="gc-public-kicker">Próximos eventos</span>
      <h2 class="gc-public-section-title">Lo siguiente en el box.</h2>
      <p class="gc-public-section-lead">Eventos, combos y carreras organizados para la comunidad.</p>
    </div>
    <div class="gc-calendar-event-list" id="gcCalendarUpcoming"></div>
  </section>


  <script is:inline src="/js/gc-track-images.js"></script>
  <script is:inline>
    (() => {
      const title = document.getElementById('gcCalendarTitle');
      const meta = document.getElementById('gcCalendarMeta');
      const grid = document.getElementById('gcCalendarGrid');
      const upcoming = document.getElementById('gcCalendarUpcoming');
      const prev = document.getElementById('gcCalendarPrev');
      const next = document.getElementById('gcCalendarNext');
      const todayBtn = document.getElementById('gcCalendarToday');
      const monthNames = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
      const weekDays = ['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'];
      const typeLabels = { combo:'Combo semanal', race_lfm:'Carrera LFM', race_gc:'Carrera GrassCutters' };
      let cursor = new Date();
      let events = [];

      const pad = (n) => String(n).padStart(2, '0');
      const keyOf = (date) => `${date.getFullYear()}-${pad(date.getMonth()+1)}-${pad(date.getDate())}`;
      const escapeHtml = (value) => String(value ?? '').replace(/[&<>'"]/g, (char) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[char]));
      const parseDate = (value) => {
        const text = String(value || '').slice(0, 10);
        if (!/^\d{4}-\d{2}-\d{2}$/.test(text)) return null;
        const [y, m, d] = text.split('-').map(Number);
        const date = new Date(y, m - 1, d);
        return Number.isNaN(date.getTime()) ? null : date;
      };
      const addDays = (date, days) => { const next = new Date(date); next.setDate(next.getDate() + days); return next; };
      const daysBetween = (a, b) => Math.round((rangeStartOfDay(b) - rangeStartOfDay(a)) / 86400000);
      const eventDate = (event) => parseDate(event.startDate || event.date);
      const eventEndDate = (event) => parseDate(event.endDate) || eventDate(event);
      const isWeeklyRepeat = (event) => Boolean(event.repeatEnabled || event.repeatFrequency === 'weekly');
      const fmtEventTime = (event) => [event.startTime, event.endTime].filter(Boolean).join(' - ') || 'Horario por confirmar';
      const rangeStartOfDay = (date) => new Date(date.getFullYear(), date.getMonth(), date.getDate());
      const isRangeEvent = (event) => {
        const start = eventDate(event);
        const end = eventEndDate(event);
        return Boolean(start && end && daysBetween(start, end) > 0);
      };

      function pushRangeOccurrences(output, event, start, end, rangeStart, rangeEnd, repeatLabel, isOccurrence) {
        const durationDays = Math.max(0, daysBetween(start, end));
        for (let offset = 0; offset <= durationDays; offset += 1) {
          const day = addDays(start, offset);
          if (day < rangeStart || day > rangeEnd) continue;
          output.push({
            ...event,
            startDate: keyOf(day),
            occurrenceDate: keyOf(day),
            occurrenceStartDate: keyOf(start),
            occurrenceEndDate: keyOf(end),
            isOccurrence,
            isRangeDay: durationDays > 0,
            rangeDayIndex: offset + 1,
            rangeDayTotal: durationDays + 1,
            repeatLabel
          });
        }
      }

      function occurrenceStartsForEvent(event, rangeStart, rangeEnd) {
        const start = rangeStartOfDay(eventDate(event));
        const end = rangeStartOfDay(eventEndDate(event));
        const durationDays = Math.max(0, daysBetween(start, end));
        const starts = [];

        if (!isWeeklyRepeat(event)) return [{ start, end }];

        const untilRaw = parseDate(event.repeatUntil);
        const until = untilRaw ? rangeStartOfDay(untilRaw) : rangeEnd;
        const hardEnd = until < rangeEnd ? until : rangeEnd;
        let current = new Date(start);
        while (addDays(current, durationDays) < rangeStart) current = addDays(current, 7);

        let guard = 0;
        while (current <= hardEnd && guard < 370) {
          starts.push({ start: new Date(current), end: addDays(current, durationDays) });
          current = addDays(current, 7);
          guard += 1;
        }

        return starts;
      }

      function occurrencesForRange(rangeStart, rangeEnd, mode = 'days') {
        const from = rangeStartOfDay(rangeStart);
        const to = rangeStartOfDay(rangeEnd);
        const output = [];

        events.filter((event) => event.visible !== false && eventDate(event)).forEach((event) => {
          occurrenceStartsForEvent(event, from, to).forEach(({ start, end }) => {
            const isOccurrence = keyOf(start) !== keyOf(eventDate(event));
            const repeatLabel = isWeeklyRepeat(event) ? 'Semanal' : '';
            if (mode === 'blocks') {
              if (end < from || start > to) return;
              output.push({
                ...event,
                startDate: keyOf(start),
                occurrenceDate: keyOf(start),
                occurrenceStartDate: keyOf(start),
                occurrenceEndDate: keyOf(end),
                isOccurrence,
                isRangeDay: daysBetween(start, end) > 0,
                rangeDayTotal: daysBetween(start, end) + 1,
                repeatLabel
              });
              return;
            }
            pushRangeOccurrences(output, event, start, end, from, to, repeatLabel, isOccurrence);
          });
        });

        return output.sort((a, b) => String(a.occurrenceDate || a.startDate || '').localeCompare(String(b.occurrenceDate || b.startDate || '')) || String(a.startTime || '').localeCompare(String(b.startTime || '')));
      }

      function eventHtml(event) {
        const marks = [];
        if (event.repeatLabel) marks.push(event.repeatLabel);
        if (event.isRangeDay) marks.push(`${event.rangeDayIndex}/${event.rangeDayTotal}`);
        const meta = marks.length ? `<span class="gc-calendar-event-repeat">${escapeHtml(marks.join(' · '))}</span>` : '';
        const classes = `gc-calendar-event gc-track-image-card ${event.isRangeDay ? 'is-range' : ''}`;
        const content = `<strong>${escapeHtml(event.title || 'Evento')}</strong><small>${escapeHtml(fmtEventTime(event))}</small>${meta}`;
        return event.linkUrl ? `<a class="${classes}" data-track-image data-track-name="${escapeHtml(event.trackName || event.track || '')}" data-type="${escapeHtml(event.type || 'combo')}" href="${escapeHtml(event.linkUrl)}" target="_blank" rel="noreferrer">${content}</a>` : `<div class="${classes}" data-track-image data-track-name="${escapeHtml(event.trackName || event.track || '')}" data-type="${escapeHtml(event.type || 'combo')}">${content}</div>`;
      }

      function render() {
        const year = cursor.getFullYear();
        const month = cursor.getMonth();
        title.textContent = `${monthNames[month]} ${year}`;
        const first = new Date(year, month, 1);
        const offset = (first.getDay() + 6) % 7;
        const start = new Date(year, month, 1 - offset);
        const end = addDays(start, 41);
        const todayKey = keyOf(new Date());
        const allVisible = occurrencesForRange(start, end, 'days');
        const monthEvents = allVisible.filter((event) => {
          const d = eventDate(event);
          return d && d.getFullYear() === year && d.getMonth() === month;
        });
        const uniqueMonthEvents = new Set(monthEvents.map((event) => `${event.id || event.title}|${event.occurrenceStartDate || event.startDate}`));
        meta.textContent = `${uniqueMonthEvents.size} eventos · ${monthEvents.length} días ocupados este mes`;

        const head = weekDays.map((day) => `<div class="gc-calendar-head">${day}</div>`).join('');
        const cells = [];
        for (let i = 0; i < 42; i++) {
          const date = new Date(start);
          date.setDate(start.getDate() + i);
          const key = keyOf(date);
          const dayEvents = allVisible.filter((event) => String(event.occurrenceDate || event.startDate) === key);
          cells.push(`<article class="gc-calendar-day ${date.getMonth() !== month ? 'is-muted' : ''} ${key === todayKey ? 'is-today' : ''}"><div class="gc-calendar-day-number"><span>${date.getDate()}</span>${key === todayKey ? '<small>Hoy</small>' : ''}</div><div class="gc-calendar-events">${dayEvents.slice(0,4).map(eventHtml).join('')}${dayEvents.length > 4 ? `<small class="gc-soft">+${dayEvents.length - 4} más</small>` : ''}</div></article>`);
        }
        grid.innerHTML = head + cells.join('');
        renderUpcoming();
        window.GCTrackImages?.applyAll(document);
        console.info('[GC calendar track images v3.5]');
      }

      function renderUpcoming() {
        const now = new Date();
        const from = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        const to = addDays(from, 120);
        const list = occurrencesForRange(from, to, 'blocks').slice(0, 8);
        upcoming.innerHTML = list.length ? list.map((event) => {
          const d = eventDate(event);
          const end = parseDate(event.occurrenceEndDate || event.endDate);
          const type = String(event.type || 'combo');
          const rangeText = end && keyOf(end) !== keyOf(d) ? `Del ${keyOf(d)} al ${keyOf(end)}` : keyOf(d);
          const timeText = fmtEventTime(event);
          const trackText = [event.trackName || event.track, event.carNames].filter(Boolean).join(' · ');
          const repeatTag = event.repeatLabel ? '<span class="gc-calendar-upcoming-repeat">Repetición semanal</span>' : '';
          const description = event.description ? `<p class="gc-calendar-upcoming-description">${escapeHtml(event.description)}</p>` : '';
          const action = event.linkUrl ? `<a class="gc-public-btn gc-public-btn-secondary" href="${escapeHtml(event.linkUrl)}" target="_blank" rel="noreferrer">Abrir</a>` : '';
          return `
            <article class="gc-calendar-upcoming-card gc-track-image-card" data-track-image data-track-name="${escapeHtml(event.trackName || event.track || '')}" data-type="${escapeHtml(type)}">
              <div class="gc-calendar-upcoming-date">
                <span>${pad(d.getDate())}</span>
                <small>${monthNames[d.getMonth()].slice(0,3)}</small>
              </div>
              <div class="gc-calendar-upcoming-main">
                <div class="gc-calendar-upcoming-head">
                  <span class="gc-calendar-upcoming-type">${escapeHtml(typeLabels[type] || 'Combo semanal')}</span>
                  ${repeatTag}
                </div>
                <h3>${escapeHtml(event.title || 'Evento')}</h3>
                <dl class="gc-calendar-upcoming-meta">
                  <div><dt>Fecha</dt><dd>${escapeHtml(rangeText)}</dd></div>
                  <div><dt>Hora</dt><dd>${escapeHtml(timeText)}</dd></div>
                  ${trackText ? `<div><dt>Combo</dt><dd>${escapeHtml(trackText)}</dd></div>` : ''}
                </dl>
                ${description}
              </div>
              ${action}
            </article>
          `;
        }).join('') : '<div class="gc-public-panel"><p>No hay próximos eventos visibles todavía.</p></div>';
      }

      async function loadEvents() {
        try {
          const response = await fetch('/api/calendar-events', { cache:'no-store' });
          if (!response.ok) throw new Error(String(response.status));
          const data = await response.json();
          events = (data.events || data.items || []).filter((event) => ['combo','race_lfm','race_gc'].includes(String(event.type || 'combo')));
        } catch (error) {
          events = [];
          meta.textContent = 'No se pudo cargar el calendario.';
        }
        render();
      }

      prev.addEventListener('click', () => { cursor = new Date(cursor.getFullYear(), cursor.getMonth() - 1, 1); render(); });
      next.addEventListener('click', () => { cursor = new Date(cursor.getFullYear(), cursor.getMonth() + 1, 1); render(); });
      todayBtn.addEventListener('click', () => { cursor = new Date(); render(); });
      loadEvents();
    })();
  </script>
</MarketingLayout>


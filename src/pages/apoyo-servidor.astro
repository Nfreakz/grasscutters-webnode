---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const discordUrl = 'https://discord.gg/jA4yuuH5T';
const gtxSupportUrl = 'https://www.gtxgaming.co.uk/clientarea/index.php?m=public_pay&hash_id=mW1QWBg9XVJn';

const supportWays = [
  ['Carreras y combos', 'Organizar una carrera, proponer un combo o ayudar a probar formatos para que el servidor siga teniendo vida.'],
  ['Setups y pruebas', 'Compartir setups, sensaciones de coche, feedback de volante o pruebas del servidor cuando algo cambia.'],
  ['Clips y redes', 'Subir clips, highlights, momentos buenos y compartir la comunidad en redes sociales para que llegue a más pilotos.'],
  ['Comunidad y proyectos', 'Aportar en Discord, WhatsApp, la app, la web, moderación o cualquier proyecto de GC que necesite manos.'],
];
---
<MarketingLayout
  title="Apoyo al servidor | GrassCutters Racing"
  description="Formas de apoyar el servidor GrassCutters Racing: donaciones para GTX, participación, moderación, clips, redes sociales, app, web y proyectos GC."
  ogImage="/og/apoyo-servidor-og-v1531.png"
  bodyClass="gc-page-apoyo-v121"
>
  <section class="gc-public-shell gc-public-page-hero gc-apoyo-hero-v121">
    <div class="gc-public-page-hero__grid">
      <div class="gc-public-page-hero__main">
        <span class="gc-public-kicker">Apoyo GC</span>
        <h1 class="gc-public-title">El servidor se mantiene entre todos.</h1>
        <p class="gc-public-description">
        Apoyar GrassCutters no va solo de donar. También cuenta participar, compartir, probar cosas, cuidar el ambiente y ayudar a que la comunidad siga rodando.
        </p>
        <div class="gc-community-social-actions gc-actions">
          <a class="gc-public-btn gc-public-btn-primary" href={gtxSupportUrl} target="_blank" rel="noreferrer">Apoyar servidor GTX</a>
          <a class="gc-public-btn gc-public-btn-secondary" href={discordUrl} target="_blank" rel="noreferrer">Entrar al Discord</a>
        </div>
      </div>
    </div>
  </section>

  <section class="gc-public-shell gc-public-section gc-apoyo-main-v121">
    <div class="gc-apoyo-grid-v121">
      <article class="gc-apoyo-card-v121 gc-apoyo-card-v121--primary gc-public-card">
        <span class="gc-public-kicker">Apoyo al servidor</span>
        <h2 class="gc-public-card-title gc-public-card-title--large">Donaciones para GTX, slots y mantenimiento.</h2>
        <p>
          Las donaciones voluntarias se usan únicamente para pagar el proveedor de hosting GTX:
          mantenimiento, slots y servidor. Nada de compras externas ni historias raras.
        </p>
        <div class="gc-actions">
          <a class="gc-public-btn gc-public-btn-primary" href={gtxSupportUrl} target="_blank" rel="noreferrer">Apoyar servidor GTX</a>
        </div>
      </article>

      <article class="gc-apoyo-card-v121 gc-public-card">
        <span class="gc-public-kicker">También puedes sumar</span>
        <h2 class="gc-public-card-title gc-public-card-title--large">GrassCutters crece con gente que participa.</h2>
        <p>
          Puedes organizar una carrera, proponer combos, compartir setups, subir clips, compartir la comunidad en redes sociales,
          probar cosas nuevas o ayudar a que el ambiente se mantenga limpio cuando haga falta.
        </p>
        <p>
          También buscamos gente para aportar en Discord, WhatsApp, la app, la web y otros proyectos de GC.
          Si quieres implicarte un poco más, díselo a un admin.
        </p>
        <div class="gc-actions">
          <a class="gc-public-btn gc-public-btn-secondary" href={discordUrl} target="_blank" rel="noreferrer">Entrar al Discord</a>
        </div>
      </article>
    </div>
  </section>

  <section class="gc-public-shell gc-public-section gc-apoyo-ways-v121">
    <div class="gc-public-section-head">
      <span class="gc-public-kicker">Formas de aportar</span>
      <h2 class="gc-public-section-title">No todo el apoyo pasa por pagar.</h2>
      <p class="gc-public-section-lead">
        A veces lo que más ayuda es una mano concreta: una prueba, una idea, un clip, una carrera bien montada o una conversación que evita ruido.
      </p>
    </div>

    <div class="gc-apoyo-ways-grid-v121">
      {supportWays.map(([title, text]) => (
        <article class="gc-public-card">
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="gc-public-shell gc-public-section gc-page-narrow gc-apoyo-final-v121">
    <div class="gc-public-cta">
      <div>
        <h2 class="gc-public-cta-title">¿Quieres ayudar?</h2>
        <p class="gc-public-cta-text">Entra al Discord y habla con un admin. No hace falta prometer media vida: aportar cuando puedas ya suma.</p>
      </div>
      <div class="gc-actions">
        <a class="gc-public-btn gc-public-btn-primary" href={discordUrl} target="_blank" rel="noreferrer">Entrar al Discord</a>
        <a class="gc-public-btn gc-public-btn-secondary" href="/comunidad">Ver comunidad</a>
      </div>
    </div>
  </section>
</MarketingLayout>

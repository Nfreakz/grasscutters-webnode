---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const discordUrl = 'https://discord.gg/jA4yuuH5T';
const gtxSupportUrl = 'https://www.gtxgaming.co.uk/clientarea/index.php?m=public_pay&hash_id=mW1QWBg9XVJn';

const supportWays = [
  ['Carreras y combos', 'Organizar una carrera, proponer un combo o ayudar a probar formatos para que el servidor siga teniendo vida.'],
  ['Setups y pruebas', 'Compartir setups, sensaciones de coche, feedback de volante o pruebas del servidor cuando algo cambia.'],
  ['Clips y redes', 'Subir clips, highlights, momentos buenos y compartir la comunidad en redes sociales para que llegue a más pilotos.'],
  ['Comunidad y proyectos', 'Aportar en Discord, WhatsApp, la app, la web, moderación o cualquier proyecto de GC que necesite manos.'],
];
---
<MarketingLayout
  title="Apoyo al servidor | GrassCutters Racing"
  description="Formas de apoyar el servidor GrassCutters Racing: donaciones para GTX, participación, moderación, clips, redes sociales, app, web y proyectos GC."
  bodyClass="gc-page-apoyo-v121"
>
  <section class="gc-page gc-hero gc-hero-compact gc-apoyo-hero-v121">
    <div>
      <span class="gc-kicker">Apoyo GC</span>
      <h1 class="gc-title">El servidor se mantiene entre todos.</h1>
      <p class="gc-lead">
        Apoyar GrassCutters no va solo de donar. También cuenta participar, compartir, probar cosas, cuidar el ambiente y ayudar a que la comunidad siga rodando.
      </p>
      <div class="gc-actions">
        <a class="gc-btn gc-btn-primary" href={gtxSupportUrl} target="_blank" rel="noreferrer">Apoyar servidor GTX</a>
        <a class="gc-btn" href={discordUrl} target="_blank" rel="noreferrer">Entrar al Discord</a>
      </div>
    </div>
  </section>

  <section class="gc-page gc-apoyo-main-v121">
    <div class="gc-apoyo-grid-v121">
      <article class="gc-apoyo-card-v121 gc-apoyo-card-v121--primary">
        <span class="gc-section-kicker">Apoyo al servidor</span>
        <h2>Donaciones para GTX, slots y mantenimiento.</h2>
        <p>
          Las donaciones voluntarias se usan únicamente para pagar el proveedor de hosting GTX:
          mantenimiento, slots y servidor. Nada de compras externas ni historias raras.
        </p>
        <div class="gc-actions">
          <a class="gc-btn gc-btn-primary" href={gtxSupportUrl} target="_blank" rel="noreferrer">Apoyar servidor GTX</a>
        </div>
      </article>

      <article class="gc-apoyo-card-v121">
        <span class="gc-section-kicker">También puedes sumar</span>
        <h2>GrassCutters crece con gente que participa.</h2>
        <p>
          Puedes organizar una carrera, proponer combos, compartir setups, subir clips, compartir la comunidad en redes sociales,
          probar cosas nuevas o ayudar a que el ambiente se mantenga limpio cuando haga falta.
        </p>
        <p>
          También buscamos gente para aportar en Discord, WhatsApp, la app, la web y otros proyectos de GC.
          Si quieres implicarte un poco más, díselo a un admin.
        </p>
        <div class="gc-actions">
          <a class="gc-btn gc-apoyo-discord-v121" href={discordUrl} target="_blank" rel="noreferrer">Entrar al Discord</a>
        </div>
      </article>
    </div>
  </section>

  <section class="gc-page gc-apoyo-ways-v121">
    <div class="gc-section-head">
      <span class="gc-section-kicker">Formas de aportar</span>
      <h2 class="gc-section-title">No todo el apoyo pasa por pagar.</h2>
      <p class="gc-section-lead">
        A veces lo que más ayuda es una mano concreta: una prueba, una idea, un clip, una carrera bien montada o una conversación que evita ruido.
      </p>
    </div>

    <div class="gc-apoyo-ways-grid-v121">
      {supportWays.map(([title, text]) => (
        <article>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="gc-page gc-page-narrow gc-apoyo-final-v121">
    <div class="gc-cta-box">
      <div>
        <h2>¿Quieres ayudar?</h2>
        <p>Entra al Discord y habla con un admin. No hace falta prometer media vida: aportar cuando puedas ya suma.</p>
      </div>
      <div class="gc-actions">
        <a class="gc-btn gc-btn-primary" href={discordUrl} target="_blank" rel="noreferrer">Entrar al Discord</a>
        <a class="gc-btn" href="/comunidad">Ver comunidad</a>
      </div>
    </div>
  </section>

  <style is:global>
    .gc-page-apoyo-v121 .gc-apoyo-hero-v121{
      padding-bottom:clamp(28px,5vw,66px);
    }

    .gc-apoyo-grid-v121{
      display:grid;
      grid-template-columns:minmax(0,1fr) minmax(0,1fr);
      gap:clamp(18px,3vw,34px);
    }

    .gc-apoyo-card-v121,
    .gc-apoyo-ways-grid-v121 article{
      border:1px solid var(--gc-mk-line);
      border-radius:24px;
      background:
        radial-gradient(circle at 10% 0%, color-mix(in srgb,var(--gc-mk-accent) 9%, transparent), transparent 22rem),
        linear-gradient(180deg,rgba(255,255,255,.07),rgba(255,255,255,.028));
      box-shadow:0 22px 70px rgba(0,0,0,.24);
    }

    .gc-apoyo-card-v121{
      padding:clamp(24px,4vw,42px);
      display:grid;
      align-content:center;
    }

    .gc-apoyo-card-v121 h2{
      margin:12px 0 12px;
      font-size:clamp(2rem,4vw,4rem);
      line-height:.94;
      letter-spacing:-.075em;
    }

    .gc-apoyo-card-v121 p,
    .gc-apoyo-ways-grid-v121 p{
      color:var(--gc-mk-muted);
      line-height:1.68;
    }

    .gc-apoyo-card-v121 .gc-actions{
      margin-top:16px;
    }

    .gc-apoyo-discord-v121{
      color:#fff!important;
      border-color:rgba(255,255,255,.14)!important;
      background:linear-gradient(135deg,#5865f2,#7c88ff)!important;
      box-shadow:0 16px 42px rgba(0,0,0,.26)!important;
    }

    .gc-apoyo-ways-grid-v121{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:14px;
    }

    .gc-apoyo-ways-grid-v121 article{
      padding:22px;
      box-shadow:none;
    }

    .gc-apoyo-ways-grid-v121 h3{
      margin:0 0 10px;
      color:var(--gc-mk-text);
      font-size:1.18rem;
      letter-spacing:-.035em;
    }

    .gc-apoyo-ways-grid-v121 p{
      margin:0;
    }

    @media(max-width:980px){
      .gc-apoyo-grid-v121,
      .gc-apoyo-ways-grid-v121{
        grid-template-columns:1fr;
      }
    }
  </style>
</MarketingLayout>

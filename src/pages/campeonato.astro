---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout
  title="Campeonato ACSR | GrassCutters Racing"
  description="Campeonato ACSR semanal de GrassCutters Racing: próxima carrera, resultados, clasificación y calendario de rondas."
  ogImage="/og/campeonato-og-v1531.png"
  bodyClass="gc-page-acsr"
  canonicalPath="/campeonato"
>
  <section class="gc-public-hero gc-acsr-hero gc-acsr-hero-video" aria-labelledby="gc-campeonato-title">
    <video
      class="gc-public-hero__media gc-acsr-hero-bg-video"
      src="/videos/campeonato.mp4"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
    ></video>
    <div class="gc-public-hero__scrim gc-acsr-hero-scrim" aria-hidden="true"></div>

    <div class="gc-public-shell gc-public-hero__inner gc-acsr-hero-inner">
      <div>
        <span class="gc-public-kicker">Campeonato ACSR</span>
        <h1 id="gc-campeonato-title" class="gc-public-title">Combos semanales con clasificación.</h1>
        <p class="gc-public-description">
          Carrera del campeonato cada domingo. Consulta la próxima ronda, resultados anteriores y clasificación general.
        </p>
        <div class="gc-actions">
          <a class="gc-public-btn gc-public-btn-primary" href="#" id="acsrSignupHero" target="_blank" rel="noreferrer">Inscribirse con Steam</a>
          <a class="gc-public-btn gc-public-btn-secondary" href="#acsrStandings">Ver clasificación</a>
        </div>
      </div>
    </div>
  </section>

  <section class="gc-public-shell gc-public-section gc-community-championship" data-acsr-championship>
    <div class="gc-public-section-head gc-acsr-head-row">
      <div>
        <span class="gc-public-kicker">Campeonato</span>
        <h2 class="gc-public-section-title">Campeonato semanal ACSM.</h2>
        <p class="gc-public-section-lead" id="acsrChampionshipLead">Cargando campeonato...</p>
      </div>
      <button class="gc-public-btn gc-public-btn-secondary" type="button" id="acsrRefresh">Actualizar</button>
    </div>

    <div class="gc-acsr-grid gc-acsr-grid--hub">
      <article class="gc-acsr-main-card gc-public-card">
        <span class="gc-public-kicker">Estado</span>
        <h3 id="acsrChampionshipName" class="gc-public-card-title">Campeonato ACSR</h3>
        <p id="acsrChampionshipMeta" class="gc-public-card-text">Conectando con Assetto Corsa Server Manager.</p>

        <div class="gc-acsr-stats gc-public-stat-grid">
          <div class="gc-public-stat"><span>Rondas</span><strong id="acsrStatEvents">--</strong></div>
          <div class="gc-public-stat"><span>Completadas</span><strong id="acsrStatCompleted">--</strong></div>
          <div class="gc-public-stat"><span>Inscritos</span><strong id="acsrStatEntrants">--</strong></div>
          <div class="gc-public-stat"><span>Clasificados</span><strong id="acsrStatStandings">--</strong></div>
        </div>

        <div class="gc-actions">
          <a class="gc-public-btn gc-public-btn-primary" href="#" id="acsrSignupLink" target="_blank" rel="noreferrer">Inscribirse al campeonato</a>
          <a class="gc-public-btn gc-public-btn-secondary" href="#" id="acsrOfficialLink" target="_blank" rel="noreferrer">Ver ACSM oficial</a>
        </div>
      </article>

      <article class="gc-acsr-next-card gc-public-card">
        <span class="gc-public-kicker">Próximo domingo</span>
        <h3 id="acsrNextTitle" class="gc-public-card-title">Por confirmar</h3>
        <p id="acsrNextMeta" class="gc-public-card-text">Cuando ACSM tenga la siguiente ronda, aparecerá aquí.</p>
        <div class="gc-acsr-track" id="acsrNextTrack">Circuito pendiente</div>
        <figure class="gc-acsr-track-media" id="acsrTrackFigure" hidden>
          <img id="acsrTrackImage" src="" alt="" loading="lazy" />
        </figure>
      </article>

      <article class="gc-acsr-last-card gc-public-card" id="acsrLastCard">
        <span class="gc-public-kicker">Última carrera</span>
        <h3 id="acsrLastTitle" class="gc-public-card-title">Sin resultados todavía</h3>
        <p id="acsrLastMeta" class="gc-public-card-text">Cuando termine una carrera, tendrás aquí el resumen.</p>
        <div class="gc-acsr-podium" id="acsrLastPodium"></div>
        <a class="gc-public-btn gc-public-btn-secondary gc-acsr-last-link" href="#" id="acsrLastLink">Ver resultados</a>
      </article>
    </div>

    <div class="gc-acsr-standings-shell" id="acsrStandings">
      <div class="gc-public-section-head">
        <span class="gc-public-kicker">Clasificación</span>
        <h2 class="gc-public-section-title">Clasificación general.</h2>
        <p class="gc-public-section-lead" id="acsrStandingsLead">Puntos calculados desde los resultados de carrera de ACSM.</p>
      </div>

      <div class="gc-acsr-standings-table-wrap">
        <table class="gc-acsr-standings-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Piloto</th>
              <th>Puntos</th>
              <th>Victorias</th>
              <th>Podios</th>
              <th>Último resultado</th>
            </tr>
          </thead>
          <tbody id="acsrStandingsBody">
            <tr><td colspan="6">Cargando clasificación...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="gc-acsr-events-shell">
      <div class="gc-public-section-head">
        <span class="gc-public-kicker">Rondas</span>
        <h2 class="gc-public-section-title">Calendario del campeonato.</h2>
        <p class="gc-public-section-lead">Cada card abre la página de resultados de esa carrera.</p>
      </div>
      <div class="gc-acsr-events" id="acsrEventsList">
        <article class="gc-acsr-event"><strong>Cargando rondas...</strong></article>
      </div>
    </div>

    <div class="gc-acsr-drivers-shell">
      <div class="gc-public-section-head">
        <span class="gc-public-kicker">Inscritos</span>
        <h2 class="gc-public-section-title">Pilotos registrados.</h2>
        <p class="gc-public-section-lead">Lista limpia de pilotos inscritos en el campeonato semanal.</p>
      </div>
      <div class="gc-acsr-drivers" id="acsrDriversList">
        <article class="gc-acsr-driver"><strong>Cargando pilotos...</strong></article>
      </div>
    </div>
  </section>

  <style is:global>
    .gc-acsr-hero{
      position:relative!important;
      display:block!important;
      overflow:hidden!important;
      isolation:isolate!important;
      min-height:0!important;
      padding-top:clamp(72px,8vw,120px)!important;
      padding-bottom:clamp(72px,8vw,118px)!important;
      margin-bottom:0!important;
      background:var(--gc-mk-bg,#070a08)!important;
      border-bottom:0!important;
    }

    .gc-acsr-hero-bg-video{
      position:absolute!important;
      inset:0!important;
      width:100%!important;
      height:100%!important;
      object-fit:cover!important;
      z-index:0!important;
      opacity:.50!important;
      filter:saturate(1.05) contrast(1.04) brightness(.78)!important;
      pointer-events:none!important;
    }

    .gc-acsr-hero-scrim{
      position:absolute!important;
      inset:0!important;
      z-index:1!important;
      pointer-events:none!important;
      background:
        radial-gradient(circle at 70% 18%, color-mix(in srgb,var(--gc-mk-accent) 22%, transparent), transparent 28rem),
        linear-gradient(90deg, rgba(1,7,4,.96) 0%, rgba(1,7,4,.68) 44%, rgba(1,7,4,.93) 100%),
        linear-gradient(180deg, rgba(1,7,4,.14) 0%, rgba(1,7,4,.38) 58%, var(--gc-mk-bg,#070a08) 100%)!important;
    }

    .gc-acsr-hero::before{
      content:""!important;
      position:absolute!important;
      inset:auto 0 0 0!important;
      height:clamp(250px,29vw,440px)!important;
      z-index:2!important;
      pointer-events:none!important;
      background:linear-gradient(180deg, rgba(7,10,8,0) 0%, rgba(7,10,8,.44) 36%, rgba(7,10,8,.84) 72%, var(--gc-mk-bg,#070a08) 100%)!important;
    }

    .gc-acsr-hero-inner{
      position:relative!important;
      z-index:4!important;
      display:grid!important;
      align-items:center!important;
      min-height:clamp(420px,56vh,640px)!important;
      padding-top:clamp(42px,6vw,86px)!important;
      padding-bottom:clamp(54px,6vw,94px)!important;
    }

    .gc-acsr-hero-inner > div{ max-width:820px!important; }

    .gc-community-championship{
      position:relative;
      z-index:5;
      display:grid;
      gap:clamp(22px,3vw,38px);
      padding-top:clamp(34px,5vw,70px);
    }

    .gc-acsr-head-row{
      display:flex;
      justify-content:space-between;
      align-items:end;
      gap:18px;
    }

    .gc-acsr-grid{
      display:grid;
      grid-template-columns:minmax(0,1.05fr) minmax(280px,.82fr);
      gap:16px;
      align-items:stretch;
    }

    .gc-acsr-grid--hub{
      grid-template-columns:minmax(0,1.05fr) minmax(280px,.78fr) minmax(280px,.82fr);
    }

    .gc-acsr-main-card.gc-public-card,
    .gc-acsr-next-card.gc-public-card,
    .gc-acsr-last-card.gc-public-card{
      position:relative;
      overflow:hidden;
      padding:clamp(18px,2.2vw,28px);
      border:1px solid var(--line,var(--gc-mk-line,rgba(126,255,39,.22)));
      border-radius:var(--radius,18px);
      background:var(--panel,rgba(255,255,255,.025));
      box-shadow:0 20px 60px rgba(0,0,0,.32);
    }

    .gc-acsr-stats{
      grid-template-columns:repeat(2,minmax(0,1fr));
      margin:18px 0;
    }

    .gc-acsr-track{
      margin-top:16px;
      padding:12px;
      border:1px solid var(--line,var(--gc-mk-line,rgba(126,255,39,.22)));
      border-radius:var(--radius-sm,10px);
      color:var(--gc-mk-accent,#80ff1f);
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.05em;
      background:rgba(255,255,255,.035);
    }

    .gc-acsr-track-media,
    .gc-acsr-event-media{
      margin:16px 0 0;
      border:1px solid var(--line,var(--gc-mk-line,rgba(126,255,39,.22)));
      border-radius:var(--radius,18px);
      overflow:hidden;
      background:rgba(0,0,0,.18);
    }

    .gc-acsr-track-media[hidden],
    .gc-acsr-event-media[hidden]{ display:none!important; }

    .gc-acsr-track-media img{
      display:block;
      width:100%;
      height:clamp(170px,18vw,260px);
      object-fit:cover;
    }

    .gc-acsr-event-media{
      margin:0 0 4px;
      border-radius:13px;
    }

    .gc-acsr-event-media img{
      display:block;
      width:100%;
      height:clamp(105px,8.5vw,138px);
      object-fit:cover;
      filter:saturate(1.04) contrast(1.04) brightness(.9);
    }

    .gc-acsr-podium{
      display:grid;
      gap:8px;
      margin:18px 0;
    }

    .gc-acsr-podium-row{
      display:grid;
      grid-template-columns:auto minmax(0,1fr) auto;
      gap:10px;
      align-items:center;
      padding:10px 12px;
      border:1px solid rgba(126,255,39,.16);
      border-radius:12px;
      background:rgba(126,255,39,.045);
    }

    .gc-acsr-podium-row span{
      color:var(--gc-mk-accent,#80ff1f);
      font-weight:900;
      font-family:var(--font-mono,monospace);
    }

    .gc-acsr-podium-row small{
      color:var(--gc-mk-muted,#8d968c);
      text-align:right;
      font-family:var(--font-mono,monospace);
    }

    .gc-acsr-last-link[hidden]{ display:none!important; }

    .gc-acsr-events-shell,
    .gc-acsr-standings-shell,
    .gc-acsr-drivers-shell{
      display:grid;
      gap:16px;
    }

    .gc-acsr-events{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:14px;
      align-items:stretch;
    }

    .gc-acsr-event{
      position:relative;
      display:grid;
      grid-template-rows:auto auto auto 1fr auto;
      gap:9px;
      overflow:hidden;
      padding:12px;
      border:1px solid var(--gc-mk-line,rgba(126,255,39,.22));
      border-radius:16px;
      background:rgba(255,255,255,.025);
      color:inherit;
      text-decoration:none;
      box-shadow:none;
      transition:transform .18s ease, border-color .18s ease, background .18s ease;
      min-height:100%;
    }

    a.gc-acsr-event:hover{
      transform:translateY(-2px);
      border-color:rgba(126,255,39,.48);
      background:rgba(126,255,39,.055);
    }

    .gc-acsr-event span,
    .gc-acsr-driver span{
      color:var(--gc-mk-accent,#80ff1f);
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.08em;
      font-family:var(--font-mono,monospace);
      font-size:.78rem;
    }

    .gc-acsr-event strong{
      display:block;
      margin-top:3px;
      font-size:clamp(.96rem,1.05vw,1.12rem);
      line-height:1.05;
    }

    .gc-acsr-event p{
      margin:0;
      color:var(--gc-mk-muted,#9ca59a);
      font-size:.88rem;
      line-height:1.35;
    }

    .gc-acsr-event__meta{
      display:flex;
      flex-wrap:wrap;
      gap:6px;
      margin-top:2px;
    }

    .gc-acsr-chip{
      display:inline-flex;
      align-items:center;
      width:max-content;
      max-width:100%;
      padding:4px 7px;
      border:1px solid rgba(126,255,39,.18);
      border-radius:999px;
      color:var(--gc-mk-muted,#9ca59a);
      font-size:.68rem;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.05em;
    }

    .gc-acsr-standings-table-wrap{
      overflow:auto;
      border:1px solid var(--gc-mk-line,rgba(126,255,39,.22));
      border-radius:18px;
      background:rgba(255,255,255,.018);
    }

    .gc-acsr-standings-table{
      width:100%;
      border-collapse:collapse;
      min-width:860px;
    }

    .gc-acsr-standings-table th,
    .gc-acsr-standings-table td{
      padding:14px 16px;
      border-bottom:1px solid rgba(126,255,39,.12);
      text-align:left;
      vertical-align:middle;
    }

    .gc-acsr-standings-table th{
      color:var(--gc-mk-muted,#9ca59a);
      font-family:var(--font-mono,monospace);
      font-size:.78rem;
      text-transform:uppercase;
      letter-spacing:.08em;
      background:rgba(126,255,39,.055);
    }

    .gc-acsr-standings-table tr:last-child td{ border-bottom:0; }

    .gc-acsr-standings-table td strong{
      font-weight:900;
    }

    .gc-acsr-points{
      color:var(--gc-mk-accent,#80ff1f);
      font-weight:950;
      font-family:var(--font-mono,monospace);
    }

    .gc-acsr-drivers{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:14px;
    }

    .gc-acsr-driver{
      display:grid;
      gap:8px;
      padding:16px;
      border:1px solid var(--gc-mk-line,rgba(126,255,39,.22));
      border-radius:16px;
      background:rgba(255,255,255,.025);
    }

    .gc-acsr-driver strong{
      font-size:1.02rem;
    }

    .gc-acsr-driver small{
      color:var(--gc-mk-muted,#9ca59a);
    }

    @media (max-width:1180px){
      .gc-acsr-grid--hub{
        grid-template-columns:1fr 1fr;
      }

      .gc-acsr-main-card{
        grid-column:1/-1;
      }

      .gc-acsr-events{
        grid-template-columns:repeat(3,minmax(0,1fr));
      }

      .gc-acsr-drivers{
        grid-template-columns:repeat(3,minmax(0,1fr));
      }
    }

    @media (max-width:860px){
      .gc-acsr-head-row{
        align-items:start;
        flex-direction:column;
      }

      .gc-acsr-grid,
      .gc-acsr-grid--hub{
        grid-template-columns:1fr;
      }

      .gc-acsr-events{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }

      .gc-acsr-drivers{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }

      .gc-acsr-track-media img{
        height:210px;
      }

      .gc-acsr-event-media img{
        height:128px;
      }
    }

    @media (max-width:560px){
      .gc-acsr-events,
      .gc-acsr-drivers{
        grid-template-columns:1fr;
      }

      .gc-acsr-stats{
        grid-template-columns:1fr 1fr;
      }

      .gc-acsr-event-media img{
        height:150px;
      }

      .gc-acsr-standings-table{
        min-width:720px;
      }
    }
  </style>

  <script>
    (() => {
      const root = document.querySelector('[data-acsr-championship]');
      if (!root) return;

      const $ = (id) => document.getElementById(id);
      const els = {
        lead: $('acsrChampionshipLead'),
        name: $('acsrChampionshipName'),
        meta: $('acsrChampionshipMeta'),
        events: $('acsrStatEvents'),
        completed: $('acsrStatCompleted'),
        entrants: $('acsrStatEntrants'),
        standings: $('acsrStatStandings'),
        official: $('acsrOfficialLink'),
        signup: $('acsrSignupLink'),
        signupHero: $('acsrSignupHero'),
        refresh: $('acsrRefresh'),
        nextTitle: $('acsrNextTitle'),
        nextMeta: $('acsrNextMeta'),
        nextTrack: $('acsrNextTrack'),
        trackFigure: $('acsrTrackFigure'),
        trackImage: $('acsrTrackImage'),
        lastTitle: $('acsrLastTitle'),
        lastMeta: $('acsrLastMeta'),
        lastPodium: $('acsrLastPodium'),
        lastLink: $('acsrLastLink'),
        list: $('acsrEventsList'),
        drivers: $('acsrDriversList'),
        standingsBody: $('acsrStandingsBody'),
        standingsLead: $('acsrStandingsLead')
      };

      const escapeHtml = (value) => String(value ?? '').replace(/[&<>'"]/g, (char) => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', "'":'&#39;', '"':'&quot;' }[char]));
      const fmtDate = (value) => {
        if (!value) return 'Fecha por confirmar';
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return 'Fecha por confirmar';
        return date.toLocaleString('es-ES', { weekday:'short', day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
      };

      const statusLabel = {
        pending: 'Pendiente',
        scheduled: 'Programada',
        in_progress: 'En curso',
        completed: 'Completada',
        cancelled: 'Cancelada'
      };

      const sessionLabel = {
        PRACTICE: 'Práctica',
        QUALIFY: 'Qualy',
        QUALIFICATION: 'Qualy',
        RACE: 'Carrera'
      };

      const slugify = (value) => String(value || '')
        .toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '_')
        .replace(/^_+|_+$/g, '');

      const normalizeTrackSlug = (value) => {
        const raw = slugify(value);
        return raw
          .replace(/^(fn|ks|rt|mx|acu|nrms)_/, '')
          .replace(/_?(circuit|circuito|track|spain|italy|italia)$/g, '')
          .replace(/^_+|_+$/g, '') || raw;
      };

      // GC_TRACK_ASSETS_SINGLE_SOURCE_V19
      // Fuente estable para fotos/mapas de calendario. No depende de GCTrackImages ni de manifests.
      const TRACK_ASSET_REGISTRY = {
        jerez: { keys: ['jerez', 'fn_jerez', 'circuito_de_jerez', 'circuito_de_jerez_spain', 'circuito_de_jerez_angel_nieto', 'jerez_angel_nieto', 'angel_nieto_jerez'], photo: '/images/tracks/jerez.png', map: '/images/tracks/jerez_mapa.png' },
        mugello: { keys: ['mugello', 'ks_mugello', 'autodromo_internazionale_del_mugello'], photo: '/images/tracks/mugello.webp', map: '/images/tracks/mugello_mapa.png' },
        bathurst: { keys: ['bathurst', 'mount_panorama'], photo: '/images/tracks/bathurst.png' },
        brands_hatch: { keys: ['brands_hatch', 'ks_brands_hatch'], photo: '/images/tracks/brands_hatch.webp' },
        estoril: { keys: ['estoril'], photo: '/images/tracks/estoril.webp' },
        hockenheim: { keys: ['hockenheim', 'ks_hockenheim', 've_hockenheim_gp', 'hockenheimring'], photo: '/images/tracks/hockenheim.png' },
        imola: { keys: ['imola'], photo: '/images/tracks/imola.webp' },
        nordschleife: { keys: ['nordschleife', 'nurburgring_nordschleife'], photo: '/images/tracks/nordschleife.webp' },
        nurburgring: { keys: ['nurburgring', 'ks_nurburgring'], photo: '/images/tracks/nurburgring.jpg' },
        okayama: { keys: ['okayama', 'okayama_international', 'okayama_circuit'], photo: '/images/tracks/okayama.jpg' },
        phillip_island: { keys: ['phillip_island', 'phillipisland', 'phillip_island_2013'], photo: '/images/tracks/phillip_island.png' },
        road_atlanta: { keys: ['road_atlanta'], photo: '/images/tracks/road_atlanta.webp' },
        salzburgring: { keys: ['salzburgring', 'salzburg_ring', 'salzburg'], photo: '/images/tracks/salzburgring.png' },
        sebring: { keys: ['sebring', 'mx_sb_day_standing'], photo: '/images/tracks/sebring.png' },
        spa: { keys: ['spa', 'ks_spa', 'rt_spa', 'spa_francorchamps'], photo: '/images/tracks/spa.png' },
        suzuka: { keys: ['suzuka', 'ks_suzuka'], photo: '/images/tracks/suzuka.png' },
        vallelunga: { keys: ['vallelunga', 'ks_vallelunga'], photo: '/images/tracks/vallelunga.webp' },
        zolder: { keys: ['zolder', 'rt_zolder', 'circuit_zolder'], photo: '/images/tracks/zolder.webp' }
      };

      const trackAssetNames = (event) => {
        const raw = [event?.trackRaw, event?.track, event?.name].filter(Boolean);
        const names = [...new Set(raw.flatMap((value) => [slugify(value), normalizeTrackSlug(value)]).filter(Boolean))];
        Object.values(TRACK_ASSET_REGISTRY).forEach((track) => {
          if ((track.keys || []).some((key) => names.some((name) => name === key || name.includes(key) || key.includes(name)))) {
            names.push(...track.keys);
          }
        });
        return [...new Set(names.filter(Boolean))];
      };

      const registeredTrackAsset = (event) => {
        const names = trackAssetNames(event);
        return Object.values(TRACK_ASSET_REGISTRY).find((track) => (track.keys || []).some((key) => names.some((name) => name === key || name.includes(key) || key.includes(name)))) || null;
      };

      const localTrackMapCandidates = (event) => {
        const names = trackAssetNames(event);
        const exact = registeredTrackAsset(event)?.map ? [registeredTrackAsset(event).map] : [];
        const roots = ['/images/tracks', '/imagenes/tracks'];
        const exts = ['png', 'webp', 'jpg', 'jpeg', 'svg'];
        const out = [];
        names.forEach((name) => {
          ['_mapa', '_map'].forEach((suffix) => {
            roots.forEach((root) => {
              exts.forEach((ext) => out.push(`${root}/${name}${suffix}.${ext}`));
            });
          });
        });
        return [...new Set([...exact, ...out])];
      };

      const localTrackPhotoCandidates = (event) => {
        const names = trackAssetNames(event);
        const exact = registeredTrackAsset(event)?.photo ? [registeredTrackAsset(event).photo] : [];
        const roots = ['/images/tracks', '/imagenes/tracks'];
        const exts = ['webp', 'jpg', 'jpeg', 'png', 'avif'];
        const out = [];
        names.forEach((name) => {
          ['', '_photo', '_foto', '_hero'].forEach((suffix) => {
            roots.forEach((root) => {
              exts.forEach((ext) => out.push(`${root}/${name}${suffix}.${ext}`));
            });
          });
        });
        return [...new Set([...exact, ...out].filter((url) => !/_mapa\.|_map\.|_outline\./i.test(url)))];
      };

      const setImageWithFallback = (img, figure, candidates) => {
        const cleanCandidates = (Array.isArray(candidates) ? candidates : []).filter(Boolean);
        if (!img || !figure || !cleanCandidates.length) {
          if (figure) figure.hidden = true;
          return;
        }

        figure.hidden = false;
        img.style.display = '';
        img.dataset.fallbackIndex = '0';
        img.dataset.fallbacks = cleanCandidates.slice(1).join('|');
        img.onerror = function () {
          const list = (this.dataset.fallbacks || '').split('|').filter(Boolean);
          const index = Number(this.dataset.fallbackIndex || 0);
          if (list[index]) {
            this.dataset.fallbackIndex = String(index + 1);
            this.src = list[index];
            return;
          }
          this.closest('figure')?.setAttribute('hidden', '');
          this.style.display = 'none';
        };
        img.src = cleanCandidates[0];
      };

      const eventImageHtml = (event) => {
        const candidates = event?.trackPhotoCandidates?.length ? event.trackPhotoCandidates : localTrackPhotoCandidates(event);
        const primary = candidates[0] || '';
        const fallbacks = candidates.slice(1).join('|');
        if (!primary) return '';

        return `
          <figure class="gc-acsr-event-media gc-acsr-event-media--photo">
            <img
              src="${escapeHtml(primary)}"
              alt="${escapeHtml(event.track || event.name || '')}"
              loading="lazy"
              data-fallbacks="${escapeHtml(fallbacks)}"
              data-fallback-index="0"
              onerror="const list=(this.dataset.fallbacks||'').split('|').filter(Boolean);const i=Number(this.dataset.fallbackIndex||0);if(list[i]){this.dataset.fallbackIndex=String(i+1);this.src=list[i];}else{this.closest('figure')?.setAttribute('hidden','');this.style.display='none';}"
            />
          </figure>
        `;
      };

      const renderTrackImage = (event) => {
        const candidates = event?.trackMapCandidates?.length ? event.trackMapCandidates : localTrackMapCandidates(event);
        if (els.trackImage) els.trackImage.alt = event?.track || event?.name || '';
        setImageWithFallback(els.trackImage, els.trackFigure, candidates);
      };

      function renderDrivers(rows) {
        const drivers = Array.isArray(rows) ? rows : [];

        if (!drivers.length) {
          els.drivers.innerHTML = '<article class="gc-acsr-driver"><strong>Sin pilotos inscritos</strong><small>Cuando haya pilotos registrados, aparecerán aquí.</small></article>';
          return;
        }

        els.drivers.innerHTML = drivers.slice(0, 48).map((driver) => `
          <article class="gc-acsr-driver">
            <span>${escapeHtml(driver.className || 'General')}</span>
            <strong>${escapeHtml(driver.name || 'Piloto')}</strong>
            <small>${escapeHtml(driver.model || driver.team || 'Inscrito')}</small>
          </article>
        `).join('');
      }

      function renderStandings(rows) {
        const standings = Array.isArray(rows) ? rows : [];

        els.standingsLead.textContent = standings.length
          ? `${standings.length} pilotos en la clasificación. Puntos calculados desde RACE.Results.Result.`
          : 'La clasificación se actualizará cuando haya resultados de carrera.';

        els.standingsBody.innerHTML = standings.length ? standings.slice(0, 80).map((driver) => `
          <tr>
            <td><strong>${escapeHtml(driver.position)}</strong></td>
            <td>
              <strong>${escapeHtml(driver.name || 'Piloto')}</strong>
              <br><small>${escapeHtml(driver.model || '')}</small>
            </td>
            <td><span class="gc-acsr-points">${escapeHtml(driver.points ?? 0)}</span></td>
            <td>${escapeHtml(driver.wins ?? 0)}</td>
            <td>${escapeHtml(driver.podiums ?? 0)}</td>
            <td>${driver.lastResult ? `${escapeHtml(driver.lastResult.eventName)} · P${escapeHtml(driver.lastResult.position)} · ${escapeHtml(driver.lastResult.points)} pts` : 'Sin carrera completada'}</td>
          </tr>
        `).join('') : '<tr><td colspan="6">La clasificación se actualizará cuando haya resultados de carrera.</td></tr>';
      }

      function renderLastCompleted(event) {
        if (!event) {
          els.lastTitle.textContent = 'Sin resultados todavía';
          els.lastMeta.textContent = 'Cuando termine una carrera, tendrás aquí el resumen.';
          els.lastPodium.innerHTML = '';
          els.lastLink.hidden = true;
          return;
        }

        els.lastTitle.textContent = event.name || `Ronda ${event.index}`;
        els.lastMeta.textContent = `${fmtDate(event.completedAt || event.scheduledAt)} · ${event.track || 'Circuito por confirmar'}`;
        els.lastLink.href = event.href || `/campeonato/ronda/${encodeURIComponent(event.id)}`;
        els.lastLink.hidden = false;

        const podium = Array.isArray(event.podium) ? event.podium : [];
        els.lastPodium.innerHTML = podium.length ? podium.map((driver) => `
          <div class="gc-acsr-podium-row">
            <span>P${escapeHtml(driver.position)}</span>
            <strong>${escapeHtml(driver.name)}</strong>
            <small>${escapeHtml(driver.points)} pts</small>
          </div>
        `).join('') : '<p>No hay podio disponible.</p>';
      }

      function renderError(data) {
        els.lead.textContent = data?.message || 'No se pudo cargar el campeonato.';
        els.meta.textContent = 'No se pudo cargar el campeonato en este momento.';
        els.list.innerHTML = `<article class="gc-acsr-event"><strong>No se pudo cargar el campeonato</strong><p>${escapeHtml(data?.message || 'Error desconocido')}</p></article>`;
        renderStandings([]);
        renderDrivers([]);
        renderLastCompleted(null);

        if (data?.acsm?.championshipUrl) els.official.href = data.acsm.championshipUrl;
        if (data?.acsm?.signUpUrl) {
          els.signup.href = data.acsm.signUpUrl;
          els.signupHero.href = data.acsm.signUpUrl;
        }
      }

      function render(data) {
        if (!data?.ok || !data?.championship) {
          renderError(data);
          return;
        }

        const championship = data.championship;
        const next = championship.nextEvent;
        const last = championship.lastCompletedEvent;
        const events = Array.isArray(championship.events) ? championship.events : [];
        const standings = Array.isArray(championship.standings) ? championship.standings : [];
        const drivers = Array.isArray(championship.registeredDrivers) ? championship.registeredDrivers : [];
        const stats = championship.stats || {};

        els.lead.textContent = `Calendario actualizado. Progreso del campeonato: ${championship.progressPercent || 0}%.`;
        els.name.textContent = championship.name || 'Campeonato ACSR';
        els.meta.textContent = `ID ${championship.id} · ${championship.acsrEnabled ? 'ACSR activo' : 'ACSR no marcado'} · actualizado ${fmtDate(championship.updatedAt)}`;
        els.events.textContent = String(stats.events ?? events.length ?? '--');
        els.completed.textContent = String(stats.completedEvents ?? '--');
        els.entrants.textContent = String(stats.entrants ?? drivers.length ?? '--');
        els.standings.textContent = String(stats.standings ?? standings.length ?? '--');

        if (data.acsm?.championshipUrl) els.official.href = data.acsm.championshipUrl;
        if (data.acsm?.signUpUrl) {
          els.signup.href = data.acsm.signUpUrl;
          els.signupHero.href = data.acsm.signUpUrl;
        }

        if (next) {
          els.nextTitle.textContent = next.name || `Ronda ${next.index}`;
          els.nextMeta.textContent = `${fmtDate(next.scheduledAt)} · ${statusLabel[next.status] || next.status || 'Pendiente'}`;
          els.nextTrack.textContent = [next.track, next.carSummary].filter(Boolean).join(' · ') || 'Circuito pendiente';
          renderTrackImage(next);
        } else {
          els.nextTitle.textContent = 'Sin próxima ronda';
          els.nextMeta.textContent = 'Todas las rondas parecen completadas o no hay eventos programados.';
          els.nextTrack.textContent = 'Campeonato sin próxima fecha';
          renderTrackImage(null);
        }

        renderLastCompleted(last);
        renderStandings(standings);
        renderDrivers(drivers);

        els.list.innerHTML = events.slice(0, 24).map((event) => {
          const winner = event.winner ? `${event.winner.name} · ${event.winner.points} pts` : 'Resultados pendientes';
          return `
            <a class="gc-acsr-event" href="${escapeHtml(event.href || `/campeonato/ronda/${encodeURIComponent(event.id)}`)}" data-status="${escapeHtml(event.status || 'pending')}">
              ${eventImageHtml(event)}
              <div>
                <span>${escapeHtml(statusLabel[event.status] || event.status || 'Pendiente')}</span>
                <strong>${escapeHtml(event.name || `Ronda ${event.index}`)}</strong>
              </div>
              <p>${escapeHtml(fmtDate(event.scheduledAt))}</p>
              <p>${escapeHtml([event.track, event.carSummary].filter(Boolean).join(' · ') || 'Combo por confirmar')}</p>
              <div class="gc-acsr-event__meta">
                <span class="gc-acsr-chip">${escapeHtml(event.raceResults?.length ? `${event.raceResults.length} pilotos` : 'Sin resultados')}</span>
                <span class="gc-acsr-chip">${escapeHtml(winner)}</span>
              </div>
            </a>
          `;
        }).join('') || '<article class="gc-acsr-event"><strong>Sin rondas</strong><p>Todavía no hay rondas visibles.</p></article>';

        // No aplicar GCTrackImages sobre las cards: ya llevan fallbacks locales estables.

        console.info('[GC campeonato ACSR hub v17 calendar cards]', {
          ok: true,
          events: events.length,
          standings: standings.length,
          registeredDrivers: drivers.length
        });
      }

      async function load(refresh = false) {
        els.lead.textContent = refresh ? 'Actualizando campeonato...' : 'Cargando campeonato...';

        try {
          const response = await fetch(`/api/community/acsr-championship${refresh ? '?refresh=1' : ''}`, { cache: 'no-store' });
          const data = await response.json();
          render(data);
        } catch (error) {
          renderError({ message: error?.message || String(error) });
        }
      }

      els.refresh?.addEventListener('click', () => load(true));
      load();
    })();
  </script>
</MarketingLayout>

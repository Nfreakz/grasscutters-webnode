---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---
<MarketingLayout
  title="Campeonato ACSR | GrassCutters Racing"
  description="Campeonato ACSR de GrassCutters Racing: inscripción, próximas rondas, clasificación y pilotos registrados."
  ogImage="/og/campeonato-og-v1531.png"
  bodyClass="gc-page-acsr"
  canonicalPath="/campeonato"
>
  <section class="gc-hero gc-hero-compact gc-acsr-hero gc-acsr-hero-video">
    <video
      class="gc-acsr-hero-bg-video"
      src="/videos/campeonato.mp4"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
    ></video>
    <div class="gc-acsr-hero-scrim" aria-hidden="true"></div>

    <div class="gc-page gc-acsr-hero-inner">
      <div>
        <span class="gc-kicker">Campeonato ACSR</span>
        <h1 class="gc-title">Combos semanales con clasificación.</h1>
        <p class="gc-lead">
          Inscripción Steam, próxima ronda, calendario, clasificación y pilotos registrados del campeonato.
        </p>
        <div class="gc-actions">
          <a class="gc-btn gc-btn-primary" href="#" id="acsrSignupHero" target="_blank" rel="noreferrer">Inscribirse con Steam</a>
          <a class="gc-btn" href="/discord">Discord</a>
        </div>
      </div>
    </div>
  </section>

  <section class="gc-page gc-community-championship" data-acsr-championship>
    <div class="gc-section-head">
      <span class="gc-section-kicker">Campeonato</span>
      <h2 class="gc-section-title">Campeonato de combos semanales.</h2>
      <p class="gc-section-lead" id="acsrChampionshipLead">
        Cargando campeonato...
      </p>
    </div>

    <div class="gc-acsr-grid">
      <article class="gc-acsr-main-card">
        <span class="gc-panel-kicker">Estado</span>
        <h3 id="acsrChampionshipName">Campeonato ACSR</h3>
        <p id="acsrChampionshipMeta">Conectando con Assetto Corsa Server Manager.</p>

        <div class="gc-acsr-stats">
          <div><span>Eventos</span><strong id="acsrStatEvents">--</strong></div>
          <div><span>Completados</span><strong id="acsrStatCompleted">--</strong></div>
          <div><span>Clases</span><strong id="acsrStatClasses">--</strong></div>
          <div><span>Inscritos</span><strong id="acsrStatEntrants">--</strong></div>
        </div>

        <div class="gc-actions">
          <a class="gc-btn gc-btn-primary" href="#" id="acsrSignupLink" target="_blank" rel="noreferrer">Inscribirse al campeonato</a>
          <a class="gc-btn" href="#" id="acsrOfficialLink" target="_blank" rel="noreferrer">Ver campeonato oficial</a>
          <button class="gc-btn" type="button" id="acsrRefresh">Actualizar</button>
        </div>
      </article>

      <article class="gc-acsr-next-card">
        <span class="gc-panel-kicker">Próxima ronda</span>
        <h3 id="acsrNextTitle">Por confirmar</h3>
        <p id="acsrNextMeta">Cuando ACSM tenga la siguiente ronda, aparecerá aquí.</p>
        <div class="gc-acsr-track" id="acsrNextTrack">Circuito pendiente</div>
        <figure class="gc-acsr-track-media" id="acsrTrackFigure" hidden>
          <img id="acsrTrackImage" src="" alt="" loading="lazy" />
        </figure>
      </article>
    </div>

    <div class="gc-acsr-events-shell">
      <div class="gc-section-head">
        <span class="gc-section-kicker">Rondas</span>
        <h2 class="gc-section-title">Calendario del campeonato.</h2>
      </div>
      <div class="gc-acsr-events" id="acsrEventsList">
        <article class="gc-acsr-event"><strong>Cargando rondas...</strong></article>
      </div>
    </div>

    <div class="gc-acsr-standings-shell">
      <div class="gc-section-head">
        <span class="gc-section-kicker">Clasificación</span>
        <h2 class="gc-section-title">Clasificación del campeonato.</h2>
        <p class="gc-section-lead" id="acsrStandingsLead">Posiciones, puntos y pilotos del campeonato.</p>
      </div>

      <div class="gc-acsr-standings-table-wrap">
        <table class="gc-acsr-standings-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Piloto</th>
              <th>Clase</th>
              <th>Coche</th>
              <th>Puntos</th>
            </tr>
          </thead>
          <tbody id="acsrStandingsBody">
            <tr><td colspan="5">Cargando clasificación...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="gc-acsr-drivers-shell">
      <div class="gc-section-head">
        <span class="gc-section-kicker">Inscritos</span>
        <h2 class="gc-section-title">Pilotos registrados.</h2>
        <p class="gc-section-lead">Pilotos inscritos actualmente en el campeonato.</p>
      </div>
      <div class="gc-acsr-drivers" id="acsrDriversList">
        <article class="gc-acsr-driver"><strong>Cargando pilotos...</strong></article>
      </div>
    </div>
  </section>

  <section class="gc-page gc-acsr-note">
    <div class="gc-grid-3">
      <article class="gc-card">
        <code>01</code>
        <h3>Inscripción</h3>
        <p>Registro rápido con Steam para participar en el campeonato.</p>
      </article>
      <article class="gc-card">
        <code>02</code>
        <h3>Clasificación</h3>
        <p>Seguimiento de pilotos, puntos y próximas rondas.</p>
      </article>
      <article class="gc-card">
        <code>03</code>
        <h3>Comunidad</h3>
        <p>El Discord sigue siendo el paddock principal para avisos y comentarios.</p>
      </article>
    </div>
  </section>

  <style is:global>
    .gc-acsr-hero{
      position:relative!important;
      display:block!important;
      overflow:hidden!important;
      isolation:isolate!important;
      min-height:0!important;
      padding-top:clamp(72px,8vw,120px)!important;
      padding-bottom:clamp(72px,8vw,118px)!important;
      margin-bottom:0!important;
      background:var(--gc-mk-bg,#070a08)!important;
      border-bottom:0!important;
    }

    .gc-acsr-hero-bg-video{
      position:absolute!important;
      inset:0!important;
      width:100%!important;
      height:100%!important;
      min-height:100%!important;
      object-fit:cover!important;
      z-index:0!important;
      opacity:.50!important;
      filter:saturate(1.05) contrast(1.04) brightness(.78)!important;
      transform:none!important;
      pointer-events:none!important;
    }

    .gc-acsr-hero-scrim{
      position:absolute!important;
      inset:0!important;
      z-index:1!important;
      pointer-events:none!important;
      background:
        radial-gradient(circle at 70% 18%, color-mix(in srgb,var(--gc-mk-accent) 22%, transparent), transparent 28rem),
        radial-gradient(circle at 28% 74%, color-mix(in srgb,var(--gc-mk-accent-2) 12%, transparent), transparent 30rem),
        linear-gradient(90deg, rgba(1,7,4,.96) 0%, rgba(1,7,4,.68) 44%, rgba(1,7,4,.93) 100%),
        linear-gradient(180deg, rgba(1,7,4,.14) 0%, rgba(1,7,4,.38) 58%, var(--gc-mk-bg,#070a08) 100%)!important;
    }

    .gc-acsr-hero::before{
      content:""!important;
      position:absolute!important;
      inset:auto 0 0 0!important;
      height:clamp(250px,29vw,440px)!important;
      z-index:2!important;
      pointer-events:none!important;
      background:
        linear-gradient(180deg,
          rgba(7,10,8,0) 0%,
          rgba(7,10,8,.44) 36%,
          rgba(7,10,8,.84) 72%,
          var(--gc-mk-bg,#070a08) 100%
        )!important;
    }

    .gc-acsr-hero::after{
      content:""!important;
      position:absolute!important;
      left:50%!important;
      bottom:clamp(44px,5vw,82px)!important;
      width:min(1060px,90vw)!important;
      height:230px!important;
      transform:translateX(-50%)!important;
      z-index:2!important;
      pointer-events:none!important;
      background:radial-gradient(ellipse at center, color-mix(in srgb,var(--gc-mk-accent) 13%, transparent), transparent 68%)!important;
      filter:blur(48px)!important;
      opacity:.46!important;
    }

    .gc-acsr-hero-inner{
      position:relative!important;
      z-index:4!important;
      display:grid!important;
      align-items:center!important;
      min-height:clamp(420px,56vh,640px)!important;
      padding-top:clamp(42px,6vw,86px)!important;
      padding-bottom:clamp(54px,6vw,94px)!important;
    }

    .gc-acsr-hero-inner > div{
      max-width:760px!important;
    }

    .gc-acsr-hero .gc-title{
      text-shadow:0 18px 62px rgba(0,0,0,.50);
    }

    .gc-acsr-hero .gc-lead{
      text-shadow:0 10px 34px rgba(0,0,0,.42);
    }

    .gc-community-championship{
      position:relative;
      z-index:5;
      display:grid;
      gap:clamp(18px,2.5vw,30px);
      padding-top:clamp(34px,5vw,70px);
    }

    .gc-acsr-grid{
      display:grid;
      grid-template-columns:minmax(0,1.15fr) minmax(280px,.85fr);
      gap:16px;
      align-items:stretch;
    }

    .gc-acsr-main-card,
    .gc-acsr-next-card,
    .gc-acsr-event{
      position:relative;
      overflow:hidden;
      padding:clamp(18px,2.2vw,28px);
      border:1px solid var(--gc-mk-line);
      border-top:2px solid var(--gc-mk-accent);
      border-radius:24px;
      background:
        radial-gradient(circle at 12% 10%, color-mix(in srgb,var(--gc-mk-accent) 12%, transparent), transparent 26rem),
        linear-gradient(135deg,rgba(255,255,255,.06),rgba(255,255,255,.02));
      box-shadow:0 20px 80px rgba(0,0,0,.18);
    }

    .gc-acsr-main-card h3,
    .gc-acsr-next-card h3{
      margin:.45rem 0;
      color:var(--gc-mk-text);
      font-size:clamp(1.8rem,3.8vw,3.6rem);
      line-height:.9;
      letter-spacing:-.07em;
      text-transform:uppercase;
    }

    .gc-acsr-main-card p,
    .gc-acsr-next-card p{
      color:var(--gc-mk-muted);
      line-height:1.5;
    }

    .gc-acsr-stats{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:8px;
      margin:18px 0;
    }

    .gc-acsr-stats div{
      padding:12px;
      border:1px solid var(--gc-mk-line);
      border-radius:14px;
      background:rgba(0,0,0,.16);
    }

    .gc-acsr-stats span{
      display:block;
      color:var(--gc-mk-soft);
      font-size:.66rem;
      font-weight:950;
      text-transform:uppercase;
      letter-spacing:.09em;
    }

    .gc-acsr-stats strong{
      display:block;
      margin-top:6px;
      color:var(--gc-mk-text);
      font-size:1.35rem;
      line-height:1;
    }

    .gc-acsr-track{
      margin-top:16px;
      padding:12px;
      border:1px solid var(--gc-mk-line);
      border-radius:14px;
      color:var(--gc-mk-accent);
      font-weight:950;
      text-transform:uppercase;
      letter-spacing:.05em;
      background:rgba(255,255,255,.035);
    }

    .gc-acsr-track-media{
      margin:16px 0 0;
      border:1px solid var(--gc-mk-line);
      border-radius:18px;
      overflow:hidden;
      background:rgba(0,0,0,.18);
    }

    .gc-acsr-track-media[hidden],
    .gc-acsr-event-media[hidden]{
      display:none;
    }

    .gc-acsr-track-media img{
      display:block;
      width:100%;
      aspect-ratio:16/9;
      object-fit:cover;
      background:rgba(0,0,0,.28);
    }

    .gc-acsr-event-media{
      margin:calc(clamp(18px,2.2vw,28px) * -1) calc(clamp(18px,2.2vw,28px) * -1) 14px;
      border-bottom:1px solid var(--gc-mk-line);
      background:rgba(0,0,0,.22);
      overflow:hidden;
    }

    .gc-acsr-event-media img{
      display:block;
      width:100%;
      aspect-ratio:16/7;
      object-fit:cover;
      opacity:.92;
      filter:saturate(1.04) contrast(1.03);
    }

    .gc-acsr-events-shell,
    .gc-acsr-standings-shell,
    .gc-acsr-drivers-shell{
      display:grid;
      gap:14px;
    }

    .gc-acsr-events{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:12px;
    }

    .gc-acsr-event{
      min-height:170px;
      display:grid;
      align-content:space-between;
      gap:12px;
      border-top:1px solid var(--gc-mk-line);
      border-left:3px solid var(--gc-mk-accent);
      border-radius:18px;
      box-shadow:none;
    }

    .gc-acsr-event[data-status="completed"]{
      border-left-color:#7e8b7c;
      opacity:.76;
    }

    .gc-acsr-event[data-status="in_progress"]{
      border-left-color:#ffc46b;
    }

    .gc-acsr-event strong{
      display:block;
      color:var(--gc-mk-text);
      font-size:1.15rem;
      line-height:1.08;
      letter-spacing:-.03em;
    }

    .gc-acsr-event span{
      display:inline-flex;
      width:max-content;
      min-height:26px;
      align-items:center;
      padding:0 8px;
      border:1px solid var(--gc-mk-line);
      color:var(--gc-mk-soft);
      font-size:.66rem;
      font-weight:950;
      text-transform:uppercase;
      letter-spacing:.09em;
      background:rgba(255,255,255,.028);
    }

    .gc-acsr-event p{
      margin:0;
      color:var(--gc-mk-muted);
      line-height:1.42;
    }

    .gc-acsr-standings-table-wrap{
      overflow:auto;
      border:1px solid var(--gc-mk-line);
      border-radius:20px;
      background:rgba(255,255,255,.025);
    }

    .gc-acsr-standings-table{
      width:100%;
      min-width:860px;
      border-collapse:collapse;
    }

    .gc-acsr-standings-table th,
    .gc-acsr-standings-table td{
      padding:12px 14px;
      border-bottom:1px solid var(--gc-mk-line);
      text-align:left;
      vertical-align:top;
    }

    .gc-acsr-standings-table th{
      color:var(--gc-mk-soft);
      font-size:.68rem;
      font-weight:950;
      text-transform:uppercase;
      letter-spacing:.09em;
      background:rgba(255,255,255,.035);
    }

    .gc-acsr-standings-table td{
      color:var(--gc-mk-text);
    }

    .gc-acsr-standings-table small{
      display:block;
      margin-top:3px;
      color:var(--gc-mk-muted);
      font-size:.76rem;
    }

    .gc-acsr-drivers{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:10px;
    }

    .gc-acsr-driver{
      display:grid;
      gap:7px;
      min-height:112px;
      padding:14px;
      border:1px solid var(--gc-mk-line);
      border-radius:18px;
      background:linear-gradient(135deg,rgba(255,255,255,.045),rgba(255,255,255,.016));
    }

    .gc-acsr-driver strong{
      color:var(--gc-mk-text);
      line-height:1.1;
      letter-spacing:-.025em;
    }

    .gc-acsr-driver span{
      color:var(--gc-mk-accent);
      font-size:.68rem;
      font-weight:950;
      text-transform:uppercase;
      letter-spacing:.08em;
    }

    .gc-acsr-driver small{
      color:var(--gc-mk-muted);
      line-height:1.35;
    }

    .gc-acsr-note{
      padding-top:0;
    }

    @media(max-width:1050px){
      .gc-acsr-grid,
      .gc-acsr-events,
      .gc-acsr-drivers{
        grid-template-columns:1fr;
      }

      .gc-acsr-stats{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }
    }

    @media(max-width:860px){
      .gc-acsr-hero{
        padding-top:clamp(54px,12vw,82px)!important;
        padding-bottom:clamp(54px,12vw,88px)!important;
      }

      .gc-acsr-hero-inner{
        min-height:clamp(430px,78vh,620px)!important;
        padding-top:clamp(28px,7vw,48px)!important;
        padding-bottom:clamp(44px,10vw,72px)!important;
      }

      .gc-acsr-hero::before{
        height:clamp(220px,45vw,360px)!important;
      }
    }

    @media(max-width:640px){
      .gc-acsr-stats{
        grid-template-columns:1fr;
      }
    }
  </style>

  <script is:inline src="/js/gc-track-images.js"></script>
  <script is:inline>
    (() => {
      const $ = (id) => document.getElementById(id);
      const els = {
        lead: $('acsrChampionshipLead'),
        name: $('acsrChampionshipName'),
        meta: $('acsrChampionshipMeta'),
        events: $('acsrStatEvents'),
        completed: $('acsrStatCompleted'),
        classes: $('acsrStatClasses'),
        entrants: $('acsrStatEntrants'),
        official: $('acsrOfficialLink'),
        signup: $('acsrSignupLink'),
        signupHero: $('acsrSignupHero'),
        refresh: $('acsrRefresh'),
        nextTitle: $('acsrNextTitle'),
        nextMeta: $('acsrNextMeta'),
        nextTrack: $('acsrNextTrack'),
        trackFigure: $('acsrTrackFigure'),
        trackImage: $('acsrTrackImage'),
        list: $('acsrEventsList'),
        drivers: $('acsrDriversList'),
        standingsBody: $('acsrStandingsBody'),
        standingsLead: $('acsrStandingsLead')
      };

      const escapeHtml = (value) => String(value ?? '').replace(/[&<>'"]/g, (char) => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', "'":'&#39;', '"':'&quot;' }[char]));
      const fmtDate = (value) => {
        if (!value) return 'Fecha por confirmar';
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return 'Fecha por confirmar';
        return date.toLocaleString('es-ES', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
      };

      const statusLabel = {
        pending: 'Pendiente',
        scheduled: 'Programada',
        in_progress: 'En curso',
        completed: 'Completada',
        cancelled: 'Cancelada'
      };

      const cleanTrackText = (value) => {
        if (value === undefined || value === null) return '';
        if (typeof value === 'string' || typeof value === 'number') return String(value).trim();
        if (typeof value === 'object') {
          return cleanTrackText(
            value.track ||
            value.Track ||
            value.trackName ||
            value.TrackName ||
            value.name ||
            value.Name ||
            value.id ||
            value.ID ||
            ''
          );
        }
        return '';
      };

      const trackImageCandidates = (trackName) => {
        const clean = cleanTrackText(trackName);
        const helper = window.GCTrackImages;

        if (helper?.candidates) {
          return helper.candidates(clean).filter((url) => !url.includes('object_object'));
        }

        const slug = clean
          .toLowerCase()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .replace(/[^a-z0-9]+/g, '_')
          .replace(/^_+|_+$/g, '');

        return [
          `/images/tracks/${slug}.webp`,
          `/images/tracks/${slug}.jpg`,
          `/images/tracks/${slug}.png`,
          `/imagenes/tracks/${slug}.webp`,
          `/imagenes/tracks/${slug}.jpg`
        ];
      };

      const imageErrorHandler = (list) => {
        const safeList = (Array.isArray(list) ? list : []).filter(Boolean).map((item) => String(item).replace(/"/g, '&quot;')).join('|');
        return `const list=(this.dataset.fallbacks||'').split('|').filter(Boolean); const i=Number(this.dataset.fallbackIndex||0); if(list[i]){this.dataset.fallbackIndex=String(i+1); this.src=list[i];} else { this.closest('figure')?.setAttribute('hidden',''); this.style.display='none'; }`;
      };

      const renderTrackFigureHtml = (trackName, className = 'gc-acsr-event-media') => {
        const clean = cleanTrackText(trackName);
        const candidates = trackImageCandidates(clean);
        const primary = candidates[0] || '';
        const fallbacks = candidates.slice(1).join('|');

        if (!clean || !primary) return '';

        return `
          <figure class="${className}" data-track-name="${escapeHtml(clean)}">
            <img
              src="${escapeHtml(primary)}"
              alt="${escapeHtml(clean)}"
              loading="lazy"
              data-fallbacks="${escapeHtml(fallbacks)}"
              data-fallback-index="0"
              onerror="${imageErrorHandler(candidates.slice(1))}"
            />
          </figure>
        `;
      };

      function renderTrackImage(trackName) {
        const clean = cleanTrackText(trackName);
        const candidates = trackImageCandidates(clean);

        if (!clean || !candidates.length || !els.trackImage || !els.trackFigure) {
          if (els.trackFigure) els.trackFigure.hidden = true;
          return;
        }

        els.trackFigure.hidden = false;
        els.trackImage.style.display = '';
        els.trackImage.alt = clean;
        els.trackImage.dataset.fallbacks = candidates.slice(1).join('|');
        els.trackImage.dataset.fallbackIndex = '0';
        els.trackImage.onerror = function () {
          const list = (this.dataset.fallbacks || '').split('|').filter(Boolean);
          const index = Number(this.dataset.fallbackIndex || 0);
          if (list[index]) {
            this.dataset.fallbackIndex = String(index + 1);
            this.src = list[index];
            return;
          }

          this.closest('figure')?.setAttribute('hidden', '');
          this.style.display = 'none';
        };
        els.trackImage.src = candidates[0];
      }

      function renderDrivers(rows) {
        const drivers = Array.isArray(rows) ? rows : [];

        if (!drivers.length) {
          els.drivers.innerHTML = '<article class="gc-acsr-driver"><strong>Sin pilotos inscritos</strong><small>Cuando haya pilotos registrados, aparecerán aquí.</small></article>';
          return;
        }

        els.drivers.innerHTML = drivers.slice(0, 48).map((driver) => {
          const details = [driver.team, driver.model].filter(Boolean).join(' · ');
          return `
            <article class="gc-acsr-driver">
              <span>${escapeHtml(driver.className || 'General')}</span>
              <strong>${escapeHtml(driver.name || 'Piloto sin nombre')}</strong>
              <small>${escapeHtml(details || 'Inscrito')}</small>
            </article>
          `;
        }).join('');
      }

      function renderStandings(rows) {
        const standings = Array.isArray(rows) ? rows : [];

        els.standingsLead.textContent = standings.length
          ? `${standings.length} pilotos en la clasificación.`
          : 'La clasificación se actualizará cuando haya datos disponibles.';

        els.standingsBody.innerHTML = standings.length ? standings.slice(0, 80).map((driver, index) => `
          <tr>
            <td><strong>${escapeHtml(driver.position || index + 1)}</strong></td>
            <td>
              <strong>${escapeHtml(driver.name || 'Piloto sin nombre')}</strong>
            </td>
            <td>${escapeHtml(driver.className || 'General')}</td>
            <td>${escapeHtml(driver.model || 'Sin coche')}</td>
            <td><strong>${escapeHtml(driver.points ?? 0)}</strong></td>
          </tr>
        `).join('') : '<tr><td colspan="5">La clasificación se actualizará cuando haya resultados disponibles.</td></tr>';
      }

      function renderError(data) {
        els.lead.textContent = data?.message || 'No se pudo cargar el campeonato.';
        els.meta.textContent = 'No se pudo cargar el campeonato en este momento.';
        els.list.innerHTML = `<article class="gc-acsr-event"><strong>No se pudo cargar el campeonato</strong><p>${escapeHtml(data?.message || 'Error desconocido')}</p></article>`;
        renderStandings([]);
        renderDrivers([]);
        if (data?.acsm?.championshipUrl) els.official.href = data.acsm.championshipUrl;
        if (data?.acsm?.signUpUrl) {
          els.signup.href = data.acsm.signUpUrl;
          els.signupHero.href = data.acsm.signUpUrl;
        }
      }

      function render(data) {
        if (!data?.ok || !data?.championship) {
          renderError(data);
          return;
        }

        const championship = data.championship;
        const next = championship.nextEvent;
        const events = Array.isArray(championship.events) ? championship.events : [];
        const standings = Array.isArray(championship.standings) ? championship.standings : [];
        const drivers = Array.isArray(championship.registeredDrivers) ? championship.registeredDrivers : [];
        const stats = championship.stats || {};

        els.lead.textContent = `Calendario actualizado. Progreso del campeonato: ${championship.progressPercent || 0}%.`;
        els.name.textContent = championship.name || 'Campeonato ACSR';
        els.meta.textContent = `ID ${championship.id} · ${championship.acsrEnabled ? 'ACSR activo' : 'ACSR no marcado'} · actualizado ${fmtDate(championship.updatedAt)}`;
        els.events.textContent = String(stats.events ?? events.length ?? '--');
        els.completed.textContent = String(stats.completedEvents ?? '--');
        els.classes.textContent = String(stats.classes ?? '--');
        els.entrants.textContent = String(stats.entrants ?? drivers.length ?? '--');

        if (data.acsm?.championshipUrl) els.official.href = data.acsm.championshipUrl;
        if (data.acsm?.signUpUrl) {
          els.signup.href = data.acsm.signUpUrl;
          els.signupHero.href = data.acsm.signUpUrl;
        }

        if (next) {
          els.nextTitle.textContent = next.name || `Ronda ${next.index}`;
          els.nextMeta.textContent = `${fmtDate(next.scheduledAt)} · ${statusLabel[next.status] || next.status || 'Pendiente'}`;
          const nextTrackName = cleanTrackText(next.track || next.trackName);
          els.nextTrack.textContent = [nextTrackName, next.carSummary].filter(Boolean).join(' · ') || 'Circuito pendiente';
          renderTrackImage(nextTrackName);
        } else {
          els.nextTitle.textContent = 'Sin próxima ronda';
          els.nextMeta.textContent = 'Todas las rondas parecen completadas o no hay eventos programados.';
          els.nextTrack.textContent = 'Campeonato sin próxima fecha';
          renderTrackImage('');
        }

        els.list.innerHTML = events.slice(0, 12).map((event) => {
          const eventTrackName = cleanTrackText(event.track || event.trackName);
          return `
            <article class="gc-acsr-event" data-status="${escapeHtml(event.status || 'pending')}">
              ${renderTrackFigureHtml(eventTrackName)}
              <div>
                <span>${escapeHtml(statusLabel[event.status] || event.status || 'Pendiente')}</span>
                <strong>${escapeHtml(event.name || `Ronda ${event.index}`)}</strong>
              </div>
              <p>${escapeHtml(fmtDate(event.scheduledAt))}</p>
              <p>${escapeHtml([eventTrackName, event.carSummary].filter(Boolean).join(' · ') || 'Combo por confirmar')}</p>
            </article>
          `;
        }).join('') || '<article class="gc-acsr-event"><strong>Sin rondas</strong><p>Todavía no hay rondas visibles.</p></article>';

        renderStandings(standings.length ? standings : drivers);
        renderDrivers(drivers);
        console.info('[GC campeonato ACSR v5.4 hero video]', {
          ok: true,
          events: events.length,
          standings: standings.length,
          registeredDrivers: drivers.length
        });
      }

      async function load(refresh = false) {
        els.lead.textContent = refresh ? 'Actualizando campeonato...' : 'Cargando campeonato...';

        try {
          const response = await fetch(`/api/community/acsr-championship${refresh ? '?refresh=1' : ''}`, { cache: 'no-store' });
          const data = await response.json();
          render(data);
        } catch (error) {
          renderError({ message: error?.message || String(error) });
        }
      }

      els.refresh?.addEventListener('click', () => load(true));
      load();
    })();
  </script>
</MarketingLayout>

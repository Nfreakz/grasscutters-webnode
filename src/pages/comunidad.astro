---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const discordUrl = 'https://discord.gg/jA4yuuH5T';
const whatsappUrl = 'https://chat.whatsapp.com/JMXKRF4XnG73D4xLzzrlHa';
const instagramUrl = 'https://www.instagram.com/grasscutters_ac/';
const gtxSupportUrl = 'https://www.gtxgaming.co.uk/clientarea/index.php?m=public_pay&hash_id=mW1QWBg9XVJn';

const textChannels = [
  ['💬', 'general · chat', 'Charla diaria, dudas rápidas, avisos entre pilotos y conversación sin tener que abrir veinte hilos.'],
  ['📋', 'info', 'Información básica del servidor, accesos y cosas que conviene tener localizadas.'],
  ['📢', 'anuncios', 'Avisos importantes, cambios de combo, eventos y novedades de la comunidad.'],
  ['🚀', 'mods · ac', 'Mods de Assetto Corsa, packs, enlaces y material para tener el garaje al día.'],
  ['💯', 'setups-ac', 'Ajustes de coche, volante, sensaciones y pruebas compartidas por la gente.'],
  ['🖥️', 'servidor · ac', 'Estado y detalles del servidor de Assetto Corsa.'],
  ['🏁', 'campeonatos', 'Organización de carreras, rondas y seguimiento cuando se monta algo más serio.'],
  ['🚗', 'servidor · raceroom', 'Espacio para RaceRoom cuando toca salir del garaje habitual.'],
  ['💯', 'grasscutters-hud-ac', 'Feedback, dudas y versiones del HUD de GrassCutters para Assetto Corsa.'],
  ['🛡️', 'lowfuelmotorsport-ac', 'Charla y dudas sobre LFM dentro del grupo.'],
  ['🎥', 'clips · highlights', 'Vueltas buenas, adelantamientos, fails y momentos para enseñar al paddock.'],
  ['🤓', 'datos-curiosos', 'Cosas raras, detalles técnicos y pequeñas joyas del sim racing.'],
  ['🏛️', 'donaciones', 'Apoyo voluntario para mantener el servidor y sus costes.'],
  ['🗳️', 'votaciones', 'Donde se decide qué se prueba, qué se corre y qué toca mover después.']
];

const voiceChannels = [
  ['🎙️', 'Lobby', 'Para entrar, hablar y organizarse sin complicarse.'],
  ['🎙️', 'Lobby AC', 'Voz rápida cuando se está rodando en Assetto Corsa.']
];

const principles = [
  ['01', 'Actitud antes que ritmo', 'No hace falta ser el más rápido. Hace falta sumar buen ambiente, respetar y querer mejorar.'],
  ['02', 'Pista limpia', 'Se puede competir fuerte, pero sin choques intencionados, sin zigzag y dejando espacio cuando toca.'],
  ['03', 'Sin dramas en caliente', 'Si hay incidente, se enfría primero y se habla después. El chat no es dirección de carrera con fuego en el casco.']
];

const dailyRacers = [
  'Participar regularmente en carreras o hotlaps.',
  'Estar activo en Discord: chat, feedback, dudas, ambiente.',
  'Implicarse en eventos, votaciones o pruebas del servidor.',
  'Mantener una actitud positiva y respetuosa.'
];
---
<MarketingLayout
  title="Comunidad | GrassCutters Racing"
  description="Comunidad GrassCutters Racing: Discord, hotlaps semanales, setups, mods, votaciones, fair play y buen ambiente en Assetto Corsa."
  bodyClass="gc-page-comunidad gc-community-rework-v104"
>
  <section class="gc-hero gc-hero-compact gc-community-hero gc-community-hero-video gc-home-hero-video">
    <video
      class="gc-community-hero-bg-video gc-home-hero-bg-video"
      src="/videos/comunidad-hero.mp4"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
    ></video>
    <div class="gc-community-hero-scrim gc-home-hero-scrim"></div>

    <div class="gc-page gc-community-hero-inner gc-home-hero-inner gc-community-home-inner-v113">
      <div>
        <span class="gc-kicker">Comunidad GC</span>
        <h1 class="gc-title">Un paddock para correr, mejorar y volver.</h1>
        <p class="gc-lead">
          GrassCutters es una comunidad para rodar, comentar carreras, seguir campeonatos y compartir pista sin perder el buen ambiente.
        </p>
        <div class="gc-actions gc-community-social-actions" aria-label="Canales de la comunidad">
          <a class="gc-btn gc-community-social-btn gc-community-social-btn--discord" href={discordUrl} target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19.55 5.45A16.4 16.4 0 0 0 15.45 4l-.2.4a12.6 12.6 0 0 1 3.52 1.77A14.9 14.9 0 0 0 12 4.55a14.9 14.9 0 0 0-6.77 1.62A12.6 12.6 0 0 1 8.75 4.4L8.55 4c-1.43.25-2.8.74-4.1 1.45C1.86 9.3 1.17 13.05 1.53 16.75A16.6 16.6 0 0 0 6.55 19.3l.62-.86a10.6 10.6 0 0 1-1.62-.77l.39-.29A11.55 11.55 0 0 0 12 19a11.55 11.55 0 0 0 6.06-1.62l.39.29a10.6 10.6 0 0 1-1.62.77l.62.86a16.6 16.6 0 0 0 5.02-2.55c.43-4.29-.73-8-2.92-11.3ZM8.32 14.35c-.96 0-1.74-.88-1.74-1.96s.77-1.96 1.74-1.96c.98 0 1.77.88 1.75 1.96 0 1.08-.77 1.96-1.75 1.96Zm7.36 0c-.96 0-1.75-.88-1.75-1.96s.77-1.96 1.75-1.96c.98 0 1.75.88 1.75 1.96s-.77 1.96-1.75 1.96Z" /></svg>
            <span>Discord</span>
          </a>
          <a class="gc-btn gc-community-social-btn gc-community-social-btn--whatsapp" href={whatsappUrl} target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12.05 3a8.82 8.82 0 0 0-7.49 13.49L3.7 21l4.6-1.2A8.82 8.82 0 1 0 12.05 3Zm0 1.7a7.12 7.12 0 0 1 6.05 10.87 7.09 7.09 0 0 1-8.85 2.65l-.32-.15-2.72.71.73-2.64-.18-.34A7.12 7.12 0 0 1 12.05 4.7Zm-3.1 3.78c-.2 0-.52.08-.8.38-.27.3-1.05 1.03-1.05 2.52 0 1.48 1.08 2.92 1.23 3.12.15.2 2.1 3.36 5.2 4.57 2.57 1 3.1.8 3.66.75.56-.05 1.8-.74 2.05-1.45.25-.72.25-1.33.18-1.46-.08-.13-.28-.2-.58-.36-.3-.15-1.8-.9-2.08-1-.28-.1-.48-.15-.68.15-.2.3-.78 1-.96 1.2-.18.2-.36.22-.66.07-.3-.15-1.26-.47-2.4-1.5-.88-.78-1.48-1.75-1.65-2.05-.18-.3-.02-.46.13-.61.13-.13.3-.36.45-.54.15-.18.2-.3.3-.5.1-.2.05-.38-.03-.53-.08-.15-.68-1.64-.94-2.25-.25-.6-.5-.51-.68-.52h-.58Z" /></svg>
            <span>WhatsApp</span>
          </a>
          <a class="gc-btn gc-community-social-btn gc-community-social-btn--instagram" href={instagramUrl} target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.2 3h9.6A4.2 4.2 0 0 1 21 7.2v9.6a4.2 4.2 0 0 1-4.2 4.2H7.2A4.2 4.2 0 0 1 3 16.8V7.2A4.2 4.2 0 0 1 7.2 3Zm0 1.8a2.4 2.4 0 0 0-2.4 2.4v9.6a2.4 2.4 0 0 0 2.4 2.4h9.6a2.4 2.4 0 0 0 2.4-2.4V7.2a2.4 2.4 0 0 0-2.4-2.4H7.2ZM12 8.15A3.85 3.85 0 1 1 12 15.85 3.85 3.85 0 0 1 12 8.15Zm0 1.8a2.05 2.05 0 1 0 0 4.1 2.05 2.05 0 0 0 0-4.1Zm4.15-2.85a.9.9 0 1 1 0 1.8.9.9 0 0 1 0-1.8Z" /></svg>
            <span>Instagram</span>
          </a>
          <a class="gc-btn gc-community-pilots-btn" href="/pilotos">Ver pilotos</a>
        </div>
      </div>
    </div>
  </section>

  <section class="gc-page gc-community-manifest-v104 gc-week-combo-section gc-community-first-after-hero-v113">
    <div class="gc-community-manifest-grid-v104">
      <article class="gc-community-copy-v104">
        <span class="gc-section-kicker">Qué es GrassCutters</span>
        <h2>Un servidor para correr sin problemas.</h2>
        <p>
          Aquí se viene a desconectar, probar coches, compartir setups, votar combos y hacer vueltas sin convertir cada tarde en una reunión de comisarios.
          Si hablas español, perfecto. Si no, pero te adaptas al ambiente del grupo, también tienes sitio.
        </p>
        <p>
          Nos gusta correr limpio y apretar cuando toca, pero valoramos más la actitud que el ritmo. Puedes entrar siendo nuevo, rápido, lento o irregular:
          lo importante es respetar, aprender y no traer toxicidad al box.
        </p>
      </article>

      <aside class="gc-community-pitwall-v104" aria-label="Resumen de comunidad">
        <div class="gc-community-pitwall-top-v105">
          <img src="/images/comunidad-card-bg3.webp" alt="" loading="lazy" aria-hidden="true" />
        </div>
        <ul>
          <li><strong>Hotlaps</strong><span>Semanales con Stracker</span></li>
          <li><strong>Combos</strong><span>Votados por la comunidad</span></li>
          <li><strong>Setups</strong><span>Coche, volante y sensaciones</span></li>
          <li><strong>Clips</strong><span>Highlights, fails y momentos buenos</span></li>
          <li><strong>Eventos</strong><span>Carreras semanales, LFM y otros sims de vez en cuando</span></li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="gc-page gc-community-how-v104">
    <div class="gc-section-head">
      <span class="gc-section-kicker">Cómo funciona</span>
      <h2 class="gc-section-title">Discord para hablar. La web para seguir resultados, combos y pilotos.</h2>
      <p class="gc-section-lead">
        Todo gira alrededor de probar, votar, correr y comentar. Sin hacerlo más complicado de lo necesario.
      </p>
    </div>

    <div class="gc-community-steps-v104">
      <article>
        <span>01</span>
        <h3>Entras al Discord</h3>
        <p>Saludas, miras anuncios, preguntas lo que haga falta y te pones al día con el combo o el evento activo.</p>
      </article>
      <article>
        <span>02</span>
        <h3>Pruebas el combo</h3>
        <p>El servidor va rotando. Hay coches, circuitos, hotlaps y referencias para saber dónde estás.</p>
      </article>
      <article>
        <span>03</span>
        <h3>Compartes lo que aprendes</h3>
        <p>Setups, clips, dudas, errores, mejoras y feedback. Nadie nace sabiendo frenar tarde en todos los circuitos.</p>
      </article>
      <article>
        <span>04</span>
        <h3>Votas lo siguiente</h3>
        <p>La comunidad decide qué apetece probar. Coches, tracks, eventos y pruebas salen del propio grupo.</p>
      </article>
    </div>
  </section>

  <section class="gc-page gc-community-rules-v104">
    <div class="gc-community-rules-grid-v104">
      <div>
        <span class="gc-section-kicker">Filosofía GC</span>
        <h2>Pocas normas. Buen ambiente. Pista limpia.</h2>
        <p>
          No buscamos un servidor lleno de sanciones absurdas. Tampoco un sitio donde valga todo.
          La línea es sencilla: respeto en el chat, respeto en pista y cero dramas cuando algo sale mal.
        </p>
      </div>

      <div class="gc-community-principles-v104">
        {principles.map(([number, title, text]) => (
          <article>
            <span>{number}</span>
            <div>
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="gc-page gc-community-discord-v104">
    <div class="gc-section-head">
      <span class="gc-section-kicker">Canales del Discord</span>
      <h2 class="gc-section-title">Cada cosa en su sitio.</h2>
      <p class="gc-section-lead">
        El Discord no está para perderse. Hay canales para hablar, votar, compartir mods, subir clips y organizar carreras.
      </p>
    </div>

    <div class="gc-community-discord-layout-v104">
      <article class="gc-community-channel-panel-v104">
        <div class="gc-community-channel-head-v104">
          <h3>Canales de texto</h3>
          <span>{textChannels.length} canales</span>
        </div>

        <div class="gc-community-channel-list-v104">
          {textChannels.map(([icon, name, text]) => (
            <div class="gc-community-channel-v104">
              <span aria-hidden="true">{icon}</span>
              <div>
                <strong># {name}</strong>
                <p>{text}</p>
              </div>
            </div>
          ))}
        </div>
      </article>

      <aside class="gc-community-side-stack-v104">
        <article class="gc-community-channel-panel-v104 gc-community-voice-v104">
          <div class="gc-community-channel-head-v104">
            <h3>Canales de voz</h3>
            <span>Lobby</span>
          </div>

          <div class="gc-community-channel-list-v104">
            {voiceChannels.map(([icon, name, text]) => (
              <div class="gc-community-channel-v104">
                <span aria-hidden="true">{icon}</span>
                <div>
                  <strong>{name}</strong>
                  <p>{text}</p>
                </div>
              </div>
            ))}
          </div>
        </article>

        <article class="gc-community-note-v104">
          <span>Regla de oro</span>
          <h3>Lo que pase en pista no se discute en caliente.</h3>
          <p>
            Si hay incidente, se revisa con calma después. Primero enfriar. Luego hablar.
          </p>
        </article>
      </aside>
    </div>
  </section>

  <section class="gc-page gc-community-daily-v104">
    <div class="gc-community-daily-card-v104">
      <div>
        <span class="gc-section-kicker">Daily Racers</span>
        <h2>No se pide. Se gana.</h2>
        <p>
          Daily Racers es para quienes están de verdad en el día a día de la comunidad.
          No va de ser el más rápido, va de aparecer, participar y mantener vivo el servidor.
        </p>
      </div>

      <ul>
        {dailyRacers.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="gc-page gc-community-support-v104">
    <div class="gc-community-support-grid-v104">
      <article>
        <span class="gc-section-kicker">Apoyo al servidor</span>
        <h2>El servidor se mantiene entre todos.</h2>
        <p>
          Las donaciones voluntarias se usan únicamente para pagar el proveedor de hosting GTX:
          mantenimiento, slots y servidor. Nada de compras externas ni historias raras.
        </p>
        <div class="gc-actions">
          <a class="gc-btn gc-btn-primary" href={gtxSupportUrl} target="_blank" rel="noreferrer">Apoyar servidor GTX</a>
        </div>
      </article>

      <aside>
        <h3>Otras formas de ayudar</h3>
        <p>
          Participar, votar, compartir clips, pasar setups, reportar problemas y asignar boosts al Discord si te sobra alguno.
          Todo suma más de lo que parece.
        </p>
      </aside>
    </div>
  </section>

  <section class="gc-page gc-community-final-v104">
    <div class="gc-community-final-card-v104">
      <span class="gc-section-kicker">Entrada al paddock</span>
      <h2>Entra, saluda y prueba el combo.</h2>
      <p>
        Si quieres rodar en Assetto Corsa, compartir setups, mirar hotlaps y correr con gente sin convertirlo en un drama,
        GrassCutters te queda cerca.
      </p>
      <div class="gc-actions">
        <a class="gc-btn gc-btn-primary" href="/pilotos">Ver pilotos</a>
        <a class="gc-btn" href="/hotlaps">Ver hotlaps</a>
        <a class="gc-btn" href="/app">Ver plataforma</a>
      </div>
    </div>
  </section>

  <style is:global>
    .gc-community-social-actions{
      display:flex;
      flex-wrap:wrap;
      gap:12px;
      align-items:center;
    }

    .gc-community-social-btn,
    .gc-community-pilots-btn{
      min-height:52px;
      padding:0 20px!important;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      border-radius:999px!important;
      color:#fff!important;
      font-weight:950;
      letter-spacing:.06em;
      text-transform:uppercase;
      line-height:1;
      border:1px solid rgba(255,255,255,.14)!important;
      box-shadow:0 16px 46px rgba(0,0,0,.28);
    }

    .gc-community-social-btn svg{
      width:22px;
      height:22px;
      display:block;
      fill:currentColor;
      color:#fff!important;
      flex:0 0 auto;
    }

    .gc-community-social-btn span{
      color:#fff!important;
    }

    .gc-community-pilots-btn{
      color:var(--text)!important;
    }

    .gc-community-social-btn--discord{
      background:linear-gradient(135deg,#5865f2,#7c88ff)!important;
    }

    .gc-community-social-btn--whatsapp{
      background:linear-gradient(135deg,#20c85a,#42e878)!important;
    }

    .gc-community-social-btn--instagram{
      background:linear-gradient(135deg,#feda75,#fa7e1e 34%,#d62976 68%,#4f5bd5)!important;
    }

    .gc-community-pilots-btn{
      background:var(--gc-btn-bg, rgba(255,255,255,.045))!important;
      color:var(--text)!important;
      box-shadow:none!important;
    }

    .gc-community-rework-v104 .gc-page{
      position:relative;
    }



    .gc-community-manifest-v104{
      padding-top:clamp(26px,5vw,64px);
    }

    .gc-page-comunidad .gc-community-home-inner-v113{
      display:block!important;
      grid-template-columns:1fr!important;
    }

    .gc-page-comunidad .gc-community-first-after-hero-v113{
      position:relative;
      z-index:6;
    }

    .gc-community-manifest-grid-v104,
    .gc-community-rules-grid-v104,
    .gc-community-support-grid-v104{
      display:grid;
      grid-template-columns:minmax(0,1.04fr) minmax(320px,.72fr);
      gap:clamp(20px,4vw,54px);
      align-items:stretch;
    }

    .gc-community-copy-v104,
    .gc-community-pitwall-v104,
    .gc-community-steps-v104 article,
    .gc-community-channel-panel-v104,
    .gc-community-note-v104,
    .gc-community-daily-card-v104,
    .gc-community-support-grid-v104 article,
    .gc-community-support-grid-v104 aside,
    .gc-community-final-card-v104{
      border:1px solid var(--gc-mk-line);
      border-radius:24px;
      background:
        radial-gradient(circle at 10% 0%, color-mix(in srgb,var(--gc-mk-accent) 9%, transparent), transparent 22rem),
        linear-gradient(180deg,rgba(255,255,255,.07),rgba(255,255,255,.028));
      box-shadow:0 22px 70px rgba(0,0,0,.24);
    }

    .gc-community-copy-v104{
      padding:clamp(24px,4vw,42px);
    }

    .gc-community-copy-v104 h2,
    .gc-community-rules-v104 h2,
    .gc-community-daily-card-v104 h2,
    .gc-community-support-grid-v104 h2,
    .gc-community-final-card-v104 h2{
      margin:12px 0 0;
      font-size:clamp(2.15rem,4.8vw,4.7rem);
      line-height:.93;
      letter-spacing:-.075em;
    }

    .gc-community-copy-v104 p,
    .gc-community-rules-v104 p,
    .gc-community-daily-card-v104 p,
    .gc-community-support-grid-v104 p,
    .gc-community-final-card-v104 p{
      max-width:760px;
      color:var(--gc-mk-muted);
      font-size:1.02rem;
      line-height:1.72;
    }

    .gc-community-pitwall-v104{
      padding:24px;
      display:grid;
      align-content:space-between;
      gap:22px;
    }

    .gc-community-pitwall-top-v105{
      position:relative;
      display:grid;
      place-items:center;
      min-height:clamp(120px,16vw,210px);
      padding-top:4px;
    }

    .gc-community-pitwall-top-v105 img{
      width:clamp(150px,15vw,230px);
      max-height:clamp(112px,13vw,190px);
      height:auto;
      object-fit:contain;
      opacity:.94;
      margin:0 auto;
      filter:
        drop-shadow(0 18px 34px rgba(0,0,0,.42))
        drop-shadow(0 0 24px color-mix(in srgb,var(--gc-mk-accent) 24%, transparent));
    }

    .gc-community-pitwall-tag-v104{
      color:var(--gc-mk-accent);
      text-transform:uppercase;
      letter-spacing:.13em;
      font-weight:950;
      font-size:.72rem;
    }

    .gc-community-pitwall-v104 ul{
      list-style:none;
      margin:0;
      padding:0;
      display:grid;
      border-top:1px solid var(--gc-mk-line);
      border-bottom:1px solid var(--gc-mk-line);
    }

    .gc-community-pitwall-v104 li{
      display:grid;
      grid-template-columns:minmax(110px,.34fr) 1fr;
      gap:12px;
      padding:15px 0;
      border-bottom:1px solid var(--gc-mk-line-soft);
    }

    .gc-community-pitwall-v104 li:last-child{
      border-bottom:0;
    }

    .gc-community-pitwall-v104 strong{
      color:var(--gc-mk-text);
      text-transform:uppercase;
      letter-spacing:.08em;
      font-size:.8rem;
    }

    .gc-community-pitwall-v104 span{
      color:var(--gc-mk-muted);
    }

    .gc-community-steps-v104{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:14px;
    }

    .gc-community-steps-v104 article{
      padding:22px;
      box-shadow:none;
    }

    .gc-community-steps-v104 article > span,
    .gc-community-principles-v104 article > span{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:38px;
      height:38px;
      border-radius:14px;
      color:#07110a;
      background:linear-gradient(135deg,var(--gc-mk-accent),var(--gc-mk-accent-2));
      font-weight:1000;
    }

    .gc-community-steps-v104 h3,
    .gc-community-principles-v104 h3,
    .gc-community-channel-head-v104 h3,
    .gc-community-note-v104 h3,
    .gc-community-support-grid-v104 h3{
      margin:16px 0 8px;
      color:var(--gc-mk-text);
      font-size:1.18rem;
      letter-spacing:-.035em;
    }

    .gc-community-steps-v104 p,
    .gc-community-principles-v104 p,

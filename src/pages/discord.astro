---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---
<MarketingLayout
  title="Calendario | GrassCutters Racing"
  description="La antigua página de Discord ahora redirige al calendario de eventos GrassCutters."
  canonicalPath="/calendario"
  noindex={true}
>
  <meta http-equiv="refresh" content="0; url=/calendario" />
  <section class="gc-public-shell gc-public-page-hero">
    <div class="gc-public-page-hero__grid">
      <div class="gc-public-page-hero__main">
        <span class="gc-public-kicker">Redirección</span>
        <h1 class="gc-public-title">Calendario GC.</h1>
        <p class="gc-public-description">La página de Discord se ha movido al calendario de eventos.</p>
        <div class="gc-actions">
          <a class="gc-public-btn gc-public-btn-primary" href="/calendario">Abrir calendario</a>
        </div>
      </div>
    </div>
  </section>
  <script is:inline>window.location.replace('/calendario');</script>
</MarketingLayout>

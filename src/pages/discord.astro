---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---
<MarketingLayout title="Calendario | GrassCutters Racing" description="La antigua página de Discord ahora redirige al calendario de eventos GrassCutters." canonicalPath="/calendario" noindex={true}>
  <meta http-equiv="refresh" content="0; url=/calendario" />
  <section class="gc-page gc-hero gc-hero-compact">
    <div>
      <span class="gc-kicker">Redirección</span>
      <h1 class="gc-title">Calendario GC.</h1>
      <p class="gc-lead">La página de Discord se ha movido al calendario de eventos.</p>
      <div class="gc-actions">
        <a class="gc-btn gc-btn-primary" href="/calendario">Abrir calendario</a>
      </div>
    </div>
  </section>
  <script is:inline>window.location.replace('/calendario');</script>
</MarketingLayout>

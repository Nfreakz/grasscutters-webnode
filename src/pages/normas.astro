---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const discordUrl = 'https://discord.gg/jA4yuuH5T';

const ruleCards = [
  ['01', 'Respeto primero', 'Cero insultos, ataques personales, acoso, discriminación o toxicidad. Se puede bromear y competir fuerte, pero sin cruzar líneas raras.'],
  ['02', 'Cada canal en su sitio', 'Usa los canales para lo que toca: anuncios, info, mods, setups, servidor, campeonatos, clips, votaciones o dudas de LFM. Así nadie tiene que perseguir mensajes por todo el paddock.'],
  ['03', 'Sin spam ni ruido', 'Evita flood, mayúsculas excesivas, enlaces maliciosos, NSFW o autopromoción sin permiso. Si algo necesita contexto, mejor explicarlo bien que soltarlo al aire.'],
  ['04', 'Nick reconocible', 'Intenta usar un nombre claro o reconocible. Ayuda a vincular perfiles, tiempos, Discord, servidor y web sin jugar a detectives con casco.'],
  ['05', 'Pista limpia', 'Nada de choques intencionados, zigzag absurdo, reincorporaciones peligrosas, exploits o abuso de bugs. El ritmo importa menos que saber compartir pista.'],
  ['06', 'Incidentes en frío', 'Lo que pasa en pista no se discute en caliente. Primero enfriar. Luego hablar con datos, repetición, captura o contexto.'],
  ['07', 'Temas que no suman', 'Evita política, religión y discusiones de equipos deportivos cuando solo van a prender fuego al chat. Aquí venimos a correr y desconectar.'],
  ['08', 'Actitud antes que ritmo', 'No hace falta ser el más rápido. Hace falta respetar, aprender, aportar y no convertir cada vuelta mala en un drama de box.'],
];

const textChannels = [
  'normas',
  'general · chat',
  'info',
  'anuncios',
  'mods · ac',
  'setups-ac',
  'servidor · ac',
  'campeonatos',
  'servidor · raceroom',
  'grasscutters-hud-ac',
  'lowfuelmotorsport-ac',
  'clips · highlights',
  'datos-curiosos',
  'donaciones',
  'votaciones',
];

const voiceChannels = ['Lobby', 'Lobby AC'];
---
<MarketingLayout
  title="Normas | GrassCutters Racing"
  description="Normas de convivencia, Discord, pista limpia y fair play para la comunidad GrassCutters Racing."
  ogImage="/og/normas-og-v1531.png"
  bodyClass="gc-page-normas-v121"
>
  <section class="gc-public-shell gc-public-page-hero gc-normas-hero-v121">
    <div class="gc-public-page-hero__grid">
      <div class="gc-public-page-hero__main">
        <span class="gc-public-kicker">Normas GC</span>
        <h1 class="gc-public-title">Pocas normas. Buen ambiente. Pista limpia.</h1>
        <p class="gc-public-description">
        GrassCutters es una comunidad para correr, desconectar y compartir pista sin toxicidad. No buscamos llenar el servidor de sanciones:
        buscamos sentido común, respeto y ganas de sumar.
        </p>
        <div class="gc-actions">
          <a class="gc-public-btn gc-public-btn-primary" href={discordUrl} target="_blank" rel="noreferrer">Entrar al Discord</a>
          <a class="gc-public-btn gc-public-btn-secondary" href="/comunidad">Ver comunidad</a>
        </div>
      </div>
    </div>
  </section>

  <section class="gc-public-shell gc-public-section gc-normas-intro-v121">
    <div class="gc-public-section-head">
      <span class="gc-public-kicker">Regla de oro</span>
      <h2 class="gc-public-section-title">Primero enfriar. Luego hablar.</h2>
      <p class="gc-public-section-lead">
        Si hay un incidente en pista, no se convierte el chat en dirección de carrera con gasolina en el suelo.
        Se revisa con calma, con contexto y sin ataques personales.
      </p>
    </div>
  </section>

  <section class="gc-public-shell gc-public-section">
    <div class="gc-normas-grid-v121">
      {ruleCards.map(([number, title, text]) => (
        <article class="gc-normas-card-v121 gc-public-card">
          <span>{number}</span>
          <h2>{title}</h2>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="gc-public-shell gc-public-section gc-normas-discord-v121">
    <div class="gc-normas-discord-card-v121 gc-public-card">
      <div>
        <span class="gc-public-kicker">Discord</span>
        <h2>Un canal para cada cosa.</h2>
        <p>
          El Discord está para organizar la comunidad sin perderse: avisos importantes, combos, setups, mods, clips, votaciones,
          dudas del servidor y charlas del día a día. Cuanto mejor usemos los canales, menos ruido y más pista.
        </p>
      </div>

      <div class="gc-normas-channel-block-v121">
        <h3>Texto</h3>
        <div class="gc-normas-channel-list-v121">
          {textChannels.map((channel) => <span># {channel}</span>)}
        </div>
      </div>

      <div class="gc-normas-channel-block-v121">
        <h3>Voz</h3>
        <div class="gc-normas-channel-list-v121 gc-normas-channel-list-v121--voice">
          {voiceChannels.map((channel) => <span>{channel}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section class="gc-public-shell gc-public-section gc-page-narrow gc-normas-cta-v121">
    <div class="gc-public-cta">
      <div>
        <h2 class="gc-public-cta-title">¿Dudas con una norma?</h2>
        <p class="gc-public-cta-text">
          Pregunta en Discord con calma. Si hay una carrera, un incidente o un problema de convivencia, mejor resolverlo con contexto que en caliente.
        </p>
      </div>
      <div class="gc-actions">
        <a class="gc-public-btn gc-public-btn-primary" href={discordUrl} target="_blank" rel="noreferrer">Ir a Discord</a>
        <a class="gc-public-btn gc-public-btn-secondary" href="/apoyo-servidor">Apoyar servidor</a>
      </div>
    </div>
  </section>
</MarketingLayout>

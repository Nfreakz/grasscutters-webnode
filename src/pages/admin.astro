---
import AppLayout from '../layouts/AppLayout.astro';
import AdminSubnav from '../components/AdminSubnav.astro';
---
<AppLayout title="Admin | GrassCutters">
  <div class="gc-page gc-admin-page-clean gc-admin-page-v30">
    <section class="gc-hero gc-hero--compact gc-admin-hero-v30">
      <div>
        <span class="gc-kicker">Admin console</span>
        <h1 class="gc-title">Control de boxes</h1>
        <p class="gc-subtitle">Panel rápido de administración: usuarios, nombres visibles, calendario, sistema, stracker y ACSM.</p>
        <div class="gc-hero__meta">
          <span class="gc-chip gc-chip--accent">Resumen</span>
          <span class="gc-chip">MySQL</span>
          <span class="gc-chip">ACSM</span>
          <span class="gc-chip">stracker</span>
        </div>
      </div>

      <aside class="gc-live-panel gc-admin-status-panel-v30">
        <div class="gc-live-panel__title">
          <span>Admin</span>
          <strong id="adminState">Comprobando</strong>
        </div>
        <div class="gc-status-list" id="adminStatusRows">
          <div class="gc-status-row"><span>Estado</span><strong>Cargando</strong></div>
        </div>
      </aside>
    </section>

    <div class="gc-admin-subnav-shell-v30">
      <AdminSubnav />
    </div>

    <section class="gc-section gc-admin-gate-v30" id="adminGate" hidden>
      <div class="gc-section-head">
        <div>
          <span class="gc-kicker">Acceso</span>
          <h2>Acceso restringido</h2>
          <p>Solo administradores.</p>
        </div>
      </div>

      <div class="gc-slab gc-admin-gate-slab-v30">
        <h3 id="adminGateTitle">No tienes permisos de admin</h3>
        <p id="adminGateText">Inicia sesión con una cuenta administradora.</p>
        <div class="gc-actions">
          <a class="gc-btn gc-btn--primary" href="/login">Login</a>
          <button class="gc-btn" id="adminGateRetry" type="button">Reintentar</button>
        </div>
      </div>
    </section>

    <section id="adminContent" class="gc-admin-content-v30" hidden>
      <section class="gc-metrics gc-admin-metrics-v30">
        <div class="gc-metric"><span>Usuarios</span><strong id="metricUsers">...</strong><small>cuentas web</small></div>
        <div class="gc-metric"><span>Admins</span><strong id="metricAdmins">...</strong><small>permisos</small></div>
        <div class="gc-metric"><span>Vinculados</span><strong id="metricLinked">...</strong><small>piloto real</small></div>
        <div class="gc-metric"><span>Sesiones</span><strong id="metricSessions">...</strong><small>activas</small></div>
      </section>

      <section class="gc-admin-main-grid-v30">
        <div class="gc-section gc-admin-modules-card-v30">
          <div class="gc-section-head">
            <div>
              <span class="gc-kicker">Módulos</span>
              <h2>Módulos de administración</h2>
              <p>Accesos separados para trabajar sin una página infinita.</p>
            </div>
          </div>

          <div class="gc-admin-module-grid-v30">
            <a class="gc-admin-module-card-v30" href="/admin/usuarios">
              <span class="gc-admin-module-card-v30__num">01</span>
              <span class="gc-admin-module-card-v30__body">
                <strong>Usuarios</strong>
                <small>Cuentas, roles, sesiones y pilotos vinculados.</small>
              </span>
              <span class="gc-admin-module-card-v30__cta">Abrir</span>
            </a>

            <a class="gc-admin-module-card-v30" href="/admin/nombres">
              <span class="gc-admin-module-card-v30__num">02</span>
              <span class="gc-admin-module-card-v30__body">
                <strong>Nombres visibles</strong>
                <small>Alias de pilotos, coches y circuitos.</small>
              </span>
              <span class="gc-admin-module-card-v30__cta">Abrir</span>
            </a>

            <a class="gc-admin-module-card-v30" href="/admin/calendario">
              <span class="gc-admin-module-card-v30__num">03</span>
              <span class="gc-admin-module-card-v30__body">
                <strong>Calendario</strong>
                <small>Eventos, combo semanal y sincronización ACSM.</small>
              </span>
              <span class="gc-admin-module-card-v30__cta">Abrir</span>
            </a>

            <a class="gc-admin-module-card-v30" href="/admin/sistema">
              <span class="gc-admin-module-card-v30__num">04</span>
              <span class="gc-admin-module-card-v30__body">
                <strong>Sistema</strong>
                <small>Storage, stracker, ACSM y diagnóstico.</small>
              </span>
              <span class="gc-admin-module-card-v30__cta">Abrir</span>
            </a>

            <a class="gc-admin-module-card-v30" href="/admin/historial">
              <span class="gc-admin-module-card-v30__num">05</span>
              <span class="gc-admin-module-card-v30__body">
                <strong>Historial</strong>
                <small>Auditoría de acciones sensibles.</small>
              </span>
              <span class="gc-admin-module-card-v30__cta">Abrir</span>
            </a>
          </div>
        </div>

        <aside class="gc-section gc-admin-quick-card-v30">
          <div class="gc-section-head">
            <div>
              <span class="gc-kicker">Sistema</span>
              <h2>Estado rápido</h2>
              <p>Datos principales del panel.</p>
            </div>
          </div>

          <div class="gc-admin-health-stack-v30">
            <article class="gc-admin-health-card-v30">
              <div class="gc-admin-health-card-v30__head">
                <h3>Storage</h3>
                <span id="storageBadge">...</span>
              </div>
              <p id="storageText">Cargando...</p>
              <div class="gc-slab-list gc-admin-mini-list-v30" id="storageRows">
                <div><span>Storage</span><strong>...</strong></div>
              </div>
            </article>

            <article class="gc-admin-health-card-v30">
              <div class="gc-admin-health-card-v30__head">
                <h3>stracker</h3>
                <span id="strackerBadge">...</span>
              </div>
              <p id="strackerText">Cargando...</p>
              <div class="gc-slab-list gc-admin-mini-list-v30" id="strackerRows">
                <div><span>DB</span><strong>...</strong></div>
              </div>
            </article>

            <article class="gc-admin-health-card-v30">
              <div class="gc-admin-health-card-v30__head">
                <h3>ACSM</h3>
                <span id="acsmBadge">Manual</span>
              </div>
              <p id="acsmText">Sincronización del combo actual desde ACSM.</p>
              <div class="gc-actions gc-admin-acsm-actions-v30">
                <button class="gc-btn gc-btn--primary" id="syncAcsmBtn" type="button">Sincronizar combo</button>
                <a class="gc-btn" href="/calendario">Ver calendario</a>
              </div>
              <p class="gc-message" id="acsmMessage"></p>
            </article>
          </div>
        </aside>
      </section>
    </section>
  </div>

  <style is:global>
    .gc-admin-page-v30{
      display:grid;
      gap:clamp(18px,2.3vw,28px);
      width:100%;
      max-width:1480px;
      margin-inline:auto;
      padding-inline:clamp(8px,1.2vw,18px);
      box-sizing:border-box;
    }

    .gc-admin-hero-v30{
      position:relative;
      overflow:hidden;
      margin:0;
      padding-block:clamp(26px,3.4vw,40px)!important;
      border:1px solid color-mix(in srgb,var(--accent,#9dff00) 30%,var(--line));
      border-radius:28px;
      background:
        linear-gradient(120deg,rgba(255,255,255,.07),rgba(255,255,255,.018)),
        radial-gradient(circle at 82% 12%, color-mix(in srgb,var(--accent2,#35d3ff) 10%,transparent), transparent 22rem),
        radial-gradient(circle at 8% 18%, color-mix(in srgb,var(--accent,#9dff00) 12%,transparent), transparent 20rem);
      box-shadow:0 18px 70px rgba(0,0,0,.20), inset 0 0 0 1px rgba(255,255,255,.035);
    }

    .gc-admin-hero-v30::after{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background:
        linear-gradient(90deg,rgba(255,255,255,.045) 1px,transparent 1px),
        linear-gradient(0deg,rgba(255,255,255,.026) 1px,transparent 1px);
      background-size:42px 42px;
      opacity:.34;
      mask-image:linear-gradient(90deg,rgba(0,0,0,.48),transparent 72%);
    }

    .gc-admin-hero-v30 > *{
      position:relative;
      z-index:1;
    }

    .gc-admin-hero-v30 > div:first-child{
      padding-left:clamp(30px,4.2vw,86px);
    }

    .gc-admin-hero-v30 .gc-title{
      font-size:clamp(3.2rem,7vw,6rem);
      line-height:.86;
      letter-spacing:-.075em;
      margin:8px 0 12px;
    }

    .gc-admin-hero-v30 .gc-subtitle{
      max-width:820px;
      color:color-mix(in srgb,var(--text,#f2fff0) 74%,var(--muted));
    }

    .gc-admin-status-panel-v30{
      width:min(440px,100%);
      justify-self:end;
      margin-right:clamp(28px,4vw,78px);
      align-self:center;
      min-height:auto;
      padding:0;
      overflow:hidden;
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb,var(--accent,#9dff00) 16%,transparent), transparent 10rem),
        rgba(0,0,0,.18);
      border-color:color-mix(in srgb,var(--accent,#9dff00) 18%,var(--line));
      box-shadow:inset 0 0 0 1px rgba(255,255,255,.035);
    }

    .gc-admin-status-panel-v30 .gc-live-panel__title{
      padding:14px 16px;
      margin:0;
      border-bottom:1px solid rgba(255,255,255,.08);
      background:rgba(0,0,0,.14);
    }

    .gc-admin-status-panel-v30 .gc-status-list{
      padding:0;
      gap:0;
    }

    .gc-admin-status-panel-v30 .gc-status-row{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      padding:13px 16px;
      border-width:0 0 1px;
      border-radius:0;
      background:rgba(0,0,0,.08);
    }

    .gc-admin-status-panel-v30 .gc-status-row:last-child{
      border-bottom:0;
    }

    .gc-admin-status-panel-v30 .gc-status-row strong{
      max-width:260px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      text-align:right;
    }

    .gc-admin-subnav-shell-v30{
      margin-top:-8px;
    }

    .gc-admin-subnav-shell-v30 :is(nav, .gc-admin-subnav, .gc-subnav){
      border-radius:20px;
      border-color:rgba(255,255,255,.08);
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb,var(--accent,#9dff00) 6%,transparent), transparent 12rem),
        linear-gradient(135deg,rgba(255,255,255,.04),rgba(255,255,255,.014));
    }

    .gc-admin-gate-v30,
    .gc-admin-modules-card-v30,
    .gc-admin-quick-card-v30{
      margin:0;
      overflow:hidden;
      border-radius:28px;
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb,var(--accent,#9dff00) 7%,transparent), transparent 16rem),
        linear-gradient(135deg,rgba(255,255,255,.045),rgba(255,255,255,.014));
      border:1px solid rgba(255,255,255,.08);
      box-shadow:0 18px 70px rgba(0,0,0,.16);
    }

    .gc-admin-gate-v30 .gc-section-head,
    .gc-admin-modules-card-v30 .gc-section-head,
    .gc-admin-quick-card-v30 .gc-section-head{
      margin:0;
      padding:clamp(22px,2.4vw,32px) clamp(22px,2.6vw,34px) 16px;
      border-bottom:1px solid rgba(255,255,255,.07);
    }

    .gc-admin-gate-slab-v30{
      margin:clamp(16px,2vw,22px) clamp(22px,2.6vw,34px) clamp(22px,2.6vw,34px);
      padding:18px;
      border-radius:18px;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(0,0,0,.15);
    }

    .gc-admin-content-v30{
      display:grid;
      gap:clamp(18px,2.3vw,28px);
    }

    .gc-admin-metrics-v30{
      margin:0;
      gap:0;
      border:1px solid color-mix(in srgb,var(--accent,#9dff00) 18%,var(--line));
      border-radius:0;
      overflow:hidden;
      background:rgba(255,255,255,.018);
    }

    .gc-admin-metrics-v30 .gc-metric{
      border-width:0 1px 0 0;
      border-radius:0;
      min-height:112px;
      box-shadow:none;
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb,var(--accent,#9dff00) 9%,transparent), transparent 8rem),
        linear-gradient(135deg,rgba(255,255,255,.052),rgba(255,255,255,.018));
    }

    .gc-admin-metrics-v30 .gc-metric:last-child{
      border-right:0;
    }

    .gc-admin-metrics-v30 .gc-metric strong{
      max-width:100%;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      font-size:clamp(1.85rem,3.2vw,2.85rem);
      line-height:.92;
      letter-spacing:-.06em;
      color:var(--text);
      font-variant-numeric:tabular-nums;
    }

    .gc-admin-main-grid-v30{
      display:grid;
      grid-template-columns:minmax(0,1fr) minmax(380px,.72fr);
      gap:clamp(18px,2.3vw,28px);
      align-items:start;
    }

    .gc-admin-module-grid-v30{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:12px;
      padding:clamp(16px,2vw,24px) clamp(22px,2.6vw,34px) clamp(22px,2.6vw,34px);
    }

    .gc-admin-module-card-v30{
      position:relative;
      overflow:hidden;
      display:grid;
      grid-template-columns:auto minmax(0,1fr) auto;
      gap:14px;
      align-items:center;
      min-height:116px;
      padding:16px;
      color:var(--text);
      text-decoration:none;
      border:1px solid color-mix(in srgb,var(--accent,#9dff00) 14%,var(--line));
      border-radius:20px;
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb,var(--accent,#9dff00) 9%,transparent), transparent 8rem),
        linear-gradient(135deg,rgba(255,255,255,.054),rgba(255,255,255,.018));
      box-shadow:0 16px 48px rgba(0,0,0,.14), inset 0 0 0 1px rgba(255,255,255,.025);
      transition:transform .16s ease, border-color .16s ease, background .16s ease;
    }

    .gc-admin-module-card-v30:hover{
      transform:translateY(-2px);
      border-color:color-mix(in srgb,var(--accent,#9dff00) 34%,var(--line));
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb,var(--accent,#9dff00) 14%,transparent), transparent 8rem),
        linear-gradient(135deg,rgba(255,255,255,.07),rgba(255,255,255,.022));
    }

    .gc-admin-module-card-v30::after{
      content:"";
      position:absolute;
      right:-44px;
      bottom:-54px;
      width:126px;
      height:126px;
      border:1px solid color-mix(in srgb,var(--accent,#9dff00) 24%,transparent);
      border-radius:50%;
      opacity:.18;
      pointer-events:none;
    }

    .gc-admin-module-card-v30__num{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:42px;
      height:42px;
      border:1px solid color-mix(in srgb,var(--accent,#9dff00) 28%,var(--line));
      color:var(--accent);
      font-weight:950;
      font-size:.78rem;
      font-variant-numeric:tabular-nums;
      background:rgba(0,0,0,.18);
    }

    .gc-admin-module-card-v30__body{
      min-width:0;
    }

    .gc-admin-module-card-v30__body strong{
      display:block;
      color:var(--text);
      font-size:1.1rem;
      line-height:1.05;
      letter-spacing:-.04em;
    }

    .gc-admin-module-card-v30__body small{
      display:block;
      margin-top:7px;
      color:var(--soft);
      line-height:1.35;
    }

    .gc-admin-module-card-v30__cta{
      position:relative;
      z-index:1;
      display:inline-flex;
      min-height:34px;
      align-items:center;
      justify-content:center;
      padding:0 14px;
      border:1px solid rgba(255,255,255,.1);
      border-radius:999px;
      color:var(--text);
      font-size:.72rem;
      font-weight:950;
      letter-spacing:.08em;
      text-transform:uppercase;
      background:rgba(0,0,0,.16);
    }

    .gc-admin-health-stack-v30{
      display:grid;
      gap:12px;
      padding:clamp(16px,2vw,24px) clamp(22px,2.6vw,34px) clamp(22px,2.6vw,34px);
    }

    .gc-admin-health-card-v30{
      padding:16px;
      border:1px solid rgba(255,255,255,.08);
      border-radius:18px;
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb,var(--accent,#9dff00) 7%,transparent), transparent 8rem),
        rgba(0,0,0,.13);
    }

    .gc-admin-health-card-v30__head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      margin-bottom:10px;
    }

    .gc-admin-health-card-v30 h3{
      margin:0;
      color:var(--text);
      font-size:1.05rem;
      text-transform:uppercase;
      letter-spacing:-.035em;
    }

    .gc-admin-health-card-v30__head span{
      display:inline-flex;
      min-height:26px;
      align-items:center;
      justify-content:center;
      padding:0 9px;
      border:1px solid color-mix(in srgb,var(--accent,#9dff00) 32%,var(--line));
      color:var(--accent);
      font-size:.66rem;
      font-weight:950;
      letter-spacing:.08em;
      text-transform:uppercase;
      background:rgba(0,0,0,.15);
    }

    .gc-admin-health-card-v30 p{
      margin:0 0 12px;
      color:var(--soft);
      line-height:1.45;
    }

    .gc-admin-mini-list-v30{
      display:grid;
      gap:8px;
      margin:0;
    }

    .gc-admin-mini-list-v30 div{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      min-height:38px;
      padding:9px 10px;
      border:1px solid rgba(255,255,255,.06);
      border-radius:12px;
      background:rgba(255,255,255,.018);
    }

    .gc-admin-mini-list-v30 span{
      color:var(--dim);
      font-size:.68rem;
      font-weight:950;
      letter-spacing:.08em;
      text-transform:uppercase;
    }

    .gc-admin-mini-list-v30 strong{
      color:var(--text);
      text-align:right;
      max-width:210px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      font-variant-numeric:tabular-nums;
    }

    .gc-admin-acsm-actions-v30{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
    }

    .gc-admin-acsm-actions-v30 .gc-btn{
      border-radius:999px;
    }

    .gc-admin-health-card-v30 .gc-message{
      min-height:1.4em;
      margin:10px 0 0;
    }

    @media(max-width:1180px){
      .gc-admin-main-grid-v30{
        grid-template-columns:1fr;
      }
    }

    @media(max-width:980px){
      .gc-admin-hero-v30 > div:first-child{
        padding-left:clamp(12px,2vw,24px);
      }

      .gc-admin-status-panel-v30{
        margin-right:0;
        justify-self:stretch;
        width:100%;
      }

      .gc-admin-metrics-v30{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }

      .gc-admin-metrics-v30 .gc-metric:nth-child(2){
        border-right:0;
      }

      .gc-admin-metrics-v30 .gc-metric:nth-child(n+3){
        border-top:1px solid var(--line);
      }

      .gc-admin-module-grid-v30{
        grid-template-columns:1fr;
      }
    }

    @media(max-width:640px){
      .gc-admin-page-v30{
        padding-inline:0;
      }

      .gc-admin-hero-v30 > div:first-child{
        padding-left:0;
      }

      .gc-admin-metrics-v30{
        grid-template-columns:1fr;
      }

      .gc-admin-metrics-v30 .gc-metric{
        border-right:0;
        border-top:1px solid var(--line);
      }

      .gc-admin-metrics-v30 .gc-metric:first-child{
        border-top:0;
      }

      .gc-admin-module-card-v30{
        grid-template-columns:1fr;
      }

      .gc-admin-module-card-v30__cta{
        width:max-content;
      }

      .gc-admin-acsm-actions-v30 .gc-btn,
      .gc-admin-gate-slab-v30 .gc-btn{
        width:100%;
        justify-content:center;
      }

      .gc-admin-modules-card-v30 .gc-section-head,
      .gc-admin-quick-card-v30 .gc-section-head,
      .gc-admin-gate-v30 .gc-section-head,
      .gc-admin-module-grid-v30,
      .gc-admin-health-stack-v30{
        padding-inline:16px;
      }

      .gc-admin-gate-slab-v30{
        margin-inline:16px;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const $ = (id) => document.getElementById(id);

      const els = {
        gate: $('adminGate'),
        content: $('adminContent'),
        state: $('adminState'),
        rows: $('adminStatusRows'),
        retry: $('adminGateRetry'),
        metricUsers: $('metricUsers'),
        metricAdmins: $('metricAdmins'),
        metricLinked: $('metricLinked'),
        metricSessions: $('metricSessions'),
        storageText: $('storageText'),
        storageRows: $('storageRows'),
        storageBadge: $('storageBadge'),
        strackerText: $('strackerText'),
        strackerRows: $('strackerRows'),
        strackerBadge: $('strackerBadge'),
        acsmText: $('acsmText'),
        acsmBadge: $('acsmBadge'),
        acsmMessage: $('acsmMessage'),
        syncAcsmBtn: $('syncAcsmBtn')
      };

      const esc = (v) => String(v ?? '').replace(/[&<>'"]/g, (c) => ({
        '&':'&amp;',
        '<':'&lt;',
        '>':'&gt;',
        "'":'&#39;',
        '"':'&quot;'
      }[c]));

      const setText = (el, value) => {
        if (el) el.textContent = String(value ?? '-');
      };

      async function fetchJson(url, options = {}) {
        const response = await fetch(url, {
          credentials:'include',
          cache:'no-store',
          headers:{ 'Content-Type':'application/json' },
          ...options
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok || data.ok === false) {
          throw new Error(data.message || `HTTP ${response.status}`);
        }

        return data;
      }

      async function getAdminStatus() {
        try {
          const status = await fetchJson('/api/admin/status');
          if (status.authorized === true || status.setupRequired === true) return status;
        } catch {}

        const profile = await fetchJson('/api/profile');

        return {
          ok:true,
          authenticated: profile.authenticated !== false,
          authorized: profile.user?.role === 'admin',
          setupRequired:false,
          currentUser: profile.user || null,
          summary:{},
          admin:{}
        };
      }

      function show(mode) {
        if (els.gate) els.gate.hidden = mode !== 'gate';
        if (els.content) els.content.hidden = mode !== 'content';
      }

      function setBadge(el, text, tone = '') {
        if (!el) return;
        el.textContent = text;
        el.style.color = tone === 'warn' ? 'var(--warn)' : tone === 'bad' ? 'var(--danger)' : 'var(--accent)';
        el.style.borderColor = tone === 'warn'
          ? 'color-mix(in srgb,var(--warn) 40%,var(--line))'
          : tone === 'bad'
            ? 'color-mix(in srgb,var(--danger) 40%,var(--line))'
            : 'color-mix(in srgb,var(--accent) 40%,var(--line))';
      }

      function renderStatus(data) {
        const summary = data.summary || {};

        setText(els.metricUsers, summary.usersCount ?? '-');
        setText(els.metricAdmins, summary.adminsCount ?? '-');
        setText(els.metricLinked, summary.linkedUsersCount ?? '-');
        setText(els.metricSessions, summary.activeSessionsCount ?? '-');

        setText(els.state, data.authorized ? 'Activo' : 'Bloqueado');
        if (els.state) els.state.style.color = data.authorized ? 'var(--accent)' : 'var(--warn)';

        if (els.rows) {
          els.rows.innerHTML =
            `<div class="gc-status-row"><span>Usuario</span><strong>${esc(data.currentUser?.displayName || '-')}</strong></div>` +
            `<div class="gc-status-row"><span>Rol</span><strong>${esc(data.currentUser?.role || '-')}</strong></div>` +
            `<div class="gc-status-row"><span>Setup</span><strong>${data.setupRequired ? 'Pendiente' : 'OK'}</strong></div>`;
        }

        const storage = data.admin?.storage?.storage || data.admin?.storage || {};
        const files = data.admin?.storage?.files || {};

        setBadge(els.storageBadge, storage.persistent === false ? 'Revisar' : 'OK', storage.persistent === false ? 'warn' : '');

        if (els.storageText) {
          els.storageText.textContent = storage.persistent === false
            ? 'Atención: revisa la ruta persistente.'
            : `OK: ${storage.source || files.users?.source || 'storage'} persistente.`;
        }

        if (els.storageRows) {
          els.storageRows.innerHTML =
            `<div><span>Usuarios</span><strong>${esc(files.users?.source || storage.source || '-')}</strong></div>` +
            `<div><span>Nombres</span><strong>${esc(files.displayNames?.source || storage.source || '-')}</strong></div>` +
            `<div><span>Persistente</span><strong>${storage.persistent === false ? 'No' : 'Sí'}</strong></div>`;
        }

        const stracker = data.admin?.stracker || {};

        setBadge(els.strackerBadge, stracker.exists ? 'OK' : 'No DB', stracker.exists ? '' : 'warn');

        if (els.strackerText) {
          els.strackerText.textContent = stracker.exists
            ? 'Base stracker detectada.'
            : 'No se ha detectado stracker.db3.';
        }

        if (els.strackerRows) {
          els.strackerRows.innerHTML =
            `<div><span>Existe</span><strong>${stracker.exists ? 'Sí' : 'No'}</strong></div>` +
            `<div><span>SQLite</span><strong>${stracker.validSQLite ? 'Válido' : '-'}</strong></div>` +
            `<div><span>Tamaño</span><strong>${Math.round(((stracker.sizeBytes || 0) / 1024 / 1024) * 10) / 10} MB</strong></div>`;
        }

        setBadge(els.acsmBadge, 'Manual');
      }

      async function syncAcsm() {
        const button = els.syncAcsmBtn;

        try {
          if (button) {
            button.disabled = true;
            button.textContent = 'Sincronizando...';
          }

          if (els.acsmMessage) {
            els.acsmMessage.textContent = 'Sincronizando combo desde ACSM...';
            els.acsmMessage.style.color = 'var(--soft)';
          }

          const data = await fetchJson('/api/admin/acsm/sync-current-combo', {
            method:'POST'
          });

          if (els.acsmText) els.acsmText.textContent = `Último sync correcto. Storage: ${data.source || '-'}.`;

          if (els.acsmMessage) {
            els.acsmMessage.textContent = `Combo sincronizado. Eventos: ${data.totalEvents ?? '-'}`;
            els.acsmMessage.style.color = 'var(--accent)';
          }

          setBadge(els.acsmBadge, 'OK');
        } catch (error) {
          if (els.acsmText) els.acsmText.textContent = 'No se pudo sincronizar ACSM.';

          if (els.acsmMessage) {
            els.acsmMessage.textContent = error.message || 'Error ACSM.';
            els.acsmMessage.style.color = 'var(--soft)';
          }

          setBadge(els.acsmBadge, 'Error', 'warn');
        } finally {
          if (button) {
            button.disabled = false;
            button.textContent = 'Sincronizar combo';
          }
        }
      }

      async function init() {
        show('gate');

        try {
          const status = await getAdminStatus();
          renderStatus(status);

          if (status.authorized === true) {
            show('content');
            return;
          }

          show('gate');
        } catch (error) {
          show('gate');
          setText(els.state, 'Error');
          if (els.state) els.state.style.color = 'var(--warn)';

          if (els.rows) {
            els.rows.innerHTML = `<div class="gc-status-row"><span>Error</span><strong>${esc(error.message || 'No disponible')}</strong></div>`;
          }
        }
      }

      els.retry?.addEventListener('click', init);
      els.syncAcsmBtn?.addEventListener('click', syncAcsm);

      init();
    })();
  </script>
</AppLayout>

---
import AppLayout from '../layouts/AppLayout.astro';
import AdminSubnav from '../components/AdminSubnav.astro';
---
<AppLayout title="Admin | GrassCutters">
  <div class="gc-page gc-admin-page-clean">
    <section class="gc-hero gc-hero--compact">
      <div>
        <span class="gc-kicker">Admin console</span>
        <h1 class="gc-title">Control de boxes.</h1>
        <p class="gc-subtitle">Resumen de administración. Los módulos pesados ahora están separados para evitar una página infinita.</p>
        <div class="gc-hero__meta">
          <span class="gc-chip gc-chip--accent">Resumen</span>
          <span class="gc-chip">MySQL</span>
          <span class="gc-chip">ACSM</span>
          <span class="gc-chip">stracker</span>
        </div>
      </div>
      <aside class="gc-live-panel">
        <div class="gc-live-panel__title"><span>Admin</span><strong id="adminState">Comprobando</strong></div>
        <div class="gc-status-list" id="adminStatusRows">
          <div class="gc-status-row"><span>Estado</span><strong>Cargando</strong></div>
        </div>
      </aside>
    </section>

    <AdminSubnav />

    <section class="gc-section" id="adminGate" hidden>
      <div class="gc-section-head"><h2>Acceso restringido</h2><p>Solo administradores</p></div>
      <div class="gc-slab">
        <h3 id="adminGateTitle">No tienes permisos de admin</h3>
        <p id="adminGateText">Inicia sesión con una cuenta administradora.</p>
        <div class="gc-actions"><a class="gc-btn gc-btn--primary" href="/login">Login</a><button class="gc-btn" id="adminGateRetry" type="button">Reintentar</button></div>
      </div>
    </section>

    <section id="adminContent" hidden>
      <section class="gc-metrics">
        <div class="gc-metric"><span>Usuarios</span><strong id="metricUsers">...</strong><small>cuentas web</small></div>
        <div class="gc-metric"><span>Admins</span><strong id="metricAdmins">...</strong><small>permisos</small></div>
        <div class="gc-metric"><span>Vinculados</span><strong id="metricLinked">...</strong><small>piloto real</small></div>
        <div class="gc-metric"><span>Sesiones</span><strong id="metricSessions">...</strong><small>activas</small></div>
      </section>

      <section class="gc-grid-2">
        <div class="gc-section">
          <div class="gc-section-head"><h2>Módulos de administración</h2><p>Accesos separados para trabajar sin scroll infinito.</p></div>
          <div class="gc-row-list">
            <a class="gc-row-link" href="/admin/usuarios"><span class="gc-row-link__num">01</span><span><strong class="gc-row-link__title">Usuarios</strong><br><span class="gc-row-link__desc">Cuentas, roles, sesiones y pilotos vinculados.</span></span><span class="gc-row-link__cta">Abrir</span></a>
            <a class="gc-row-link" href="/admin/nombres"><span class="gc-row-link__num">02</span><span><strong class="gc-row-link__title">Nombres visibles</strong><br><span class="gc-row-link__desc">Alias de pilotos, coches y circuitos.</span></span><span class="gc-row-link__cta">Abrir</span></a>
            <a class="gc-row-link" href="/admin/calendario"><span class="gc-row-link__num">03</span><span><strong class="gc-row-link__title">Calendario</strong><br><span class="gc-row-link__desc">Eventos, combo semanal y sincronización ACSM.</span></span><span class="gc-row-link__cta">Abrir</span></a>
            <a class="gc-row-link" href="/admin/sistema"><span class="gc-row-link__num">04</span><span><strong class="gc-row-link__title">Sistema</strong><br><span class="gc-row-link__desc">Storage, stracker, ACSM y diagnóstico.</span></span><span class="gc-row-link__cta">Abrir</span></a>
            <a class="gc-row-link" href="/admin/historial"><span class="gc-row-link__num">05</span><span><strong class="gc-row-link__title">Historial</strong><br><span class="gc-row-link__desc">Auditoría de acciones sensibles.</span></span><span class="gc-row-link__cta">Abrir</span></a>
          </div>
        </div>

        <aside class="gc-section">
          <div class="gc-section-head"><h2>Estado rápido</h2><p>Datos principales del sistema.</p></div>
          <div class="gc-slab">
            <h3>Storage</h3>
            <p id="storageText">Cargando...</p>
            <div class="gc-slab-list" id="storageRows"><div><span>Storage</span><strong>...</strong></div></div>
          </div>
          <div class="gc-slab">
            <h3>stracker</h3>
            <p id="strackerText">Cargando...</p>
            <div class="gc-slab-list" id="strackerRows"><div><span>DB</span><strong>...</strong></div></div>
          </div>
          <div class="gc-slab">
            <h3>ACSM</h3>
            <p id="acsmText">Cargando...</p>
            <div class="gc-actions"><button class="gc-btn gc-btn--primary" id="syncAcsmBtn" type="button">Sincronizar combo</button><a class="gc-btn" href="/calendario">Ver calendario</a></div>
            <p class="gc-message" id="acsmMessage"></p>
          </div>
        </aside>
      </section>
    </section>
  </div>

  <script is:inline>
    (() => {
      const $ = (id) => document.getElementById(id);
      const els = {
        gate: $('adminGate'), content: $('adminContent'), state: $('adminState'), rows: $('adminStatusRows'), retry: $('adminGateRetry'),
        metricUsers: $('metricUsers'), metricAdmins: $('metricAdmins'), metricLinked: $('metricLinked'), metricSessions: $('metricSessions'),
        storageText: $('storageText'), storageRows: $('storageRows'), strackerText: $('strackerText'), strackerRows: $('strackerRows'), acsmText: $('acsmText'), acsmMessage: $('acsmMessage'), syncAcsmBtn: $('syncAcsmBtn')
      };
      const esc = (v) => String(v ?? '').replace(/[&<>'"]/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));
      async function fetchJson(url, options = {}) {
        const response = await fetch(url, { credentials:'include', cache:'no-store', headers:{ 'Content-Type':'application/json' }, ...options });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || data.ok === false) throw new Error(data.message || `HTTP ${response.status}`);
        return data;
      }
      async function getAdminStatus() {
        try {
          const status = await fetchJson('/api/admin/status');
          if (status.authorized === true || status.setupRequired === true) return status;
        } catch {}
        const profile = await fetchJson('/api/profile');
        return { ok:true, authenticated: profile.authenticated !== false, authorized: profile.user?.role === 'admin', setupRequired:false, currentUser: profile.user || null, summary:{}, admin:{} };
      }
      function show(mode) { els.gate.hidden = mode !== 'gate'; els.content.hidden = mode !== 'content'; }
      function renderStatus(data) {
        const summary = data.summary || {};
        els.metricUsers.textContent = summary.usersCount ?? '-';
        els.metricAdmins.textContent = summary.adminsCount ?? '-';
        els.metricLinked.textContent = summary.linkedUsersCount ?? '-';
        els.metricSessions.textContent = summary.activeSessionsCount ?? '-';
        els.state.textContent = data.authorized ? 'Activo' : 'Bloqueado';
        els.state.style.color = data.authorized ? 'var(--accent)' : 'var(--warn)';
        els.rows.innerHTML = `<div class="gc-status-row"><span>Usuario</span><strong>${esc(data.currentUser?.displayName || '-')}</strong></div><div class="gc-status-row"><span>Rol</span><strong>${esc(data.currentUser?.role || '-')}</strong></div><div class="gc-status-row"><span>Setup</span><strong>${data.setupRequired ? 'Pendiente' : 'OK'}</strong></div>`;
        const storage = data.admin?.storage?.storage || data.admin?.storage || {};
        const files = data.admin?.storage?.files || {};
        els.storageText.textContent = storage.persistent === false ? 'Atención: revisa la ruta persistente.' : `OK: ${storage.source || files.users?.source || 'storage'} persistente.`;
        els.storageRows.innerHTML = `<div><span>Usuarios</span><strong>${esc(files.users?.source || storage.source || '-')}</strong></div><div><span>Nombres</span><strong>${esc(files.displayNames?.source || storage.source || '-')}</strong></div><div><span>Persistente</span><strong>${storage.persistent === false ? 'No' : 'Sí'}</strong></div>`;
        const stracker = data.admin?.stracker || {};
        els.strackerText.textContent = stracker.exists ? 'Base stracker detectada.' : 'No se ha detectado stracker.db3.';
        els.strackerRows.innerHTML = `<div><span>Existe</span><strong>${stracker.exists ? 'Sí' : 'No'}</strong></div><div><span>SQLite</span><strong>${stracker.validSQLite ? 'Válido' : '-'}</strong></div><div><span>Tamaño</span><strong>${Math.round(((stracker.sizeBytes || 0) / 1024 / 1024) * 10) / 10} MB</strong></div>`;
      }
      async function syncAcsm() {
        try {
          els.acsmMessage.textContent = 'Sincronizando combo desde ACSM...';
          const data = await fetchJson('/api/admin/acsm/sync-current-combo', { method:'POST' });
          els.acsmText.textContent = `Último sync correcto. Storage: ${data.source || '-'}.`;
          els.acsmMessage.textContent = `Combo sincronizado. Eventos: ${data.totalEvents ?? '-'}`;
          els.acsmMessage.style.color = 'var(--accent)';
        } catch (error) {
          els.acsmText.textContent = 'No se pudo sincronizar ACSM.';
          els.acsmMessage.textContent = error.message || 'Error ACSM.';
          els.acsmMessage.style.color = 'var(--soft)';
        }
      }
      async function init() {
        show('gate');
        try {
          const status = await getAdminStatus();
          renderStatus(status);
          if (status.authorized === true) { show('content'); return; }
          show('gate');
        } catch (error) {
          show('gate');
          els.state.textContent = 'Error';
        }
      }
      els.retry?.addEventListener('click', init);
      els.syncAcsmBtn?.addEventListener('click', syncAcsm);
      init();
    })();
  </script>
</AppLayout>

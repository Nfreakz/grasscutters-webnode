---
import AppLayout from '../layouts/AppLayout.astro';
import AdminSubnav from '../components/AdminSubnav.astro';

const moduleGroups = [
  {
    label: 'Base',
    desc: 'Gestión de usuarios, alias y calendario.',
    modules: [
      { href: '/admin/usuarios', title: 'Usuarios', desc: 'Cuentas, roles, sesiones y pilotos vinculados.', tag: 'Core' },
      { href: '/admin/nombres', title: 'Nombres visibles', desc: 'Alias de pilotos, coches y circuitos.', tag: 'Core' },
      { href: '/admin/calendario', title: 'Calendario', desc: 'Eventos, combo semanal y sincronización ACSM.', tag: 'Eventos' },
    ],
  },
  {
    label: 'Contenido',
    desc: 'Newsroom, archivo motorsport, importadores e imágenes.',
    modules: [
      { href: '/admin/noticias', title: 'Noticias', desc: 'Gestor editorial del newsroom.', tag: 'News' },
      { href: '/admin/noticias/importar', title: 'Importar noticias', desc: 'Carga CSV para publicaciones y updates.', tag: 'CSV' },
      { href: '/admin/noticias/imagenes', title: 'Imágenes noticias', desc: 'Biblioteca visual del newsroom.', tag: 'Media' },
      { href: '/admin/archivo', title: 'Archivo', desc: 'Fichas de circuitos, coches, pilotos y conceptos.', tag: 'DB' },
      { href: '/admin/archivo/importar', title: 'Importar archivo', desc: 'Carga CSV para dossiers del archivo.', tag: 'CSV' },
      { href: '/admin/archivo/imagen-url', title: 'Imágenes archivo', desc: 'Biblioteca visual de fichas del archivo.', tag: 'Media' },
    ],
  },
  {
    label: 'Herramientas',
    desc: 'Revisión, conexiones, endpoints y diagnóstico.',
    modules: [
      { href: '/admin/archivo/calidad', title: 'Calidad archivo', desc: 'Checklist editorial de fichas.', tag: 'QA' },
      { href: '/admin/archivo/relaciones', title: 'Relaciones archivo', desc: 'Conexiones entre fichas y entidades.', tag: 'Graph' },
      { href: '/admin/endpoints', title: 'Endpoints', desc: 'Pruebas rápidas de API.', tag: 'API' },
      { href: '/admin/sistema', title: 'Sistema', desc: 'Storage, stracker, ACSM y diagnóstico.', tag: 'Ops' },
      { href: '/admin/historial', title: 'Historial', desc: 'Auditoría de acciones sensibles.', tag: 'Log' },
    ],
  },
];
---

<AppLayout title="Admin | GrassCutters">
  <div class="gc-page gc-admin-page-clean gc-admin-hub-v1">
    <section class="gc-admin-hub-hero">
      <div>
        <span class="gc-kicker">Admin console</span>
        <h1>Control de boxes</h1>
        <p>Panel central para gestionar comunidad, calendario, noticias, archivo, imágenes, importadores y herramientas internas.</p>

        <div class="gc-admin-hub-hero__chips">
          <span>Base</span>
          <span>Contenido</span>
          <span>Herramientas</span>
          <span>Sistema</span>
        </div>
      </div>

      <aside class="gc-admin-status-panel-v1">
        <div class="gc-admin-status-panel-v1__head">
          <span>Admin</span>
          <strong id="adminState">Comprobando</strong>
        </div>
        <div id="adminStatusRows" class="gc-admin-status-panel-v1__rows">
          <div><span>Estado</span><strong>Cargando</strong></div>
        </div>
      </aside>
    </section>

    <AdminSubnav />

    <section class="gc-section gc-admin-gate-v1" id="adminGate" hidden>
      <div class="gc-section-head">
        <div>
          <span class="gc-kicker">Acceso</span>
          <h2>Acceso restringido</h2>
          <p>Solo administradores.</p>
        </div>
      </div>

      <div class="gc-slab gc-admin-gate-slab-v1">
        <h3 id="adminGateTitle">No tienes permisos de admin</h3>
        <p id="adminGateText">Inicia sesión con una cuenta administradora.</p>
        <div class="gc-actions">
          <a class="gc-btn gc-btn--primary" href="/login">Login</a>
          <button class="gc-btn" id="adminGateRetry" type="button">Reintentar</button>
        </div>
      </div>
    </section>

    <section id="adminContent" class="gc-admin-content-v1" hidden>
      <section class="gc-admin-metrics-v1">
        <div><span>Usuarios</span><strong id="metricUsers">...</strong><small>cuentas web</small></div>
        <div><span>Admins</span><strong id="metricAdmins">...</strong><small>permisos</small></div>
        <div><span>Vinculados</span><strong id="metricLinked">...</strong><small>piloto real</small></div>
        <div><span>Sesiones</span><strong id="metricSessions">...</strong><small>activas</small></div>
      </section>

      <section class="gc-admin-hub-layout-v1">
        <main class="gc-admin-hub-main-v1">
          {moduleGroups.map((group) => (
            <section class="gc-admin-module-group-v1">
              <div class="gc-admin-module-group-v1__head">
                <div>
                  <span class="gc-kicker">{group.label}</span>
                  <h2>{group.label}</h2>
                  <p>{group.desc}</p>
                </div>
              </div>

              <div class="gc-admin-module-grid-v1">
                {group.modules.map((item) => (
                  <a class="gc-admin-module-card-v1" href={item.href}>
                    <span class="gc-admin-module-card-v1__tag">{item.tag}</span>
                    <strong>{item.title}</strong>
                    <small>{item.desc}</small>
                    <em>Abrir</em>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </main>

        <aside class="gc-admin-side-v1">
          <section class="gc-admin-side-card-v1">
            <div class="gc-section-head">
              <div>
                <span class="gc-kicker">Sistema</span>
                <h2>Estado rápido</h2>
                <p>Datos principales del panel.</p>
              </div>
            </div>

            <div class="gc-admin-health-stack-v1">
              <article>
                <header><h3>Storage</h3><span id="storageBadge">...</span></header>
                <p id="storageText">Cargando...</p>
                <div class="gc-admin-mini-list-v1" id="storageRows">
                  <div><span>Storage</span><strong>...</strong></div>
                </div>
              </article>

              <article>
                <header><h3>stracker</h3><span id="strackerBadge">...</span></header>
                <p id="strackerText">Cargando...</p>
                <div class="gc-admin-mini-list-v1" id="strackerRows">
                  <div><span>DB</span><strong>...</strong></div>
                </div>
              </article>

              <article>
                <header><h3>ACSM</h3><span id="acsmBadge">Manual</span></header>
                <p id="acsmText">Sincronización del combo actual desde ACSM.</p>
                <div class="gc-actions gc-admin-acsm-actions-v1">
                  <button class="gc-btn gc-btn--primary" id="syncAcsmBtn" type="button">Sincronizar combo</button>
                  <a class="gc-btn" href="/calendario">Ver calendario</a>
                </div>
                <p class="gc-message" id="acsmMessage"></p>
              </article>
            </div>
          </section>
        </aside>
      </section>
    </section>
  </div>

  <style is:global>
    .gc-admin-hub-v1 {
      display: grid;
      gap: clamp(18px, 2.3vw, 28px);
      width: 100%;
      max-width: 1480px;
      margin-inline: auto;
      padding-inline: clamp(8px, 1.2vw, 18px);
      box-sizing: border-box;
    }

    .gc-admin-hub-hero {
      position: relative;
      overflow: hidden;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(320px, .42fr);
      gap: clamp(18px, 2.3vw, 28px);
      align-items: center;
      margin: 0;
      padding: clamp(26px, 3.4vw, 42px);
      border: 1px solid color-mix(in srgb, var(--accent, #9dff00) 30%, var(--line));
      border-radius: 28px;
      background:
        linear-gradient(120deg, rgba(255,255,255,.07), rgba(255,255,255,.018)),
        radial-gradient(circle at 82% 12%, color-mix(in srgb, var(--accent2, #35d3ff) 10%, transparent), transparent 22rem),
        radial-gradient(circle at 8% 18%, color-mix(in srgb, var(--accent, #9dff00) 12%, transparent), transparent 20rem);
      box-shadow: 0 18px 70px rgba(0,0,0,.20), inset 0 0 0 1px rgba(255,255,255,.035);
    }

    .gc-admin-hub-hero::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(90deg, rgba(255,255,255,.045) 1px, transparent 1px),
        linear-gradient(0deg, rgba(255,255,255,.026) 1px, transparent 1px);
      background-size: 42px 42px;
      opacity: .34;
      mask-image: linear-gradient(90deg, rgba(0,0,0,.48), transparent 72%);
    }

    .gc-admin-hub-hero > * {
      position: relative;
      z-index: 1;
    }

    .gc-admin-hub-hero h1 {
      margin: 8px 0 12px;
      font-size: clamp(3.2rem, 7vw, 6rem);
      line-height: .86;
      letter-spacing: -.075em;
      text-transform: uppercase;
    }

    .gc-admin-hub-hero p {
      max-width: 820px;
      margin: 0;
      color: color-mix(in srgb, var(--text, #f2fff0) 74%, var(--muted));
      line-height: 1.5;
    }

    .gc-admin-hub-hero__chips {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 18px;
    }

    .gc-admin-hub-hero__chips span {
      display: inline-flex;
      min-height: 30px;
      align-items: center;
      padding: 0 10px;
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 999px;
      color: var(--soft);
      font-size: .72rem;
      font-weight: 950;
      letter-spacing: .08em;
      text-transform: uppercase;
      background: rgba(0,0,0,.14);
    }

    .gc-admin-status-panel-v1 {
      border: 1px solid color-mix(in srgb, var(--accent, #9dff00) 18%, var(--line));
      border-radius: 22px;
      overflow: hidden;
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--accent, #9dff00) 16%, transparent), transparent 10rem),
        rgba(0,0,0,.18);
      box-shadow: inset 0 0 0 1px rgba(255,255,255,.035);
    }

    .gc-admin-status-panel-v1__head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      padding: 14px 16px;
      border-bottom: 1px solid rgba(255,255,255,.08);
      background: rgba(0,0,0,.14);
    }

    .gc-admin-status-panel-v1__head span,
    .gc-admin-status-panel-v1__rows span,
    .gc-admin-mini-list-v1 span {
      color: var(--dim);
      font-size: .68rem;
      font-weight: 950;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .gc-admin-status-panel-v1__rows {
      display: grid;
    }

    .gc-admin-status-panel-v1__rows div {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 13px 16px;
      border-bottom: 1px solid rgba(255,255,255,.07);
      background: rgba(0,0,0,.08);
    }

    .gc-admin-status-panel-v1__rows div:last-child {
      border-bottom: 0;
    }

    .gc-admin-content-v1 {
      display: grid;
      gap: clamp(18px, 2.3vw, 28px);
    }

    .gc-admin-metrics-v1 {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0;
      border: 1px solid color-mix(in srgb, var(--accent, #9dff00) 18%, var(--line));
      overflow: hidden;
      background: rgba(255,255,255,.018);
    }

    .gc-admin-metrics-v1 div {
      min-height: 112px;
      padding: 18px;
      border-right: 1px solid var(--line);
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--accent, #9dff00) 9%, transparent), transparent 8rem),
        linear-gradient(135deg, rgba(255,255,255,.052), rgba(255,255,255,.018));
    }

    .gc-admin-metrics-v1 div:last-child {
      border-right: 0;
    }

    .gc-admin-metrics-v1 span {
      color: var(--dim);
      font-size: .72rem;
      font-weight: 950;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .gc-admin-metrics-v1 strong {
      display: block;
      margin-top: 8px;
      color: var(--text);
      font-size: clamp(1.85rem, 3.2vw, 2.85rem);
      line-height: .92;
      letter-spacing: -.06em;
      font-variant-numeric: tabular-nums;
    }

    .gc-admin-metrics-v1 small {
      display: block;
      margin-top: 8px;
      color: var(--soft);
    }

    .gc-admin-hub-layout-v1 {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(360px, .42fr);
      gap: clamp(18px, 2.3vw, 28px);
      align-items: start;
    }

    .gc-admin-hub-main-v1 {
      display: grid;
      gap: 18px;
    }

    .gc-admin-module-group-v1,
    .gc-admin-side-card-v1,
    .gc-admin-gate-v1 {
      margin: 0;
      overflow: hidden;
      border-radius: 28px;
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--accent, #9dff00) 7%, transparent), transparent 16rem),
        linear-gradient(135deg, rgba(255,255,255,.045), rgba(255,255,255,.014));
      border: 1px solid rgba(255,255,255,.08);
      box-shadow: 0 18px 70px rgba(0,0,0,.16);
    }

    .gc-admin-module-group-v1__head,
    .gc-admin-side-card-v1 .gc-section-head,
    .gc-admin-gate-v1 .gc-section-head {
      margin: 0;
      padding: clamp(20px, 2.2vw, 28px) clamp(20px, 2.4vw, 30px) 14px;
      border-bottom: 1px solid rgba(255,255,255,.07);
    }

    .gc-admin-module-group-v1__head h2,
    .gc-admin-side-card-v1 h2 {
      margin: 4px 0 6px;
      font-size: clamp(1.55rem, 2.6vw, 2.35rem);
      line-height: .95;
      letter-spacing: -.05em;
      text-transform: uppercase;
    }

    .gc-admin-module-group-v1__head p,
    .gc-admin-side-card-v1 p {
      margin: 0;
      color: var(--soft);
      line-height: 1.45;
    }

    .gc-admin-module-grid-v1 {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      padding: clamp(16px, 2vw, 24px) clamp(20px, 2.4vw, 30px) clamp(20px, 2.4vw, 30px);
    }

    .gc-admin-module-card-v1 {
      position: relative;
      overflow: hidden;
      display: grid;
      align-content: start;
      min-height: 150px;
      padding: 16px;
      color: var(--text);
      text-decoration: none;
      border: 1px solid color-mix(in srgb, var(--accent, #9dff00) 14%, var(--line));
      border-radius: 20px;
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--accent, #9dff00) 9%, transparent), transparent 8rem),
        linear-gradient(135deg, rgba(255,255,255,.054), rgba(255,255,255,.018));
      box-shadow: 0 16px 48px rgba(0,0,0,.14), inset 0 0 0 1px rgba(255,255,255,.025);
      transition: transform .16s ease, border-color .16s ease, background .16s ease;
    }

    .gc-admin-module-card-v1:hover {
      transform: translateY(-2px);
      border-color: color-mix(in srgb, var(--accent, #9dff00) 34%, var(--line));
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--accent, #9dff00) 14%, transparent), transparent 8rem),
        linear-gradient(135deg, rgba(255,255,255,.07), rgba(255,255,255,.022));
    }

    .gc-admin-module-card-v1__tag {
      width: max-content;
      display: inline-flex;
      min-height: 26px;
      align-items: center;
      padding: 0 9px;
      border: 1px solid color-mix(in srgb, var(--accent, #9dff00) 28%, var(--line));
      color: var(--accent);
      font-size: .66rem;
      font-weight: 950;
      letter-spacing: .08em;
      text-transform: uppercase;
      background: rgba(0,0,0,.18);
    }

    .gc-admin-module-card-v1 strong {
      display: block;
      margin-top: 16px;
      color: var(--text);
      font-size: 1.12rem;
      line-height: 1.05;
      letter-spacing: -.04em;
      text-transform: uppercase;
    }

    .gc-admin-module-card-v1 small {
      display: block;
      margin-top: 8px;
      color: var(--soft);
      line-height: 1.35;
    }

    .gc-admin-module-card-v1 em {
      width: max-content;
      display: inline-flex;
      min-height: 32px;
      align-items: center;
      margin-top: 16px;
      padding: 0 12px;
      border-radius: 999px;
      color: var(--text);
      font-size: .72rem;
      font-style: normal;
      font-weight: 950;
      letter-spacing: .08em;
      text-transform: uppercase;
      background: rgba(0,0,0,.18);
      border: 1px solid rgba(255,255,255,.1);
    }

    .gc-admin-side-v1 {
      position: sticky;
      top: 86px;
    }

    .gc-admin-health-stack-v1 {
      display: grid;
      gap: 12px;
      padding: clamp(16px, 2vw, 24px) clamp(20px, 2.4vw, 30px) clamp(20px, 2.4vw, 30px);
    }

    .gc-admin-health-stack-v1 article {
      padding: 16px;
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 18px;
      background:
        radial-gradient(circle at 100% 0%, color-mix(in srgb, var(--accent, #9dff00) 7%, transparent), transparent 8rem),
        rgba(0,0,0,.13);
    }

    .gc-admin-health-stack-v1 header {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
    }

    .gc-admin-health-stack-v1 h3 {
      margin: 0;
      color: var(--text);
      font-size: 1.05rem;
      text-transform: uppercase;
      letter-spacing: -.035em;
    }

    .gc-admin-health-stack-v1 header span {
      display: inline-flex;
      min-height: 26px;
      align-items: center;
      padding: 0 9px;
      border: 1px solid color-mix(in srgb, var(--accent, #9dff00) 32%, var(--line));
      color: var(--accent);
      font-size: .66rem;
      font-weight: 950;
      letter-spacing: .08em;
      text-transform: uppercase;
      background: rgba(0,0,0,.15);
    }

    .gc-admin-mini-list-v1 {
      display: grid;
      gap: 8px;
      margin: 0;
    }

    .gc-admin-mini-list-v1 div {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      min-height: 38px;
      padding: 9px 10px;
      border: 1px solid rgba(255,255,255,.06);
      border-radius: 12px;
      background: rgba(255,255,255,.018);
    }

    .gc-admin-mini-list-v1 strong {
      color: var(--text);
      text-align: right;
      max-width: 210px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }

    .gc-admin-gate-slab-v1 {
      margin: clamp(16px, 2vw, 22px) clamp(20px, 2.4vw, 30px) clamp(20px, 2.4vw, 30px);
      padding: 18px;
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,.08);
      background: rgba(0,0,0,.15);
    }

    @media (max-width: 1180px) {
      .gc-admin-hub-layout-v1,
      .gc-admin-hub-hero {
        grid-template-columns: 1fr;
      }

      .gc-admin-side-v1 {
        position: static;
      }

      .gc-admin-module-grid-v1 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 760px) {
      .gc-admin-metrics-v1,
      .gc-admin-module-grid-v1 {
        grid-template-columns: 1fr;
      }

      .gc-admin-hub-v1 {
        padding-inline: 0;
      }

      .gc-admin-module-card-v1 {
        min-height: auto;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const $ = (id) => document.getElementById(id);

      const els = {
        gate: $('adminGate'),
        content: $('adminContent'),
        state: $('adminState'),
        rows: $('adminStatusRows'),
        retry: $('adminGateRetry'),
        metricUsers: $('metricUsers'),
        metricAdmins: $('metricAdmins'),
        metricLinked: $('metricLinked'),
        metricSessions: $('metricSessions'),
        storageText: $('storageText'),
        storageRows: $('storageRows'),
        storageBadge: $('storageBadge'),
        strackerText: $('strackerText'),
        strackerRows: $('strackerRows'),
        strackerBadge: $('strackerBadge'),
        acsmText: $('acsmText'),
        acsmBadge: $('acsmBadge'),
        acsmMessage: $('acsmMessage'),
        syncAcsmBtn: $('syncAcsmBtn')
      };

      const esc = (v) => String(v ?? '').replace(/[&<>'"]/g, (c) => ({
        '&':'&amp;',
        '<':'&lt;',
        '>':'&gt;',
        "'":'&#39;',
        '"':'&quot;'
      }[c]));

      const setText = (el, value) => {
        if (el) el.textContent = String(value ?? '-');
      };

      async function fetchJson(url, options = {}) {
        const response = await fetch(url, {
          credentials:'include',
          cache:'no-store',
          headers:{ 'Content-Type':'application/json' },
          ...options
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok || data.ok === false) {
          throw new Error(data.message || `HTTP ${response.status}`);
        }

        return data;
      }

      async function getAdminStatus() {
        try {
          const status = await fetchJson('/api/admin/status');
          if (status.authorized === true || status.setupRequired === true) return status;
        } catch {}

        const profile = await fetchJson('/api/profile');

        return {
          ok:true,
          authenticated: profile.authenticated !== false,
          authorized: profile.user?.role === 'admin',
          setupRequired:false,
          currentUser: profile.user || null,
          summary:{},
          admin:{}
        };
      }

      function show(mode) {
        if (els.gate) els.gate.hidden = mode !== 'gate';
        if (els.content) els.content.hidden = mode !== 'content';
      }

      function setBadge(el, text, tone = '') {
        if (!el) return;
        el.textContent = text;
        el.style.color = tone === 'warn' ? 'var(--warn)' : tone === 'bad' ? 'var(--danger)' : 'var(--accent)';
        el.style.borderColor = tone === 'warn'
          ? 'color-mix(in srgb,var(--warn) 40%,var(--line))'
          : tone === 'bad'
            ? 'color-mix(in srgb,var(--danger) 40%,var(--line))'
            : 'color-mix(in srgb,var(--accent) 40%,var(--line))';
      }

      function renderStatus(data) {
        const summary = data.summary || {};

        setText(els.metricUsers, summary.usersCount ?? '-');
        setText(els.metricAdmins, summary.adminsCount ?? '-');
        setText(els.metricLinked, summary.linkedUsersCount ?? '-');
        setText(els.metricSessions, summary.activeSessionsCount ?? '-');

        setText(els.state, data.authorized ? 'Activo' : 'Bloqueado');
        if (els.state) els.state.style.color = data.authorized ? 'var(--accent)' : 'var(--warn)';

        if (els.rows) {
          els.rows.innerHTML =
            `<div><span>Usuario</span><strong>${esc(data.currentUser?.displayName || '-')}</strong></div>` +
            `<div><span>Rol</span><strong>${esc(data.currentUser?.role || '-')}</strong></div>` +
            `<div><span>Setup</span><strong>${data.setupRequired ? 'Pendiente' : 'OK'}</strong></div>`;
        }

        const storage = data.admin?.storage?.storage || data.admin?.storage || {};
        const files = data.admin?.storage?.files || {};

        setBadge(els.storageBadge, storage.persistent === false ? 'Revisar' : 'OK', storage.persistent === false ? 'warn' : '');

        if (els.storageText) {
          els.storageText.textContent = storage.persistent === false
            ? 'Atención: revisa la ruta persistente.'
            : `OK: ${storage.source || files.users?.source || 'storage'} persistente.`;
        }

        if (els.storageRows) {
          els.storageRows.innerHTML =
            `<div><span>Usuarios</span><strong>${esc(files.users?.source || storage.source || '-')}</strong></div>` +
            `<div><span>Nombres</span><strong>${esc(files.displayNames?.source || storage.source || '-')}</strong></div>` +
            `<div><span>Persistente</span><strong>${storage.persistent === false ? 'No' : 'Sí'}</strong></div>`;
        }

        const stracker = data.admin?.stracker || {};

        setBadge(els.strackerBadge, stracker.exists ? 'OK' : 'No DB', stracker.exists ? '' : 'warn');

        if (els.strackerText) {
          els.strackerText.textContent = stracker.exists
            ? 'Base stracker detectada.'
            : 'No se ha detectado stracker.db3.';
        }

        if (els.strackerRows) {
          els.strackerRows.innerHTML =
            `<div><span>Existe</span><strong>${stracker.exists ? 'Sí' : 'No'}</strong></div>` +
            `<div><span>SQLite</span><strong>${stracker.validSQLite ? 'Válido' : '-'}</strong></div>` +
            `<div><span>Tamaño</span><strong>${Math.round(((stracker.sizeBytes || 0) / 1024 / 1024) * 10) / 10} MB</strong></div>`;
        }

        setBadge(els.acsmBadge, 'Manual');
      }

      async function syncAcsm() {
        const button = els.syncAcsmBtn;

        try {
          if (button) {
            button.disabled = true;
            button.textContent = 'Sincronizando...';
          }

          if (els.acsmMessage) {
            els.acsmMessage.textContent = 'Sincronizando combo desde ACSM...';
            els.acsmMessage.style.color = 'var(--soft)';
          }

          const data = await fetchJson('/api/admin/acsm/sync-current-combo', {
            method:'POST'
          });

          if (els.acsmText) els.acsmText.textContent = `Último sync correcto. Storage: ${data.source || '-'}.`;

          if (els.acsmMessage) {
            els.acsmMessage.textContent = `Combo sincronizado. Eventos: ${data.totalEvents ?? '-'}`;
            els.acsmMessage.style.color = 'var(--accent)';
          }

          setBadge(els.acsmBadge, 'OK');
        } catch (error) {
          if (els.acsmText) els.acsmText.textContent = 'No se pudo sincronizar ACSM.';

          if (els.acsmMessage) {
            els.acsmMessage.textContent = error.message || 'Error ACSM.';
            els.acsmMessage.style.color = 'var(--soft)';
          }

          setBadge(els.acsmBadge, 'Error', 'warn');
        } finally {
          if (button) {
            button.disabled = false;
            button.textContent = 'Sincronizar combo';
          }
        }
      }

      async function init() {
        show('gate');

        try {
          const status = await getAdminStatus();
          renderStatus(status);

          if (status.authorized === true) {
            show('content');
            return;
          }

          show('gate');
        } catch (error) {
          show('gate');
          setText(els.state, 'Error');
          if (els.state) els.state.style.color = 'var(--warn)';

          if (els.rows) {
            els.rows.innerHTML = `<div><span>Error</span><strong>${esc(error.message || 'No disponible')}</strong></div>`;
          }
        }
      }

      els.retry?.addEventListener('click', init);
      els.syncAcsmBtn?.addEventListener('click', syncAcsm);

      init();
    })();
  </script>
</AppLayout>

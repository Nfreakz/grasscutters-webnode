---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---
<MarketingLayout title="Estado | GrassCutters Racing" description="Estado público de la plataforma GrassCutters Racing.">
  <section class="gc-page gc-hero gc-hero-compact">
    <div>
      <span class="gc-kicker">Estado público</span>
      <h1 class="gc-title">Servicios de la comunidad.</h1>
      <p class="gc-lead">Vista rápida para comprobar si la web, API, stracker y módulos principales responden correctamente.</p>
    </div>
  </section>

  <section class="gc-page">
    <div class="gc-status-grid" data-status-grid>
      <article class="gc-status-card" data-endpoint="/api/status">
        <span class="gc-status-pill">Comprobando</span>
        <h3>API base</h3>
        <p>/api/status</p>
      </article>
      <article class="gc-status-card" data-endpoint="/api/stracker/status">
        <span class="gc-status-pill">Comprobando</span>
        <h3>stracker</h3>
        <p>/api/stracker/status</p>
      </article>
      <article class="gc-status-card" data-endpoint="/api/hotlaps">
        <span class="gc-status-pill">Comprobando</span>
        <h3>Hotlaps</h3>
        <p>/api/hotlaps</p>
      </article>
      <article class="gc-status-card" data-endpoint="/api/pilots">
        <span class="gc-status-pill">Comprobando</span>
        <h3>Pilotos</h3>
        <p>/api/pilots</p>
      </article>
      <article class="gc-status-card" data-endpoint="/api/combos/stats">
        <span class="gc-status-pill">Comprobando</span>
        <h3>Combos</h3>
        <p>/api/combos/stats</p>
      </article>
      <article class="gc-status-card" data-endpoint="/api/auth/status">
        <span class="gc-status-pill">Comprobando</span>
        <h3>Auth</h3>
        <p>/api/auth/status</p>
      </article>
    </div>
  </section>

  <script is:inline>
    const cards = Array.from(document.querySelectorAll('[data-endpoint]'));
    cards.forEach(async (card) => {
      const endpoint = card.getAttribute('data-endpoint');
      const pill = card.querySelector('.gc-status-pill');
      try {
        const res = await fetch(endpoint, { cache: 'no-store' });
        if (!res.ok) throw new Error(String(res.status));
        card.setAttribute('data-status', 'ok');
        if (pill) pill.textContent = 'OK';
      } catch (error) {
        card.setAttribute('data-status', 'error');
        if (pill) pill.textContent = 'Error';
      }
    });
  </script>
</MarketingLayout>

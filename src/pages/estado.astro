---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---
<MarketingLayout title="Estado | GrassCutters Racing" description="Estado de la plataforma GrassCutters Racing.">
  <section class="gc-page gc-hero gc-hero-compact">
    <div>
      <span class="gc-kicker">Estado</span>
      <h1 class="gc-title">Servicios principales.</h1>
      <p class="gc-lead">Una comprobación rápida de la web, la API, hotlaps, pilotos y combos.</p>
    </div>
  </section>

  <section class="gc-page">
    <div class="gc-status-grid" data-status-grid>
      <article class="gc-status-card" data-endpoint="/api/status"><span class="gc-status-pill">Comprobando</span><h3>API base</h3><p>Estado general</p></article>
      <article class="gc-status-card" data-endpoint="/api/stracker/status"><span class="gc-status-pill">Comprobando</span><h3>Tracker</h3><p>Base de vueltas</p></article>
      <article class="gc-status-card" data-endpoint="/api/hotlaps"><span class="gc-status-pill">Comprobando</span><h3>Hotlaps</h3><p>Leaderboard</p></article>
      <article class="gc-status-card" data-endpoint="/api/pilots"><span class="gc-status-pill">Comprobando</span><h3>Pilotos</h3><p>Directorio</p></article>
      <article class="gc-status-card" data-endpoint="/api/combos/stats"><span class="gc-status-pill">Comprobando</span><h3>Combos</h3><p>Actividad</p></article>
      <article class="gc-status-card" data-endpoint="/api/auth/status"><span class="gc-status-pill">Comprobando</span><h3>Login</h3><p>Sesión</p></article>
    </div>
  </section>

  <script is:inline>
    const cards = Array.from(document.querySelectorAll('[data-endpoint]'));
    cards.forEach(async (card) => {
      const endpoint = card.getAttribute('data-endpoint');
      const pill = card.querySelector('.gc-status-pill');
      try {
        const res = await fetch(endpoint, { cache: 'no-store' });
        if (!res.ok) throw new Error(String(res.status));
        card.setAttribute('data-status', 'ok');
        if (pill) pill.textContent = 'OK';
      } catch (error) {
        card.setAttribute('data-status', 'error');
        if (pill) pill.textContent = 'Error';
      }
    });
  </script>
</MarketingLayout>

---
export const prerender = false;
import MarketingLayout from '../../../layouts/MarketingLayout.astro';
import '../../../styles/motorsport.css';
const { slug } = Astro.params;
---
<MarketingLayout title="Circuito · Guía Motorsport" description="Ficha de circuito de la Guía Motorsport GrassCutters.">
<section class="gc-ms" data-slug={slug}><div class="gc-ms-hero gc-ms-hero-detail" data-hero><div><span class="gc-ms-kicker">Circuito</span><h1>Cargando ficha</h1><p>Preparando datos técnicos, galería, layouts, records, curvas y fuentes.</p></div><div class="gc-ms-cover"><span class="gc-ms-placeholder">Ficha técnica</span></div></div><div class="gc-ms-section gc-ms-grid" data-panels></div></section>
<script is:inline>
const slug=document.querySelector('[data-slug]').dataset.slug; const hero=document.querySelector('[data-hero]'); const panels=document.querySelector('[data-panels]');
function list(title,items,render){return `<div class="gc-ms-panel"><h2>${title}</h2><div class="gc-ms-list">${(items||[]).map(render).join('')||'<p class="gc-ms-muted">Sin datos todavía.</p>'}</div></div>`}
fetch('/api/motorsport/circuits/'+encodeURIComponent(slug)).then(r=>r.json()).then(d=>{const c=d.circuit;if(!c){hero.innerHTML='<h1>Circuito no encontrado</h1>';return}document.title=c.name+' · Guía Motorsport';hero.innerHTML=`<div><span class="gc-ms-kicker">${c.country||c.continent||'Circuito'}</span><h1>${c.name}</h1><p>${c.description||'Ficha técnica visual generada desde la Guía Motorsport.'}</p><div class="gc-ms-actions"><span class="gc-ms-chip">${c.type||'Trazado'}</span><span class="gc-ms-chip">${c.lengthMeters?c.lengthMeters+' m':'Longitud por confirmar'}</span><span class="gc-ms-chip">${c.openedYear||'Año por confirmar'}</span></div></div><div class="gc-ms-cover">${c.cover?.url?`<img src="${c.cover.url}" alt="${c.cover.alt||c.name}" onerror="this.remove();this.parentElement.innerHTML='<span class=gc-ms-placeholder>Ficha técnica</span>'">`:'<span class="gc-ms-placeholder">Ficha técnica</span>'}</div>`;panels.innerHTML=list('Galería',(c.gallery||[]).filter(m=>m.media_type!=='referencia'),m=>`<div class="gc-ms-row"><strong>${m.title||m.media_type}</strong><br><span class="gc-ms-muted">${m.media_type}</span></div>`)+list('Layouts',c.layouts,l=>`<div class="gc-ms-row"><strong>${l.name}</strong><br><span class="gc-ms-muted">${l.length_meters||l.lengthMeters||'—'} m</span></div>`)+list('Records',c.records,r=>`<div class="gc-ms-row"><strong>${r.title}</strong><br><span class="gc-ms-muted">${r.value||''} ${r.year||''}</span></div>`)+list('Curvas icónicas',c.corners,k=>`<div class="gc-ms-row"><strong>${k.corner_number?('#'+k.corner_number+' '):''}${k.name}</strong><br><span class="gc-ms-muted">${k.description||''}</span></div>`)+list('Series/campeonatos',c.series,s=>`<div class="gc-ms-row"><strong>${s.name}</strong><br><span class="gc-ms-muted">${s.category||''}</span></div>`)+list('Aliases y fuentes',[...(c.aliases||[]).map(a=>({name:a,kind:'Alias'})),...(c.sources||[]).map(s=>({name:s.title,url:s.url,kind:'Fuente'}))],x=>`<div class="gc-ms-row"><strong>${x.name}</strong><br><span class="gc-ms-muted">${x.kind}</span></div>`)}).catch(()=>{hero.innerHTML='<h1>No se pudo cargar la ficha</h1>'});
</script>
</MarketingLayout>

---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import '../../styles/motorsport.css';
---
<MarketingLayout title="Circuitos · Guía Motorsport" description="Listado de circuitos de la Guía Motorsport GrassCutters." canonicalPath="/guia-motorsport/circuitos">
<section class="gc-ms"><div class="gc-ms-hero"><span class="gc-ms-kicker">Guía Motorsport</span><h1>Circuitos</h1><p>Listado filtrable por país, continente, tipo, fotos y records.</p><div class="gc-ms-filters"><input class="gc-ms-input" data-filter="q" placeholder="Filtrar por nombre o país"><select class="gc-ms-select" data-filter="photo"><option value="">Foto: todos</option><option value="yes">Con foto</option></select><select class="gc-ms-select" data-filter="records"><option value="">Records: todos</option><option value="yes">Con records</option></select></div></div><div class="gc-ms-section gc-ms-grid" data-circuits></div></section>
<script is:inline>
let circuits=[]; const box=document.querySelector('[data-circuits]');
function render(){const q=document.querySelector('[data-filter=q]').value.toLowerCase();const photo=document.querySelector('[data-filter=photo]').value;const records=document.querySelector('[data-filter=records]').value;const list=circuits.filter(c=>(!q||[c.name,c.country,c.continent,c.type].join(' ').toLowerCase().includes(q))&&(!photo||c.hasPhoto)&&(!records||c.hasRecords));box.innerHTML=list.map(c=>`<a class="gc-ms-card" href="/guia-motorsport/circuitos/${c.slug}"><div class="gc-ms-cover">${c.cover?.url?`<img src="${c.cover.url}" alt="${c.cover.alt||c.name}" loading="lazy" onerror="this.remove();this.parentElement.innerHTML='<span class=gc-ms-placeholder>Ficha técnica</span>'">`:'<span class="gc-ms-placeholder">Ficha técnica</span>'}</div><span class="gc-ms-kicker">${c.country||c.continent||'Circuito'}</span><h3>${c.name}</h3><p>${c.type||'Trazado'} · ${c.recordsCount||0} records</p></a>`).join('')||'<p>No hay circuitos para los filtros seleccionados.</p>'}
fetch('/api/motorsport/circuits').then(r=>r.json()).then(d=>{circuits=d.circuits||[];render()});document.querySelectorAll('[data-filter]').forEach(el=>el.addEventListener('input',render));
</script>
</MarketingLayout>

---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import '../styles/home2.css';

const title = 'Home2 · GrassCutters Racing';
const description = 'Portada experimental oculta de GrassCutters Racing.';
---

<MarketingLayout title={title} description={description} noindex={true}>
  <main class="gc-home2" data-gc-home2="hybrid-v4">
    <section class="gc-home2-hero" aria-labelledby="gc-home2-title">
      <img
        class="gc-home2-hero__bg"
        data-home2-track-image
        src="/ui/home2/gc-home2-track-fallback.svg"
        alt=""
        width="1600"
        height="900"
        loading="eager"
        decoding="async"
      />

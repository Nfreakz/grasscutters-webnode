---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import '../styles/home2.css';

const title = 'Home2 · GrassCutters Racing';
const description = 'Portada experimental oculta de GrassCutters Racing con competición, noticias, archivo y herramientas.';
---

<MarketingLayout title={title} description={description} noindex={true}>
  <main class="gc-home2" data-gc-home2="hybrid-v1">
    <section class="gc-home2-hero" aria-labelledby="gc-home2-title">
      <img
        class="gc-home2-hero__bg"
        data-home2-track-image
        src="/ui/home2/gc-home2-track-fallback.svg"
        alt=""
        width="1600"
        height="900"
        loading="eager"
        decoding="async"
      />
      <div class="gc-home2-hero__shade" aria-hidden="true"></div>
      <div class="gc-home2-hero__grid" aria-hidden="true"></div>

      <div class="gc-home2-shell gc-home2-hero__inner">
        <div class="gc-home2-hero__copy">
          <div class="gc-home2-statusline" aria-label="Estado de la plataforma">
            <span class="gc-home2-badge gc-home2-badge--live" data-home2-live>LIVE</span>
            <span class="gc-home2-badge">TRACKER OK</span>
            <span class="gc-home2-badge" data-home2-updated>ACTUALIZANDO</span>
          </div>

          <p class="gc-home2-kicker">GRASSCUTTERS RACE CONTROL</p>
          <h1 id="gc-home2-title">Vive la competición</h1>
          <p class="gc-home2-lead">Cada vuelta cuenta.</p>

          <div class="gc-home2-hero__actions">
            <a class="gc-home2-btn gc-home2-btn--primary" href="https://acstuff.ru/s/q:race/online/join?httpPort=8381&ip=185.216.144.78" target="_blank" rel="noreferrer">
              Entrar al servidor
              <span aria-hidden="true">→</span>
            </a>
            <a class="gc-home2-btn gc-home2-btn--ghost" href="/app">Ver plataforma</a>
          </div>
        </div>

        <article class="gc-home2-feature-card" aria-labelledby="gc-home2-combo-title">
          <p class="gc-home2-card-label">Combo activo</p>
          <h2 id="gc-home2-combo-title" data-home2-track>Mugello</h2>
          <p class="gc-home2-feature-card__cars" data-home2-cars>BMW M3 GT2 / Ferrari F430 GT2</p>

          <div class="gc-home2-driver">
            <div class="gc-home2-driver__avatar">
              <img data-home2-best-avatar src="/images/pilot-avatar-default.png" alt="" width="88" height="88" loading="lazy" decoding="async" />
              <span class="gc-home2-driver__dot" aria-hidden="true"></span>
            </div>
            <div>
              <span class="gc-home2-card-label">Mejor vuelta</span>
              <strong data-home2-best-driver>Nandy</strong>
              <small data-home2-best-car>BMW M3 GT2</small>
            </div>
            <div class="gc-home2-time" data-home2-best-time>1:50.264</div>
          </div>

          <a class="gc-home2-btn gc-home2-btn--primary gc-home2-feature-card__join" href="https://acstuff.ru/s/q:race/online/join?httpPort=8381&ip=185.216.144.78" target="_blank" rel="noreferrer">
            Entrar al servidor
            <span aria-hidden="true">→</span>
          </a>

          <p class="gc-home2-feature-card__meta"><span data-home2-server-users>8 / 32</span> conectados</p>
        </article>
      </div>
    </section>

    <section class="gc-home2-board gc-home2-shell" aria-label="Actividad principal">
      <div class="gc-home2-grid-main">
        <article class="gc-home2-panel gc-home2-panel--now">
          <div class="gc-home2-panel__head">
            <div>
              <p class="gc-home2-panel__eyebrow">Now Racing</p>
              <h2 data-home2-now-title>Mugello</h2>
            </div>
            <span class="gc-home2-country">🇮🇹</span>
          </div>

          <div class="gc-home2-track-mini">
            <img src="/ui/home2/gc-home2-track-outline.svg" alt="" width="220" height="130" loading="lazy" decoding="async" />
          </div>

          <dl class="gc-home2-metrics">
            <div>
              <dt>Pilotos</dt>
              <dd data-home2-drivers>23</dd>
            </div>
            <div>
              <dt>Vueltas</dt>
              <dd data-home2-laps>156</dd>
            </div>
            <div>
              <dt>Best lap</dt>
              <dd data-home2-best-mini>1:50.264</dd>
            </div>
          </dl>

          <div class="gc-home2-card-actions">
            <a href="/combos" class="gc-home2-btn gc-home2-btn--small">Ver combo →</a>
            <a href="/hotlaps" class="gc-home2-btn gc-home2-btn--small">Ver hotlaps →</a>
          </div>
        </article>

        <article class="gc-home2-panel gc-home2-panel--reference">
          <p class="gc-home2-panel__eyebrow">Mejor referencia</p>
          <div class="gc-home2-profile">
            <img data-home2-reference-avatar src="/images/pilot-avatar-default.png" alt="" width="112" height="112" loading="lazy" decoding="async" />
            <div>
              <strong data-home2-reference-driver>Nandy</strong>
              <span data-home2-reference-car>BMW M3 GT2</span>
            </div>
          </div>
          <div class="gc-home2-reference-time" data-home2-reference-time>1:50.264</div>
          <dl class="gc-home2-metrics gc-home2-metrics--compact">
            <div>
              <dt>Mejoras hoy</dt>
              <dd data-home2-improvements>12</dd>
            </div>
            <div>
              <dt>Vueltas limpias</dt>
              <dd data-home2-clean>--</dd>
            </div>
          </dl>
        </article>

        <article class="gc-home2-panel gc-home2-panel--laps">
          <div class="gc-home2-panel__head">
            <div>
              <p class="gc-home2-panel__eyebrow">Últimas vueltas</p>
              <h2>Timing sheet</h2>
            </div>
            <a href="/hotlaps" class="gc-home2-link">Ver todas →</a>
          </div>

          <div class="gc-home2-table" role="table" aria-label="Últimas vueltas">
            <div class="gc-home2-table__row gc-home2-table__row--head" role="row">
              <span>Piloto</span>
              <span>Coche</span>
              <span>Tiempo</span>
              <span>Hace</span>
            </div>
            <div data-home2-recent-laps>
              <div class="gc-home2-table__row" role="row">
                <span>Nandy</span><span>BMW M3 GT2</span><strong>1:50.264</strong><small>4 min</small>
              </div>
              <div class="gc-home2-table__row" role="row">
                <span>Neo RS</span><span>Ferrari F430 GT2</span><strong>1:51.102</strong><small>11 min</small>
              </div>
              <div class="gc-home2-table__row" role="row">
                <span>DaniRS</span><span>BMW M3 GT2</span><strong>1:51.589</strong><small>17 min</small>
              </div>
              <div class="gc-home2-table__row" role="row">
                <span>JaviMart</span><span>Ferrari F430 GT2</span><strong>1:52.013</strong><small>23 min</small>
              </div>
            </div>
          </div>
        </article>

        <article class="gc-home2-panel gc-home2-panel--server">
          <p class="gc-home2-panel__eyebrow">Estado del servidor</p>
          <dl class="gc-home2-server-list">
            <div><dt>Servidor</dt><dd data-home2-server-state>Online</dd></div>
            <div><dt>Tracker</dt><dd>OK</dd></div>
            <div><dt>Latencia</dt><dd data-home2-latency>-- ms</dd></div>
            <div><dt>Uptime</dt><dd data-home2-uptime>--</dd></div>
          </dl>
          <a href="/estado" class="gc-home2-btn gc-home2-btn--small gc-home2-btn--wide">Ver estado completo →</a>
        </article>
      </div>
    </section>

    <section class="gc-home2-section gc-home2-shell" aria-labelledby="gc-home2-news-title">
      <div class="gc-home2-section__head">
        <div>
          <p class="gc-home2-panel__eyebrow">Paddock Wire</p>
          <h2 id="gc-home2-news-title">Últimas del paddock</h2>
        </div>
        <a href="/novedades" class="gc-home2-btn gc-home2-btn--small">Ver todas las noticias →</a>
      </div>

      <div class="gc-home2-news-grid" data-home2-news>
        <article class="gc-home2-news-card gc-home2-news-card--main">
          <img src="/ui/home2/gc-home2-news-hud.svg" alt="" width="760" height="430" loading="lazy" decoding="async" />
          <div>
            <span class="gc-home2-tag gc-home2-tag--green">Update</span>
            <time>28 may 2026</time>
            <h3>HUD Lite 2.3 ya disponible</h3>
            <p>Nuevo overlay, mejor rendimiento y lectura ampliada.</p>
            <a href="/novedades" class="gc-home2-link">Leer más →</a>
          </div>
        </article>

        <article class="gc-home2-news-card">
          <img src="/ui/home2/gc-home2-news-combo.svg" alt="" width="380" height="214" loading="lazy" decoding="async" />
          <div>
            <span class="gc-home2-tag">Comunidad</span>
            <time>27 may 2026</time>
            <h3>Nuevo combo semanal</h3>
            <p>Mugello y GT2, la combinación perfecta para tandas rápidas.</p>
            <a href="/combos" class="gc-home2-link">Leer más →</a>
          </div>
        </article>

        <article class="gc-home2-news-card">
          <img src="/ui/home2/gc-home2-news-race.svg" alt="" width="380" height="214" loading="lazy" decoding="async" />
          <div>
            <span class="gc-home2-tag gc-home2-tag--red">Crónica</span>
            <time>26 may 2026</time>
            <h3>Crónica GC Weekly Race</h3>
            <p>Resumen de carrera, batallas y vueltas clave del sábado.</p>
            <a href="/novedades" class="gc-home2-link">Leer más →</a>
          </div>
        </article>

        <article class="gc-home2-news-card">
          <img src="/ui/home2/gc-home2-news-sim.svg" alt="" width="380" height="214" loading="lazy" decoding="async" />
          <div>
            <span class="gc-home2-tag gc-home2-tag--cyan">Simracing</span>
            <time>25 may 2026</time>
            <h3>Formula Drift todo lo nuevo</h3>
            <p>Análisis de una nueva actualización con coches añadidos.</p>
            <a href="/novedades" class="gc-home2-link">Leer más →</a>
          </div>
        </article>
      </div>
    </section>

    <section class="gc-home2-section gc-home2-shell gc-home2-bottom-grid" aria-label="Archivo y herramientas">
      <article class="gc-home2-panel gc-home2-archive">
        <div class="gc-home2-panel__head">
          <div>
            <p class="gc-home2-panel__eyebrow">Archivo GC</p>
            <h2>Fichas técnicas e históricas</h2>
          </div>
          <a href="/archivo" class="gc-home2-btn gc-home2-btn--small">Ver todo el archivo →</a>
        </div>

        <div class="gc-home2-archive-grid" data-home2-archive>
          <a class="gc-home2-archive-card" href="/archivo">
            <img src="/ui/home2/gc-home2-archive-circuit.svg" alt="" width="360" height="205" loading="lazy" decoding="async" />
            <span>Circuito</span>
            <strong>Mugello</strong>
            <small>Guía completa del circuito, referencias y líneas.</small>
          </a>
          <a class="gc-home2-archive-card" href="/archivo">
            <img src="/ui/home2/gc-home2-archive-car.svg" alt="" width="360" height="205" loading="lazy" decoding="async" />
            <span>Coche</span>
            <strong>BMW M3 GT2</strong>
            <small>Ficha técnica, setup base y puntos fuertes.</small>
          </a>
          <a class="gc-home2-archive-card" href="/archivo">
            <img src="/ui/home2/gc-home2-archive-driver.svg" alt="" width="360" height="205" loading="lazy" decoding="async" />
            <span>Piloto</span>
            <strong>Nandy</strong>
            <small>Perfil, estadísticas y mejores resultados.</small>
          </a>
        </div>
      </article>

      <article class="gc-home2-panel gc-home2-tools">
        <div class="gc-home2-panel__head">
          <div>
            <p class="gc-home2-panel__eyebrow">Box Tools</p>
            <h2>Recursos para pilotos</h2>
          </div>
        </div>

        <div class="gc-home2-tools-grid">
          <a href="https://www.overtake.gg/downloads/grasscutters-lua-hud-lite.84201/" target="_blank" rel="noreferrer" class="gc-home2-tool">
            <img src="/ui/home2/icons/hud.svg" alt="" width="52" height="52" loading="lazy" />
            <strong>HUD / Overlays</strong>
            <span>Descarga el HUD oficial GC</span>
          </a>
          <a href="/app-android" class="gc-home2-tool">
            <img src="/ui/home2/icons/android.svg" alt="" width="52" height="52" loading="lazy" />
            <strong>App Android</strong>
            <span>Lleva GC en el móvil</span>
          </a>
          <a href="/combos" class="gc-home2-tool">
            <img src="/ui/home2/icons/car.svg" alt="" width="52" height="52" loading="lazy" />
            <strong>Coches</strong>
            <span>Lista de coches disponibles</span>
          </a>
          <a href="/archivo" class="gc-home2-tool">
            <img src="/ui/home2/icons/track.svg" alt="" width="52" height="52" loading="lazy" />
            <strong>Circuitos</strong>
            <span>Fichas y referencias rápidas</span>
          </a>
        </div>
      </article>
    </section>

    <section class="gc-home2-community gc-home2-shell" aria-label="Comunidad GrassCutters">
      <div>
        <p class="gc-home2-panel__eyebrow">Comunidad</p>
        <h2>Entra al paddock.</h2>
        <p>Pocas normas, buen ambiente y pista limpia.</p>
      </div>
      <div class="gc-home2-community__links">
        <a href="https://discord.gg/jA4yuuH5T" target="_blank" rel="noreferrer">
          <img src="/ui/home2/icons/discord.svg" alt="" width="28" height="28" /> Discord
        </a>
        <a href="https://chat.whatsapp.com/JMXKRF4XnG73D4xLzzrlHa" target="_blank" rel="noreferrer">
          <img src="/ui/home2/icons/whatsapp.svg" alt="" width="28" height="28" /> WhatsApp
        </a>
        <a href="https://www.instagram.com/grasscutters_ac/" target="_blank" rel="noreferrer">
          <img src="/ui/home2/icons/instagram.svg" alt="" width="28" height="28" /> Instagram
        </a>
        <a href="/normas">
          <img src="/ui/home2/icons/rules.svg" alt="" width="28" height="28" /> Normas
        </a>
        <a href="/apoyo-servidor">
          <img src="/ui/home2/icons/support.svg" alt="" width="28" height="28" /> Apoya el server
        </a>
      </div>
    </section>
  </main>

  <script is:inline src="/js/gc-track-images.js"></script>
  <script>
    (() => {
      const root = document.querySelector('[data-gc-home2]');
      if (!root) return;

      const $ = (selector) => root.querySelector(selector);
      const $$ = (selector) => Array.from(root.querySelectorAll(selector));

      const setText = (selector, value) => {
        const el = $(selector);
        if (!el) return;
        const clean = value === undefined || value === null || value === '' ? '--' : String(value);
        el.textContent = clean;
      };

      const getArray = (payload) => {
        if (!payload) return [];
        if (Array.isArray(payload)) return payload;
        if (Array.isArray(payload.items)) return payload.items;
        if (Array.isArray(payload.data)) return payload.data;
        if (Array.isArray(payload.laps)) return payload.laps;
        if (Array.isArray(payload.results)) return payload.results;
        if (Array.isArray(payload.combos)) return payload.combos;
        if (payload.leaderboard && Array.isArray(payload.leaderboard)) return payload.leaderboard;
        return [];
      };

      const firstValue = (obj, keys) => {
        if (!obj) return '';
        for (const key of keys) {
          if (key.includes('.')) {
            const parts = key.split('.');
            let current = obj;
            for (const part of parts) {
              current = current && current[part];
            }
            if (current !== undefined && current !== null && current !== '') return current;
          } else if (obj[key] !== undefined && obj[key] !== null && obj[key] !== '') {
            return obj[key];
          }
        }
        return '';
      };

      const fetchJson = async (url) => {
        try {
          const res = await fetch(url, { headers: { Accept: 'application/json' } });
          if (!res.ok) return null;
          return await res.json();
        } catch (_) {
          return null;
        }
      };

      const slugify = (value) => String(value || '')
        .toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '_')
        .replace(/^_+|_+$/g, '');

      const formatLap = (value) => {
        if (value === undefined || value === null || value === '') return '--';
        if (typeof value === 'string') {
          const trimmed = value.trim();
          if (trimmed.includes(':')) return trimmed;
          const numeric = Number(trimmed);
          if (!Number.isFinite(numeric)) return trimmed;
          value = numeric;
        }
        const num = Number(value);
        if (!Number.isFinite(num) || num <= 0) return '--';
        const ms = num > 1000 ? Math.round(num) : Math.round(num * 1000);
        const minutes = Math.floor(ms / 60000);
        const seconds = Math.floor((ms % 60000) / 1000);
        const millis = ms % 1000;
        return `${minutes}:${String(seconds).padStart(2, '0')}.${String(millis).padStart(3, '0')}`;
      };

      const formatAgo = (value) => {
        if (!value) return '--';
        const time = new Date(value).getTime();
        if (!Number.isFinite(time)) return String(value);
        const diff = Math.max(0, Date.now() - time);
        const min = Math.floor(diff / 60000);
        if (min < 1) return 'ahora';
        if (min < 60) return `${min} min`;
        const hours = Math.floor(min / 60);
        if (hours < 24) return `${hours} h`;
        const days = Math.floor(hours / 24);
        return `${days} d`;
      };

      const pilotAvatarUrl = (pilot) => {
        const direct = firstValue(pilot, ['avatarUrl', 'avatar_url', 'imageUrl', 'image', 'driver.avatarUrl', 'player.avatarUrl', 'pilot.avatarUrl']);
        if (direct) return String(direct);
        const id = firstValue(pilot, ['pilotId', 'playerId', 'driverId', 'id', 'player.id', 'driver.id']);
        if (id !== undefined && id !== null && id !== '') return `/api/pilot-avatar/${encodeURIComponent(String(id))}`;
        return '/images/pilot-avatar-default.png';
      };

      const setTrackImage = async (trackName) => {
        const img = $('[data-home2-track-image]');
        if (!img || !trackName) return;

        if (window.GCTrackImages && typeof window.GCTrackImages.bestAsset === 'function') {
          try {
            const asset = window.GCTrackImages.bestAsset(trackName);
            if (asset && asset.url) {
              img.src = asset.url;
              return;
            }
          } catch (_) {}
        }

        const slug = slugify(trackName);
        const candidates = [
          `/images/tracks/${slug}.webp`,
          `/images/tracks/${slug}.png`,
          `/images/tracks/${slug}.jpg`,
          `/imagenes/tracks/${slug}.webp`,
          `/imagenes/tracks/${slug}.png`,
          '/ui/home2/gc-home2-track-fallback.svg'
        ];

        const probe = (src) => new Promise((resolve) => {
          const test = new Image();
          test.onload = () => resolve(src);
          test.onerror = () => resolve('');
          test.src = src;
        });

        for (const candidate of candidates) {
          const ok = await probe(candidate);
          if (ok) {
            img.src = ok;
            return;
          }
        }
      };

      const renderRows = (selector, rows) => {
        const host = $(selector);
        if (!host) return;
        const cleanRows = rows.slice(0, 5);
        if (!cleanRows.length) return;
        host.innerHTML = cleanRows.map((lap) => {
          const driver = firstValue(lap, ['driverName', 'pilotName', 'playerName', 'name', 'driver.displayName', 'player.name']) || 'Piloto';
          const car = firstValue(lap, ['carName', 'car', 'carDisplayName', 'vehicle', 'car.displayName']) || 'Coche';
          const rawTime = firstValue(lap, ['lapTimeFormatted', 'bestLapTimeFormatted', 'timeFormatted', 'lapTime', 'lapMs', 'time', 'bestLap']);
          const date = firstValue(lap, ['createdAt', 'date', 'timestamp', 'lapDate', 'finishedAt', 'updatedAt']);
          return `<div class="gc-home2-table__row" role="row"><span>${driver}</span><span>${car}</span><strong>${formatLap(rawTime)}</strong><small>${formatAgo(date)}</small></div>`;
        }).join('');
      };

      const renderNews = async () => {
        const data = await fetchJson('/data/home2-news.json');
        const items = getArray(data);
        const host = $('[data-home2-news]');
        if (!host || !items.length) return;

        host.innerHTML = items.slice(0, 4).map((item, index) => {
          const image = item.image || '/ui/home2/gc-home2-news-sim.svg';
          const cls = index === 0 ? 'gc-home2-news-card gc-home2-news-card--main' : 'gc-home2-news-card';
          return `
            <article class="${cls}">
              <img src="${image}" alt="" width="${index === 0 ? 760 : 380}" height="${index === 0 ? 430 : 214}" loading="lazy" decoding="async" />
              <div>
                <span class="gc-home2-tag">${item.category || 'Paddock'}</span>
                <time>${item.date || item.publishedAt || ''}</time>
                <h3>${item.title || 'Noticia'}</h3>
                <p>${item.excerpt || ''}</p>
                <a href="${item.href || '/novedades'}" class="gc-home2-link">Leer más →</a>
              </div>
            </article>
          `;
        }).join('');
      };

      const renderArchive = async () => {
        const data = await fetchJson('/api/archive/items.json') || await fetchJson('/api/archive/items?featured=1&limit=3') || await fetchJson('/api/archive/items?limit=3');
        const items = getArray(data).slice(0, 3);
        const host = $('[data-home2-archive]');
        if (!host || !items.length) return;

        host.innerHTML = items.map((item) => {
          const title = firstValue(item, ['title', 'nombre', 'name']) || 'Ficha';
          const type = firstValue(item, ['type', 'tipo', 'category', 'categoria']) || 'Archivo';
          const summary = firstValue(item, ['summary', 'descripcion_corta', 'description', 'subtitle']) || 'Ficha técnica e histórica.';
          const image = firstValue(item, ['image', 'imageUrl', 'imagen_url', 'cover', 'media.0.url']) || '/ui/home2/gc-home2-archive-circuit.svg';
          const href = firstValue(item, ['href', 'url', 'publicUrl']);
          const slug = firstValue(item, ['slug']);
          const tipo = firstValue(item, ['tipo', 'type', 'category']);
          const finalHref = href || (slug && tipo ? `/archivo/${tipo}/${slug}` : '/archivo');
          return `
            <a class="gc-home2-archive-card" href="${finalHref}">
              <img src="${image}" alt="" width="360" height="205" loading="lazy" decoding="async" />
              <span>${type}</span>
              <strong>${title}</strong>
              <small>${summary}</small>
            </a>
          `;
        }).join('');
      };

      const init = async () => {
        const now = new Date();
        setText('[data-home2-updated]', `ACTUALIZADO ${now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}`);

        const diagnostics = await fetchJson('/api/gc/diagnostics') || await fetchJson('/api/status') || await fetchJson('/api/stats/overview');
        const combosPayload = await fetchJson('/api/gc/combos?limit=1&sort=recent') || await fetchJson('/api/combos/stats?limit=1&sort=recent') || await fetchJson('/api/combos?limit=1&sort=recent');
        const recentPayload = await fetchJson('/api/gc/recent-laps?limit=8&sort=recent&valid=all') || await fetchJson('/api/laps?limit=8&sort=recent&valid=all') || await fetchJson('/api/hotlaps?limit=8');
        const leaderboardPayload = await fetchJson('/api/gc/leaderboard?scope=activeCombo&limit=5') || await fetchJson('/api/hotlaps?limit=5');

        const raceData = diagnostics && (diagnostics.raceData || diagnostics.stats || diagnostics);
        if (raceData) {
          const totalLaps = firstValue(raceData, ['lapsCount', 'validLapsCount', 'totalLaps', 'hotlaps']);
          const drivers = firstValue(raceData, ['driversCount', 'pilotsCount', 'totalDrivers', 'pilots']);
          const active = diagnostics && (diagnostics.health === 'ok' || diagnostics.ok);
          setText('[data-home2-live]', active ? 'LIVE' : 'STATUS');
          setText('[data-home2-server-state]', active ? 'Online' : 'Revisar');
          if (drivers) setText('[data-home2-drivers]', drivers);
          if (totalLaps) setText('[data-home2-laps]', totalLaps);
        }

        const combo = getArray(combosPayload)[0] || combosPayload?.activeCombo || combosPayload?.combo || {};
        const track = firstValue(combo, ['canonicalTrackName', 'trackName', 'track', 'circuitName', 'name']) || 'Mugello';
        const cars = firstValue(combo, ['publicComboCars', 'carNames', 'cars', 'mainVariantAllCars']);
        const carList = Array.isArray(cars) ? cars.map((car) => typeof car === 'string' ? car : firstValue(car, ['name', 'carName', 'displayName'])).filter(Boolean) : String(cars || 'BMW M3 GT2 / Ferrari F430 GT2').split(',').map((s) => s.trim()).filter(Boolean);
        const totalComboLaps = firstValue(combo, ['totalLaps', 'validLaps', 'lapsCount', 'summary.totalLaps']);
        const comboDrivers = firstValue(combo, ['driversCount', 'pilotsCount', 'summary.driversCount']);
        const bestDriver = firstValue(combo, ['bestDriverName', 'bestPilotName', 'leaderboard.0.driverName', 'best.driverName']) || 'Nandy';
        const bestCar = firstValue(combo, ['bestCarName', 'best.carName', 'leaderboard.0.carName']) || carList[0] || 'BMW M3 GT2';
        const bestTime = formatLap(firstValue(combo, ['bestLapTimeFormatted', 'bestLapFormatted', 'bestLapTime', 'bestLap', 'best.time', 'leaderboard.0.lapTime']));

        setText('[data-home2-track]', track);
        setText('[data-home2-now-title]', track);
        setText('[data-home2-cars]', carList.slice(0, 3).join(' / '));
        setText('[data-home2-best-driver]', bestDriver);
        setText('[data-home2-reference-driver]', bestDriver);
        setText('[data-home2-best-car]', bestCar);
        setText('[data-home2-reference-car]', bestCar);
        setText('[data-home2-best-time]', bestTime);
        setText('[data-home2-best-mini]', bestTime);
        setText('[data-home2-reference-time]', bestTime);
        if (totalComboLaps) setText('[data-home2-laps]', totalComboLaps);
        if (comboDrivers) setText('[data-home2-drivers]', comboDrivers);

        const bestAvatar = pilotAvatarUrl(combo.best || combo.leaderboard?.[0] || combo);
        const avatarNodes = $$('[data-home2-best-avatar], [data-home2-reference-avatar]');
        avatarNodes.forEach((img) => { img.src = bestAvatar; });

        await setTrackImage(track);

        renderRows('[data-home2-recent-laps]', getArray(recentPayload));
        const board = getArray(leaderboardPayload);
        if (board.length) {
          const firstBoard = board[0];
          const boardDriver = firstValue(firstBoard, ['driverName', 'pilotName', 'playerName', 'name']) || bestDriver;
          const boardCar = firstValue(firstBoard, ['carName', 'car', 'carDisplayName']) || bestCar;
          const boardTime = formatLap(firstValue(firstBoard, ['lapTimeFormatted', 'bestLapTimeFormatted', 'lapTime', 'time', 'bestLap']));
          setText('[data-home2-best-driver]', boardDriver);
          setText('[data-home2-reference-driver]', boardDriver);
          setText('[data-home2-best-car]', boardCar);
          setText('[data-home2-reference-car]', boardCar);
          setText('[data-home2-best-time]', boardTime);
          setText('[data-home2-best-mini]', boardTime);
          setText('[data-home2-reference-time]', boardTime);
        }

        await renderNews();
        await renderArchive();

        document.documentElement.dataset.gcHome2 = 'hybrid-v1-ready';
      };

      init();
    })();
  </script>
</MarketingLayout>

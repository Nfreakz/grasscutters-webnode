      <div class="gc-home2-hero__grid" aria-hidden="true"></div>

      <div class="gc-home2-shell gc-home2-hero__shell">
        <div class="gc-home2-hero__copy">
          <p class="gc-home2-kicker">GRASSCUTTERS RACE CONTROL</p>
          <h1 id="gc-home2-title">Vive la competición</h1>
          <p class="gc-home2-lead">Cada vuelta cuenta</p>

          <div class="gc-home2-statusline" aria-label="Estado de la plataforma">
            <span class="gc-home2-badge gc-home2-badge--live" data-home2-live>LIVE</span>
            <span class="gc-home2-badge">TRACKER OK</span>
            <span class="gc-home2-badge" data-home2-updated>ACTUALIZANDO</span>
          </div>

          <div class="gc-home2-hero__actions">
            <a class="gc-home2-btn gc-home2-btn--primary" href="https://acstuff.ru/s/q:race/online/join?httpPort=8381&ip=185.216.144.78" target="_blank" rel="noreferrer">
              Entrar al servidor
              <span aria-hidden="true">→</span>
            </a>
            <a class="gc-home2-btn gc-home2-btn--ghost" href="/app">Ver plataforma</a>
          </div>
        </div>

        <article class="gc-home2-combo-card" aria-labelledby="gc-home2-combo-title">
          <p class="gc-home2-combo-card__label">Combo activo</p>
          <h2 id="gc-home2-combo-title" data-home2-track>Mugello</h2>

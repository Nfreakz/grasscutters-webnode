  <script is:inline src="/js/gc-track-images.js"></script>
  <script>
    (() => {
      const root = document.querySelector('[data-gc-home2]');
      if (!root) return;

      const $ = (selector) => root.querySelector(selector);
      const $$ = (selector) => Array.from(root.querySelectorAll(selector));

      const setText = (selector, value) => {
        const el = $(selector);
        if (!el) return;
        el.textContent = value === undefined || value === null || value === '' ? '--' : String(value);
      };

      const getArray = (payload) => {
        if (!payload) return [];
        if (Array.isArray(payload)) return payload;
        if (Array.isArray(payload.items)) return payload.items;
        if (Array.isArray(payload.data)) return payload.data;
        if (payload.data && Array.isArray(payload.data.items)) return payload.data.items;
        if (payload.data && Array.isArray(payload.data.entries)) return payload.data.entries;
        if (payload.data && Array.isArray(payload.data.results)) return payload.data.results;
        if (Array.isArray(payload.entries)) return payload.entries;
        if (Array.isArray(payload.archiveItems)) return payload.archiveItems;
        if (Array.isArray(payload.records)) return payload.records;
        if (Array.isArray(payload.laps)) return payload.laps;
        if (Array.isArray(payload.results)) return payload.results;
        if (Array.isArray(payload.combos)) return payload.combos;
        if (Array.isArray(payload.leaderboard)) return payload.leaderboard;
        return [];
      };

      const firstValue = (obj, keys) => {
        if (!obj) return '';
        for (const key of keys) {
          if (key.includes('.')) {
            const parts = key.split('.');
            let current = obj;
            for (const part of parts) current = current && current[part];
            if (current !== undefined && current !== null && current !== '') return current;
          } else if (obj[key] !== undefined && obj[key] !== null && obj[key] !== '') {
            return obj[key];
          }
        }
        return '';
      };

      const fetchJson = async (url) => {
        try {
          const res = await fetch(url, { headers: { Accept: 'application/json' } });
          if (!res.ok) return null;
          return await res.json();
        } catch (_) {
          return null;
        }
      };

      const slugify = (value) => String(value || '')
        .toLowerCase()
        .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '_')
        .replace(/^_+|_+$/g, '');

      const countryFlag = (code) => {
        const normalized = String(code || '').trim().toUpperCase();
        if (!/^[A-Z]{2}$/.test(normalized)) return '';
        return normalized.replace(/./g, (char) => String.fromCodePoint(127397 + char.charCodeAt(0)));
      };

      const inferTrackCountry = (trackName, combo = {}) => {
        const direct = firstValue(combo, [
          'track.countryCode',
          'track.country',
          'countryCode',
          'country',
          'trackCountry',
          'trackCountryCode'
        ]);
        if (direct) {
          const code = String(direct).trim().slice(0, 2).toUpperCase();
          return countryFlag(code) || code;
        }

        const slug = slugify(trackName);
        const countryMap = [
          [['mugello', 'monza', 'imola', 'vallelunga', 'misano'], 'IT'],
          [['spa', 'zolder'], 'BE'],
          [['silverstone', 'brands_hatch', 'donington', 'oulton'], 'GB'],
          [['sebring', 'laguna_seca', 'road_america', 'road_atlanta', 'watkins', 'daytona'], 'US'],
          [['nurburgring', 'nordschleife', 'hockenheim', 'lausitz'], 'DE'],
          [['barcelona', 'valencia', 'jarama', 'jerez'], 'ES'],
          [['zandvoort', 'assen'], 'NL'],
          [['suzuka', 'fuji', 'okayama'], 'JP'],
          [['phillip_island', 'mount_panorama', 'bathurst'], 'AU'],
          [['red_bull', 'spielberg'], 'AT'],
          [['paul_ricard', 'magny'], 'FR'],
          [['interlagos'], 'BR']
        ];

        const hit = countryMap.find(([names]) => names.some((name) => slug.includes(name)));
        return hit ? countryFlag(hit[1]) : '';
      };

      const normalizeArchiveType = (value) => {
        const raw = slugify(value || 'archivo');
        if (['circuito', 'circuit', 'track', 'tracks'].includes(raw)) return 'circuitos';
        if (['coche', 'coches', 'car', 'cars', 'vehiculo', 'vehiculos', 'vehicle'].includes(raw)) return 'coches';
        if (['piloto', 'pilotos', 'driver', 'drivers'].includes(raw)) return 'pilotos';
        if (raw.endsWith('s')) return raw;
        return `${raw}s`;
      };

      const archiveImage = (item, index = 0) => {
        const mediaArray = Array.isArray(item?.media) ? item.media : [];
        const firstMedia = mediaArray.find((media) => media && (
          media.isCover ||
          media.is_cover ||
          media.portada ||
          media.role === 'cover' ||
          media.kind === 'cover' ||
          media.url ||
          media.publicUrl
        )) || mediaArray[0];

        const direct = firstValue(item, [
          'image',
          'imageUrl',
          'image_url',
          'imagen_url',
          'imagen',
          'cover',
          'coverUrl',
          'cover_url',
          'mediaUrl',
          'media_url',
          'featuredImage',
          'featured_image',
          'heroImage',
          'hero_image',
          'thumbnail',
          'thumb',
          'mainImage',
          'main_image'
        ]);

        const mediaUrl = firstValue(firstMedia, [
          'url',
          'publicUrl',
          'public_url',
          'src',
          'imageUrl',
          'image_url',
          'path'
        ]);

        const chosen = direct || mediaUrl;
        if (chosen) return String(chosen);

        const fallbacks = [
          '/ui/home2/gc-home2-archive-circuit.svg',
          '/ui/home2/gc-home2-archive-car.svg',
          '/ui/home2/gc-home2-archive-driver.svg'
        ];
        return fallbacks[index % fallbacks.length];
      };

      const archiveHref = (item) => {
        const direct = firstValue(item, ['href', 'url', 'publicUrl', 'public_url', 'path']);
        if (direct) return String(direct);
        const slug = firstValue(item, ['slug', 'seoSlug', 'seo_slug']);
        const type = normalizeArchiveType(firstValue(item, ['tipo', 'type', 'category', 'categoria', 'kind']));
        return slug ? `/archivo/${type}/${slug}/` : '/archivo';
      };

      const formatLap = (value) => {
        if (value === undefined || value === null || value === '') return '--';
        if (typeof value === 'string') {
          const trimmed = value.trim();
          if (trimmed.includes(':')) return trimmed;
          const numeric = Number(trimmed);
          if (!Number.isFinite(numeric)) return trimmed;
          value = numeric;
        }
        const num = Number(value);
        if (!Number.isFinite(num) || num <= 0) return '--';
        const ms = num > 1000 ? Math.round(num) : Math.round(num * 1000);
        const minutes = Math.floor(ms / 60000);
        const seconds = Math.floor((ms % 60000) / 1000);
        const millis = ms % 1000;
        return `${minutes}:${String(seconds).padStart(2, '0')}.${String(millis).padStart(3, '0')}`;
      };

      const parseDateValue = (value) => {
        if (value === undefined || value === null || value === '') return null;

        if (value instanceof Date && Number.isFinite(value.getTime())) {
          return value.getFullYear() >= 2020 ? value : null;
        }

        if (typeof value === 'number' || (typeof value === 'string' && /^-?\d+(\.\d+)?$/.test(value.trim()))) {
          const numeric = Number(value);
          if (!Number.isFinite(numeric) || numeric <= 0) return null;

          let ms = numeric;

          // Unix seconds are around 1.7e9. Unix ms are around 1.7e12.
          if (numeric > 1e9 && numeric < 1e10) ms = numeric * 1000;
          else if (numeric > 1e12 && numeric < 1e13) ms = numeric;
          else return null;

          const date = new Date(ms);
          return Number.isFinite(date.getTime()) && date.getFullYear() >= 2020 ? date : null;
        }

        const text = String(value).trim();
        if (!text || text === '0') return null;

        const parsed = new Date(text);
        if (!Number.isFinite(parsed.getTime()) || parsed.getFullYear() < 2020) return null;
        return parsed;
      };

      const firstValidDate = (obj, keys) => {
        if (!obj) return null;
        for (const key of keys) {
          const raw = firstValue(obj, [key]);
          const date = parseDateValue(raw);
          if (date) return date;
        }
        return null;
      };

      const formatAgo = (value) => {
        const date = parseDateValue(value);
        if (!date) return '--';

        const diff = Date.now() - date.getTime();
        if (diff < 0) return '--';

        const mins = Math.floor(diff / 60000);
        if (mins < 1) return 'ahora';
        if (mins < 60) return `${mins} min`;

        const hours = Math.floor(mins / 60);
        if (hours < 24) return `${hours} h`;

        const days = Math.floor(hours / 24);
        if (days < 31) return `${days} d`;

        const months = Math.floor(days / 30);
        if (months < 24) return `${months} m`;

        const years = Math.floor(days / 365);
        return `${years} a`;
      };

      const pilotAvatarUrl = (pilot) => {
        const direct = firstValue(pilot, ['avatarUrl', 'avatar_url', 'imageUrl', 'image', 'driver.avatarUrl', 'player.avatarUrl', 'pilot.avatarUrl']);
        if (direct) return String(direct);
        const id = firstValue(pilot, ['pilotId', 'playerId', 'driverId', 'id', 'player.id', 'driver.id']);
        if (id !== undefined && id !== null && id !== '') return `/api/pilot-avatar/${encodeURIComponent(String(id))}`;
        return '/images/pilot-avatar-default.png';
      };

      const probeImage = (src) => new Promise((resolve) => {
        const test = new Image();
        test.onload = () => resolve(src);
        test.onerror = () => resolve('');
        test.src = src;
      });

      const setTrackImage = async (trackName) => {
        const img = $('[data-home2-track-image]');
        if (!img || !trackName) return;

        if (window.GCTrackImages && typeof window.GCTrackImages.bestAsset === 'function') {
          try {
            const asset = window.GCTrackImages.bestAsset(trackName);
            if (asset && asset.url) {
              img.src = asset.url;
              return;
            }
          } catch (_) {}
        }

        const slug = slugify(trackName);
        const compact = slug.replace(/^rt_/, '').replace(/^mx_/, '').replace(/^nrms_/, '');
        const candidates = [
          `/images/tracks/${slug}.webp`,
          `/images/tracks/${compact}.webp`,
          `/images/tracks/${slug}.png`,
          `/images/tracks/${compact}.png`,
          `/images/tracks/${slug}.jpg`,
          `/images/tracks/${compact}.jpg`,
          `/imagenes/tracks/${slug}.webp`,
          `/imagenes/tracks/${compact}.webp`,
          `/imagenes/tracks/${slug}.png`,
          `/imagenes/tracks/${compact}.png`,
          '/ui/home2/gc-home2-track-fallback.svg'
        ];

        for (const candidate of candidates) {
          const ok = await probeImage(candidate);
          if (ok) {
            img.src = ok;
            return;
          }
        }
      };

      const setTrackMap = async (trackName) => {
        const img = $('[data-home2-track-map]');
        if (!img || !trackName) return;
        const slug = slugify(trackName);
        const compact = slug.replace(/^rt_/, '').replace(/^mx_/, '').replace(/^nrms_/, '');
        const candidates = [
          `/images/tracks/${slug}_mapa.png`,
          `/images/tracks/${compact}_mapa.png`,
          `/images/tracks/${slug}-mapa.png`,
          `/images/tracks/${compact}-mapa.png`,
          `/images/tracks/${slug}_map.png`,
          `/images/tracks/${compact}_map.png`,
          `/images/tracks/mapa_${slug}.png`,
          `/images/tracks/mapa_${compact}.png`,
          `/imagenes/tracks/${slug}_mapa.png`,
          `/imagenes/tracks/${compact}_mapa.png`,
          '/ui/home2/gc-home2-track-outline.svg'
        ];

        for (const candidate of candidates) {
          const ok = await probeImage(candidate);
          if (ok) {
            img.src = ok;
            return;
          }
        }
      };

      const renderRows = (selector, rows) => {
        const host = $(selector);
        if (!host) return;
        const cleanRows = rows.slice(0, 11);
        if (!cleanRows.length) return;
        host.innerHTML = cleanRows.map((lap) => {
          const driver = firstValue(lap, ['driverName', 'pilotName', 'playerName', 'name', 'driver.displayName', 'player.name']) || 'Piloto';
          const car = firstValue(lap, ['carName', 'car', 'carDisplayName', 'vehicle', 'car.displayName']) || 'Coche';
          const rawTime = firstValue(lap, ['lapTimeFormatted', 'bestLapTimeFormatted', 'timeFormatted', 'lapTime', 'lapMs', 'time', 'bestLap']);
          const agoText = firstValue(lap, ['ago', 'timeAgo', 'relativeTime', 'ageText']);
          const date = firstValidDate(lap, ['createdAt', 'created_at', 'date', 'timestamp', 'lapDate', 'lap_date', 'finishedAt', 'finished_at', 'updatedAt', 'updated_at']);
          const ago = agoText || (date ? formatAgo(date) : '--');
          return `<div class="gc-home2-table__row" role="row"><span>${driver}</span><span>${car}</span><strong>${formatLap(rawTime)}</strong><small>${ago}</small></div>`;
        }).join('');
      };

      const rankTimeValue = (row) => {
        const raw = firstValue(row, ['lapTimeMs', 'LapTime', 'lapMs', 'lapTime', 'time', 'bestLap', 'bestLapTime']);
        if (raw === undefined || raw === null || raw === '') return Number.POSITIVE_INFINITY;
        if (typeof raw === 'string' && raw.includes(':')) {
          const parts = raw.split(':');
          const minutes = Number(parts[0]) || 0;
          const seconds = Number(parts[1]) || 0;
          return (minutes * 60 + seconds) * 1000;
        }
        const num = Number(raw);
        if (!Number.isFinite(num) || num <= 0) return Number.POSITIVE_INFINITY;
        return num > 1000 ? num : num * 1000;
      };

      const rowTrackMatches = (row, trackName) => {
        if (!trackName) return true;
        const rowTrack = firstValue(row, ['trackName', 'trackDisplayName', 'trackVisibleName', 'track.name', 'track.displayName', 'Track', 'track']);
        if (!rowTrack) return true;
        const a = slugify(rowTrack).replace(/^(ks_|rt_|mx_|nrms_)/, '');
        const b = slugify(trackName).replace(/^(ks_|rt_|mx_|nrms_)/, '');
        return a.includes(b) || b.includes(a);
      };

      const rowCarMatches = (row, activeCars = []) => {
        if (!activeCars.length) return true;
        const rowCar = firstValue(row, ['carName', 'carDisplayName', 'carVisibleName', 'car.name', 'car.displayName', 'Car', 'car']);
        if (!rowCar) return true;
        const carSlug = slugify(rowCar);
        return activeCars.some((car) => {
          const wanted = slugify(car);
          return carSlug.includes(wanted) || wanted.includes(carSlug);
        });
      };

      const bestRowsForCombo = (rows, trackName = '', activeCars = []) => {
        const allRows = getArray(rows)
          .filter((row) => rankTimeValue(row) !== Number.POSITIVE_INFINITY)
          .filter((row) => rowTrackMatches(row, trackName))
          .filter((row) => rowCarMatches(row, activeCars));

        const byDriver = new Map();
        allRows.forEach((row) => {
          const driver = firstValue(row, ['driverName', 'pilotName', 'playerName', 'name', 'driver.displayName', 'player.name']) || 'Piloto';
          const key = slugify(driver);
          const current = byDriver.get(key);
          if (!current || rankTimeValue(row) < rankTimeValue(current)) byDriver.set(key, row);
        });

        return [...byDriver.values()].sort((a, b) => rankTimeValue(a) - rankTimeValue(b));
      };

      const syncBestFromRow = (row) => {
        if (!row) return;
        const driver = firstValue(row, ['driverName', 'pilotName', 'playerName', 'name', 'driver.displayName', 'player.name']) || 'Piloto';
        const car = firstValue(row, ['carName', 'car', 'carDisplayName', 'vehicle', 'car.displayName']) || 'Coche';
        const rawTime = firstValue(row, ['lapTimeFormatted', 'bestLapTimeFormatted', 'timeFormatted', 'lapTime', 'lapMs', 'time', 'bestLap', 'bestLapTime']);
        const bestTime = formatLap(rawTime);

        setText('[data-home2-best-driver]', driver);
        setText('[data-home2-best-car]', car);
        setText('[data-home2-best-time]', bestTime);
      };

      const comboRankBadge = (index) => {
        if (index === 0) return '<span class="gc-home2-rank-badge gc-home2-rank-badge--gold" aria-label="1º">🥇</span>';
        if (index === 1) return '<span class="gc-home2-rank-badge gc-home2-rank-badge--silver" aria-label="2º">🥈</span>';
        if (index === 2) return '<span class="gc-home2-rank-badge gc-home2-rank-badge--bronze" aria-label="3º">🥉</span>';
        return `<span class="gc-home2-rank-badge gc-home2-rank-badge--plain">${index + 1}</span>`;
      };

      const renderComboRanking = (rows, trackName = '', activeCars = []) => {
        const host = $('[data-home2-combo-ranking]');
        if (!host) return [];

        const cleanRows = bestRowsForCombo(rows, trackName, activeCars).slice(0, 10);

        if (!cleanRows.length) {
          host.innerHTML = '<div class="gc-home2-combo-rank gc-home2-combo-rank--empty"><div><strong>Sin ranking disponible</strong><small>Esperando datos del combo</small></div></div>';
          return [];
        }

        syncBestFromRow(cleanRows[0]);

        host.innerHTML = cleanRows.map((lap, index) => {
          const driver = firstValue(lap, ['driverName', 'pilotName', 'playerName', 'name', 'driver.displayName', 'player.name']) || 'Piloto';
          const car = firstValue(lap, ['carName', 'car', 'carDisplayName', 'vehicle', 'car.displayName']) || 'Coche';
          const rawTime = firstValue(lap, ['lapTimeFormatted', 'bestLapTimeFormatted', 'timeFormatted', 'lapTime', 'lapMs', 'time', 'bestLap', 'bestLapTime']);
          return `
            <div class="gc-home2-combo-rank ${index >= 3 ? 'gc-home2-combo-rank--compact' : ''}">
              ${comboRankBadge(index)}
              <div><strong>${driver}</strong><small>${car}</small></div>
              <em>${formatLap(rawTime)}</em>
            </div>
          `;
        }).join('');

        return cleanRows;
      };


      const numericValue = (value) => {
        if (typeof value === 'number' && Number.isFinite(value)) return value;
        if (typeof value === 'string' && value.trim() !== '') {
          const parsed = Number(value.replace(/[^\d.-]/g, ''));
          if (Number.isFinite(parsed)) return parsed;
        }
        return null;
      };

      const fetchJsonFirstWithSource = async (urls) => {
        for (const url of urls) {
          const payload = await fetchJson(url);
          if (payload) return { payload, url };
        }
        return { payload: null, url: '' };
      };

      const driverKeyFromLap = (lap) => {
        const driver =
          firstValue(lap, ['driverName', 'pilotName', 'playerName', 'name', 'driver.displayName', 'player.name', 'DriverName', 'steamName']) ||
          firstValue(lap, ['guid', 'steamGuid', 'driverGuid', 'playerGuid', 'DriverGuid']);
        return driver ? slugify(driver) : '';
      };

      const lapDateFromRow = (lap) => firstValidDate(lap, [
        'createdAt',
        'created_at',
        'date',
        'timestamp',
        'lapDate',
        'lap_date',
        'finishedAt',
        'finished_at',
        'updatedAt',
        'updated_at'
      ]);

      const countActiveDriversLastHour = async (fallbackRows = []) => {
        const { payload, url } = await fetchJsonFirstWithSource([
          '/api/gc/recent-laps?limit=1000&sort=recent&valid=all&since=1h',
          '/api/gc/recent-laps?limit=1000&sort=recent&valid=all&hours=1',
          '/api/laps?limit=1000&sort=recent&valid=all&since=1h',
          '/api/hotlaps?limit=1000&sort=recent&valid=all&since=1h',
          '/api/gc/recent-laps?limit=1000&sort=recent&valid=all',
          '/api/laps?limit=1000&sort=recent&valid=all',
          '/api/hotlaps?limit=1000&sort=recent&valid=all'
        ]);

        const rows = getArray(payload).length ? getArray(payload) : getArray(fallbackRows);
        const endpointClaimsLastHour = /since=1h|hours=1/.test(url);
        const cutoff = Date.now() - (60 * 60 * 1000);
        const drivers = new Set();

        rows.forEach((lap) => {
          const key = driverKeyFromLap(lap);
          if (!key) return;

          if (endpointClaimsLastHour) {
            drivers.add(key);
            return;
          }

          const date = lapDateFromRow(lap);
          if (date && date.getTime() >= cutoff) drivers.add(key);
        });

        return drivers.size;
      };

      const updateActiveDriversLastHour = async (fallbackRows = [], maxSlots = 32) => {
        const active = await countActiveDriversLastHour(fallbackRows);
        const value = `${active} / ${maxSlots || 32}`;
        setText('[data-home2-server-users]', value);
        setText('[data-home2-live-connections]', value);
        return active;
      };

      const updateServerAgeFromFirstLap = async (fallbackRows = []) => {
        const { payload } = await fetchJsonFirstWithSource([
          '/api/gc/recent-laps?limit=1&sort=oldest&valid=all',
          '/api/laps?limit=1&sort=oldest&valid=all',
          '/api/hotlaps?limit=1&sort=oldest',
          '/api/gc/recent-laps?limit=1000&sort=recent&valid=all',
          '/api/laps?limit=1000&sort=recent&valid=all',
          '/api/hotlaps?limit=1000&sort=recent&valid=all'
        ]);

        const rows = getArray(payload).length ? getArray(payload) : getArray(fallbackRows);
        const validDates = rows
          .map((row) => lapDateFromRow(row))
          .filter(Boolean)
          .sort((a, b) => a.getTime() - b.getTime());

        const startDate = validDates[0];
        if (!startDate) {
          setText('[data-home2-server-since]', '--');
          setText('[data-home2-first-lap]', '--');
          return;
        }

        const daysLive = Math.max(0, Math.floor((Date.now() - startDate.getTime()) / 86400000));
        setText('[data-home2-server-since]', `${daysLive} d`);
        setText('[data-home2-first-lap]', startDate.toLocaleDateString('es-ES'));
      };

      const renderNews = async () => {
        const data = await fetchJson('/data/home2-news.json');
        const items = getArray(data);
        const host = $('[data-home2-news]');
        if (!host || !items.length) return;
        host.innerHTML = items.slice(0, 4).map((item) => `
          <article class="gc-home2-news-card">
            <img src="${item.image || '/ui/home2/gc-home2-news-sim.svg'}" alt="" width="380" height="216" loading="lazy" decoding="async" />
            <div class="gc-home2-news-card__body">
              <span class="gc-home2-tag">${item.category || 'Paddock'}</span>
              <time>${item.date || item.publishedAt || ''}</time>
              <h3>${item.title || 'Noticia'}</h3>
              <p>${item.excerpt || ''}</p>
              <a href="${item.href || '/novedades'}" class="gc-home2-link">Leer más →</a>
            </div>
          </article>
        `).join('');
      };

      const renderArchive = async (activeTrack = '', activeCars = []) => {
        const endpoints = [
          '/api/archive/items.json?limit=100',
          '/api/archive/items.json?limit=100&status=published',
          '/api/archive/items.json?featured=1&limit=100',
          '/api/archive/items?limit=100',
          '/api/archive/items?featured=1&limit=100',
          '/api/archive',
          '/api/archivo',
          '/data/archive/items.json',
          '/data/app/motorsport-archive.json'
        ];

        let payload = null;
        let items = [];

        for (const endpoint of endpoints) {
          payload = await fetchJson(endpoint);
          items = getArray(payload);
          if (items.length) break;
        }

        const wanted = [activeTrack, ...activeCars].filter(Boolean).map((value) => slugify(value));
        const wantedWords = [activeTrack, ...activeCars].filter(Boolean).join(' ').toLowerCase();

        const visiblePool = items
          .filter((item) => {
            const status = String(firstValue(item, ['status', 'estado']) || 'published').toLowerCase();
            return !['draft', 'borrador', 'trash', 'deleted'].includes(status);
          })
          .map((item, index) => {
            const title = firstValue(item, ['title', 'nombre', 'name']) || '';
            const slug = firstValue(item, ['slug', 'seoSlug', 'seo_slug']) || '';
            const type = firstValue(item, ['tipo', 'type', 'category', 'categoria', 'kind']) || '';
            const text = `${title} ${slug} ${type}`.toLowerCase();
            const compact = slugify(`${title} ${slug} ${type}`);

            let score = 0;
            wanted.forEach((needle) => {
              if (!needle) return;
              if (compact.includes(needle) || needle.includes(compact)) score += 100;
              const shortNeedle = needle.replace(/^(ks_|rt_|mx_|nrms_)/, '');
              if (shortNeedle && compact.includes(shortNeedle)) score += 80;
            });

            // Prefer one circuit, then combo cars, then any featured/public card.
            const normalizedType = normalizeArchiveType(type);
            if (activeTrack && ['circuitos', 'tracks'].includes(normalizedType) && compact.includes(slugify(activeTrack).replace(/^(ks_|rt_|mx_|nrms_)/, ''))) score += 60;
            if (String(firstValue(item, ['featured', 'destacado', 'isFeatured', 'is_featured'])).toLowerCase() === 'true') score += 20;
            score += Math.max(0, 10 - index);

            return { item, score, index };
          })
          .sort((a, b) => b.score - a.score || a.index - b.index);

        // Keep the active combo feeling: if Mugello exists anywhere, it should surface.
        const visible = visiblePool.slice(0, 3).map((entry) => entry.item);

        const host = $('[data-home2-archive]');
        if (!host || !visible.length) return;

        host.innerHTML = visible.map((item, index) => {
          const title = firstValue(item, ['title', 'nombre', 'name']) || 'Ficha';
          const type = firstValue(item, ['tipo', 'type', 'category', 'categoria', 'kind']) || 'Archivo';
          const summary = firstValue(item, ['descripcion_corta', 'summary', 'description', 'descripcion', 'subtitle', 'subtitulo']) || 'Ficha técnica e histórica.';
          const image = archiveImage(item, index);
          const finalHref = archiveHref(item);
          return `
            <a class="gc-home2-archive-card" href="${finalHref}">
              <img src="${image}" alt="" width="340" height="190" loading="lazy" decoding="async" />
              <span class="gc-home2-archive-card__tag">${type}</span>
              <strong>${title}</strong>
              <small>${summary}</small>
              <em>Ver ficha →</em>
            </a>
          `;
        }).join('');
      };

      const fetchText = async (url) => {
        try {
          const res = await fetch(url, { headers: { Accept: 'text/html,application/xhtml+xml' } });
          if (!res.ok) return '';
          return await res.text();
        } catch (_) {
          return '';
        }
      };

      const textNumberNear = (text, labels) => {
        const clean = String(text || '').replace(/\s+/g, ' ');
        for (const label of labels) {
          const re1 = new RegExp(`${label}[^0-9]{0,40}(\\d+)`, 'i');
          const re2 = new RegExp(`(\\d+)[^A-Za-zÁÉÍÓÚáéíóúÑñ]{0,20}${label}`, 'i');
          const m = clean.match(re1) || clean.match(re2);
          if (m && m[1]) return m[1];
        }
        return '';
      };

      const renderChampionshipFromPage = async () => {
        const html = await fetchText('/campeonato');
        if (!html) return false;

        const doc = new DOMParser().parseFromString(html, 'text/html');
        const bodyText = doc.body ? doc.body.innerText : html.replace(/<[^>]+>/g, ' ');
        const titleNode =
          doc.querySelector('h1') ||
          doc.querySelector('[data-acsm-title]') ||
          doc.querySelector('[data-championship-title]');

        const title = titleNode ? titleNode.textContent.trim() : 'Campeonato ACSM';
        const events = textNumberNear(bodyText, ['Eventos', 'Rondas', 'Carreras']);
        const entrants = textNumberNear(bodyText, ['Pilotos inscritos', 'Inscritos', 'Participantes', 'Drivers']);
        const classes = textNumberNear(bodyText, ['Clases', 'Categorías', 'Categories']);
        const nextNode =
          doc.querySelector('[data-next-event]') ||
          doc.querySelector('.next-event') ||
          doc.querySelector('.gc-champ-next') ||
          Array.from(doc.querySelectorAll('h2,h3,strong')).find((node) => /próximo|proximo|next|evento/i.test(node.textContent || ''));

        setText('[data-home2-champ-name]', title || 'Campeonato ACSM');
        setText('[data-home2-champ-events]', events || '--');
        setText('[data-home2-champ-upcoming]', bodyText.match(/próxim/i) ? 'Sí' : '--');
        setText('[data-home2-champ-entrants]', entrants || '--');
        setText('[data-home2-champ-classes]', classes || '--');
        setText('[data-home2-champ-next]', nextNode ? nextNode.textContent.trim().slice(0, 80) : 'Ver campeonato activo');
        setText('[data-home2-champ-next-meta]', 'Datos desde /campeonato');

        return true;
      };

      const renderChampionshipDrivers = (drivers = []) => {
        const host = $('[data-home2-champ-drivers]');
        if (!host) return;

        const list = Array.isArray(drivers) ? drivers : [];
        if (!list.length) {
          host.innerHTML = '<div><strong>Sin inscritos visibles</strong><small>ACSM</small></div>';
          return;
        }

        host.innerHTML = list.slice(0, 8).map((driver, index) => {
          const name = firstValue(driver, ['name', 'driverName', 'displayName', 'steamName', 'Name']) || `Piloto ${index + 1}`;
          const klass = firstValue(driver, ['className', 'class', 'ClassName']) || 'General';
          const car = firstValue(driver, ['model', 'car', 'carName', 'vehicle']) || '';
          return `<div><span>${index + 1}</span><strong>${name}</strong><small>${[klass, car].filter(Boolean).join(' · ')}</small></div>`;
        }).join('');
      };

      const renderChampionship = async () => {
        const payload =
          await fetchJson('/api/community/acsr-championship') ||
          await fetchJson('/api/community/acsr-championship?refresh=1') ||
          await fetchJson('/api/acsm/championship') ||
          await fetchJson('/api/campeonato');

        const box = $('[data-home2-championship]');
        if (!box || !payload || payload.ok === false || !payload.championship) {
          renderChampionshipDrivers([]);
          return;
        }

        const championship = payload.championship;
        const next = championship.nextEvent || null;
        const events = Array.isArray(championship.events) ? championship.events : [];
        const standings = Array.isArray(championship.standings) ? championship.standings : [];
        const drivers = Array.isArray(championship.registeredDrivers) ? championship.registeredDrivers : [];
        const stats = championship.stats || {};

        setText('[data-home2-champ-name]', championship.name || 'Campeonato ACSM');
        setText('[data-home2-champ-events]', stats.events ?? events.length ?? '--');
        setText('[data-home2-champ-completed]', stats.completedEvents ?? '--');
        setText('[data-home2-champ-classes]', stats.classes ?? '--');
        setText('[data-home2-champ-entrants]', stats.entrants ?? drivers.length ?? standings.length ?? '--');

        if (next) {
          const track = firstValue(next, ['track', 'trackName']);
          const carSummary = firstValue(next, ['carSummary']);
          setText('[data-home2-champ-next]', next.name || `Ronda ${next.index || ''}`.trim() || 'Próxima ronda');
          setText('[data-home2-champ-next-meta]', [track, carSummary].filter(Boolean).join(' · ') || 'Próxima sesión');
        } else {
          setText('[data-home2-champ-next]', 'Calendario activo');
          setText('[data-home2-champ-next-meta]', 'Ver próximas sesiones');
        }

        renderChampionshipDrivers(drivers.length ? drivers : standings);
      };

      const init = async () => {
        const now = new Date();
        setText('[data-home2-updated]', `ACTUALIZADO ${now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}`);

        const diagnostics = await fetchJson('/api/gc/diagnostics') || await fetchJson('/api/status') || await fetchJson('/api/stats/overview');
        const combosPayload = await fetchJson('/api/gc/combos?limit=1&sort=recent') || await fetchJson('/api/combos/stats?limit=1&sort=recent') || await fetchJson('/api/combos?limit=1&sort=recent');
        const recentPayload = await fetchJson('/api/gc/recent-laps?limit=20&sort=recent&valid=all') || await fetchJson('/api/laps?limit=20&sort=recent&valid=all') || await fetchJson('/api/hotlaps?limit=20');
        const leaderboardPayload =
          await fetchJson('/api/gc/leaderboard?scope=activeCombo&limit=25') ||
          await fetchJson('/api/gc/leaderboard?scope=currentCombo&limit=25') ||
          await fetchJson('/api/gc/leaderboard?scope=all&limit=200') ||
          await fetchJson('/api/gc/recent-laps?limit=200&sort=recent&valid=all') ||
          await fetchJson('/api/hotlaps?limit=200');

        const raceData = diagnostics && (diagnostics.raceData || diagnostics.stats || diagnostics);
        if (raceData) {
          const totalLaps = firstValue(raceData, ['lapsCount', 'validLapsCount', 'totalLaps', 'hotlaps']);
          const drivers = firstValue(raceData, ['driversCount', 'pilotsCount', 'totalDrivers', 'pilots']);
          const active = diagnostics && (diagnostics.health === 'ok' || diagnostics.ok);
          setText('[data-home2-live]', active ? 'LIVE' : 'STATUS');
          setText('[data-home2-server-state]', active ? 'Online' : 'Revisar');
          if (drivers) setText('[data-home2-drivers]', drivers);
          if (totalLaps) setText('[data-home2-laps]', totalLaps);
        }

        const combo = getArray(combosPayload)[0] || combosPayload?.activeCombo || combosPayload?.combo || {};
        const track = firstValue(combo, ['canonicalTrackName', 'trackName', 'track', 'circuitName', 'name']) || 'Mugello';
        const cars = firstValue(combo, ['publicComboCars', 'carNames', 'cars', 'mainVariantAllCars']);
        const carList = Array.isArray(cars) ? cars.map((car) => typeof car === 'string' ? car : firstValue(car, ['name', 'carName', 'displayName'])).filter(Boolean) : String(cars || 'BMW M3 GT2 / Ferrari F430 GT2').split(',').map((s) => s.trim()).filter(Boolean);
        const totalComboLaps = firstValue(combo, ['totalLaps', 'validLaps', 'lapsCount', 'summary.totalLaps']);
        const comboDrivers = firstValue(combo, ['driversCount', 'pilotsCount', 'summary.driversCount']);
        const bestDriver = firstValue(combo, ['bestDriverName', 'bestPilotName', 'leaderboard.0.driverName', 'best.driverName']) || 'Nandy';
        const bestCar = firstValue(combo, ['bestCarName', 'best.carName', 'leaderboard.0.carName']) || carList[0] || 'BMW M3 GT2';
        const bestTime = formatLap(firstValue(combo, ['bestLapTimeFormatted', 'bestLapFormatted', 'bestLapTime', 'bestLap', 'best.time', 'leaderboard.0.lapTime'])) || '1:50.264';

        setText('[data-home2-track]', track);
        setText('[data-home2-now-title]', track);
        const inferredCountry = inferTrackCountry(track, combo) || '--';
        setText('[data-home2-track-country]', inferredCountry);
        setText('[data-home2-now-country]', inferredCountry);
        setText('[data-home2-cars]', carList.slice(0, 3).join(' / '));
        setText('[data-home2-now-cars]', String(carList.length || '--'));
        setText('[data-home2-best-driver]', bestDriver);
        setText('[data-home2-reference-driver]', bestDriver);
        setText('[data-home2-best-car]', bestCar);
        setText('[data-home2-reference-car]', bestCar);
        setText('[data-home2-best-time]', bestTime);
        setText('[data-home2-reference-time]', bestTime);
        if (totalComboLaps) setText('[data-home2-laps]', totalComboLaps);
        if (comboDrivers) setText('[data-home2-drivers]', comboDrivers);

        const bestAvatar = pilotAvatarUrl(combo.best || combo.leaderboard?.[0] || combo);
        $$('[data-home2-best-avatar], [data-home2-reference-avatar]').forEach((img) => img.src = bestAvatar);

        await setTrackImage(track);
        await setTrackMap(track);

        const champTrackImage = $('[data-home2-champ-track-image]');
        const heroTrackImage = $('[data-home2-track-image]');
        if (champTrackImage && heroTrackImage) {
          champTrackImage.src = heroTrackImage.currentSrc || heroTrackImage.src;
        }
        renderRows('[data-home2-recent-laps]', getArray(recentPayload));

        await updateServerAgeFromFirstLap(getArray(recentPayload));
        await updateActiveDriversLastHour(getArray(recentPayload), 32);


        const boardCandidates = [
          ...getArray(leaderboardPayload),
          ...getArray(combo.leaderboard),
          ...getArray(combo.bestLaps),
          ...getArray(combo.laps),
          ...getArray(recentPayload)
        ];

        renderComboRanking(boardCandidates, track, carList);

        await Promise.all([
          renderChampionship(),
          renderNews(),
          renderArchive(track, carList)
        ]);
      };

      init();
    })();
  </script>
</MarketingLayout>

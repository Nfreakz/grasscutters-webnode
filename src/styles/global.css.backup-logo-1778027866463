:root{
  color-scheme:dark;
  --bg:#061008;
  --bg2:#0a170c;
  --panel:#0e1d11;
  --panel2:#142418;
  --line:rgba(255,255,255,.10);
  --line2:rgba(255,255,255,.18);
  --text:#f4fff1;
  --soft:#c8dcc7;
  --dim:#748b75;
  --muted:#405342;
  --accent:#9dff00;
  --accent2:#35d3ff;
  --ok:#9dff00;
  --warn:#ffd166;
  --danger:#ff5872;
  --rail:292px;
  --top:66px;
  --container:1540px;
  --shadow:0 20px 80px rgba(0,0,0,.32);
}

:root[data-theme=grass]{--bg:#061008;--bg2:#0a170c;--panel:#0e1d11;--panel2:#142418;--accent:#7dff72;--accent2:#00d084}
:root[data-theme=ocean]{--bg:#041014;--bg2:#071923;--panel:#0c2028;--panel2:#132c35;--accent:#31d8ff;--accent2:#00ffb3}
:root[data-theme=violet]{--bg:#0c0816;--bg2:#141024;--panel:#1a142f;--panel2:#221a3f;--accent:#ad7cff;--accent2:#72d2ff}
:root[data-theme=amber]{--bg:#100b05;--bg2:#171006;--panel:#1b140a;--panel2:#261b0d;--accent:#ffb23e;--accent2:#ffe066}
:root[data-theme=crimson]{--bg:#12070b;--bg2:#1a0c11;--panel:#211016;--panel2:#301620;--accent:#ff5872;--accent2:#ffb84d}
:root[data-theme=mono]{--bg:#080808;--bg2:#101010;--panel:#151515;--panel2:#202020;--accent:#f2f2f2;--accent2:#aaa}

*{box-sizing:border-box}
html,body{margin:0;min-height:100%}
html{scroll-behavior:smooth}
body{
  background:
    linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px),
    linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),
    radial-gradient(circle at 78% -10%,color-mix(in srgb,var(--accent) 18%,transparent),transparent 30%),
    radial-gradient(circle at 18% 12%,color-mix(in srgb,var(--accent2) 10%,transparent),transparent 28%),
    linear-gradient(180deg,var(--bg2),var(--bg) 360px,var(--bg));
  background-size:28px 28px,28px 28px,auto,auto,auto;
  color:var(--text);
  font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
  line-height:1.55;
  overflow-x:hidden;
}
body::after{
  content:"";
  position:fixed;
  inset:0;
  pointer-events:none;
  background:linear-gradient(180deg,transparent,rgba(0,0,0,.16));
  z-index:-1;
}
a{color:inherit;text-decoration:none}
button,input,select{font:inherit}
button{cursor:pointer}
::selection{background:color-mix(in srgb,var(--accent) 35%,transparent);color:var(--text)}
:focus-visible{outline:2px solid var(--accent);outline-offset:3px}

.gc-sr{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
.gc-skip{position:fixed;top:10px;left:10px;z-index:1000;background:var(--accent);color:#061018;padding:10px 14px;font-weight:950;transform:translateY(-140%)}
.gc-skip:focus{transform:translateY(0)}

.gc-shell{display:grid;grid-template-columns:var(--rail) 1fr;min-height:100vh;position:relative}
.gc-shell::before{content:"";position:fixed;top:0;left:var(--rail);width:1px;height:100vh;background:linear-gradient(180deg,transparent,var(--accent),transparent);opacity:.36;z-index:30;pointer-events:none}
.gc-app{min-width:0}

.gc-rail{
  position:sticky;
  top:0;
  height:100vh;
  border-right:1px solid var(--line);
  background:linear-gradient(180deg,rgba(255,255,255,.045),rgba(255,255,255,.012)),rgba(0,0,0,.28);
  backdrop-filter:blur(14px);
  padding:22px;
  display:flex;
  flex-direction:column;
  gap:22px;
  box-shadow:var(--shadow);
  z-index:40;
}
.gc-brand{display:flex;gap:12px;align-items:center;padding-bottom:22px;border-bottom:1px solid var(--line)}
.gc-brand__mark{width:48px;height:48px;display:grid;place-items:center;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#061018;font-weight:1000;letter-spacing:-.08em;box-shadow:0 0 34px color-mix(in srgb,var(--accent) 18%,transparent)}
.gc-brand__copy{display:grid;line-height:1.05}
.gc-brand__copy strong{text-transform:uppercase;font-weight:950;letter-spacing:.02em}
.gc-brand__copy small{color:var(--dim);font-size:.78rem}

.gc-railnav{display:grid;gap:4px}
.gc-railnav a{display:grid;grid-template-columns:34px 1fr;align-items:center;gap:10px;padding:12px 11px;color:var(--soft);border-left:2px solid transparent;text-transform:uppercase;letter-spacing:.08em;font-size:.82rem;font-weight:850;background:transparent;transition:background .16s ease,color .16s ease,border-color .16s ease,transform .16s ease}
.gc-railnav a span{font-size:.72rem;color:var(--dim);font-weight:900;letter-spacing:.04em}
.gc-railnav a:hover,.gc-railnav a[aria-current=page]{background:rgba(255,255,255,.052);color:var(--text);border-left-color:var(--accent);transform:translateX(3px)}
.gc-railnav a[aria-current=page] span{color:var(--accent)}

.gc-rail__system{border-top:1px solid var(--line2);border-bottom:1px solid var(--line);padding:14px 0;display:grid;gap:8px}
.gc-rail__system-title{font-size:.72rem;text-transform:uppercase;letter-spacing:.13em;color:var(--dim);font-weight:950;margin-bottom:4px}
.gc-rail__system-row{display:grid;grid-template-columns:1fr auto;gap:10px;font-size:.82rem;color:var(--soft)}
.gc-rail__system-row strong{color:var(--text);text-transform:uppercase;letter-spacing:.08em;font-size:.72rem}
.gc-rail__footer{margin-top:auto;color:var(--dim);font-size:.78rem;text-transform:uppercase;letter-spacing:.08em;display:flex;gap:9px;align-items:center}
.gc-live-dot{width:8px;height:8px;background:var(--ok);box-shadow:0 0 16px var(--ok);display:inline-block;flex:0 0 auto}

.gc-nav-backdrop{display:none}

.gc-topbar{height:var(--top);position:sticky;top:0;z-index:25;border-bottom:1px solid var(--line);background:color-mix(in srgb,var(--bg) 88%,transparent);backdrop-filter:blur(14px);display:flex;align-items:center;justify-content:space-between;gap:18px;padding:0 22px}
.gc-menu-button{display:none;background:transparent;color:var(--text);border:1px solid var(--line);height:40px;width:44px;padding:9px}
.gc-menu-button span{display:block;height:2px;background:var(--text);margin:4px 0}
.gc-topbar__left,.gc-topbar__right,.gc-topnav{display:flex;align-items:center;gap:12px}
.gc-topbar__kicker{color:var(--dim);text-transform:uppercase;letter-spacing:.11em;font-size:.75rem;font-weight:850}
.gc-topnav a{color:var(--soft);font-size:.78rem;text-transform:uppercase;letter-spacing:.1em;font-weight:850;padding:24px 2px;border-bottom:2px solid transparent}
.gc-topnav a:hover{color:var(--accent);border-bottom-color:var(--accent)}
.gc-top-status{height:36px;display:flex;gap:8px;align-items:center;color:var(--soft);border:1px solid var(--line);padding:0 12px;text-transform:uppercase;font-size:.72rem;letter-spacing:.1em;font-weight:900;background:rgba(255,255,255,.018)}
.gc-login-link{height:36px;padding:0 13px;display:inline-flex;align-items:center;border:1px solid var(--line2);font-size:.78rem;text-transform:uppercase;letter-spacing:.08em;font-weight:900;background:rgba(255,255,255,.018)}
.gc-login-link:hover{border-color:var(--accent);color:var(--accent)}

.gc-theme{display:flex;gap:9px;align-items:center;border:1px solid var(--line);height:36px;padding:0 9px;background:rgba(255,255,255,.018)}
.gc-theme__label{font-size:.68rem;text-transform:uppercase;letter-spacing:.12em;color:var(--dim);font-weight:950}
.gc-theme__grid{display:flex;gap:7px;align-items:center}
.gc-theme__swatch{position:relative;width:16px;height:16px;border:1px solid var(--line2);background:#777;padding:0;box-shadow:inset 0 0 0 1px rgba(0,0,0,.25)}
.gc-theme__swatch[aria-pressed=true]{outline:2px solid var(--text);outline-offset:2px}
.gc-theme__swatch--lfm{background:linear-gradient(135deg,#9dff00,#35d3ff)}
.gc-theme__swatch--grass{background:linear-gradient(135deg,#7dff72,#00d084)}
.gc-theme__swatch--ocean{background:linear-gradient(135deg,#31d8ff,#00ffb3)}
.gc-theme__swatch--violet{background:linear-gradient(135deg,#ad7cff,#72d2ff)}
.gc-theme__swatch--amber{background:linear-gradient(135deg,#ffb23e,#ffe066)}
.gc-theme__swatch--crimson{background:linear-gradient(135deg,#ff5872,#ffb84d)}
.gc-theme__swatch--mono{background:linear-gradient(135deg,#fff,#777)}

.gc-main{width:min(100%,var(--container));margin:0 auto;padding:34px 30px 74px}
.gc-page{display:grid;gap:30px}

.gc-hero{display:grid;grid-template-columns:minmax(0,1.35fr) 390px;gap:30px;align-items:end;padding:30px 0 36px;border-bottom:1px solid var(--line2);position:relative}
.gc-hero::after{content:"";position:absolute;left:0;bottom:-1px;width:120px;height:1px;background:var(--accent);box-shadow:0 0 18px var(--accent)}
.gc-hero--compact{padding-top:18px}
.gc-kicker{color:var(--accent);text-transform:uppercase;letter-spacing:.14em;font-size:.78rem;font-weight:950}
.gc-title{font-size:clamp(2.45rem,5vw,5.8rem);line-height:.92;letter-spacing:-.075em;margin:10px 0 12px;text-transform:uppercase;max-width:1080px;text-wrap:balance}
.gc-subtitle{max-width:82ch;color:var(--soft);font-size:1.03rem;margin:0}
.gc-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}
.gc-hero__meta{display:flex;gap:8px;flex-wrap:wrap;margin-top:18px}

.gc-chip,.gc-badge{display:inline-flex;align-items:center;gap:8px;border:1px solid var(--line);padding:7px 10px;background:rgba(255,255,255,.018);color:var(--soft);text-transform:uppercase;letter-spacing:.08em;font-size:.72rem;font-weight:900}
.gc-chip strong,.gc-badge strong{color:var(--text)}
.gc-chip--accent{border-color:color-mix(in srgb,var(--accent) 42%,var(--line));color:var(--accent)}
.gc-chip--danger{border-color:color-mix(in srgb,var(--danger) 50%,var(--line));color:var(--danger)}
.gc-chip--warn{border-color:color-mix(in srgb,var(--warn) 50%,var(--line));color:var(--warn)}

.gc-btn{height:44px;padding:0 15px;border:1px solid var(--line2);display:inline-flex;align-items:center;justify-content:center;text-transform:uppercase;font-size:.78rem;letter-spacing:.08em;font-weight:900;background:rgba(255,255,255,.012);color:var(--text);transition:filter .15s ease,border-color .15s ease,color .15s ease,background .15s ease}
.gc-btn:hover{border-color:var(--accent);color:var(--accent);background:rgba(255,255,255,.035)}
.gc-btn--primary{background:linear-gradient(135deg,var(--accent),var(--accent2));border-color:transparent;color:#061018;box-shadow:0 0 28px color-mix(in srgb,var(--accent) 16%,transparent)}
.gc-btn--primary:hover{color:#061018;filter:brightness(1.08)}
.gc-btn--ghost{border-color:var(--line);color:var(--soft)}
.gc-btn[disabled]{opacity:.42;cursor:not-allowed}

.gc-live-panel{border-top:2px solid var(--accent);border-bottom:1px solid var(--line2);background:linear-gradient(180deg,rgba(255,255,255,.048),rgba(255,255,255,.014));padding:18px 0;box-shadow:0 18px 70px rgba(0,0,0,.18)}
.gc-live-panel__title{display:flex;justify-content:space-between;gap:12px;color:var(--dim);text-transform:uppercase;letter-spacing:.1em;font-size:.76rem;font-weight:950;margin-bottom:12px}
.gc-live-panel__title strong{color:var(--accent)}
.gc-status-list{display:grid}
.gc-status-row,.gc-data-row{display:grid;grid-template-columns:1fr auto;gap:12px;align-items:center;padding:11px 0;border-top:1px solid var(--line)}
.gc-status-row:first-child,.gc-data-row:first-child{border-top:0}
.gc-status-row span:first-child,.gc-data-row span:first-child{color:var(--soft)}
.gc-status-row strong,.gc-data-row strong{color:var(--text);text-align:right}

.gc-metrics{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));border-top:1px solid var(--line2);border-bottom:1px solid var(--line2);background:rgba(255,255,255,.018);position:relative}
.gc-metric{padding:18px;border-right:1px solid var(--line);min-width:0}
.gc-metric:last-child{border-right:0}
.gc-metric span{display:block;color:var(--dim);text-transform:uppercase;letter-spacing:.1em;font-size:.72rem;font-weight:950;margin-bottom:9px}
.gc-metric strong{display:block;font-size:clamp(1.45rem,2.4vw,2.55rem);letter-spacing:-.055em;line-height:1;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.gc-metric strong.is-accent{color:var(--accent)}
.gc-metric small{display:block;color:var(--muted);margin-top:8px;font-size:.78rem;text-transform:uppercase;letter-spacing:.08em}

.gc-command-strip{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));border-top:1px solid var(--line2);border-bottom:1px solid var(--line2);background:linear-gradient(90deg,rgba(255,255,255,.024),rgba(255,255,255,.008))}
.gc-command-item{padding:16px 18px;border-right:1px solid var(--line)}
.gc-command-item:last-child{border-right:0}
.gc-command-item span{display:block;color:var(--dim);font-size:.7rem;text-transform:uppercase;letter-spacing:.12em;font-weight:950;margin-bottom:6px}
.gc-command-item strong{display:block;font-size:1rem;text-transform:uppercase;letter-spacing:-.02em}
.gc-command-item p{margin:5px 0 0;color:var(--soft);font-size:.9rem}

.gc-section{display:grid;gap:14px;min-width:0}
.gc-section-head{display:flex;align-items:end;justify-content:space-between;gap:16px;border-bottom:1px solid var(--line2);padding-bottom:10px}
.gc-section-head h2{font-size:1.25rem;text-transform:uppercase;letter-spacing:-.035em;margin:0}
.gc-section-head p{margin:0;color:var(--dim);font-size:.9rem;text-align:right}
.gc-grid-2{display:grid;grid-template-columns:minmax(0,1fr) 390px;gap:28px;align-items:start}
.gc-grid-3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:22px}

.gc-row-list{border-top:1px solid var(--line2);border-bottom:1px solid var(--line2)}
.gc-row-link{display:grid;grid-template-columns:74px 1fr auto;gap:18px;align-items:center;padding:20px 0;border-top:1px solid var(--line);transition:background .15s ease,padding-left .15s ease}
.gc-row-link:first-child{border-top:0}
.gc-row-link:hover{background:rgba(255,255,255,.02);padding-left:10px}
.gc-row-link:hover .gc-row-link__title{color:var(--accent)}
.gc-row-link__num{font-size:1.5rem;font-weight:950;color:var(--dim);letter-spacing:-.06em}
.gc-row-link__title{text-transform:uppercase;font-size:clamp(1.2rem,1.85vw,1.92rem);font-weight:950;letter-spacing:-.06em;line-height:1.03}
.gc-row-link__desc{color:var(--soft);font-size:.95rem;margin-top:3px}
.gc-row-link__cta{color:var(--accent);text-transform:uppercase;letter-spacing:.1em;font-size:.78rem;font-weight:950;white-space:nowrap}

.gc-panel-flat,.gc-slab{border-top:2px solid var(--accent);border-bottom:1px solid var(--line2);padding:18px 0;background:rgba(255,255,255,.012);min-width:0}
.gc-panel-flat h3,.gc-slab h3{margin:0 0 12px;text-transform:uppercase;letter-spacing:-.035em;font-size:1.05rem}
.gc-slab p{color:var(--soft);margin:0 0 12px}
.gc-slab-list{display:grid;border-top:1px solid var(--line);margin-top:10px}
.gc-slab-list div{display:grid;grid-template-columns:1fr auto;gap:12px;padding:10px 0;border-bottom:1px solid var(--line);color:var(--soft)}
.gc-slab-list strong{color:var(--text);text-align:right}

.gc-table-wrap{border-top:1px solid var(--line2);border-bottom:1px solid var(--line2);overflow:auto;max-width:100%;background:rgba(255,255,255,.012)}
table.gc-table{width:100%;min-width:850px;border-collapse:collapse}
table.gc-table.gc-table--compact{min-width:620px}
table.gc-table th,table.gc-table td{padding:13px 12px;border-bottom:1px solid var(--line);text-align:left;vertical-align:middle}
table.gc-table th{position:sticky;top:0;z-index:2;color:var(--dim);font-size:.72rem;text-transform:uppercase;letter-spacing:.11em;font-weight:950;background:color-mix(in srgb,var(--panel) 84%,#000);white-space:nowrap}
table.gc-table td{color:var(--soft)}
table.gc-table td strong{color:var(--text)}
table.gc-table tbody tr:hover td{background:rgba(255,255,255,.03);color:var(--text)}
.gc-table-meta{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:10px 0;color:var(--dim);font-size:.82rem;text-transform:uppercase;letter-spacing:.08em;font-weight:900}

.gc-toolbar{display:flex;gap:10px;flex-wrap:wrap;padding:14px 0;border-top:1px solid var(--line2);border-bottom:1px solid var(--line2);align-items:end}
.gc-field{display:grid;gap:8px;min-width:180px;flex:1 1 190px}
.gc-field label{color:var(--dim);text-transform:uppercase;letter-spacing:.1em;font-size:.72rem;font-weight:950}
.gc-input,.gc-select,input,select{height:42px;background:var(--panel2);color:var(--text);border:1px solid var(--line);padding:0 12px;border-radius:0;min-width:0}
.gc-input::placeholder{color:color-mix(in srgb,var(--dim) 80%,transparent)}
.gc-input:focus,.gc-select:focus,input:focus,select:focus{border-color:var(--accent);outline:0;box-shadow:0 0 0 2px color-mix(in srgb,var(--accent) 18%,transparent)}

.gc-form{display:grid;gap:14px;border-top:2px solid var(--accent);border-bottom:1px solid var(--line2);padding:18px 0;background:rgba(255,255,255,.012)}
.gc-form h2{margin:0;text-transform:uppercase;letter-spacing:-.035em}
.gc-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:26px;align-items:start}
.gc-message{color:var(--soft);min-height:24px;margin:0}
.gc-empty{color:var(--dim);padding:16px 0}
.gc-note{color:var(--dim);font-size:.9rem}
.gc-small{font-size:.82rem;color:var(--dim)}
.gc-profile-grid{display:grid;grid-template-columns:360px 1fr;gap:28px;align-items:start}
.gc-login-hint{display:grid;gap:10px;border-top:1px solid var(--line2);border-bottom:1px solid var(--line);padding:15px 0;color:var(--soft)}

.gc-timeline{border-top:1px solid var(--line2);border-bottom:1px solid var(--line2)}
.gc-timeline__item{display:grid;grid-template-columns:70px 1fr;gap:16px;padding:15px 0;border-top:1px solid var(--line)}
.gc-timeline__item:first-child{border-top:0}
.gc-timeline__item span{color:var(--dim);font-weight:950;letter-spacing:-.04em}
.gc-timeline__item strong{display:block;text-transform:uppercase;letter-spacing:-.02em}
.gc-timeline__item p{margin:4px 0 0;color:var(--soft)}

@media(max-width:1180px){
  .gc-shell{grid-template-columns:1fr}
  .gc-shell::before{display:none}
  .gc-rail{position:fixed;z-index:50;transform:translateX(-105%);transition:transform .2s ease;width:300px;max-width:86vw}
  .gc-nav-open .gc-rail{transform:translateX(0)}
  .gc-nav-open .gc-nav-backdrop{display:block;position:fixed;inset:0;background:rgba(0,0,0,.58);backdrop-filter:blur(3px);z-index:45}
  .gc-menu-button{display:block}
  .gc-hero,.gc-grid-2,.gc-profile-grid{grid-template-columns:1fr}
  .gc-topnav{display:none}
  .gc-main{padding:26px 20px 64px}
}

@media(max-width:820px){
  .gc-topbar{padding:0 14px}
  .gc-topbar__kicker,.gc-top-status,.gc-theme__label{display:none}
  .gc-title{font-size:clamp(2.1rem,13vw,4.2rem)}
  .gc-metrics{grid-template-columns:1fr 1fr}
  .gc-command-strip,.gc-grid-3{grid-template-columns:1fr}
  .gc-command-item{border-right:0;border-bottom:1px solid var(--line)}
  .gc-command-item:last-child{border-bottom:0}
  .gc-row-link{grid-template-columns:48px 1fr;gap:14px}
  .gc-row-link__cta{grid-column:2}
  .gc-form-grid{grid-template-columns:1fr}
  .gc-theme{padding:0 8px}
  .gc-theme__grid{gap:6px}
}

@media(max-width:560px){
  .gc-topbar__right{gap:8px}
  .gc-login-link{padding:0 10px}
  .gc-theme{display:none}
  .gc-metrics{grid-template-columns:1fr}
  .gc-metric{border-right:0;border-bottom:1px solid var(--line)}
  .gc-metric:last-child{border-bottom:0}
  .gc-hero{gap:20px;padding-bottom:28px}
  .gc-main{padding-inline:15px}
  .gc-toolbar{display:grid}
  .gc-field{min-width:0}
}

/* Admin console */
.gc-admin-page .gc-form p.gc-admin-note{margin:0;color:var(--soft)}
.gc-message{min-height:1.3em;color:var(--soft);font-size:.9rem;margin:0}
.gc-admin-actions{display:flex;gap:7px;flex-wrap:wrap}
.gc-btn--mini{height:32px;padding:0 9px;font-size:.66rem;letter-spacing:.06em}
.gc-muted-text{color:var(--dim);font-size:.83rem}
.gc-row-list--compact .gc-row-link{grid-template-columns:44px 1fr auto;padding:12px 0;gap:12px}
.gc-row-list--compact .gc-row-link__title{font-size:1rem;letter-spacing:-.03em}
.gc-row-list--compact .gc-row-link__desc{font-size:.84rem}
.gc-row-list--compact .gc-row-link__num{font-size:1rem}

@media (max-width:760px){
  .gc-admin-actions{display:grid;grid-template-columns:1fr;gap:6px}
  .gc-btn--mini{width:100%}
}

---
import '../styles/global.css';

import '../styles/app-no-grid.css';
import '../styles/auth-header-status.css';
import '../styles/palette-unify-v7.css';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import AuthHeader from '../components/AuthHeader.astro';

const {
  title = 'GrassCutters Platform',
  description = 'GrassCutters Racing Platform'
} = Astro.props;

const normalizePath = (path) => {
  if (!path || path === '/') return '/';
  return path.replace(/\/$/, '');
};

const current = normalizePath(Astro.url.pathname);
const nav = [
  { href: '/app', label: 'Panel', code: '01' },
  { href: '/hotlaps', label: 'Hotlaps', code: '02' },
  { href: '/pilotos', label: 'Pilotos', code: '03' },
  { href: '/combos', label: 'Combos', code: '04' },
  {
    label: 'Herramientas',
    code: '05',
    children: [
      { href: '/herramientas/fov', label: 'FOV Calculator', code: '05.1' }
    ]
  },
  { href: '/perfil', label: 'Perfil', code: '06' },
  { href: '/admin', label: 'Admin', code: '07', adminOnly: true }
];
---
<!doctype html>
<html lang="es" data-theme="grasscutters" data-auth-ready="false" data-auth="unknown" data-admin="false">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07110a" />
    <title>{title}</title>
    <style is:inline>
      .gc-backtop,
      .gc-back-top,
      .gc-back-to-top,
      .gc-scroll-top,
      .gc-scrolltop,
      .gc-top-button,
      [data-backtop],
      [data-back-top],
      [data-back-to-top],
      [data-scroll-top],
      [aria-label*="Volver"],
      [aria-label*="volver"],
      [aria-label*="Back to top"],
      [aria-label*="back to top"],
      [title*="Volver"],
      [title*="volver"],
      [title*="Back to top"],
      [title*="back to top"]{
        position:fixed !important;
        top:auto !important;
        left:auto !important;
        right:max(18px, env(safe-area-inset-right)) !important;
        bottom:max(18px, env(safe-area-inset-bottom)) !important;
        z-index:80 !important;
      }


      .gc-railnav__group{
        display:grid;
        gap:4px;
      }

      .gc-railnav__parent{
        width:100%;
        appearance:none;
        -webkit-appearance:none;
        display:grid;
        grid-template-columns:36px minmax(0,1fr) auto;
        align-items:center;
        gap:12px;
        min-height:48px;
        padding:0 14px;
        border:1px solid transparent;
        background:transparent!important;
        color:var(--text);
        text-align:left;
        font:inherit;
        cursor:pointer;
        text-transform:uppercase;
        letter-spacing:.08em;
      }

      .gc-railnav__parent:hover{
        border-color:color-mix(in srgb,var(--accent) 22%,transparent);
        background:rgba(255,255,255,.018)!important;
      }

      .gc-railnav__parent span{
        color:var(--muted);
        font-size:.72rem;
        font-weight:950;
        letter-spacing:.06em;
      }

      .gc-railnav__parent strong{
        color:var(--text);
        font-size:.94rem;
        font-weight:950;
        min-width:0;
      }

      .gc-railnav__parent em{
        color:var(--muted);
        font-style:normal;
        transition:transform .16s ease,color .16s ease;
      }

      .gc-railnav__group.is-open .gc-railnav__parent{
        background:transparent!important;
        border-color:transparent;
      }

      .gc-railnav__group.is-open .gc-railnav__parent em{
        transform:rotate(180deg);
        color:var(--accent);
      }

      .gc-railnav__children{
        display:none;
        gap:4px;
        margin-left:0;
        padding-left:18px;
        border-left:0;
      }

      .gc-railnav__group.is-open .gc-railnav__children{
        display:grid;
      }

      .gc-railnav .gc-railnav__child{
        min-height:36px;
        padding-block:8px;
        opacity:.88;
      }

      .gc-railnav .gc-railnav__child span{
        font-size:.66rem;
      }

      .gc-railnav .gc-railnav__child strong{
        font-size:.86rem;
      }

      .gc-railnav .gc-railnav__child[aria-current="page"]{
        opacity:1;
      }

      @media(max-width:720px){
        .gc-backtop,
        .gc-back-top,
        .gc-back-to-top,
        .gc-scroll-top,
        .gc-scrolltop,
        .gc-top-button,
        [data-backtop],
        [data-back-top],
        [data-back-to-top],
        [data-scroll-top],
        [aria-label*="Volver"],
        [aria-label*="volver"],
        [aria-label*="Back to top"],
        [aria-label*="back to top"],
        [title*="Volver"],
        [title*="volver"],
        [title*="Back to top"],
        [title*="back to top"]{
          right:14px !important;
          bottom:14px !important;
        }
      }
    
      /* v7.0 palette-aware rail + safer back-to-top */
      .gc-floating-scrolltop,
      .gc-backtop,
      .gc-back-top,
      .gc-back-to-top,
      .gc-scroll-top,
      .gc-scrolltop,
      .gc-top-button,
      [data-backtop],
      [data-back-top],
      [data-back-to-top],
      [data-scroll-top],
      [aria-label*="Volver"],
      [aria-label*="volver"],
      [aria-label*="Back to top"],
      [aria-label*="back to top"],
      [title*="Volver"],
      [title*="volver"],
      [title*="Back to top"],
      [title*="back to top"]{
        bottom:max(70px, env(safe-area-inset-bottom)) !important;
      }

      .gc-rail{
        background:
          radial-gradient(circle at 50% 0%, color-mix(in srgb,var(--gc-sidebar-palette-edge,var(--accent,#9dff00)) 10%, transparent), transparent 22rem),
          linear-gradient(180deg,var(--gc-sidebar-palette-bg,var(--bg,#061008)),var(--gc-sidebar-palette-bg2,var(--bg2,#0a170c)))!important;
      }


      /* v7.1 stronger palette hooks for sidebar and app cursor */
      html[data-theme="grasscutters"] .gc-rail{--gc-side-bg:#061008;--gc-side-bg2:#0a170c;--gc-side-accent:#9dff00;--gc-side-accent2:#35d3ff;}
      html[data-theme="ocean"] .gc-rail{--gc-side-bg:#041014;--gc-side-bg2:#071923;--gc-side-accent:#31d8ff;--gc-side-accent2:#00ffb3;}
      html[data-theme="violet"] .gc-rail{--gc-side-bg:#0c0816;--gc-side-bg2:#141024;--gc-side-accent:#ad7cff;--gc-side-accent2:#72d2ff;}
      html[data-theme="amber"] .gc-rail{--gc-side-bg:#100b05;--gc-side-bg2:#171006;--gc-side-accent:#ffb23e;--gc-side-accent2:#ffe066;}
      html[data-theme="crimson"] .gc-rail{--gc-side-bg:#12070b;--gc-side-bg2:#1a0c11;--gc-side-accent:#ff5872;--gc-side-accent2:#ffb84d;}
      html[data-theme="mono"] .gc-rail{--gc-side-bg:#080908;--gc-side-bg2:#111312;--gc-side-accent:#d7dad5;--gc-side-accent2:#8c948e;}

      .gc-rail{
        background:
          radial-gradient(circle at 50% 0%, color-mix(in srgb,var(--gc-side-accent,var(--accent,#9dff00)) 15%, transparent), transparent 24rem),
          linear-gradient(180deg,var(--gc-side-bg,var(--bg,#061008)),var(--gc-side-bg2,var(--bg2,#0a170c)))!important;
        border-right-color:color-mix(in srgb,var(--gc-side-accent,var(--accent,#9dff00)) 32%, transparent)!important;
      }

      .gc-rail a[aria-current="page"],
      .gc-railnav__child[aria-current="page"],
      .gc-railnav__group.is-open .gc-railnav__parent{
        border-left-color:var(--gc-side-accent,var(--accent,#9dff00))!important;
      }

      .gc-live-dot{
        background:var(--gc-side-accent,var(--accent,#9dff00))!important;
        box-shadow:0 0 18px color-mix(in srgb,var(--gc-side-accent,var(--accent,#9dff00)) 55%, transparent)!important;
      }

      html[data-theme="grasscutters"]{--gc-cursor-accent:#9dff00;--gc-cursor-accent2:#35d3ff;}
      html[data-theme="ocean"]{--gc-cursor-accent:#31d8ff;--gc-cursor-accent2:#00ffb3;}
      html[data-theme="violet"]{--gc-cursor-accent:#ad7cff;--gc-cursor-accent2:#72d2ff;}
      html[data-theme="amber"]{--gc-cursor-accent:#ffb23e;--gc-cursor-accent2:#ffe066;}
      html[data-theme="crimson"]{--gc-cursor-accent:#ff5872;--gc-cursor-accent2:#ffb84d;}
      html[data-theme="mono"]{--gc-cursor-accent:#d7dad5;--gc-cursor-accent2:#8c948e;}

      .gc-cursor,
      .gc-custom-cursor,
      .custom-cursor,
      .cursor-dot,
      .cursor-ring,
      .mouse-cursor,
      .mouse-dot,
      [data-cursor],
      [data-cursor-dot],
      [data-custom-cursor]{
        border-color:var(--gc-cursor-accent,var(--accent,#9dff00))!important;
        color:var(--gc-cursor-accent,var(--accent,#9dff00))!important;
        box-shadow:0 0 24px color-mix(in srgb,var(--gc-cursor-accent,var(--accent,#9dff00)) 45%, transparent)!important;
      }

      .gc-cursor-core,
      .cursor-core,
      [data-cursor-core]{
        background:linear-gradient(135deg,var(--gc-cursor-accent,var(--accent,#9dff00)),var(--gc-cursor-accent2,var(--accent2,#35d3ff)))!important;
      }

      .gc-floating-scrolltop,
      .gc-backtop,
      .gc-back-top,
      .gc-back-to-top,
      .gc-scroll-top,
      .gc-scrolltop,
      .gc-top-button,
      [data-backtop],
      [data-back-top],
      [data-back-to-top],
      [data-scroll-top],
      [aria-label*="Volver"],
      [aria-label*="volver"],
      [title*="Volver"],
      [title*="volver"]{
        bottom:clamp(126px,13vh,190px)!important;
      }

</style>
  </head>
  <body>
    <a class="gc-skip" href="#contenido">Saltar al contenido</a>
    <div class="gc-shell">
      <div class="gc-nav-backdrop" data-menu-close></div>

      <aside class="gc-rail" aria-label="Panel lateral GrassCutters">
        <a class="gc-brand" href="/" aria-label="Ir a la home pública de GrassCutters Racing" title="Ir a la home pública">
          <span class="gc-brand__mark gc-brand__mark--logo"><img src="/images/newlogo.png" alt="" loading="eager" /></span>
          <span class="gc-brand__copy">
            <strong>GrassCutters</strong>
            <small>Racing Platform</small>
          </span>
        </a>

        <nav class="gc-railnav" aria-label="Navegación principal">
          {nav.map((item) => (
            item.children ? (
              <div
                class:list={['gc-railnav__group', item.children.some((child) => current === child.href) ? 'is-open' : '']}
                data-nav-group
                data-admin-only={item.adminOnly ? 'true' : undefined}
                hidden={item.adminOnly ? true : undefined}
                aria-hidden={item.adminOnly ? 'true' : undefined}
              >
                <button
                  class="gc-railnav__parent"
                  type="button"
                  aria-expanded={item.children.some((child) => current === child.href) ? 'true' : 'false'}
                  data-nav-group-toggle
                >
                  <span>{item.code}</span>
                  <strong>{item.label}</strong>
                  <em aria-hidden="true">▾</em>
                </button>
                <div class="gc-railnav__children" data-nav-group-panel>
                  {item.children.map((child) => (
                    <a
                      class="gc-railnav__child"
                      href={child.href}
                      aria-current={current === child.href ? 'page' : undefined}
                    >
                      <span>{child.code}</span>
                      <strong>{child.label}</strong>
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a
                href={item.href}
                aria-current={current === item.href ? 'page' : undefined}
                data-admin-only={item.adminOnly ? 'true' : undefined}
                hidden={item.adminOnly ? true : undefined}
                aria-hidden={item.adminOnly ? 'true' : undefined}
              >
                <span>{item.code}</span>
                <strong>{item.label}</strong>
              </a>
            )
          ))}
        </nav>

        <div class="gc-rail__system">
          <div class="gc-rail__system-title">Sistema</div>
          <div class="gc-rail__system-row"><span>Web</span><strong>Astro</strong></div>
          <div class="gc-rail__system-row"><span>API</span><strong>Node</strong></div>
          <div class="gc-rail__system-row"><span>DB</span><strong>stracker</strong></div>
        </div>

        <div class="gc-rail__footer">
          <span class="gc-live-dot"></span>
          <span>GTX sync monitor</span>
        </div>
      </aside>

      <div class="gc-app">
        <header class="gc-topbar">
          <div class="gc-topbar__left">
            <button class="gc-menu-button" type="button" aria-label="Abrir navegación" aria-expanded="false" data-menu-toggle>
              <span></span><span></span><span></span>
            </button>
            <span class="gc-topbar__kicker">GrassCutters Node Platform</span>
          </div>

          <div class="gc-topbar__right">
            <div class="gc-top-status" aria-label="Estado rápido">
              <span class="gc-live-dot"></span>
              <span>Live</span>
            </div>
            <ThemeSwitcher />
            <span class="gc-auth-status" data-auth-status hidden>Conectado</span>
            <a class="gc-login-link" href="/login" data-auth-link>Login</a>
            <button class="gc-auth-logout" type="button" data-auth-logout hidden>Salir</button>
          </div>
        </header>

        <main class="gc-main" id="contenido">
          <slot />
        </main>
      </div>
    </div>

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const btn = document.querySelector('[data-menu-toggle]');
        const closeTargets = document.querySelectorAll('[data-menu-close], .gc-railnav a');
        const setOpen = (open) => {
          root.classList.toggle('gc-nav-open', open);
          btn?.setAttribute('aria-expanded', String(open));
        };
        btn?.addEventListener('click', () => setOpen(!root.classList.contains('gc-nav-open')));
        closeTargets.forEach((el) => el.addEventListener('click', () => setOpen(false)));

        document.querySelectorAll('[data-nav-group]').forEach((group) => {
          const toggle = group.querySelector('[data-nav-group-toggle]');
          const panel = group.querySelector('[data-nav-group-panel]');
          if (!toggle || !panel) return;

          toggle.addEventListener('click', () => {
            const isOpen = group.classList.toggle('is-open');
            toggle.setAttribute('aria-expanded', String(isOpen));
          });
        });

        window.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') setOpen(false);
        });
      })();
    </script>
    <AuthHeader />
  </body>
</html>

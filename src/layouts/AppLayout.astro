---
import '../styles/global.css';
import '../styles/app-no-grid.css';
import '../styles/auth-header-status.css';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';

const {
  title = 'GrassCutters Platform',
  description = 'GrassCutters Racing Platform'
} = Astro.props;

const normalizePath = (path) => {
  if (!path || path === '/') return '/';
  return path.replace(/\/$/, '');
};

const current = normalizePath(Astro.url.pathname);
const nav = [
  { href: '/app', label: 'Panel', code: '00' },
  { href: '/hotlaps', label: 'Hotlaps', code: '01' },
  { href: '/pilotos', label: 'Pilotos', code: '02' },
  { href: '/combos', label: 'Combos', code: '03' },
  { href: '/tracker', label: 'Tracker', code: '04' },
  { href: '/herramientas', label: 'Herramientas', code: '05' },
  { href: '/perfil', label: 'Perfil', code: '06' },
  { href: '/admin', label: 'Admin', code: '07' }
];
---
<!doctype html>
<html lang="es" data-theme="grasscutters">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07110a" />
    <title>{title}</title>
  </head>
  <body>
    <a class="gc-skip" href="#contenido">Saltar al contenido</a>
    <div class="gc-shell">
      <div class="gc-nav-backdrop" data-menu-close></div>

      <aside class="gc-rail" aria-label="Panel lateral GrassCutters">
        <a class="gc-brand" href="/app" aria-label="GrassCutters Racing Platform">
          <span class="gc-brand__mark">GC</span>
          <span class="gc-brand__copy">
            <strong>GrassCutters</strong>
            <small>Racing Platform</small>
          </span>
        </a>

        <nav class="gc-railnav" aria-label="Navegación principal">
          {nav.map((item) => (
            <a href={item.href} aria-current={current === item.href ? 'page' : undefined}>
              <span>{item.code}</span>
              <strong>{item.label}</strong>
            </a>
          ))}
        </nav>

        <div class="gc-rail__system">
          <div class="gc-rail__system-title">Sistema</div>
          <div class="gc-rail__system-row"><span>Web</span><strong>Astro</strong></div>
          <div class="gc-rail__system-row"><span>API</span><strong>Node</strong></div>
          <div class="gc-rail__system-row"><span>DB</span><strong>stracker</strong></div>
        </div>

        <div class="gc-rail__footer">
          <span class="gc-live-dot"></span>
          <span>GTX sync monitor</span>
        </div>
      </aside>

      <div class="gc-app">
        <header class="gc-topbar">
          <div class="gc-topbar__left">
            <button class="gc-menu-button" type="button" aria-label="Abrir navegación" aria-expanded="false" data-menu-toggle>
              <span></span><span></span><span></span>
            </button>
            <span class="gc-topbar__kicker">GrassCutters Node Platform</span>
          </div>

          <nav class="gc-topnav" aria-label="Navegación superior">
            <a href="/">Landing</a>
            <a href="/hotlaps">Hotlaps</a>
            <a href="/combos">Combos</a>
            <a href="/pilotos">Pilotos</a>
            <a href="/perfil">Mi perfil</a>
            <a href="/admin">Admin</a>
          </nav>

          <div class="gc-topbar__right">
            <div class="gc-top-status" aria-label="Estado rápido">
              <span class="gc-live-dot"></span>
              <span>Live</span>
            </div>
            <ThemeSwitcher />
            <span class="gc-auth-status" data-auth-status hidden>Conectado</span>
            <a class="gc-login-link" href="/login" data-auth-link>Login</a>
          </div>
        </header>

        <main class="gc-main" id="contenido">
          <slot />
        </main>
      </div>
    </div>

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const btn = document.querySelector('[data-menu-toggle]');
        const closeTargets = document.querySelectorAll('[data-menu-close], .gc-railnav a');
        const setOpen = (open) => {
          root.classList.toggle('gc-nav-open', open);
          btn?.setAttribute('aria-expanded', String(open));
        };
        btn?.addEventListener('click', () => setOpen(!root.classList.contains('gc-nav-open')));
        closeTargets.forEach((el) => el.addEventListener('click', () => setOpen(false)));
        window.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') setOpen(false);
        });
      })();

      (() => {

        const updateAuthHeader = () => {
          const headerRoots = Array.from(document.querySelectorAll('.gc-public-header, .gc-topbar, header'));
          const isInHeader = (el) => headerRoots.some((root) => root && root.contains(el));
          const statusItems = Array.from(document.querySelectorAll('[data-auth-status], [data-auth-state]')).filter(isInHeader);
          const loginLinks = Array.from(document.querySelectorAll('[data-auth-link], [data-login-link], a[href="/login"], a[href="/login/"]'))
            .filter((link) => isInHeader(link));

          const readUser = (data) => (
            data?.user ||
            data?.currentUser ||
            data?.account ||
            data?.session?.user ||
            data?.auth?.user ||
            data?.profile ||
            null
          );

          const readName = (user, data) => {
            const raw = user?.displayName || user?.display_name || user?.name || user?.username || user?.email || data?.email || '';
            return String(raw || '').trim() || 'Mi perfil';
          };

          fetch('/api/auth/status', { cache: 'no-store', credentials: 'include' })
            .then((res) => res.ok ? res.json() : null)
            .then((data) => {
              const user = readUser(data);
              const authenticated = data?.authenticated === true || data?.ok === true && Boolean(user) || Boolean(user?.id || user?.email || user?.displayName || user?.display_name || user?.name);
              if (!authenticated) {
                document.documentElement.dataset.auth = 'false';
                return;
              }

              const name = readName(user, data);
              document.documentElement.dataset.auth = 'true';

              statusItems.forEach((item) => {
                item.hidden = false;
                item.textContent = 'Conectado';
                item.setAttribute('title', `Conectado como ${name}`);
              });

              loginLinks.forEach((link) => {
                link.textContent = name;
                link.setAttribute('href', '/perfil');
                link.setAttribute('title', 'Abrir mi perfil');
                link.setAttribute('aria-label', `Abrir perfil de ${name}`);
                link.classList.add('is-authenticated');
                link.removeAttribute('data-login-link');
                link.setAttribute('data-auth-profile-link', 'true');
              });

              // Red de seguridad: si algún enlace de Login queda en el header sin selector,
              // también se convierte. Evita que aparezcan “Conectado” y “Login” a la vez.
              headerRoots.forEach((root) => {
                root.querySelectorAll('a').forEach((link) => {
                  const text = String(link.textContent || '').trim().toLowerCase();
                  const href = link.getAttribute('href') || '';
                  if (text === 'login' || href === '/login' || href === '/login/') {
                    link.textContent = name;
                    link.setAttribute('href', '/perfil');
                    link.setAttribute('title', 'Abrir mi perfil');
                    link.classList.add('is-authenticated');
                    link.setAttribute('data-auth-profile-link', 'true');
                  }
                });
              });
            })
            .catch(() => {
              document.documentElement.dataset.auth = 'unknown';
            });
        };

        updateAuthHeader();
      })();

    </script>
  </body>
</html>

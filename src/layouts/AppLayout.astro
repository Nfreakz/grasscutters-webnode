---
import '../styles/global.css';
import '../styles/app-no-grid.css';
import '../styles/auth-header-status.css';
import '../styles/palette-unify-v7.css';
import '../styles/app-glow-tune-v103.css';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import PaletteCursor from '../components/PaletteCursor.astro';
import AuthHeader from '../components/AuthHeader.astro';
import PilotAvatarSystem from '../components/PilotAvatarSystem.astro';
import AppVisualPass from '../components/AppVisualPass.astro';

const {
  title = 'GrassCutters Platform',
  description = 'GrassCutters Racing Platform',
  canonicalPath,
  ogImage,
  ogImageAlt,
  ogType = 'website',
  noindex,
} = Astro.props;

const siteUrl = (import.meta.env.PUBLIC_SITE_URL || Astro.site?.toString() || Astro.url.origin || 'https://grasscuttersracing.com').replace(/\/$/, '');
const normalizePath = (path) => {
  if (!path || path === '/') return '/';
  return path.replace(/\/$/, '');
};
const currentPathForSeo = normalizePath(Astro.url.pathname);
const canonicalUrl = new URL(canonicalPath || Astro.url.pathname, siteUrl).toString();

const pageOgImages = {
  '/app': '/og/platform-og-v1531.png',
  '/hotlaps': '/og/hotlaps-og-v1531.png',
  '/combos': '/og/combos-og-v1531.png',
  '/pilotos': '/og/pilotos-og-v1531.png',
  '/perfil': '/og/perfil-og.png',
  '/login': '/og/login-og-v1531.png',
  '/herramientas/fov': '/og/fov-og-v1531.png',
  '/admin': '/og/admin-og.png',
};

/* GC_GLOBAL_SOCIAL_META_V15_31 START */
const routeSocialMeta = {
  '/app': {
    title: 'Panel | GrassCutters Racing',
    description: 'Panel de pista de GrassCutters Racing con combo activo, actividad reciente, hotlaps y accesos principales.',
    image: '/og/platform-og-v1531.png',
    imageAlt: 'Panel GrassCutters Racing',
  },
  '/hotlaps': {
    title: 'Hotlaps | GrassCutters Racing',
    description: 'Leaderboard de GrassCutters Racing con tiempos de referencia, filtros por piloto, coche, circuito y vueltas válidas.',
    image: '/og/hotlaps-og-v1531.png',
    imageAlt: 'Hotlaps GrassCutters Racing',
  },
  '/combos': {
    title: 'Combos | GrassCutters Racing',
    description: 'Centro de combos de GrassCutters Racing con circuitos, coches, actividad real y referencias para decidir dónde rodar.',
    image: '/og/combos-og-v1531.png',
    imageAlt: 'Combos GrassCutters Racing',
  },
  '/pilotos': {
    title: 'Pilotos | GrassCutters Racing',
    description: 'Directorio de pilotos de GrassCutters Racing con perfiles públicos, actividad reciente y datos desde stracker.',
    image: '/og/pilotos-og-v1531.png',
    imageAlt: 'Pilotos GrassCutters Racing',
  },
  '/herramientas/fov': {
    title: 'FOV Calculator | GrassCutters Racing',
    description: 'Calculadora de FOV para ajustar la visión del cockpit y mejorar la referencia en pista.',
    image: '/og/fov-og-v1531.png',
    imageAlt: 'FOV Calculator GrassCutters Racing',
  },
  '/login': {
    title: 'Login | GrassCutters Racing',
    description: 'Acceso a la plataforma GrassCutters Racing.',
    image: '/og/login-og-v1531.png',
    imageAlt: 'Login GrassCutters Racing',
  },
};

const exactRouteSocialMeta = routeSocialMeta[currentPathForSeo];

function resolveSeoText(value, fallback = '') {
  const text = compactSeoText(value, '');
  const generic = ['grasscutters racing platform', 'grasscutters platform', ''];
  if (generic.includes(text.toLowerCase())) return compactSeoText(fallback, text || fallback);
  return text || compactSeoText(fallback, '');
}
/* GC_GLOBAL_SOCIAL_META_V15_31 END */

function compactSeoText(value, fallback = '') {
  return String(value || fallback || '')
    .replace(/<[^>]*>/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, 220);
}

function absoluteSeoUrl(value) {
  const raw = String(value || '').trim();
  if (!raw) return new URL('/og/platform-og-v1531.png', siteUrl).toString();
  if (/^https?:\/\//i.test(raw)) return raw;
  return new URL(raw.startsWith('/') ? raw : '/' + raw, siteUrl).toString();
}

function seoImageMime(value) {
  const clean = String(value || '').split('?')[0].toLowerCase();
  if (clean.endsWith('.jpg') || clean.endsWith('.jpeg')) return 'image/jpeg';
  if (clean.endsWith('.webp')) return 'image/webp';
  if (clean.endsWith('.svg')) return 'image/svg+xml';
  return 'image/png';
}

const cleanTitle = resolveSeoText(title, exactRouteSocialMeta?.title || 'GrassCutters Platform');
const cleanDescription = resolveSeoText(description, exactRouteSocialMeta?.description || 'Panel de pista, hotlaps, combos y perfiles de GrassCutters Racing.');
const matchedOgImage = pageOgImages[currentPathForSeo] || Object.entries(pageOgImages).find(([prefix]) => currentPathForSeo.startsWith(prefix + '/'))?.[1];
const selectedOgImage = ogImage || exactRouteSocialMeta?.image || matchedOgImage || '/og/platform-og-v1531.png';
const absoluteOgImage = absoluteSeoUrl(selectedOgImage);
const cleanOgImageAlt = compactSeoText(ogImageAlt, exactRouteSocialMeta?.imageAlt || 'Imagen social de ' + cleanTitle);
const ogImageType = seoImageMime(selectedOgImage);
const shouldNoindex = noindex ?? (currentPathForSeo.startsWith('/admin') || currentPathForSeo.startsWith('/perfil'));


const current = normalizePath(Astro.url.pathname);
const nav = [
  { href: '/app', label: 'Panel', code: '01' },
  { href: '/hotlaps', label: 'Hotlaps', code: '02' },
  { href: '/pilotos', label: 'Pilotos', code: '03' },
  { href: '/combos', label: 'Combos', code: '04' },
  {
    label: 'Herramientas',
    code: '05',
    children: [
      { href: '/herramientas/fov', label: 'FOV Calculator', code: '05.1' }
    ]
  },
  { href: '/perfil', label: 'Perfil', code: '06' },
  { href: '/admin', label: 'Admin', code: '07', adminOnly: true }
];
---
<!doctype html>
<html lang="es" data-theme="grasscutters" data-gc-scope="app" data-auth-ready="false" data-auth="unknown" data-admin="false">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={cleanDescription} />
    <meta name="robots" content={shouldNoindex ? 'noindex,nofollow' : 'index,follow'} />
    <meta name="theme-color" content="#07110a" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:site_name" content="GrassCutters Racing" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={cleanTitle} />
    <meta property="og:description" content={cleanDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:secure_url" content={absoluteOgImage} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={cleanOgImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={cleanTitle} />
    <meta name="twitter:description" content={cleanDescription} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:image:alt" content={cleanOgImageAlt} />
    <meta name="twitter:url" content={canonicalUrl} />

    <title>{cleanTitle}</title>
  </head>
  <body>
    <a class="gc-skip" href="#contenido">Saltar al contenido</a>
    <div class="gc-shell">
      <div class="gc-nav-backdrop" data-menu-close></div>

      <aside class="gc-rail" aria-label="Panel lateral GrassCutters">
        <a class="gc-brand" href="/" aria-label="Ir a la home pública de GrassCutters Racing" title="Ir a la home pública">
          <span class="gc-brand__mark gc-brand__mark--logo"><img src="/images/newlogo.png" alt="" loading="eager" /></span>
          <span class="gc-brand__copy">
            <strong>GrassCutters</strong>
            <small>Racing Platform</small>
          </span>
        </a>

        <nav class="gc-railnav" aria-label="Navegación principal">
          {nav.map((item) => (
            item.children ? (
              <div class:list={['gc-railnav__group', { 'is-open': item.children.some((child) => normalizePath(child.href) === current) }]} data-nav-group>
                <button
                  class="gc-railnav__parent"
                  type="button"
                  aria-expanded={item.children.some((child) => normalizePath(child.href) === current) ? 'true' : 'false'}
                  data-nav-group-toggle>
                  <span>{item.code}</span>
                  <strong>{item.label}</strong>
                  <em>▾</em>
                </button>
                <div class="gc-railnav__children" data-nav-group-panel>
                  {item.children.map((child) => (
                    <a href={child.href} class="gc-railnav__child" aria-current={normalizePath(child.href) === current ? 'page' : undefined}>
                      <span>{child.code}</span>
                      <strong>{child.label}</strong>
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a href={item.href} aria-current={normalizePath(item.href) === current ? 'page' : undefined} data-admin-only={item.adminOnly ? '' : undefined} hidden={item.adminOnly ? true : undefined}>
                <span>{item.code}</span>
                <strong>{item.label}</strong>
              </a>
            )
          ))}
        </nav>

        <div class="gc-railmeta">
          <h3>Sistema</h3>
          <dl>
            <div><dt>Web</dt><dd>Astro</dd></div>
            <div><dt>API</dt><dd>Node</dd></div>
            <div><dt>DB</dt><dd>Stracker</dd></div>
          </dl>
        </div>
      </aside>

      <div class="gc-app">
        <header class="gc-topbar">
          <div class="gc-topbar__left">
            <button class="gc-menu-button" type="button" aria-label="Abrir navegación" aria-expanded="false" data-menu-toggle>
              <span></span><span></span><span></span>
            </button>
            <span class="gc-topbar__kicker">GrassCutters Node Platform</span>
          </div>

          <div class="gc-topbar__right">
            <div class="gc-top-status" aria-label="Estado rápido">
              <span class="gc-live-dot"></span>
              <span>Live</span>
            </div>
            <ThemeSwitcher />
            <span class="gc-auth-status" data-auth-status hidden>Conectado</span>
            <a class="gc-login-link" href="/login" data-auth-link>Login</a>
            <button class="gc-auth-logout" type="button" data-auth-logout hidden>Salir</button>
          </div>
        </header>

        <main class="gc-main" id="contenido">
          <slot />
        </main>
      </div>
    </div>

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const btn = document.querySelector('[data-menu-toggle]');
        const closeTargets = document.querySelectorAll('[data-menu-close], .gc-railnav a');
        const setOpen = (open) => {
          root.classList.toggle('gc-nav-open', open);
          btn?.setAttribute('aria-expanded', String(open));
        };
        btn?.addEventListener('click', () => setOpen(!root.classList.contains('gc-nav-open')));
        closeTargets.forEach((el) => el.addEventListener('click', () => setOpen(false)));

        document.querySelectorAll('[data-nav-group]').forEach((group) => {
          const toggle = group.querySelector('[data-nav-group-toggle]');
          const panel = group.querySelector('[data-nav-group-panel]');
          if (!toggle || !panel) return;

          toggle.addEventListener('click', () => {
            const isOpen = group.classList.toggle('is-open');
            toggle.setAttribute('aria-expanded', String(isOpen));
          });
        });

        window.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') setOpen(false);
        });
      })();
    </script>
    <PaletteCursor />
    <PilotAvatarSystem />
    <AppVisualPass />
    <AuthHeader />
  </body>
</html>

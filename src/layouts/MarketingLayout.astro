---
import '../styles/marketing.css';
const {
  title = 'GrassCutters Racing',
  description = 'Comunidad sim racing, datos reales y plataforma de pilotos.'
} = Astro.props;
---
<!doctype html>
<html lang="es" data-theme="lfm">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#061008" />
    <title>{title}</title>
  </head>
  <body class="gc-marketing-body">
    <header class="mk-header">
      <a class="mk-brand" href="/" aria-label="GrassCutters Racing">
        <span class="mk-brand__mark">GC</span>
        <span><strong>GrassCutters</strong><small>Racing Community</small></span>
      </a>
      <nav class="mk-nav" aria-label="Navegación landing">
        <a href="#comunidad">Comunidad</a>
        <a href="#datos">Datos</a>
        <a href="#pilotos">Pilotos</a>
        <a href="/discord">Discord</a>
      </nav>
      <div class="mk-actions">
        <a class="mk-link" href="/login">Login</a>
        <a class="mk-btn mk-btn--primary" href="/app">Entrar a la plataforma</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mk-footer">
      <div>
        <strong>GrassCutters Racing</strong>
        <span>Astro + Node + stracker + Discord</span>
      </div>
      <a href="/app">Abrir plataforma</a>
    </footer>

    <script is:inline>
      (() => {
        const stored = localStorage.getItem('gc-theme');
        if (stored) document.documentElement.setAttribute('data-theme', stored);
      })();
    </script>
  </body>
</html>

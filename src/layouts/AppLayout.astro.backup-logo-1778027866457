---
import '../styles/global.css';
import '../styles/app-no-grid.css';
import '../styles/auth-header-status.css';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import AuthHeader from '../components/AuthHeader.astro';

const {
  title = 'GrassCutters Platform',
  description = 'GrassCutters Racing Platform'
} = Astro.props;

const normalizePath = (path) => {
  if (!path || path === '/') return '/';
  return path.replace(/\/$/, '');
};

const current = normalizePath(Astro.url.pathname);
const nav = [
  { href: '/', label: 'Inicio', code: '00' },
  { href: '/app', label: 'Panel', code: '01' },
  { href: '/hotlaps', label: 'Hotlaps', code: '02' },
  { href: '/pilotos', label: 'Pilotos', code: '03' },
  { href: '/combos', label: 'Combos', code: '04' },
  { href: '/calendario', label: 'Calendario', code: '05' },
  { href: '/herramientas', label: 'Herramientas', code: '06' },
  { href: '/perfil', label: 'Perfil', code: '07' },
  { href: '/admin', label: 'Admin', code: '08', adminOnly: true },
  { href: '/admin/calendario', label: 'Calendario admin', code: '09', adminOnly: true }
];
---
<!doctype html>
<html lang="es" data-theme="grasscutters" data-auth-ready="false" data-auth="unknown" data-admin="false">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07110a" />
    <title>{title}</title>
    <style is:inline>
      .gc-backtop,
      .gc-back-top,
      .gc-back-to-top,
      .gc-scroll-top,
      .gc-scrolltop,
      .gc-top-button,
      [data-backtop],
      [data-back-top],
      [data-back-to-top],
      [data-scroll-top],
      [aria-label*="Volver"],
      [aria-label*="volver"],
      [aria-label*="Back to top"],
      [aria-label*="back to top"],
      [title*="Volver"],
      [title*="volver"],
      [title*="Back to top"],
      [title*="back to top"]{
        position:fixed !important;
        top:auto !important;
        left:auto !important;
        right:max(18px, env(safe-area-inset-right)) !important;
        bottom:max(18px, env(safe-area-inset-bottom)) !important;
        z-index:80 !important;
      }

      @media(max-width:720px){
        .gc-backtop,
        .gc-back-top,
        .gc-back-to-top,
        .gc-scroll-top,
        .gc-scrolltop,
        .gc-top-button,
        [data-backtop],
        [data-back-top],
        [data-back-to-top],
        [data-scroll-top],
        [aria-label*="Volver"],
        [aria-label*="volver"],
        [aria-label*="Back to top"],
        [aria-label*="back to top"],
        [title*="Volver"],
        [title*="volver"],
        [title*="Back to top"],
        [title*="back to top"]{
          right:14px !important;
          bottom:14px !important;
        }
      }
    </style>
  </head>
  <body>
    <a class="gc-skip" href="#contenido">Saltar al contenido</a>
    <div class="gc-shell">
      <div class="gc-nav-backdrop" data-menu-close></div>

      <aside class="gc-rail" aria-label="Panel lateral GrassCutters">
        <a class="gc-brand" href="/app" aria-label="GrassCutters Racing Platform">
          <span class="gc-brand__mark">GC</span>
          <span class="gc-brand__copy">
            <strong>GrassCutters</strong>
            <small>Racing Platform</small>
          </span>
        </a>

        <nav class="gc-railnav" aria-label="Navegación principal">
          {nav.map((item) => (
            <a
              href={item.href}
              aria-current={current === item.href ? 'page' : undefined}
              data-admin-only={item.adminOnly ? 'true' : undefined}
              hidden={item.adminOnly ? true : undefined}
              aria-hidden={item.adminOnly ? 'true' : undefined}
            >
              <span>{item.code}</span>
              <strong>{item.label}</strong>
            </a>
          ))}
        </nav>

        <div class="gc-rail__system">
          <div class="gc-rail__system-title">Sistema</div>
          <div class="gc-rail__system-row"><span>Web</span><strong>Astro</strong></div>
          <div class="gc-rail__system-row"><span>API</span><strong>Node</strong></div>
          <div class="gc-rail__system-row"><span>DB</span><strong>stracker</strong></div>
        </div>

        <div class="gc-rail__footer">
          <span class="gc-live-dot"></span>
          <span>GTX sync monitor</span>
        </div>
      </aside>

      <div class="gc-app">
        <header class="gc-topbar">
          <div class="gc-topbar__left">
            <button class="gc-menu-button" type="button" aria-label="Abrir navegación" aria-expanded="false" data-menu-toggle>
              <span></span><span></span><span></span>
            </button>
            <span class="gc-topbar__kicker">GrassCutters Node Platform</span>
          </div>

          <div class="gc-topbar__right">
            <div class="gc-top-status" aria-label="Estado rápido">
              <span class="gc-live-dot"></span>
              <span>Live</span>
            </div>
            <ThemeSwitcher />
            <span class="gc-auth-status" data-auth-status hidden>Conectado</span>
            <a class="gc-login-link" href="/login" data-auth-link>Login</a>
            <button class="gc-auth-logout" type="button" data-auth-logout hidden>Salir</button>
          </div>
        </header>

        <main class="gc-main" id="contenido">
          <slot />
        </main>
      </div>
    </div>

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const btn = document.querySelector('[data-menu-toggle]');
        const closeTargets = document.querySelectorAll('[data-menu-close], .gc-railnav a');
        const setOpen = (open) => {
          root.classList.toggle('gc-nav-open', open);
          btn?.setAttribute('aria-expanded', String(open));
        };
        btn?.addEventListener('click', () => setOpen(!root.classList.contains('gc-nav-open')));
        closeTargets.forEach((el) => el.addEventListener('click', () => setOpen(false)));
        window.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') setOpen(false);
        });
      })();
    </script>
    <AuthHeader />
  </body>
</html>

---
const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const items = [
  { href: '/admin', label: 'Resumen', desc: 'Estado general' },
  { href: '/admin/usuarios', label: 'Usuarios', desc: 'Cuentas y permisos' },
  { href: '/admin/nombres', label: 'Nombres', desc: 'Alias visibles' },
  { href: '/admin/calendario', label: 'Calendario', desc: 'Eventos y ACSM' },
  { href: '/admin/sistema', label: 'Sistema', desc: 'Storage y sync' },
  { href: '/admin/historial', label: 'Historial', desc: 'Auditoría' }
];
const isActive = (href) => current === href || (href !== '/admin' && current.startsWith(href));
---
<nav class="gc-admin-subnav" aria-label="Navegación de administración">
  {items.map((item) => (
    <a href={item.href} class:list={[{ 'is-active': isActive(item.href) }]}>
      <strong>{item.label}</strong>
      <small>{item.desc}</small>
    </a>
  ))}
</nav>

<style is:global>
  .gc-admin-subnav{
    display:grid;
    grid-template-columns:repeat(6,minmax(0,1fr));
    gap:10px;
    margin:0 0 clamp(18px,2vw,26px);
  }
  .gc-admin-subnav a{
    display:grid;
    gap:3px;
    min-height:66px;
    padding:13px 14px;
    border:1px solid var(--line);
    background:rgba(255,255,255,.018);
    color:var(--soft);
    text-decoration:none;
    transition:transform .16s ease,border-color .16s ease,background .16s ease,color .16s ease;
  }
  .gc-admin-subnav a:hover,
  .gc-admin-subnav a.is-active{
    transform:translateY(-1px);
    border-color:var(--accent);
    background:rgba(122,255,144,.08);
    color:var(--text);
  }
  .gc-admin-subnav strong{
    font-size:.84rem;
    text-transform:uppercase;
    letter-spacing:.08em;
  }
  .gc-admin-subnav small{
    color:var(--dim);
    font-size:.72rem;
  }
  .gc-admin-page-clean [hidden]{display:none!important}
  .gc-admin-actions{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
  .gc-admin-note{color:var(--soft)}
  .gc-admin-pill-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px}
  .gc-admin-empty{padding:18px;border:1px solid var(--line);background:rgba(255,255,255,.018);color:var(--soft)}
  .gc-input--compact{min-height:36px;padding:7px 10px}
  .gc-admin-page-clean .gc-section{min-width:0}
  @media(max-width:1100px){.gc-admin-subnav{grid-template-columns:repeat(3,minmax(0,1fr))}}
  @media(max-width:720px){.gc-admin-subnav{grid-template-columns:1fr}.gc-admin-subnav a{min-height:auto}}
</style>

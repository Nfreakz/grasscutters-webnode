---
import '../../styles/archive-dossier.css';

const { entry = {}, related = [] } = Astro.props;

type AnyEntry = Record<string, any>;

const value = (keys: string[], fallback = '') => {
  for (const key of keys) {
    const raw = entry?.[key];
    if (raw !== undefined && raw !== null && String(raw).trim() !== '') return String(raw).trim();
  }
  return fallback;
};

const splitList = (raw: any) => String(raw || '')
  .split(/\|\||\n|;/g)
  .map((item) => item.trim())
  .filter(Boolean);

const parsePairs = (raw: any) => splitList(raw).map((item) => {
  const parts = item.split('::').map((part) => part.trim());
  return {
    title: parts[0] || '',
    text: parts.slice(1).join(' · ') || '',
    parts,
  };
}).filter((item) => item.title || item.text);

const parseSources = (raw: any) => splitList(raw).map((item) => {
  const [label, url] = item.split('::').map((part) => part.trim());
  if (!url && /^https?:\/\//i.test(label || '')) return { label, url: label };
  return { label: label || url || item, url: url || '' };
});

const title = value(['nombre', 'name', 'titulo', 'title'], 'Ficha sin título');
const type = value(['tipo_importacion', 'tipo', 'collection', 'categoria_tipo'], 'Archivo Motorsport');
const subtitle = value(['subtitulo', 'descripcion_corta', 'summary', 'excerpt'], 'Ficha del archivo motorsport GrassCutters.');
const category = value(['categoria', 'category'], 'Ficha motorsport');
const country = value(['pais', 'país', 'country'], '');
const region = value(['region', 'región', 'ciudad', 'ubicacion', 'ubicación'], '');
const era = value(['epoca', 'época', 'years', 'periodo'], '');
const discipline = value(['disciplina', 'discipline'], '');
const tags = splitList(value(['tags', 'etiquetas'], ''));
const imageUrl = value(['imagen_url', 'image_url', 'image', 'foto_url'], '');
const imageAlt = value(['imagen_alt', 'image_alt'], title);
const imageCredit = value(['imagen_credito', 'image_credit', 'credito_imagen'], '');
const imageLicense = value(['imagen_licencia', 'image_license', 'licencia_imagen'], '');
const author = value(['autor', 'author'], 'GrassCutters Racing');
const license = value(['licencia', 'license'], 'Texto editorial propio con fuentes indicadas.');
const lastReview = value(['ultima_revision', 'última_revisión', 'last_review'], '');

const quickFacts = [
  ['Longitud', value(['longitud_km', 'length_km']) ? `${value(['longitud_km', 'length_km'])} km` : ''],
  ['Curvas', value(['curvas', 'corners'])],
  ['Recta principal', value(['recta_principal_km', 'main_straight_km']) ? `${value(['recta_principal_km', 'main_straight_km'])} km` : ''],
  ['Sentido', value(['sentido', 'direction'])],
  ['Apertura', value(['fecha_apertura', 'apertura', 'opened'])],
  ['Tipo', value(['tipo_trazado', 'tipo_circuito', 'track_type'], category)],
  ['País', country],
  ['Zona', region],
  ['Época', era],
  ['Disciplina', discipline],
].filter(([, v]) => v);

const mainSections = [
  ['Qué es', value(['que_es', 'qué_es', 'what_is'])],
  ['Por qué importa', value(['por_que_importa', 'por_qué_importa', 'why_matters'])],
  ['Cómo se conduce', value(['como_se_conduce', 'cómo_se_conduce', 'driving_notes'])],
].filter(([, text]) => text);

const fallbackLong = value(['descripcion_larga', 'description_long', 'body'], '');
const keyZones = parsePairs(value(['zonas_clave', 'puntos_clave', 'key_zones'], ''));
const records = parsePairs(value(['records_destacados', 'records', 'referencias_tiempos'], ''));
const simTips = parsePairs(value(['consejos_simracing', 'consejos', 'simracing_tips'], ''));
const anecdotes = parsePairs(value(['anecdotas', 'anécdotas', 'stories'], ''));
const commonErrors = parsePairs(value(['errores_comunes', 'common_errors'], ''));
const comboGc = value(['combo_gc', 'combo', 'combo_relacionado'], '');
const comboCars = splitList(value(['coches_combo', 'combo_cars'], ''));
const gcReference = value(['referencia_gc', 'gc_reference'], '');
const gcDifficulty = value(['dificultad_gc', 'gc_difficulty'], '');
const gcNote = value(['nota_gc', 'gc_note'], '');
const setupNote = value(['setup_recomendado', 'setup_note'], '');
const sourceUrl = value(['fuente_url', 'source_url'], '');
const sources = parseSources(value(['fuentes', 'sources'], sourceUrl));

const hasImage = Boolean(imageUrl);
const hasAnyDeepSection = mainSections.length || keyZones.length || records.length || simTips.length || anecdotes.length || commonErrors.length || comboGc || comboCars.length || gcReference || setupNote;
---

<article class="gc-archive-dossier">
  <header class="gc-archive-dossier__hero">
    <div class="gc-archive-dossier__hero-main">
      <p class="gc-archive-dossier__breadcrumb">Archivo Motorsport / {type} / <strong>{title}</strong></p>
      <span class="gc-archive-dossier__kicker">Archivo Motorsport</span>
      <h1>{title}</h1>
      <p class="gc-archive-dossier__lead">{subtitle}</p>
      <div class="gc-archive-dossier__tags">
        {[category, country, era, discipline, ...tags].filter(Boolean).slice(0, 8).map((tag) => (
          <span>{tag}</span>
        ))}
      </div>
    </div>

    <aside class="gc-archive-dossier__media-card">
      {hasImage ? (
        <figure>
          <img src={imageUrl} alt={imageAlt} loading="eager" />
          {(imageCredit || imageLicense) && (
            <figcaption>{imageCredit}{imageCredit && imageLicense ? ' · ' : ''}{imageLicense}</figcaption>
          )}
        </figure>
      ) : (
        <div class="gc-archive-dossier__media-empty">
          <span>Imagen pendiente</span>
          <small>Añadir captura, mapa, render o foto cuando esté revisada.</small>
        </div>
      )}
    </aside>
  </header>

  {quickFacts.length > 0 && (
    <section class="gc-archive-dossier__quickfacts" aria-label="Datos rápidos">
      {quickFacts.slice(0, 10).map(([label, fact]) => (
        <div>
          <span>{label}</span>
          <strong>{fact}</strong>
        </div>
      ))}
    </section>
  )}

  <div class="gc-archive-dossier__grid">
    <main class="gc-archive-dossier__content">
      {mainSections.length > 0 ? (
        <section class="gc-archive-dossier__panel gc-archive-dossier__editorial">
          {mainSections.map(([heading, text]) => (
            <div class="gc-archive-dossier__text-section">
              <h2>{heading}</h2>
              <p>{text}</p>
            </div>
          ))}
        </section>
      ) : fallbackLong ? (
        <section class="gc-archive-dossier__panel gc-archive-dossier__editorial">
          <div class="gc-archive-dossier__text-section">
            <h2>Ficha</h2>
            <p>{fallbackLong}</p>
          </div>
        </section>
      ) : null}

      {keyZones.length > 0 && (
        <section class="gc-archive-dossier__panel">
          <div class="gc-archive-dossier__section-head">
            <span>Trazado</span>
            <h2>Zonas clave</h2>
          </div>
          <div class="gc-archive-dossier__cards gc-archive-dossier__cards--zones">
            {keyZones.map((zone) => (
              <article>
                <h3>{zone.title}</h3>
                {zone.text && <p>{zone.text}</p>}
              </article>
            ))}
          </div>
        </section>
      )}

      {records.length > 0 && (
        <section class="gc-archive-dossier__panel">
          <div class="gc-archive-dossier__section-head">
            <span>Referencias</span>
            <h2>Tiempos y récords</h2>
          </div>
          <div class="gc-archive-dossier__records">
            {records.map((record) => (
              <article>
                <strong>{record.title}</strong>
                {record.parts.slice(1).map((part) => <span>{part}</span>)}
              </article>
            ))}
          </div>
        </section>
      )}

      {(simTips.length > 0 || setupNote || commonErrors.length > 0) && (
        <section class="gc-archive-dossier__panel">
          <div class="gc-archive-dossier__section-head">
            <span>Sim racing</span>
            <h2>Cómo sacarle partido</h2>
          </div>

          {setupNote && (
            <div class="gc-archive-dossier__highlight">
              <strong>Setup / enfoque</strong>
              <p>{setupNote}</p>
            </div>
          )}

          <div class="gc-archive-dossier__cards">
            {simTips.map((tip) => (
              <article>
                <h3>{tip.title}</h3>
                {tip.text && <p>{tip.text}</p>}
              </article>
            ))}
            {commonErrors.map((error) => (
              <article class="gc-archive-dossier__card-warning">
                <h3>{error.title}</h3>
                {error.text && <p>{error.text}</p>}
              </article>
            ))}
          </div>
        </section>
      )}

      {anecdotes.length > 0 && (
        <section class="gc-archive-dossier__panel">
          <div class="gc-archive-dossier__section-head">
            <span>Contexto</span>
            <h2>Anécdotas y notas</h2>
          </div>
          <div class="gc-archive-dossier__timeline">
            {anecdotes.map((item) => (
              <article>
                <h3>{item.title}</h3>
                {item.text && <p>{item.text}</p>}
              </article>
            ))}
          </div>
        </section>
      )}
    </main>

    <aside class="gc-archive-dossier__sidebar">
      {(comboGc || comboCars.length || gcReference || gcDifficulty || gcNote) && (
        <section class="gc-archive-dossier__side-panel gc-archive-dossier__combo">
          <span class="gc-archive-dossier__side-kicker">GrassCutters</span>
          <h2>Combo relacionado</h2>
          {comboGc && <strong class="gc-archive-dossier__combo-title">{comboGc}</strong>}
          {gcDifficulty && <p><b>Dificultad:</b> {gcDifficulty}</p>}
          {gcReference && <p>{gcReference}</p>}
          {gcNote && <p>{gcNote}</p>}
          {comboCars.length > 0 && (
            <ul>
              {comboCars.map((car) => <li>{car}</li>)}
            </ul>
          )}
        </section>
      )}

      <section class="gc-archive-dossier__side-panel">
        <span class="gc-archive-dossier__side-kicker">Ficha</span>
        <h2>Datos editoriales</h2>
        <dl>
          {author && <><dt>Autor</dt><dd>{author}</dd></>}
          {license && <><dt>Licencia</dt><dd>{license}</dd></>}
          {lastReview && <><dt>Última revisión</dt><dd>{lastReview}</dd></>}
          {imageCredit && <><dt>Imagen</dt><dd>{imageCredit}</dd></>}
          {imageLicense && <><dt>Licencia imagen</dt><dd>{imageLicense}</dd></>}
        </dl>
      </section>

      {sources.length > 0 && (
        <section class="gc-archive-dossier__side-panel">
          <span class="gc-archive-dossier__side-kicker">Fuentes</span>
          <h2>Referencias</h2>
          <ul class="gc-archive-dossier__sources">
            {sources.map((source) => (
              <li>{source.url ? <a href={source.url} target="_blank" rel="noreferrer">{source.label}</a> : source.label}</li>
            ))}
          </ul>
        </section>
      )}

      {related.length > 0 && (
        <section class="gc-archive-dossier__side-panel">
          <span class="gc-archive-dossier__side-kicker">Relacionado</span>
          <h2>Más fichas</h2>
          <ul class="gc-archive-dossier__related">
            {related.map((item: AnyEntry) => <li><a href={item.href}>{item.label || item.nombre}</a></li>)}
          </ul>
        </section>
      )}
    </aside>
  </div>

  {!hasAnyDeepSection && !fallbackLong && (
    <section class="gc-archive-dossier__panel">
      <div class="gc-archive-dossier__section-head">
        <span>Pendiente</span>
        <h2>Ficha por completar</h2>
      </div>
      <p class="gc-archive-dossier__empty-note">Esta entrada ya existe, pero todavía necesita contenido editorial ampliado.</p>
    </section>
  )}
</article>

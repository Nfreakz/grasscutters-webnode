---
import {
  archiveItemHref,
  archiveTypeHref,
  getArchiveCountry,
  getArchiveImage,
  getArchivePeriod,
  normalizeArchiveType,
  prettifyArchiveType,
  singularArchiveType,
} from '../../lib/archive/archiveRuntime';

const { entry = {}, related = [] } = Astro.props;

type PairItem = { title: string; text: string; parts: string[] };
type DossierSection = { id: string; title: string; text?: string; items?: PairItem[]; eyebrow?: string };

const value = (keys: string[], fallback = '') => {
  for (const key of keys) {
    const raw = entry?.[key];
    if (raw !== undefined && raw !== null && String(raw).trim() !== '') return String(raw).trim();
  }
  return fallback;
};

const splitList = (raw: any) => String(raw || '')
  .split(/\|\||\n|;/g)
  .map((item) => item.trim())
  .filter(Boolean);

const parsePairs = (raw: any): PairItem[] => splitList(raw).map((item) => {
  const parts = item.split('::').map((part) => part.trim());
  return { title: parts[0] || '', text: parts.slice(1).join(' · ') || '', parts };
}).filter((item) => item.title || item.text);

const parseSources = (raw: any) => splitList(raw).map((item) => {
  const [label, url] = item.split('::').map((part) => part.trim());
  if (!url && /^https?:\/\//i.test(label || '')) return { label, url: label };
  return { label: label || url || item, url: url || '' };
});

const cleanText = (raw: any) => String(raw || '').trim();

const normalizeLabel = (raw: any) => cleanText(raw)
  .normalize('NFD')
  .replace(/[\u0300-\u036f]/g, '')
  .toLowerCase();

const titleCase = (raw: any) => cleanText(raw).replace(/\b\w/g, (char) => char.toUpperCase());

const prettyTrackType = (raw: any) => {
  const value = cleanText(raw);
  const normalized = normalizeLabel(value);

  if (!value) return '';
  if (normalized === 'permanente') return 'Circuito permanente';
  if (normalized === 'urbano') return 'Circuito urbano';
  if (normalized === 'temporal') return 'Trazado temporal';
  if (normalized === 'oval' || normalized === 'ovalo') return 'Óvalo';
  if (normalized.includes('circuito') || normalized.includes('trazado')) return value;

  return titleCase(value);
};

const normalizeFactLabel = (label: any, currentType: string) => {
  const clean = cleanText(label);
  const normalized = normalizeLabel(clean);

  if (currentType === 'circuitos') {
    if (['tipo', 'tipo circuito', 'track type'].includes(normalized)) return 'Tipo de trazado';
    if (['ano', 'año', 'apertura', 'opened'].includes(normalized)) return 'Apertura';
    if (['pais', 'país', 'country'].includes(normalized)) return 'País';
    if (['longitud', 'longitud km', 'length', 'length km'].includes(normalized)) return 'Longitud';
  }

  if (currentType === 'coches') {
    if (['tipo'].includes(normalized)) return 'Tipo de coche';
    if (['ano', 'año'].includes(normalized)) return 'Años';
  }

  return clean;
};

const normalizeFactValue = (label: string, fact: any, currentType: string) => {
  const value = cleanText(fact);
  const normalizedLabel = normalizeLabel(label);

  if (!value) return '';

  if (currentType === 'circuitos' && normalizedLabel === 'tipo de trazado') return prettyTrackType(value);

  if (currentType === 'circuitos' && normalizedLabel === 'longitud') {
    const normalizedValue = normalizeLabel(value);
    if (normalizedValue.includes('km')) return value;
    return `${value} km`;
  }

  return value;
};

const title = value(['nombre', 'name', 'titulo', 'title'], 'Ficha sin título');
const type = normalizeArchiveType(value(['tipo', 'tipo_importacion', 'collection', 'categoria_tipo', 'category'], 'general'));
const typeLabel = prettifyArchiveType(type);
const typeSingular = singularArchiveType(type);
const subtitle = value(['subtitulo', 'descripcion_corta', 'summary', 'excerpt'], 'Ficha del archivo.');
const rawCategory = value(['categoria', 'category', 'categoria_competicion'], '');
const category = rawCategory || typeSingular;
const country = getArchiveCountry(entry);
const period = getArchivePeriod(entry);
const discipline = value(['disciplina', 'discipline'], '');
const tags = splitList(value(['tags', 'etiquetas'], ''));
const media = Array.isArray(entry.media) ? entry.media : [];
const mainMedia = media.find((item) => item?.isMain || item?.isPrimary) || media[0];
const imageUrl = getArchiveImage(entry);
const imageAlt = value(['imagen_alt', 'image_alt', 'coverAlt'], title);
const imageCredit = value(['imagen_credito', 'image_credit', 'credito_imagen'], mainMedia?.source || '');
const imageLicense = value(['imagen_licencia', 'image_license', 'licencia_imagen'], mainMedia?.license || '');
const author = value(['autor', 'author'], 'Redacción del archivo');
const license = value(['licencia', 'license'], 'Texto editorial propio con fuentes indicadas.');
const lastReview = value(['ultima_revision', 'última_revisión', 'last_review'], '');
const sources = parseSources(value(['fuentes', 'sources'], value(['fuente_url', 'source_url'], '')));

const adminFactBlacklist = new Set(['fuente', 'fuente url', 'autor', 'licencia', 'sources', 'source', 'source url', 'license', 'author']);

const factsFromAdmin = Array.isArray(entry.facts)
  ? entry.facts
      .map((fact) => {
        const label = normalizeFactLabel(fact?.label || '', type);
        const factValue = normalizeFactValue(label, fact?.value || '', type);
        return [label, factValue] as [string, string];
      })
      .filter(([label, fact]) => label && fact && !adminFactBlacklist.has(normalizeLabel(label)))
  : [];

const introText = value(['introduccion', 'descripcion_larga', 'description_long', 'body']);

const commonSections = [
  ['Contexto histórico', value(['contexto_historico', 'historia', 'historical_context'])],
  ['Importancia', value(['importancia', 'por_que_importa', 'why_matters'])],
  ['Nota de identificación', value(['nota_identificacion', 'identificacion', 'identification_note'])],
].filter(([, text]) => text);

const trackType = prettyTrackType(value(['tipo_trazado', 'tipo_circuito', 'track_type']));
const lengthValue = value(['longitud_km', 'length_km'])
  ? `${value(['longitud_km', 'length_km'])}${normalizeLabel(value(['longitud_km', 'length_km'])).includes('km') ? '' : ' km'}`
  : value(['longitud', 'length']);

const factsByType: Record<string, [string, string][]> = {
  circuitos: [
    ['Tipo de ficha', typeSingular],
    ['Tipo de trazado', trackType],
    ['País', country],
    ['Ubicación', value(['ubicacion', 'ubicación', 'region'])],
    ['Longitud', lengthValue],
    ['Curvas', value(['curvas', 'corners'])],
    ['Sentido', value(['sentido', 'direction'])],
    ['Recta principal', value(['recta_principal_km', 'main_straight_km']) ? `${value(['recta_principal_km', 'main_straight_km'])} km` : value(['recta_principal'])],
    ['Apertura', value(['fecha_apertura', 'apertura', 'opened', 'ano', 'año'])],
  ],
  coches: [
    ['Tipo de ficha', typeSingular],
    ['Fabricante', value(['fabricante', 'manufacturer'])],
    ['Modelo base', value(['modelo_base', 'base_model'])],
    ['Constructor', value(['constructor', 'built_by'])],
    ['Categoría', value(['categoria_competicion', 'categoria', 'category'])],
    ['Años', value(['anos_actividad', 'años_actividad', 'periodo'])],
    ['Motor', value(['motor', 'engine'])],
    ['Potencia', value(['potencia', 'power'])],
    ['Peso', value(['peso', 'weight'])],
    ['Tracción', value(['traccion', 'tracción', 'drivetrain'])],
  ],
  pilotos: [
    ['Tipo de ficha', typeSingular],
    ['Nacionalidad', value(['nacionalidad', 'nationality'], country)],
    ['Años activo', value(['anos_activo', 'años_activo', 'periodo'])],
    ['Disciplinas', value(['disciplinas', 'disciplina'])],
    ['Equipos', value(['equipos', 'teams'])],
    ['Títulos', value(['titulos', 'títulos', 'titles'])],
    ['Nacimiento', value(['fecha_nacimiento', 'birth_date'])],
    ['Lugar', value(['lugar_nacimiento', 'birth_place'])],
  ],
  glosario: [
    ['Tipo de ficha', typeSingular],
    ['Área', value(['area', 'área', 'disciplina', 'category'])],
    ['Uso', value(['uso', 'aplicacion', 'aplicación'])],
    ['Relacionado con', value(['relacionado_con', 'related_to'])],
  ],
};

const fallbackFacts = [
  ['Tipo de ficha', typeSingular],
  ['Categoría', category],
  ['País', country],
  ['Periodo', period],
  ['Disciplina', discipline],
];

const mergeFacts = (baseFacts: [string, string][], extraFacts: [string, string][]) => {
  const map = new Map<string, [string, string]>();

  for (const [rawLabel, rawFact] of [...baseFacts, ...extraFacts]) {
    const label = normalizeFactLabel(rawLabel, type);
    const fact = normalizeFactValue(label, rawFact, type);
    const key = normalizeLabel(label);

    if (!label || !fact) continue;

    const previous = map.get(key);
    if (!previous || fact.length > previous[1].length || previous[1] === typeSingular) {
      map.set(key, [label, fact]);
    }
  }

  return [...map.values()].slice(0, 12);
};


const formatFactParts = (raw: string) => {
  const text = cleanText(raw);
  if (!text) return [];

  const entries = text.includes('||') || text.includes(';') || text.includes('\n')
    ? splitList(text)
    : [text];

  return entries
    .map((entry) => {
      const parts = entry.split('::').map((part) => cleanText(part)).filter(Boolean);
      if (parts.length >= 2) return { title: parts[0], text: parts.slice(1).join(' · ') };
      return { title: cleanText(entry), text: '' };
    })
    .filter((part) => part.title || part.text);
};

const buildFactCards = (facts: [string, string][]) => facts.map(([label, fact]) => {
  const parts = formatFactParts(fact);
  const isList = parts.length > 1 || parts.some((part) => part.text);
  return { label, fact, parts, isList };
});

const quickFacts = mergeFacts(factsByType[type] || fallbackFacts, factsFromAdmin);
const primaryFactCards = buildFactCards(quickFacts.slice(0, 4));
const secondaryFactCards = buildFactCards(quickFacts.slice(4));

const typeSections: Record<string, Omit<DossierSection, 'id'>[]> = {
  circuitos: [
    { title: 'Características del trazado', text: value(['caracteristicas_trazado', 'caracteristicas_conduccion', 'como_se_conduce']), eyebrow: 'Trazado' },
    { title: 'Zonas clave', items: parsePairs(value(['zonas_clave', 'puntos_clave', 'key_zones'])), eyebrow: 'Sectores' },
    { title: 'Eventos destacados', items: parsePairs(value(['eventos_destacados', 'eventos', 'major_events'])), eyebrow: 'Historial' },
    { title: 'Récords y referencias', items: parsePairs(value(['records_destacados', 'records', 'referencias_tiempos'])), eyebrow: 'Referencias' },
    { title: 'Anécdotas', items: parsePairs(value(['anecdotas', 'anécdotas', 'stories'])), eyebrow: 'Notas' },
  ],
  coches: [
    { title: 'Ficha técnica', items: parsePairs(value(['ficha_tecnica', 'caracteristicas_tecnicas'])), eyebrow: 'Specs' },
    { title: 'Desarrollo y versión de competición', text: value(['desarrollo', 'version_competicion', 'caracteristicas_tecnicas']), eyebrow: 'Desarrollo' },
    { title: 'Historial deportivo', text: value(['historial_competicion', 'competition_history']), eyebrow: 'Competición' },
    { title: 'Campeonatos, equipos y resultados', items: parsePairs(value(['campeonatos', 'equipos_destacados', 'equipos', 'victorias_destacadas', 'resultados_destacados'])), eyebrow: 'Palmarés' },
    { title: 'Variantes', items: parsePairs(value(['variantes', 'versions'])), eyebrow: 'Versiones' },
    { title: 'Anécdotas', items: parsePairs(value(['anecdotas', 'anécdotas', 'stories'])), eyebrow: 'Notas' },
  ],
  pilotos: [
    { title: 'Biografía', text: value(['biografia', 'biografía', 'trayectoria']), eyebrow: 'Perfil' },
    { title: 'Trayectoria', items: parsePairs(value(['hitos_trayectoria', 'momentos_clave'])), eyebrow: 'Carrera' },
    { title: 'Palmarés y resultados', items: parsePairs(value(['palmares', 'palmarés', 'titulos', 'victorias_destacadas', 'records_destacados'])), eyebrow: 'Palmarés' },
    { title: 'Estilo de pilotaje', text: value(['estilo_conduccion', 'estilo_pilotaje']), eyebrow: 'Estilo' },
    { title: 'Coches y circuitos asociados', items: parsePairs(value(['coches_asociados', 'circuitos_asociados'])), eyebrow: 'Conexiones' },
    { title: 'Anécdotas', items: parsePairs(value(['anecdotas', 'anécdotas', 'stories'])), eyebrow: 'Notas' },
  ],
  glosario: [
    { title: 'Definición', text: value(['definicion', 'definición', 'descripcion_larga', 'body']), eyebrow: 'Concepto' },
    { title: 'Aplicación práctica', text: value(['aplicacion_practica', 'uso', 'aplicacion']), eyebrow: 'Uso' },
    { title: 'Ejemplos', items: parsePairs(value(['ejemplos', 'examples'])), eyebrow: 'Ejemplos' },
    { title: 'Conceptos relacionados', items: parsePairs(value(['relacionados', 'related'])), eyebrow: 'Relaciones' },
  ],
};

const slugifyId = (raw: string) => cleanText(raw)
  .normalize('NFD')
  .replace(/[\u0300-\u036f]/g, '')
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/^-+|-+$/g, '') || 'seccion';

const sections: DossierSection[] = (typeSections[type] || [])
  .filter((section) => section.text || (section.items && section.items.length))
  .map((section) => ({ ...section, id: slugifyId(section.title) }));

const gallerySeen = new Set<string>();
const gallery = media
  .map((item) => {
    const url = cleanText(item?.url || item?.localUrl || item?.originalUrl);
    if (!url) return null;

    return {
      url,
      alt: cleanText(item?.alt || imageAlt || title),
      credit: [item?.source, item?.author, item?.license].map(cleanText).filter(Boolean).join(' · '),
    };
  })
  .filter((item): item is { url: string; alt: string; credit: string } => {
    if (!item?.url) return false;
    const key = item.url.replace(/\/+$/, '');
    if (gallerySeen.has(key)) return false;
    gallerySeen.add(key);
    return true;
  });

const galleryJson = JSON.stringify(gallery).replace(/</g, '\\u003c');
const hasImage = Boolean(imageUrl);
const sidebarSubtitle = [typeSingular, country, period].filter(Boolean).join(' · ');
const heroStyle = hasImage ? `--archive-hero-image:url('${String(imageUrl).replace(/'/g, '%27')}');` : '';

const navItems = [
  { id: 'resumen', label: 'Resumen', show: Boolean(introText || subtitle || primaryFactCards.length) },
  { id: 'galeria', label: 'Galería', show: gallery.length > 1 },
  { id: 'contenido', label: 'Contenido', show: commonSections.length > 0 || sections.length > 0 },
  { id: 'relacionados', label: 'Relacionados', show: related.length > 0 },
  { id: 'fuentes', label: 'Fuentes', show: true },
].filter((item) => item.show);
---

<article class={`gc-archive-dossier gc-archive-dossier--${type}`} data-archive-share-root data-share-title={title} data-share-text={subtitle}>
  <header class={`gc-archive-dossier__hero ${hasImage ? 'has-image' : ''}`} style={heroStyle}>
    <div class="gc-archive-dossier__hero-main">
      <p class="gc-archive-dossier__breadcrumb">
        <a href="/archivo/">Archivo</a> / <a href={archiveTypeHref(type)}>{typeLabel}</a> / <strong>{title}</strong>
      </p>

      <span class="gc-archive-dossier__kicker">{typeSingular}</span>
      <h1>{title}</h1>
      <p class="gc-archive-dossier__lead">{subtitle}</p>

      {primaryFactCards.length > 0 && (
        <div class="gc-archive-dossier__hero-facts" aria-label="Datos principales">
          {primaryFactCards.map((fact) => (
            <article>
              <span>{fact.label}</span>
              {fact.isList ? (
                <div class="gc-archive-dossier__fact-list">
                  {fact.parts.map((part) => (
                    <span>
                      <b>{part.title}</b>
                      {part.text && <em>{part.text}</em>}
                    </span>
                  ))}
                </div>
              ) : (
                <strong>{fact.fact}</strong>
              )}
            </article>
          ))}
        </div>
      )}

      <div class="gc-archive-dossier__tags">
        {[category !== typeSingular ? category : '', country, period, discipline, ...tags].filter(Boolean).slice(0, 8).map((tag) => <span>{tag}</span>)}
      </div>
    </div>

    <aside class="gc-archive-dossier__hero-media">
      {hasImage ? (
        <figure>
          <img src={imageUrl} alt={imageAlt} loading="eager" />
          {(imageCredit || imageLicense) && <figcaption>{imageCredit}{imageCredit && imageLicense ? ' · ' : ''}{imageLicense}</figcaption>}
        </figure>
      ) : (
        <div class="gc-archive-dossier__media-empty">
          <span>Imagen pendiente</span>
          <small>Añadir foto, mapa, render o material visual cuando esté revisado.</small>
        </div>
      )}
    </aside>
  </header>

  <div class="gc-archive-dossier__layout">
    <main class="gc-archive-dossier__main">
      <section id="resumen" class="gc-archive-dossier__panel gc-archive-dossier__overview">
        <div class="gc-archive-dossier__section-head">
          <span>Visión general</span>
          <h2>Resumen</h2>
        </div>
        <p class="gc-archive-dossier__overview-copy">{introText || subtitle}</p>

        {secondaryFactCards.length > 0 && (
          <div class="gc-archive-dossier__secondary-facts" aria-label="Datos secundarios">
            {secondaryFactCards.map((fact) => (
              <div>
                <span>{fact.label}</span>
                {fact.isList ? (
                  <div class="gc-archive-dossier__fact-list">
                    {fact.parts.map((part) => (
                      <span>
                        <b>{part.title}</b>
                        {part.text && <em>{part.text}</em>}
                      </span>
                    ))}
                  </div>
                ) : (
                  <strong>{fact.fact}</strong>
                )}
              </div>
            ))}
          </div>
        )}
      </section>

      {gallery.length > 1 && (
        <section id="galeria" class="gc-archive-dossier__panel gc-archive-dossier__gallery" data-gallery-root>
          <div class="gc-archive-dossier__section-head gc-archive-dossier__gallery-head">
            <div>
              <span>Material visual</span>
              <h2>Galería</h2>
            </div>
            <small>{gallery.length} imágenes</small>
          </div>

          <script type="application/json" data-gallery-items set:html={galleryJson}></script>

          <div class="gc-archive-dossier__gallery-grid">
            {gallery.map((image, index) => (
              <figure>
                <button
                  type="button"
                  class="gc-archive-dossier__gallery-trigger"
                  data-gallery-open
                  data-gallery-index={index}
                  aria-label={`Abrir imagen ${index + 1} de la galería`}
                >
                  <img src={image.url} alt={image.alt} loading="lazy" />
                  <span>Ampliar</span>
                </button>
                {image.credit && <figcaption>{image.credit}</figcaption>}
              </figure>
            ))}
          </div>

          <div class="gc-archive-dossier__lightbox" data-gallery-lightbox hidden>
            <button class="gc-archive-dossier__lightbox-backdrop" type="button" data-gallery-close aria-label="Cerrar galería"></button>

            <div class="gc-archive-dossier__lightbox-dialog" role="dialog" aria-modal="true" aria-label="Imagen ampliada">
              <div class="gc-archive-dossier__lightbox-top">
                <span data-gallery-counter>1 / {gallery.length}</span>
                <button type="button" data-gallery-close aria-label="Cerrar">Cerrar</button>
              </div>

              <div class="gc-archive-dossier__lightbox-stage">
                <button type="button" class="gc-archive-dossier__lightbox-nav is-prev" data-gallery-prev aria-label="Imagen anterior">‹</button>
                <img data-gallery-image src="" alt="" />
                <div class="gc-archive-dossier__lightbox-error" data-gallery-error hidden>
                  <strong>No se pudo cargar esta imagen.</strong>
                  <p>Revisa la URL en el gestor de imágenes de la ficha.</p>
                </div>
                <button type="button" class="gc-archive-dossier__lightbox-nav is-next" data-gallery-next aria-label="Imagen siguiente">›</button>
              </div>

              <div class="gc-archive-dossier__lightbox-caption">
                <strong data-gallery-alt></strong>
                <p data-gallery-credit></p>
              </div>
            </div>
          </div>
        </section>
      )}

      <div id="contenido" class="gc-archive-dossier__content-stack">
        {commonSections.length > 0 && (
          <section class="gc-archive-dossier__panel gc-archive-dossier__editorial">
            {commonSections.map(([heading, text]) => (
              <div class="gc-archive-dossier__text-section">
                <div class="gc-archive-dossier__section-head">
                  <span>Contexto</span>
                  <h2>{heading}</h2>
                </div>
                <p>{text}</p>
              </div>
            ))}
          </section>
        )}

        {sections.map((section) => (
          <section id={section.id} class="gc-archive-dossier__panel">
            <div class="gc-archive-dossier__section-head">
              <span>{section.eyebrow || typeSingular}</span>
              <h2>{section.title}</h2>
            </div>

            {section.text && <p>{section.text}</p>}

            {section.items && section.items.length > 0 && (
              <div class={`gc-archive-dossier__cards ${section.title.toLowerCase().includes('zona') ? 'gc-archive-dossier__cards--zones' : ''}`}>
                {section.items.map((item) => (
                  <article>
                    <h3>{item.title}</h3>
                    {item.text && <p>{item.text}</p>}
                    {item.parts.length > 2 && (
                      <dl>
                        {item.parts.slice(1).map((part, index) => (
                          <div>
                            <dt>{index === 0 ? 'Dato' : `Ref. ${index + 1}`}</dt>
                            <dd>{part}</dd>
                          </div>
                        ))}
                      </dl>
                    )}
                  </article>
                ))}
              </div>
            )}
          </section>
        ))}
      </div>

    </main>

    <aside class="gc-archive-dossier__sidebar">
      <section class="gc-archive-dossier__side-panel gc-archive-dossier__nav-panel">
        <span class="gc-archive-dossier__side-kicker">En esta ficha</span>
        <nav>
          {navItems.map((item) => <a href={`#${item.id}`}>{item.label}</a>)}
        </nav>
      </section>

      <section class="gc-archive-dossier__side-panel gc-archive-dossier__share-panel">
        <span class="gc-archive-dossier__side-kicker">Compartir</span>
        <div class="gc-archive-dossier__share-actions" aria-label="Compartir ficha">
          <button type="button" class="gc-share-btn gc-share-btn--native" data-share-native aria-label="Compartir ficha">
            <span class="gc-share-btn__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M14 5L19 10M19 10L14 15M19 10H9M12 19H7C5.89543 19 5 18.1046 5 17V7C5 5.89543 5.89543 5 7 5H12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <small>Compartir</small>
          </button>

          <button type="button" class="gc-share-btn gc-share-btn--copy" data-share-copy aria-label="Copiar enlace">
            <span class="gc-share-btn__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <rect x="9" y="9" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.8"/>
                <path d="M15 9V7C15 5.89543 14.1046 5 13 5H7C5.89543 5 5 5.89543 5 7V13C5 14.1046 5.89543 15 7 15H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            </span>
            <small>Copiar</small>
          </button>

          <a href="#" class="gc-share-btn gc-share-btn--x" data-share-x target="_blank" rel="noreferrer" aria-label="Compartir en X">
            <span class="gc-share-btn__icon" aria-hidden="true">

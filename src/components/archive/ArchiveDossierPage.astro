                <path d="M18.901 2H21.98l-6.726 7.69L23 22h-6.17l-4.834-6.322L6.467 22H3.387l7.193-8.222L1 2h6.327l4.37 5.79L18.901 2Zm-1.08 18.14h1.706L6.4 3.765H4.57L17.821 20.14Z"/>
              </svg>
            </span>
            <small>X</small>
          </a>

          <a href="#" class="gc-share-btn gc-share-btn--whatsapp" data-share-whatsapp target="_blank" rel="noreferrer" aria-label="Compartir en WhatsApp">
            <span class="gc-share-btn__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.52 3.48A11.83 11.83 0 0 0 12.07 0C5.5 0 .15 5.34.15 11.91c0 2.1.55 4.16 1.59 5.97L0 24l6.29-1.65a11.9 11.9 0 0 0 5.78 1.48h.01c6.57 0 11.92-5.34 11.92-11.91 0-3.18-1.24-6.17-3.48-8.44ZM12.08 21.8a9.87 9.87 0 0 1-5.04-1.38l-.36-.22-3.73.98 1-3.63-.24-.37a9.88 9.88 0 1 1 8.37 4.62Zm5.41-7.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.19.3-.76.97-.93 1.16-.17.2-.34.22-.64.08-.3-.15-1.24-.46-2.36-1.46a8.75 8.75 0 0 1-1.64-2.04c-.17-.3-.02-.46.13-.61.13-.13.3-.34.44-.5.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.6-.92-2.2-.24-.58-.49-.5-.67-.5h-.57c-.2 0-.52.08-.8.37-.27.3-1.04 1.01-1.04 2.47 0 1.45 1.06 2.86 1.2 3.06.15.2 2.1 3.2 5.08 4.48.71.3 1.26.48 1.7.61.71.22 1.35.19 1.86.12.57-.09 1.76-.72 2-1.41.25-.69.25-1.29.17-1.41-.07-.12-.27-.2-.57-.35Z"/>
              </svg>
            </span>
            <small>WhatsApp</small>
          </a>

          <a href="#" class="gc-share-btn gc-share-btn--telegram" data-share-telegram target="_blank" rel="noreferrer" aria-label="Compartir en Telegram">
            <span class="gc-share-btn__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M9.04 15.47 8.66 20.8c.54 0 .77-.23 1.04-.51l2.5-2.38 5.18 3.79c.95.53 1.62.25 1.88-.88l3.4-15.91.01-.01c.31-1.46-.53-2.03-1.46-1.68L1.42 10.86c-1.42.55-1.4 1.34-.24 1.7l5.06 1.58L17.98 6.8c.55-.36 1.05-.16.64.2"/>
              </svg>
            </span>
            <small>Telegram</small>
          </a>
        </div>
        <p class="gc-archive-dossier__share-status" data-share-status aria-live="polite"></p>
      </section>


      <section class="gc-archive-dossier__side-panel">
        <span class="gc-archive-dossier__side-kicker">Ficha</span>
        <h2>{typeSingular}</h2>
        <p>{sidebarSubtitle || category}</p>
        {(country || period || discipline) && (
          <ul class="gc-archive-dossier__meta-list">
            {country && <li><strong>Origen</strong><span>{country}</span></li>}
            {period && <li><strong>Periodo</strong><span>{period}</span></li>}
            {discipline && <li><strong>Disciplina</strong><span>{discipline}</span></li>}
          </ul>
        )}
      </section>

      {related.length > 0 && (
        <section id="relacionados" class="gc-archive-dossier__side-panel gc-archive-dossier__related-panel">
          <span class="gc-archive-dossier__side-kicker">Relacionados</span>
          <h2>Más fichas</h2>
          <div class="gc-archive-dossier__related-list">
            {related.map((item) => (
              <a href={archiveItemHref(item)}>
                <strong>{item.nombre || item.title}</strong>
                <span>{singularArchiveType(normalizeArchiveType(item.tipo || item.category || 'general'))}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <section id="fuentes" class="gc-archive-dossier__side-panel gc-archive-dossier__sources">
        <span class="gc-archive-dossier__side-kicker">Fuentes</span>
        <h2>Créditos</h2>
        <p><strong>Texto:</strong> {author}</p>
        <p><strong>Licencia:</strong> {license}</p>
        {lastReview && <p><strong>Última revisión:</strong> {lastReview}</p>}
        {sources.length > 0 && (
          <ul>
            {sources.map((source) => (
              <li>{source.url ? <a href={source.url} target="_blank" rel="noreferrer">{source.label}</a> : source.label}</li>
            ))}
          </ul>
        )}
      </section>
    </aside>
  </div>

  <style is:global>
    .gc-archive-dossier{
      --archive-line:rgba(202,255,188,.13);
      --archive-line-strong:rgba(156,255,63,.28);
      --archive-accent:var(--accent,#9cff3f);
      width:min(100%,1460px);
      margin:0 auto;
      padding:clamp(28px,5vw,74px) clamp(14px,3vw,34px) clamp(70px,8vw,118px);
      color:var(--text,#f2f7ef);
      scroll-behavior:smooth;
    }

    .gc-archive-dossier *,
    .gc-archive-dossier *::before,
    .gc-archive-dossier *::after{box-sizing:border-box}

    .gc-archive-dossier a{color:inherit}

    .gc-archive-dossier__hero{
      position:relative;
      display:grid;
      grid-template-columns:minmax(0,1.05fr) minmax(300px,.56fr);
      gap:clamp(18px,3vw,36px);
      align-items:stretch;
      min-height:clamp(430px,58vh,620px);
      padding:clamp(22px,4vw,46px);
      border:1px solid var(--archive-line);
      border-radius:38px;
      background:
        radial-gradient(circle at 12% 4%, rgba(156,255,63,.16), transparent 36%),
        radial-gradient(circle at 88% 12%, rgba(37,214,230,.10), transparent 35%),
        linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.012));
      box-shadow:0 40px 130px rgba(0,0,0,.30);
      overflow:hidden;
    }

    .gc-archive-dossier__hero.has-image::before{
      content:"";
      position:absolute;
      inset:-1px;
      background:
        linear-gradient(90deg, rgba(0,9,4,.92) 0%, rgba(0,9,4,.72) 44%, rgba(0,9,4,.28) 100%),
        var(--archive-hero-image);
      background-size:cover;
      background-position:center;
      filter:saturate(.9) contrast(1.08);
      opacity:.24;
      pointer-events:none;
    }

    .gc-archive-dossier__hero.has-image::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.024) 1px, transparent 1px);
      background-size:54px 54px;
      mask-image:linear-gradient(90deg, rgba(0,0,0,.72), transparent 92%);
      pointer-events:none;
    }

    .gc-archive-dossier__hero-main,
    .gc-archive-dossier__hero-media{
      position:relative;
      z-index:1;
    }

    .gc-archive-dossier__hero-main{
      display:grid;
      align-content:center;
      min-width:0;
    }

    .gc-archive-dossier__breadcrumb{
      display:flex;
      flex-wrap:wrap;
      gap:.5rem;
      margin:0 0 1rem;
      color:var(--muted,#7f9184);
    }

    .gc-archive-dossier__breadcrumb a{
      text-decoration:none;
    }

    .gc-archive-dossier__kicker,
    .gc-archive-dossier__side-kicker,
    .gc-archive-dossier__section-head span{
      color:var(--archive-accent);
      font-size:.74rem;
      font-weight:950;
      letter-spacing:.2em;
      text-transform:uppercase;
    }

    .gc-archive-dossier h1{
      max-width:900px;
      margin:.35rem 0 .9rem;
      font-size:clamp(3.2rem,7.2vw,7.4rem);
      line-height:.8;
      letter-spacing:-.095em;
    }

    .gc-archive-dossier__lead{
      max-width:720px;
      margin:0;
      color:var(--soft,#b6c5b8);
      font-size:clamp(1.05rem,1.45vw,1.3rem);
      line-height:1.56;
    }

    .gc-archive-dossier__hero-facts{
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:10px;
      margin-top:22px;
      max-width:900px;
    }

    .gc-archive-dossier__hero-facts article{
      min-height:92px;
      min-width:0;
      padding:14px;
      border:1px solid rgba(255,255,255,.10);
      border-radius:18px;
      background:rgba(0,0,0,.22);
      backdrop-filter:blur(12px);
    }

    .gc-archive-dossier__hero-facts span,
    .gc-archive-dossier__secondary-facts span{
      display:block;
      color:var(--muted,#7f9184);
      font-size:.7rem;
      font-weight:950;
      letter-spacing:.12em;
      text-transform:uppercase;
    }

    .gc-archive-dossier__hero-facts strong,
    .gc-archive-dossier__secondary-facts strong{
      display:block;
      margin-top:8px;
      font-size:clamp(1rem,1.35vw,1.36rem);
      line-height:1.13;
      letter-spacing:-.035em;
      overflow-wrap:anywhere;
    }

    .gc-archive-dossier__fact-list{
      display:grid;
      gap:7px;
      margin-top:8px;
      min-width:0;
    }

    .gc-archive-dossier__fact-list > span{
      display:grid;
      gap:3px;
      min-width:0;
      padding:8px 10px;
      border:1px solid rgba(255,255,255,.075);
      border-radius:12px;
      background:rgba(0,0,0,.16);
    }

    .gc-archive-dossier__fact-list b{
      display:block;
      color:var(--text,#f2f7ef);
      font-size:.92rem;
      line-height:1.16;
      letter-spacing:-.015em;
      overflow-wrap:anywhere;
    }

    .gc-archive-dossier__fact-list em{
      display:block;
      color:var(--soft,#b6c5b8);
      font-size:.84rem;
      line-height:1.34;
      font-style:normal;
      overflow-wrap:anywhere;
    }

    .gc-archive-dossier__hero-facts .gc-archive-dossier__fact-list{
      max-height:210px;
      overflow:auto;
      padding-right:2px;
    }


    .gc-archive-dossier__tags{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-top:18px;
    }

    .gc-archive-dossier__tags span{
      display:inline-flex;
      align-items:center;
      min-height:32px;
      padding:0 11px;
      border:1px solid rgba(255,255,255,.11);
      border-radius:999px;
      background:rgba(255,255,255,.045);
      color:#fff;
      font-size:.84rem;
      font-weight:800;
    }

    .gc-archive-dossier__hero-media{
      min-width:0;
      display:grid;
      align-items:center;
    }

    .gc-archive-dossier__hero-media figure,
    .gc-archive-dossier__media-empty{
      margin:0;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.11);
      border-radius:30px;
      background:rgba(0,0,0,.22);
      box-shadow:0 28px 86px rgba(0,0,0,.28);
    }

    .gc-archive-dossier__hero-media img{
      width:100%;
      aspect-ratio:4/3;
      min-height:320px;
      max-height:500px;
      object-fit:cover;
      display:block;
    }

    .gc-archive-dossier__hero-media figcaption{
      padding:11px 13px;
      color:var(--soft,#b6c5b8);
      font-size:.84rem;
      line-height:1.4;
      border-top:1px solid rgba(255,255,255,.08);
      background:rgba(0,0,0,.24);
    }

    .gc-archive-dossier__media-empty{
      min-height:320px;
      display:grid;
      place-content:center;
      gap:8px;
      text-align:center;
      padding:24px;
    }

    .gc-archive-dossier__media-empty span{
      color:var(--archive-accent);
      font-weight:950;
      letter-spacing:.16em;
      text-transform:uppercase;
    }

    .gc-archive-dossier__media-empty small{
      color:var(--soft,#b6c5b8);
    }

    .gc-archive-dossier__layout{
      display:grid;
      grid-template-columns:minmax(0,1fr) minmax(300px,.32fr);
      gap:18px;
      align-items:start;
      margin-top:18px;
    }

    .gc-archive-dossier__main,
    .gc-archive-dossier__content-stack,
    .gc-archive-dossier__sidebar{
      display:grid;
      gap:18px;
      min-width:0;
    }

    .gc-archive-dossier__sidebar{
      position:sticky;
      top:76px;
    }

    .gc-archive-dossier__panel,
    .gc-archive-dossier__side-panel{
      padding:clamp(20px,3vw,30px);
      border:1px solid var(--archive-line);
      border-radius:28px;
      background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.014));
    }

    .gc-archive-dossier__overview{
      background:
        radial-gradient(circle at 10% 0%, rgba(156,255,63,.10), transparent 34%),
        linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.014));
    }

    .gc-archive-dossier__overview-copy,
    .gc-archive-dossier__editorial > p,
    .gc-archive-dossier__lead-copy{
      margin:0;
      color:var(--text,#f2f7ef);
      font-size:clamp(1.05rem,1.28vw,1.18rem);
      line-height:1.82;
      max-width:860px;
    }

    .gc-archive-dossier__secondary-facts{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:10px;
      margin-top:20px;
    }

    .gc-archive-dossier__secondary-facts div{
      min-height:84px;
      min-width:0;
      padding:14px;
      border:1px solid rgba(255,255,255,.08);
      border-radius:18px;
      background:rgba(0,0,0,.16);
    }

    .gc-archive-dossier__text-section + .gc-archive-dossier__text-section{
      margin-top:24px;
      padding-top:24px;
      border-top:1px solid rgba(255,255,255,.08);
    }

    .gc-archive-dossier__section-head{
      margin-bottom:14px;
    }

    .gc-archive-dossier h2{
      margin:.25rem 0 .65rem;
      font-size:clamp(2rem,3.4vw,3.8rem);
      line-height:.88;
      letter-spacing:-.08em;
    }

    .gc-archive-dossier h3{
      margin:0 0 .5rem;
      font-size:1.18rem;
      line-height:1.1;
      letter-spacing:-.035em;
    }

    .gc-archive-dossier p{
      color:var(--soft,#b6c5b8);
      line-height:1.78;
    }

    .gc-archive-dossier__cards{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:12px;
    }

    .gc-archive-dossier__cards article{
      padding:16px;
      border:1px solid rgba(255,255,255,.08);
      border-radius:20px;
      background:rgba(0,0,0,.16);
    }

    .gc-archive-dossier__cards--zones{
      grid-template-columns:repeat(3,minmax(0,1fr));
    }

    .gc-archive-dossier__cards dl{
      display:grid;
      gap:7px;
      margin:12px 0 0;
    }

    .gc-archive-dossier__cards dl div{
      padding:10px;
      border-radius:12px;
      background:rgba(255,255,255,.035);
    }

    .gc-archive-dossier__cards dt{
      color:var(--muted,#7f9184);
      font-size:.72rem;
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.12em;
    }

    .gc-archive-dossier__cards dd{
      margin:4px 0 0;
    }

    .gc-archive-dossier__gallery{
      scroll-margin-top:92px;
    }

    .gc-archive-dossier__gallery-head{
      display:flex;
      align-items:end;
      justify-content:space-between;
      gap:16px;
    }

    .gc-archive-dossier__gallery-head small{
      display:inline-flex;
      align-items:center;
      min-height:30px;
      padding:0 10px;
      border:1px solid rgba(156,255,63,.16);
      border-radius:999px;
      background:rgba(156,255,63,.055);
      color:var(--archive-accent);
      font-size:.74rem;
      font-weight:950;
      letter-spacing:.08em;
      text-transform:uppercase;
      white-space:nowrap;
    }

    .gc-archive-dossier__gallery-grid{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:14px;
    }

    .gc-archive-dossier__gallery figure{
      margin:0;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.08);
      border-radius:20px;
      background:rgba(0,0,0,.16);
    }

    .gc-archive-dossier__gallery-trigger{
      position:relative;
      display:block;
      width:100%;
      padding:0;
      border:0;
      background:transparent;
      color:inherit;
      cursor:pointer;
      overflow:hidden;
      text-align:left;
    }

    .gc-archive-dossier__gallery-trigger img{
      width:100%;
      aspect-ratio:16/10;
      object-fit:cover;
      display:block;
      transition:transform .24s ease, filter .24s ease;
    }

    .gc-archive-dossier__gallery-trigger span{
      position:absolute;
      right:12px;
      bottom:12px;
      display:inline-flex;
      align-items:center;
      min-height:30px;
      padding:0 11px;
      border:1px solid rgba(255,255,255,.14);
      border-radius:999px;
      background:rgba(0,0,0,.56);
      color:#fff;
      font-size:.72rem;
      font-weight:950;
      letter-spacing:.1em;
      text-transform:uppercase;
      opacity:0;
      transform:translateY(6px);
      transition:opacity .18s ease, transform .18s ease;
      backdrop-filter:blur(10px);
    }

    .gc-archive-dossier__gallery-trigger:hover img,
    .gc-archive-dossier__gallery-trigger:focus-visible img{
      transform:scale(1.035);
      filter:saturate(1.08) contrast(1.06);
    }

    .gc-archive-dossier__gallery-trigger:hover span,
    .gc-archive-dossier__gallery-trigger:focus-visible span{
      opacity:1;
      transform:translateY(0);
    }

    .gc-archive-dossier__gallery figcaption{
      padding:10px 12px;
      color:var(--soft,#b6c5b8);
      font-size:.82rem;
      line-height:1.35;
      overflow-wrap:anywhere;
    }

    .gc-archive-dossier__lightbox[hidden]{
      display:none;
    }

    .gc-archive-dossier__lightbox{
      position:fixed;
      inset:0;
      z-index:9999;
      display:grid;
      place-items:center;
      padding:clamp(12px,3vw,34px);
    }

    .gc-archive-dossier__lightbox-backdrop{
      position:absolute;
      inset:0;
      border:0;
      background:rgba(0,0,0,.82);
      backdrop-filter:blur(12px);
      cursor:zoom-out;
    }

    .gc-archive-dossier__lightbox-dialog{
      position:relative;
      z-index:1;
      width:min(100%,1180px);
      max-height:calc(100vh - 32px);
      display:grid;
      grid-template-rows:auto minmax(0,1fr) auto;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.12);
      border-radius:28px;
      background:
        radial-gradient(circle at 12% 0%, rgba(156,255,63,.08), transparent 34%),
        #050806;
      box-shadow:0 36px 120px rgba(0,0,0,.56);
    }

    .gc-archive-dossier__lightbox-top{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      min-height:54px;
      padding:10px 14px;
      border-bottom:1px solid rgba(255,255,255,.08);
      color:var(--soft,#b6c5b8);
    }

    .gc-archive-dossier__lightbox-top span{
      color:var(--archive-accent);
      font-size:.74rem;
      font-weight:950;
      letter-spacing:.14em;
      text-transform:uppercase;
    }

    .gc-archive-dossier__lightbox-top button{
      min-height:34px;
      padding:0 12px;
      border:1px solid rgba(255,255,255,.10);
      border-radius:999px;
      background:rgba(255,255,255,.06);
      color:#fff;
      font:inherit;
      font-size:.78rem;
      font-weight:900;
      letter-spacing:.08em;
      text-transform:uppercase;
      cursor:pointer;
    }

    .gc-archive-dossier__lightbox-stage{
      position:relative;
      display:grid;
      place-items:center;
      min-height:0;
      padding:clamp(10px,2vw,18px);
      background:rgba(0,0,0,.22);
    }

    .gc-archive-dossier__lightbox-stage img{
      display:block;
      max-width:100%;
      max-height:calc(100vh - 190px);
      width:auto;
      height:auto;
      object-fit:contain;
      border-radius:18px;
      box-shadow:0 16px 60px rgba(0,0,0,.38);
    }

    .gc-archive-dossier__lightbox-stage img[hidden]{
      display:none;
    }

    .gc-archive-dossier__lightbox-error{
      max-width:520px;
      padding:22px;
      border:1px solid rgba(255,255,255,.10);
      border-radius:20px;
      background:rgba(255,255,255,.04);
      text-align:center;
    }

    .gc-archive-dossier__lightbox-error strong{
      display:block;
      color:var(--text,#f2f7ef);
      margin-bottom:6px;
    }

    .gc-archive-dossier__lightbox-error p{
      margin:0;
      color:var(--soft,#b6c5b8);
      line-height:1.45;
    }

    .gc-archive-dossier__lightbox-nav{
      position:absolute;
      top:50%;
      z-index:2;
      width:46px;
      height:70px;
      display:grid;
      place-items:center;
      border:1px solid rgba(255,255,255,.12);
      border-radius:999px;
      background:rgba(0,0,0,.46);
      color:#fff;
      font-size:2.2rem;
      line-height:1;
      cursor:pointer;
      transform:translateY(-50%);
      backdrop-filter:blur(10px);
      transition:background .16s ease, transform .16s ease;
    }

    .gc-archive-dossier__lightbox-nav:hover{
      background:rgba(156,255,63,.16);
      transform:translateY(-50%) scale(1.03);
    }

    .gc-archive-dossier__lightbox-nav.is-prev{

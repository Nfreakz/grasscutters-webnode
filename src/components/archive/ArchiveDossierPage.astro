---
import '../../styles/archive-dossier.css';
import { normalizeArchiveType, prettifyArchiveType } from '../../lib/archive/archiveData';

const { entry = {}, related = [] } = Astro.props;

type PairItem = { title: string; text: string; parts: string[] };

const value = (keys: string[], fallback = '') => {
  for (const key of keys) {
    const raw = entry?.[key];
    if (raw !== undefined && raw !== null && String(raw).trim() !== '') return String(raw).trim();
  }
  return fallback;
};

const splitList = (raw: any) => String(raw || '')
  .split(/\|\||\n|;/g)
  .map((item) => item.trim())
  .filter(Boolean);

const parsePairs = (raw: any): PairItem[] => splitList(raw).map((item) => {
  const parts = item.split('::').map((part) => part.trim());
  return {
    title: parts[0] || '',
    text: parts.slice(1).join(' · ') || '',
    parts,
  };
}).filter((item) => item.title || item.text);

const parseSources = (raw: any) => splitList(raw).map((item) => {
  const [label, url] = item.split('::').map((part) => part.trim());
  if (!url && /^https?:\/\//i.test(label || '')) return { label, url: label };
  return { label: label || url || item, url: url || '' };
});

const title = value(['nombre', 'name', 'titulo', 'title'], 'Ficha sin título');
const rawType = value(['tipo', 'tipo_importacion', 'collection', 'categoria_tipo'], 'archivo');
const type = normalizeArchiveType(rawType);
const typeLabel = prettifyArchiveType(type);
const subtitle = value(['subtitulo', 'descripcion_corta', 'summary', 'excerpt'], 'Ficha del archivo motorsport.');
const category = value(['categoria', 'category', 'categoria_competicion'], 'Ficha motorsport');
const country = value(['pais', 'país', 'country'], '');
const region = value(['region', 'región', 'ciudad', 'ubicacion', 'ubicación'], '');
const period = value(['periodo', 'epoca', 'época', 'years'], '');
const discipline = value(['disciplina', 'discipline'], '');
const tags = splitList(value(['tags', 'etiquetas'], ''));
const imageUrl = value(['imagen_url', 'image_url', 'image', 'foto_url'], '');
const imageAlt = value(['imagen_alt', 'image_alt'], title);
const imageCredit = value(['imagen_credito', 'image_credit', 'credito_imagen'], '');
const imageLicense = value(['imagen_licencia', 'image_license', 'licencia_imagen'], '');
const author = value(['autor', 'author'], 'GrassCutters Racing');
const license = value(['licencia', 'license'], 'Texto editorial propio con fuentes indicadas.');
const lastReview = value(['ultima_revision', 'última_revisión', 'last_review'], '');

const commonSections = [
  ['Introducción', value(['introduccion', 'descripcion_larga', 'description_long', 'body'])],
  ['Contexto histórico', value(['contexto_historico', 'historia', 'historical_context'])],
  ['Importancia', value(['importancia', 'por_que_importa', 'why_matters'])],
].filter(([, text]) => text);

const factsByType: Record<string, [string, string][]> = {
  circuitos: [
    ['Ubicación', value(['ubicacion', 'ubicación', 'region'])],
    ['Longitud', value(['longitud_km', 'length_km']) ? `${value(['longitud_km', 'length_km'])} km` : ''],
    ['Curvas', value(['curvas', 'corners'])],
    ['Sentido', value(['sentido', 'direction'])],
    ['Recta principal', value(['recta_principal_km', 'main_straight_km']) ? `${value(['recta_principal_km', 'main_straight_km'])} km` : value(['recta_principal'])],
    ['Apertura', value(['fecha_apertura', 'apertura', 'opened'])],
    ['Diseño', value(['diseniador', 'diseñador', 'designer'])],
    ['Propietario', value(['propietario', 'owner'])],
    ['Tipo', value(['tipo_trazado', 'tipo_circuito', 'track_type'], category)],
    ['País', country],
  ],
  coches: [
    ['Fabricante', value(['fabricante', 'manufacturer'])],
    ['Modelo base', value(['modelo_base', 'base_model'])],
    ['Constructor', value(['constructor', 'built_by'])],
    ['Categoría', value(['categoria_competicion', 'categoria', 'category'])],
    ['Años', value(['anos_actividad', 'años_actividad', 'periodo'])],
    ['Motor', value(['motor', 'engine'])],
    ['Cilindrada', value(['cilindrada', 'displacement'])],
    ['Potencia', value(['potencia', 'power'])],
    ['Peso', value(['peso', 'weight'])],
    ['Tracción', value(['traccion', 'tracción', 'drivetrain'])],
  ],
  pilotos: [
    ['Nombre completo', value(['nombre_completo', 'full_name'], title)],
    ['Nacimiento', value(['fecha_nacimiento', 'birth_date'])],
    ['Lugar', value(['lugar_nacimiento', 'birth_place'])],
    ['Nacionalidad', value(['nacionalidad', 'nationality'], country)],
    ['Años activo', value(['anos_activo', 'años_activo', 'periodo'])],
    ['Disciplinas', value(['disciplinas', 'disciplina'])],
    ['Equipos', value(['equipos', 'teams'])],
    ['Títulos', value(['titulos', 'títulos', 'titles'])],
    ['Victorias', value(['victorias', 'wins'])],
    ['Podios', value(['podios', 'podiums'])],
  ],
};

const fallbackFacts = [
  ['Categoría', category],
  ['País', country],
  ['Región', region],
  ['Periodo', period],
  ['Disciplina', discipline],
];

const quickFacts = (factsByType[type] || fallbackFacts).filter(([, v]) => v);

const typeSections: Record<string, { title: string; text?: string; items?: PairItem[]; variant?: string }[]> = {
  circuitos: [
    { title: 'Características del trazado', text: value(['caracteristicas_trazado', 'caracteristicas_conduccion', 'como_se_conduce']) },
    { title: 'Zonas clave', items: parsePairs(value(['zonas_clave', 'puntos_clave', 'key_zones'])) },
    { title: 'Eventos destacados', items: parsePairs(value(['eventos_destacados', 'eventos', 'major_events'])) },
    { title: 'Récords y referencias oficiales', items: parsePairs(value(['records_destacados', 'records', 'referencias_tiempos'])) },
    { title: 'Anécdotas', items: parsePairs(value(['anecdotas', 'anécdotas', 'stories'])) },
  ],
  coches: [
    { title: 'Ficha técnica', items: parsePairs(value(['ficha_tecnica', 'caracteristicas_tecnicas'])) },
    { title: 'Desarrollo y versión de competición', text: value(['desarrollo', 'version_competicion', 'caracteristicas_tecnicas']) },
    { title: 'Historial deportivo', text: value(['historial_competicion', 'competition_history']) },
    { title: 'Campeonatos y equipos', items: parsePairs(value(['campeonatos', 'equipos_destacados', 'equipos'])) },
    { title: 'Victorias o resultados destacados', items: parsePairs(value(['victorias_destacadas', 'resultados_destacados'])) },
    { title: 'Variantes', items: parsePairs(value(['variantes', 'versions'])) },
    { title: 'Anécdotas', items: parsePairs(value(['anecdotas', 'anécdotas', 'stories'])) },
  ],
  pilotos: [
    { title: 'Biografía', text: value(['biografia', 'biografía', 'trayectoria']) },
    { title: 'Trayectoria', items: parsePairs(value(['hitos_trayectoria', 'momentos_clave'])) },
    { title: 'Palmarés', items: parsePairs(value(['palmares', 'palmarés', 'titulos', 'victorias_destacadas'])) },
    { title: 'Estilo de pilotaje', text: value(['estilo_conduccion', 'estilo_pilotaje']) },
    { title: 'Coches y circuitos asociados', items: parsePairs(value(['coches_asociados', 'circuitos_asociados'])) },
    { title: 'Anécdotas', items: parsePairs(value(['anecdotas', 'anécdotas', 'stories'])) },
  ],
};

const sections = (typeSections[type] || [])
  .filter((section) => section.text || (section.items && section.items.length));

const sources = parseSources(value(['fuentes', 'sources'], value(['fuente_url', 'source_url'], '')));
const hasImage = Boolean(imageUrl);
---

<article class={`gc-archive-dossier gc-archive-dossier--${type}`}>
  <header class="gc-archive-dossier__hero">
    <div class="gc-archive-dossier__hero-main">
      <p class="gc-archive-dossier__breadcrumb"><a href="/archivo/">Archivo</a> / <a href={`/archivo/${type}/`}>{typeLabel}</a> / <strong>{title}</strong></p>
      <span class="gc-archive-dossier__kicker">Archivo Motorsport · {typeLabel}</span>
      <h1>{title}</h1>
      <p class="gc-archive-dossier__lead">{subtitle}</p>
      <div class="gc-archive-dossier__tags">
        {[category, country, period, discipline, ...tags].filter(Boolean).slice(0, 8).map((tag) => (
          <span>{tag}</span>
        ))}
      </div>
    </div>

    <aside class="gc-archive-dossier__media-card">
      {hasImage ? (
        <figure>
          <img src={imageUrl} alt={imageAlt} loading="eager" />
          {(imageCredit || imageLicense) && (
            <figcaption>{imageCredit}{imageCredit && imageLicense ? ' · ' : ''}{imageLicense}</figcaption>
          )}
        </figure>
      ) : (
        <div class="gc-archive-dossier__media-empty">
          <span>Imagen pendiente</span>
          <small>Añadir foto, mapa, render o material visual cuando esté revisado.</small>
        </div>
      )}
    </aside>
  </header>

  {quickFacts.length > 0 && (
    <section class="gc-archive-dossier__quickfacts" aria-label="Datos rápidos">
      {quickFacts.slice(0, 10).map(([label, fact]) => (
        <div>
          <span>{label}</span>
          <strong>{fact}</strong>
        </div>
      ))}
    </section>
  )}

  <div class="gc-archive-dossier__grid">
    <main class="gc-archive-dossier__content">
      {commonSections.length > 0 && (
        <section class="gc-archive-dossier__panel gc-archive-dossier__editorial">
          {commonSections.map(([heading, text]) => (
            <div class="gc-archive-dossier__text-section">
              <h2>{heading}</h2>
              <p>{text}</p>
            </div>
          ))}
        </section>
      )}

      {sections.map((section) => (
        <section class="gc-archive-dossier__panel">
          <div class="gc-archive-dossier__section-head">
            <span>{typeLabel}</span>
            <h2>{section.title}</h2>
          </div>
          {section.text && <p>{section.text}</p>}
          {section.items && section.items.length > 0 && (
            <div class={`gc-archive-dossier__cards ${section.title.toLowerCase().includes('zona') ? 'gc-archive-dossier__cards--zones' : ''}`}>
              {section.items.map((item) => (
                <article>
                  <h3>{item.title}</h3>
                  {item.text && <p>{item.text}</p>}
                  {item.parts.length > 2 && (
                    <dl>
                      {item.parts.slice(1).map((part, index) => (
                        <div>
                          <dt>{index === 0 ? 'Dato' : `Ref. ${index + 1}`}</dt>
                          <dd>{part}</dd>
                        </div>
                      ))}
                    </dl>
                  )}
                </article>
              ))}
            </div>
          )}
        </section>
      ))}
    </main>

    <aside class="gc-archive-dossier__sidebar">
      <section class="gc-archive-dossier__side-panel">
        <span class="gc-archive-dossier__side-kicker">Clasificación</span>
        <h2>{typeLabel}</h2>
        <p>{category}</p>
        {(country || region || period) && (
          <ul class="gc-archive-dossier__meta-list">
            {country && <li><strong>País</strong><span>{country}</span></li>}
            {region && <li><strong>Zona</strong><span>{region}</span></li>}
            {period && <li><strong>Periodo</strong><span>{period}</span></li>}
          </ul>
        )}
      </section>

      {related.length > 0 && (
        <section class="gc-archive-dossier__side-panel">
          <span class="gc-archive-dossier__side-kicker">Relacionados</span>
          <h2>Más fichas</h2>
          <div class="gc-archive-dossier__related-list">
            {related.map((item) => (
              <a href={`/archivo/${normalizeArchiveType(item.tipo)}/${item.slug}/`}>
                <strong>{item.nombre}</strong>
                <span>{prettifyArchiveType(item.tipo)}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <section class="gc-archive-dossier__side-panel gc-archive-dossier__sources">
        <span class="gc-archive-dossier__side-kicker">Fuentes</span>
        <h2>Créditos</h2>
        <p><strong>Texto:</strong> {author}</p>
        <p><strong>Licencia:</strong> {license}</p>
        {lastReview && <p><strong>Última revisión:</strong> {lastReview}</p>}
        {sources.length > 0 && (
          <ul>
            {sources.map((source) => (
              <li>{source.url ? <a href={source.url} target="_blank" rel="noreferrer">{source.label}</a> : source.label}</li>
            ))}
          </ul>
        )}
      </section>
    </aside>
  </div>
</article>

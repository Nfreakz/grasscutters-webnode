  <script is:inline>
    (() => {
      const galleries = document.querySelectorAll('[data-gallery-root]');
      if (!galleries.length) return;

      galleries.forEach((gallery) => {
        const triggers = Array.from(gallery.querySelectorAll('[data-gallery-open]'));
        const jsonNode = gallery.querySelector('[data-gallery-items]');
        const lightbox = gallery.querySelector('[data-gallery-lightbox]');
        const image = gallery.querySelector('[data-gallery-image]');
        const errorBox = gallery.querySelector('[data-gallery-error]');
        const altText = gallery.querySelector('[data-gallery-alt]');
        const credit = gallery.querySelector('[data-gallery-credit]');
        const counter = gallery.querySelector('[data-gallery-counter]');
        const closeButtons = gallery.querySelectorAll('[data-gallery-close]');
        const prevButton = gallery.querySelector('[data-gallery-prev]');
        const nextButton = gallery.querySelector('[data-gallery-next]');

        if (!triggers.length || !lightbox || !image) return;

        let currentIndex = 0;
        let items = [];

        try {
          items = JSON.parse(jsonNode?.textContent || '[]');
        } catch {
          items = [];
        }

        items = items
          .map((item) => ({
            src: String(item?.url || item?.src || '').trim(),
            alt: String(item?.alt || '').trim(),
            credit: String(item?.credit || '').trim(),
          }))
          .filter((item) => item.src);

        if (!items.length) return;

        function setError(show) {
          if (!errorBox) return;
          errorBox.hidden = !show;
          image.hidden = show;
        }

        image.addEventListener('load', () => setError(false));
        image.addEventListener('error', () => setError(true));

        function render(index) {
          currentIndex = (index + items.length) % items.length;
          const item = items[currentIndex];

          setError(false);
          image.removeAttribute('src');
          image.alt = item.alt || '';
          if (altText) altText.textContent = item.alt || 'Imagen de galería';
          if (credit) credit.textContent = item.credit || '';
          if (counter) counter.textContent = `${currentIndex + 1} / ${items.length}`;

          window.requestAnimationFrame(() => {
            image.src = item.src;
          });

          if (items.length <= 1) {
            if (prevButton) prevButton.hidden = true;
            if (nextButton) nextButton.hidden = true;
          }
        }

        function open(index) {
          render(index);
          lightbox.hidden = false;
          document.body.classList.add('gc-lightbox-open');
          nextButton?.focus({ preventScroll: true });
        }

        function close() {
          lightbox.hidden = true;
          document.body.classList.remove('gc-lightbox-open');
          image.removeAttribute('src');
          triggers[currentIndex]?.focus({ preventScroll: true });
        }

        triggers.forEach((trigger, index) => {
          trigger.addEventListener('click', () => open(index));
        });

        closeButtons.forEach((button) => button.addEventListener('click', close));
        prevButton?.addEventListener('click', () => render(currentIndex - 1));
        nextButton?.addEventListener('click', () => render(currentIndex + 1));

        document.addEventListener('keydown', (event) => {
          if (lightbox.hidden) return;

          if (event.key === 'Escape') close();
          if (event.key === 'ArrowLeft') render(currentIndex - 1);
          if (event.key === 'ArrowRight') render(currentIndex + 1);
        });
      });
    })();
  </script>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-archive-share-root]');
      if (!root) return;

      const title = root.getAttribute('data-share-title') || document.title;
      const text = root.getAttribute('data-share-text') || '';
      const url = window.location.href.split('#')[0];
      const encodedUrl = encodeURIComponent(url);
      const encodedTitle = encodeURIComponent(title);
      const encodedText = encodeURIComponent(text ? `${title} — ${text}` : title);
      const status = root.querySelector('[data-share-status]');

      const x = root.querySelector('[data-share-x]');
      const whatsapp = root.querySelector('[data-share-whatsapp]');
      const telegram = root.querySelector('[data-share-telegram]');

      if (x) x.href = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
      if (whatsapp) whatsapp.href = `https://wa.me/?text=${encodedText}%20${encodedUrl}`;
      if (telegram) telegram.href = `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`;

      function setStatus(message) {
        if (!status) return;
        status.textContent = message;
        window.clearTimeout(setStatus.timer);
        setStatus.timer = window.setTimeout(() => {
          status.textContent = '';
        }, 2200);
      }

      async function copyLink() {
        try {
          await navigator.clipboard.writeText(url);
          setStatus('Enlace copiado.');
        } catch {
          const temp = document.createElement('textarea');
          temp.value = url;
          document.body.appendChild(temp);
          temp.select();
          document.execCommand('copy');
          temp.remove();
          setStatus('Enlace copiado.');
        }
      }

      root.querySelector('[data-share-copy]')?.addEventListener('click', copyLink);

      root.querySelector('[data-share-native]')?.addEventListener('click', async () => {
        if (navigator.share) {
          try {
            await navigator.share({ title, text, url });
            return;
          } catch {
            return;
          }
        }

        await copyLink();
      });
    })();
  </script>


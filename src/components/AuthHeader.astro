<script is:inline>
  (() => {
    const root = document.documentElement;
    const authEndpoints = ['/api/auth/me', '/api/profile'];
    const logoutEndpoints = [
      { url: '/api/auth/logout', method: 'POST' },
      { url: '/api/logout', method: 'GET' }
    ];

    const headerRoots = () => Array.from(document.querySelectorAll('.gc-public-header, .gc-topbar'));
    const inHeader = (el) => headerRoots().some((rootEl) => rootEl && rootEl.contains(el));
    const authLinks = () => Array.from(document.querySelectorAll('[data-auth-link], a[href="/login"], a[href="/login/"]')).filter(inHeader);
    const authBadges = () => Array.from(document.querySelectorAll('[data-auth-status], [data-auth-state]')).filter(inHeader);
    const logoutButtons = () => Array.from(document.querySelectorAll('[data-auth-logout]')).filter(inHeader);
    const adminLinks = () => Array.from(document.querySelectorAll('[data-admin-only]'));

    const normalizedPath = () => {
      const path = window.location.pathname.replace(/\/$/, '');
      return path || '/';
    };

    const pickUser = (data) => {
      if (!data || typeof data !== 'object') return null;
      return (
        data.user ||
        data.currentUser ||
        data.account ||
        data.profile?.user ||
        data.profile?.account ||
        data.session?.user ||
        data.auth?.user ||
        null
      );
    };

    const isAdminUser = (data) => {
      const user = pickUser(data) || {};
      const role = String(user.role || data?.role || '').trim().toLowerCase();
      return role === 'admin';
    };

    const isLogged = (data) => {
      if (!data || typeof data !== 'object') return false;
      if (data.authenticated === false) return false;
      if (data.loggedIn === false || data.isAuthenticated === false) return false;
      if (data.authenticated === true || data.loggedIn === true || data.isAuthenticated === true) return true;
      return Boolean(pickUser(data));
    };

    const userName = (data) => {
      const user = pickUser(data) || {};
      const raw = user.displayName || user.display_name || user.name || user.username || user.email || data?.email || '';
      const text = String(raw || '').trim();
      if (!text) return 'Mi perfil';
      return text.includes('@') ? text.split('@')[0] : text;
    };

    const setAdminVisibility = (isAdmin) => {
      root.dataset.admin = isAdmin ? 'true' : 'false';
      adminLinks().forEach((link) => {
        link.hidden = !isAdmin;
        if (isAdmin) {
          link.removeAttribute('aria-hidden');
          link.removeAttribute('tabindex');
        } else {
          link.setAttribute('aria-hidden', 'true');
          link.setAttribute('tabindex', '-1');
        }
      });
    };

    const hideBadges = () => {
      authBadges().forEach((badge) => {
        badge.hidden = true;
        badge.setAttribute('aria-hidden', 'true');
        badge.textContent = 'Conectado';
      });
    };

    const setLoggedOut = () => {
      root.dataset.auth = 'false';
      root.dataset.authReady = 'true';
      hideBadges();
      setAdminVisibility(false);

      logoutButtons().forEach((button) => {
        button.hidden = true;
        button.disabled = false;
        button.textContent = 'Salir';
        button.setAttribute('aria-hidden', 'true');
      });

      authLinks().forEach((link) => {
        link.textContent = 'Login';
        link.setAttribute('href', '/login');
        link.classList.remove('is-authenticated', 'gc-auth-profile-link');
        link.removeAttribute('data-auth-profile-link');
        link.setAttribute('aria-label', 'Login');
        link.setAttribute('title', 'Login');
      });
    };

    const setLoggedIn = (data) => {
      const name = userName(data);
      const isAdmin = isAdminUser(data);
      root.dataset.auth = 'true';
      root.dataset.authReady = 'true';
      hideBadges();
      setAdminVisibility(isAdmin);

      authLinks().forEach((link) => {
        link.textContent = `Conectado · ${name}`;
        link.setAttribute('href', '/perfil');
        link.setAttribute('title', `Abrir perfil de ${name}`);
        link.setAttribute('aria-label', `Abrir perfil de ${name}`);
        link.classList.add('is-authenticated', 'gc-auth-profile-link');
        link.setAttribute('data-auth-profile-link', 'true');
      });

      logoutButtons().forEach((button) => {
        button.hidden = false;
        button.disabled = false;
        button.removeAttribute('aria-hidden');
        button.textContent = 'Salir';
        button.setAttribute('title', 'Cerrar sesión');
      });
    };

    async function fetchJson(url, options = {}) {
      const response = await fetch(url, {
        credentials: 'include',
        cache: 'no-store',
        ...options
      });
      if (!response.ok) return null;
      return response.json().catch(() => null);
    }

    async function fetchAuth() {
      for (const endpoint of authEndpoints) {
        try {
          const data = await fetchJson(endpoint);
          if (!data) continue;
          if (isLogged(data) || data.authenticated === false) return data;
        } catch (_) {}
      }
      return null;
    }

    async function guardAdminRoute(authData) {
      if (normalizedPath() !== '/admin') return;

      try {
        const data = await fetchJson('/api/admin/status');
        if (!data) {
          window.location.replace('/login');
          return;
        }

        if (data.setupRequired) {
          root.dataset.adminSetup = 'true';
          return;
        }

        if (data.authorized === true) {
          root.dataset.admin = 'true';
          return;
        }

        const target = data.authenticated || isLogged(authData) ? '/app' : '/login';
        window.location.replace(target);
      } catch (_) {
        if (!isAdminUser(authData)) window.location.replace('/login');
      }
    }

    const clearClientCookie = () => {
      const expires = 'Thu, 01 Jan 1970 00:00:00 GMT';
      document.cookie = `gc_session=; expires=${expires}; path=/; SameSite=Lax`;
      document.cookie = `gc_session=; Max-Age=0; path=/; SameSite=Lax`;
    };

    async function logout(button) {
      if (button?.dataset.logoutBusy === 'true') return;
      if (button) {
        button.dataset.logoutBusy = 'true';
        button.disabled = true;
        button.textContent = 'Saliendo';
      }

      let ok = false;
      for (const endpoint of logoutEndpoints) {
        try {
          const response = await fetch(endpoint.url, {
            method: endpoint.method,
            credentials: 'include',
            cache: 'no-store',
            headers: endpoint.method === 'POST' ? { 'Content-Type': 'application/json' } : undefined,
            body: endpoint.method === 'POST' ? '{}' : undefined
          });
          if (response.ok || response.redirected) {
            ok = true;
            break;
          }
        } catch (_) {}
      }

      clearClientCookie();
      setLoggedOut();
      if (!ok) console.warn('[GC] Logout sin respuesta del servidor. Se ha limpiado la sesión del cliente.');
      window.location.assign('/');
    }

    function bindLogoutButtons() {
      logoutButtons().forEach((button) => {
        if (button.dataset.logoutBound === 'true') return;
        button.dataset.logoutBound = 'true';
        button.addEventListener('click', () => logout(button));
      });
    }

    bindLogoutButtons();
    setAdminVisibility(false);

    fetchAuth().then((data) => {
      if (isLogged(data)) setLoggedIn(data);
      else setLoggedOut();
      bindLogoutButtons();
      guardAdminRoute(data);
    }).catch(() => {
      setLoggedOut();
      guardAdminRoute(null);
    });
  })();
</script>

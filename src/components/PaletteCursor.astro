---
/*
  PaletteCursor remains intentionally DOM-free.
  Native browser cursor is used site-wide.
  This component is still rendered by MarketingLayout and AppLayout, so it is a safe place
  for small global UI guards that must affect both public and app pages.
*/
---

<style is:global>
  /*
    GC button system v10.9
    Scope:
    - unify non-corporate buttons across public + app pages;
    - keep Discord / WhatsApp / Instagram corporate buttons untouched;
    - keep native cursor;
    - center the server support CTA in /comunidad.
  */

  :root{
    --gc-btn-h: 46px;
    --gc-btn-pad-x: 18px;
    --gc-btn-radius: 999px;
    --gc-btn-letter: .075em;
    --gc-btn-font: .76rem;
    --gc-btn-shadow: 0 14px 38px rgba(0,0,0,.22);
    --gc-btn-shadow-primary: 0 16px 44px color-mix(in srgb, var(--accent, var(--gc-mk-accent, #9dff00)) 20%, transparent);
  }

  /* Keep native browser cursor everywhere. */
  html,
  body,
  a,
  button,
  input,
  textarea,
  select,
  option,
  summary,
  label,
  [role="button"],
  [role="link"]{
    cursor: auto;
  }

  a,
  button,
  summary,
  label,
  [role="button"],
  [role="link"],
  .gc-btn,
  .gc-public-link,
  .gc-login-link,
  .gc-auth-logout,
  .gc-theme__trigger,
  .gc-theme__option{
    cursor: pointer;
  }

  input,
  textarea,
  [contenteditable="true"],
  [contenteditable="plaintext-only"]{
    cursor: text;
  }

  /*
    Shared non-corporate button base.
    Important exclusions:
    - gc-community-social-btn = hero Discord / WhatsApp / Instagram
    - gc-social-btn / gc-social-icon = older social buttons + footer icons
    - direct href exclusions preserve corporate social CTAs even if they use gc-btn.
  */
  .gc-btn:not(.gc-community-social-btn):not(.gc-social-btn):not(.gc-social-icon):not([href*="discord.gg"]):not([href*="whatsapp.com"]):not([href*="instagram.com"]),
  .gc-public-link,
  .gc-login-link,
  .gc-auth-profile-link,
  .gc-auth-logout{
    min-height: var(--gc-btn-h) !important;
    height: auto;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 10px !important;
    padding: 0 var(--gc-btn-pad-x) !important;
    border-radius: var(--gc-btn-radius) !important;
    font-size: var(--gc-btn-font) !important;
    font-weight: 950 !important;
    letter-spacing: var(--gc-btn-letter) !important;
    line-height: 1 !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    white-space: nowrap !important;
    border: 1px solid var(--line, var(--gc-mk-line, rgba(255,255,255,.14))) !important;
    color: var(--text, var(--gc-mk-text, #f4fff1)) !important;
    background:
      linear-gradient(180deg, rgba(255,255,255,.066), rgba(255,255,255,.026)) !important;
    box-shadow: none !important;
    transition:
      transform .16s ease,
      filter .16s ease,
      background .16s ease,
      border-color .16s ease,
      box-shadow .16s ease,
      color .16s ease !important;
  }

  .gc-btn:not(.gc-community-social-btn):not(.gc-social-btn):not(.gc-social-icon):not([href*="discord.gg"]):not([href*="whatsapp.com"]):not([href*="instagram.com"]):hover,
  .gc-public-link:hover,
  .gc-login-link:hover,
  .gc-auth-profile-link:hover{
    transform: translateY(-1px) !important;
    border-color: color-mix(in srgb, var(--accent, var(--gc-mk-accent, #9dff00)) 34%, rgba(255,255,255,.14)) !important;
    background:
      radial-gradient(circle at 50% 0%, color-mix(in srgb, var(--accent, var(--gc-mk-accent, #9dff00)) 10%, transparent), transparent 120%),
      linear-gradient(180deg, rgba(255,255,255,.09), rgba(255,255,255,.034)) !important;
    box-shadow: 0 12px 34px rgba(0,0,0,.18) !important;
  }

  .gc-btn:not(.gc-community-social-btn):not(.gc-social-btn):not(.gc-social-icon):not([href*="discord.gg"]):not([href*="whatsapp.com"]):not([href*="instagram.com"]):active,
  .gc-public-link:active,
  .gc-login-link:active,
  .gc-auth-profile-link:active{
    transform: translateY(0) scale(.985) !important;
  }

  /*
    Primary actions.
    Supports both public .gc-btn-primary and app .gc-btn--primary.
  */
  .gc-btn-primary:not(.gc-community-social-btn):not(.gc-social-btn):not([href*="discord.gg"]):not([href*="whatsapp.com"]):not([href*="instagram.com"]),
  .gc-btn--primary:not(.gc-community-social-btn):not(.gc-social-btn):not([href*="discord.gg"]):not([href*="whatsapp.com"]):not([href*="instagram.com"]),
  .gc-public-cta{
    color: #07110a !important;
    border-color: transparent !important;
    background:
      linear-gradient(135deg,
        var(--accent, var(--gc-mk-accent, #9dff00)),
        var(--accent2, var(--gc-mk-accent-2, #35d3ff))
      ) !important;
    box-shadow: var(--gc-btn-shadow-primary) !important;
  }

  .gc-btn-primary:not(.gc-community-social-btn):not(.gc-social-btn):not([href*="discord.gg"]):not([href*="whatsapp.com"]):not([href*="instagram.com"]):hover,
  .gc-btn--primary:not(.gc-community-social-btn):not(.gc-social-btn):not([href*="discord.gg"]):not([href*="whatsapp.com"]):not([href*="instagram.com"]):hover,
  .gc-public-cta:hover{
    color: #07110a !important;
    filter: brightness(1.06) saturate(1.04);
    border-color: transparent !important;
    box-shadow:
      var(--gc-btn-shadow-primary),
      0 0 0 1px color-mix(in srgb, var(--accent, var(--gc-mk-accent, #9dff00)) 18%, transparent) !important;
  }

  /*
    Login/auth buttons should match sizing but keep their meaning.
  */
  .gc-auth-logout{
    border-color: color-mix(in srgb, #ff6b6b 50%, transparent) !important;
    color: #ffd6d6 !important;
    background:
      linear-gradient(135deg, rgba(255,79,96,.17), rgba(255,157,72,.08)) !important;
  }

  .gc-auth-logout:hover{
    color:#07110a !important;
    border-color:transparent !important;
    background:linear-gradient(135deg,#ff6b6b,#ffb15e) !important;
  }

  /*
    Keep corporate buttons fully corporate.
  */
  .gc-community-social-btn,
  .gc-community-social-btn *,
  .gc-social-btn,
  .gc-social-btn *,
  .gc-social-icon,
  .gc-social-icon *,
  .gc-btn[href*="discord.gg"],
  .gc-btn[href*="discord.gg"] *,
  .gc-btn[href*="whatsapp.com"],
  .gc-btn[href*="whatsapp.com"] *,
  .gc-btn[href*="instagram.com"],
  .gc-btn[href*="instagram.com"] *{
    text-transform: uppercase;
  }

  /*
    /comunidad: center the single support button.
  */
  .gc-community-support-v104 .gc-actions,
  .gc-community-support-grid-v104 article .gc-actions{
    justify-content: center !important;
  }

  .gc-community-support-v104 .gc-actions .gc-btn,
  .gc-community-support-grid-v104 article .gc-actions .gc-btn{
    min-width: min(100%, 240px);
  }

  /*
    Final CTA: keep the three actions visually aligned.
  */
  .gc-community-final-v104 .gc-actions .gc-btn{
    min-width: min(100%, 180px);
  }

  /*
    Small mobile guard from the previous cursor reset: keep home hero from exploding
    if this component is the only global guard loaded late.
  */
  @media(max-width:760px){
    .gc-btn:not(.gc-community-social-btn):not(.gc-social-btn):not(.gc-social-icon):not([href*="discord.gg"]):not([href*="whatsapp.com"]):not([href*="instagram.com"]),
    .gc-public-link,
    .gc-login-link,
    .gc-auth-profile-link,
    .gc-auth-logout{
      min-height: 44px !important;
      padding-inline: 14px !important;
      font-size: .72rem !important;
    }

    .gc-community-support-v104 .gc-actions,
    .gc-community-support-grid-v104 article .gc-actions,
    .gc-community-final-v104 .gc-actions{
      width:100%;
    }

    .gc-community-support-v104 .gc-actions .gc-btn,
    .gc-community-support-grid-v104 article .gc-actions .gc-btn,
    .gc-community-final-v104 .gc-actions .gc-btn{
      width:100%;
    }
  }

  /*
    GC Comunidad keep video blend v11.5 FULL
    Scope:
    - complete-file pack, no scripts;
    - keeps the /comunidad hero video visible;
    - darkens only the upper glow/background enough to reduce the visible cut.
  */

  .gc-page-comunidad {
    background:
      linear-gradient(
        180deg,
        #010302 0px,
        #010302 160px,
        rgba(2, 7, 4, .98) 340px,
        var(--gc-mk-bg, #040806) 680px
      ) !important;
  }

  .gc-page-comunidad .gc-home-hero-video,
  .gc-page-comunidad .gc-community-hero-video {
    background: #010302 !important;
    box-shadow:
      inset 0 112px 180px rgba(0, 0, 0, .72),
      inset 0 -170px 250px rgba(0, 0, 0, .68) !important;
  }

  .gc-page-comunidad .gc-home-hero-bg-video,
  .gc-page-comunidad .gc-community-hero-bg-video {
    display: block !important;
    opacity: .82 !important;
    filter: brightness(.68) contrast(1.10) saturate(.88) !important;
  }

  .gc-page-comunidad .gc-home-hero-scrim,
  .gc-page-comunidad .gc-community-hero-scrim {
    background:
      radial-gradient(circle at 42% 4%, rgba(120, 255, 80, .055) 0%, rgba(120, 255, 80, .018) 24%, transparent 48%),
      linear-gradient(180deg, rgba(0, 0, 0, .88) 0%, rgba(0, 0, 0, .55) 24%, rgba(0, 0, 0, .32) 50%, rgba(0, 0, 0, .70) 100%),
      linear-gradient(90deg, rgba(0, 0, 0, .94) 0%, rgba(0, 0, 0, .66) 38%, rgba(0, 0, 0, .28) 68%, rgba(0, 0, 0, .62) 100%) !important;
    pointer-events: none;
  }

  .gc-page-comunidad .gc-home-hero-video::before,
  .gc-page-comunidad .gc-community-hero-video::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    z-index: -2;
    height: clamp(150px, 24vh, 280px);
    background:
      linear-gradient(180deg, rgba(0, 0, 0, .88) 0%, rgba(0, 0, 0, .46) 48%, rgba(0, 0, 0, 0) 100%) !important;
    pointer-events: none;
  }

  .gc-page-comunidad .gc-home-hero-video::after,
  .gc-page-comunidad .gc-community-hero-video::after {
    height: clamp(210px, 28vh, 360px) !important;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, .22) 42%, rgba(0, 0, 0, .64) 74%, var(--gc-mk-bg, #040806) 100%) !important;
    opacity: 1 !important;
  }

  .gc-page-comunidad .gc-week-combo-section,
  .gc-page-comunidad .gc-community-intro,
  .gc-page-comunidad .gc-community-main,
  .gc-page-comunidad .gc-community-content {
    background: transparent !important;
  }

  @media (max-width: 760px) {
    .gc-page-comunidad .gc-home-hero-bg-video,
    .gc-page-comunidad .gc-community-hero-bg-video {
      opacity: .78 !important;
      filter: brightness(.62) contrast(1.08) saturate(.84) !important;
    }

    .gc-page-comunidad .gc-home-hero-scrim,
    .gc-page-comunidad .gc-community-hero-scrim {
      background:
        linear-gradient(180deg, rgba(0, 0, 0, .90) 0%, rgba(0, 0, 0, .58) 38%, rgba(0, 0, 0, .76) 100%),
        linear-gradient(90deg, rgba(0, 0, 0, .90) 0%, rgba(0, 0, 0, .52) 100%) !important;
    }
  }


  /*
    GC Comunidad palette video glow v11.6 FULL
    Adds a light Home-style accent glow over the /comunidad video without hiding it.
    The glow uses palette variables, so changing palette is visible in the hero.
  */

  .gc-page-comunidad .gc-home-hero-video,
  .gc-page-comunidad .gc-community-hero-video {
    box-shadow:
      inset 0 112px 180px rgba(0, 0, 0, .68),
      inset 0 -170px 250px rgba(0, 0, 0, .66),
      inset 0 0 220px color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 4%, transparent) !important;
  }

  .gc-page-comunidad .gc-home-hero-bg-video,
  .gc-page-comunidad .gc-community-hero-bg-video {
    opacity: .84 !important;
    filter: brightness(.70) contrast(1.10) saturate(.90) !important;
  }

  .gc-page-comunidad .gc-home-hero-scrim,
  .gc-page-comunidad .gc-community-hero-scrim {
    background:
      radial-gradient(circle at 16% 22%, color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 15%, transparent) 0%, color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 7%, transparent) 24%, transparent 46%),
      radial-gradient(circle at 78% 18%, color-mix(in srgb, var(--gc-mk-accent-2, var(--gc-mk-accent, #9cff3f)) 10%, transparent) 0%, transparent 42%),
      linear-gradient(180deg, rgba(0, 0, 0, .84) 0%, rgba(0, 0, 0, .48) 24%, rgba(0, 0, 0, .30) 50%, rgba(0, 0, 0, .68) 100%),
      linear-gradient(90deg, rgba(0, 0, 0, .92) 0%, rgba(0, 0, 0, .62) 38%, rgba(0, 0, 0, .24) 68%, rgba(0, 0, 0, .58) 100%) !important;
    pointer-events: none;
  }

  .gc-page-comunidad .gc-home-hero-video::before,
  .gc-page-comunidad .gc-community-hero-video::before {
    background:
      radial-gradient(circle at 18% 10%, color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 13%, transparent) 0%, transparent 44%),
      radial-gradient(circle at 58% 6%, color-mix(in srgb, var(--gc-mk-accent-2, var(--gc-mk-accent, #9cff3f)) 8%, transparent) 0%, transparent 40%),
      linear-gradient(180deg, rgba(0, 0, 0, .84) 0%, rgba(0, 0, 0, .42) 48%, rgba(0, 0, 0, 0) 100%) !important;
  }

  .gc-page-comunidad .gc-home-hero-video .gc-title,
  .gc-page-comunidad .gc-community-hero-video .gc-title {
    text-shadow:
      0 4px 34px rgba(0, 0, 0, .78),
      0 0 38px color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 12%, transparent) !important;
  }

  @media (max-width: 760px) {
    .gc-page-comunidad .gc-home-hero-bg-video,
    .gc-page-comunidad .gc-community-hero-bg-video {
      opacity: .80 !important;
      filter: brightness(.64) contrast(1.08) saturate(.86) !important;
    }

    .gc-page-comunidad .gc-home-hero-scrim,
    .gc-page-comunidad .gc-community-hero-scrim {
      background:
        radial-gradient(circle at 16% 18%, color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 12%, transparent) 0%, transparent 44%),
        linear-gradient(180deg, rgba(0, 0, 0, .88) 0%, rgba(0, 0, 0, .54) 38%, rgba(0, 0, 0, .74) 100%),
        linear-gradient(90deg, rgba(0, 0, 0, .90) 0%, rgba(0, 0, 0, .48) 100%) !important;
    }
  }


  /*
    GC WebNode v11.9
    - Home hero: remove only the circular orbit behind the logo, keeping the glow/aura.
    - Comunidad hero: soften the upper-left palette glow so it does not look clipped.
  */

  .gc-public-body .gc-home-floating-logo-absolute[data-gc-hero-logo] .gc-home-floating-logo-absolute__orbit {
    display: none !important;
    opacity: 0 !important;
    visibility: hidden !important;
  }

  .gc-page-comunidad .gc-home-hero-scrim,
  .gc-page-comunidad .gc-community-hero-scrim {
    background:
      radial-gradient(ellipse at 5% 4%,
        color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 14%, transparent) 0%,
        color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 9%, transparent) 20%,
        color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 4%, transparent) 42%,
        transparent 72%
      ),
      radial-gradient(ellipse at 24% 0%,
        color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 8%, transparent) 0%,
        transparent 58%
      ),
      radial-gradient(circle at 78% 18%,
        color-mix(in srgb, var(--gc-mk-accent-2, var(--gc-mk-accent, #9cff3f)) 10%, transparent) 0%,
        transparent 42%
      ),
      linear-gradient(180deg,
        rgba(0, 0, 0, .82) 0%,
        rgba(0, 0, 0, .50) 24%,
        rgba(0, 0, 0, .30) 50%,
        rgba(0, 0, 0, .68) 100%
      ),
      linear-gradient(90deg,
        rgba(0, 0, 0, .91) 0%,
        rgba(0, 0, 0, .62) 38%,
        rgba(0, 0, 0, .24) 68%,
        rgba(0, 0, 0, .58) 100%
      ) !important;
  }

  .gc-page-comunidad .gc-home-hero-video::before,
  .gc-page-comunidad .gc-community-hero-video::before {
    content: "" !important;
    position: absolute !important;
    inset: 0 !important;
    z-index: 2 !important;
    width: auto !important;
    height: auto !important;
    pointer-events: none !important;
    background:
      radial-gradient(ellipse at 0% 0%,
        color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 10%, transparent) 0%,
        color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 6%, transparent) 18rem,
        transparent 42rem
      ),
      radial-gradient(ellipse at 28% 0%,
        color-mix(in srgb, var(--gc-mk-accent-2, var(--gc-mk-accent, #9cff3f)) 7%, transparent) 0%,
        transparent 34rem
      ),
      linear-gradient(180deg,
        rgba(0, 0, 0, .78) 0%,
        rgba(0, 0, 0, .36) 38%,
        rgba(0, 0, 0, 0) 72%
      ) !important;
    opacity: 1 !important;
    filter: none !important;
  }

  .gc-page-comunidad .gc-community-hero-inner,
  .gc-page-comunidad .gc-home-hero-inner {
    position: relative !important;
    z-index: 4 !important;
  }

  @media (max-width: 760px) {
    .gc-page-comunidad .gc-home-hero-scrim,
    .gc-page-comunidad .gc-community-hero-scrim {
      background:
        radial-gradient(ellipse at 0% 4%,
          color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 12%, transparent) 0%,
          color-mix(in srgb, var(--gc-mk-accent, #9cff3f) 6%, transparent) 36%,
          transparent 70%
        ),
        linear-gradient(180deg, rgba(0, 0, 0, .88) 0%, rgba(0, 0, 0, .54) 38%, rgba(0, 0, 0, .74) 100%),
        linear-gradient(90deg, rgba(0, 0, 0, .90) 0%, rgba(0, 0, 0, .48) 100%) !important;
    }
  }



  /*
    GC Home combo reference avatar v13.4
    Adds the best-reference pilot avatar to the home Combo de la semana summary.
    App/panel avatar was removed from the avatar system because this belongs on Home.
  */
  .gc-week-combo__summary-v61{
    grid-template-columns:minmax(0,1.34fr) minmax(84px,.36fr) minmax(150px,.55fr) minmax(150px,.55fr)!important;
  }

  .gc-week-combo__avatar-v134{
    position:relative;
    display:grid;
    place-items:center;
    min-height:104px;
    padding:14px 16px;
    border-right:1px solid rgba(255,255,255,.1);
    text-decoration:none!important;
    background:
      radial-gradient(circle at 50% 50%, color-mix(in srgb,var(--gc-mk-accent,var(--accent,#9dff00)) 8%, transparent), transparent 72%),
      linear-gradient(135deg,rgba(255,255,255,.025),rgba(255,255,255,.012));
  }

  .gc-week-combo__avatar-frame-v134{
    position:relative;
    width:70px;
    height:70px;
    display:block;
    border-radius:999px;
    padding:2px;
    background:
      linear-gradient(135deg,
        color-mix(in srgb,var(--gc-mk-accent,var(--accent,#9dff00)) 76%,transparent),
        color-mix(in srgb,var(--gc-mk-accent-2,var(--accent2,#35d3ff)) 58%,transparent)
      );
    box-shadow:
      0 14px 34px rgba(0,0,0,.35),
      0 0 24px color-mix(in srgb,var(--gc-mk-accent,var(--accent,#9dff00)) 22%,transparent);
    transition:transform .18s ease, box-shadow .18s ease, filter .18s ease;
  }

  .gc-week-combo__avatar-frame-v134::after{
    content:"";
    position:absolute;
    inset:-7px;
    border-radius:inherit;
    background:radial-gradient(circle, color-mix(in srgb,var(--gc-mk-accent,var(--accent,#9dff00)) 18%,transparent), transparent 68%);
    filter:blur(10px);
    opacity:.78;
    z-index:-1;
    pointer-events:none;
  }

  .gc-week-combo__avatar-img-v134{
    display:block;
    width:100%;
    height:100%;
    border-radius:999px;
    object-fit:cover;
    background:#050805;
  }

  .gc-week-combo__avatar-v134:hover .gc-week-combo__avatar-frame-v134{
    transform:translateY(-1px) scale(1.025);
    filter:saturate(1.06);
    box-shadow:
      0 18px 42px rgba(0,0,0,.40),
      0 0 34px color-mix(in srgb,var(--gc-mk-accent,var(--accent,#9dff00)) 30%,transparent);
  }

  @media(max-width:980px){
    .gc-week-combo__summary-v61{
      grid-template-columns:1fr!important;
    }

    .gc-week-combo__avatar-v134{
      min-height:94px;
      border-right:0;
      border-bottom:1px solid rgba(255,255,255,.1);
      padding:12px 16px;
    }

    .gc-week-combo__avatar-frame-v134{
      width:68px;
      height:68px;
    }
  }


</style>

<script is:inline>
  (() => {
    const iconVersion = 'gc-v12-2';
    const ensureIcon = (rel, href, type) => {
      let link = document.head.querySelector(`link[rel="${rel}"]`);
      if (!link) {
        link = document.createElement('link');
        link.setAttribute('rel', rel);
        document.head.appendChild(link);
      }
      link.setAttribute('href', `${href}?v=${iconVersion}`);
      if (type) link.setAttribute('type', type);
    };

    ensureIcon('icon', '/favicon.svg', 'image/svg+xml');
    ensureIcon('shortcut icon', '/favicon.ico', 'image/x-icon');
    ensureIcon('apple-touch-icon', '/icon-192.png', 'image/png');

    const footer = document.querySelector('.gc-public-footer-links');
    if (footer && footer.dataset.gcFooterClean !== 'true') {
      const links = [
        { href: '/normas', label: 'Normas' },
        { href: '/apoyo-servidor', label: 'Apoyo al servidor' },
        { href: '/privacidad', label: 'Privacidad' },
      ];

      footer.dataset.gcFooterClean = 'true';
      footer.innerHTML = links
        .map((item) => `<a href="${item.href}">${item.label}</a>`)
        .join('');
    }
  })();
</script>



<script is:inline>
  (() => {
    if (window.location.pathname.replace(/\/$/, '') !== '') return;

    const DEFAULT_AVATAR = '/images/pilot-avatar-default.png';
    const shellId = 'gcWeekComboAvatarV134';

    const clean = (value, fallback = '') => String(value ?? fallback).trim().replace(/\s+/g, ' ');
    const normalize = (value) => clean(value).toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();

    const getValueAt = (source, path) => {
      if (!source || typeof source !== 'object') return undefined;
      if (Object.prototype.hasOwnProperty.call(source, path)) return source[path];
      return String(path).split('.').reduce((acc, part) => acc == null ? undefined : acc[part], source);
    };

    const first = (source, paths) => {
      for (const path of paths) {
        const value = getValueAt(source, path);
        if (value !== undefined && value !== null && value !== '') return value;
      }
      return '';
    };

    const items = (data) => {
      if (Array.isArray(data)) return data;
      if (!data || typeof data !== 'object') return [];
      return data.items || data.data || data.results || data.hotlaps || data.laps || data.combos || data.pilots || data.drivers || [];
    };

    const playerIdFromAny = (row) => first(row, [
      'playerId','PlayerId','driverId','pilotId','id',
      'driver.id','player.id','pilot.id',
      'bestPlayerId','bestDriverId','leaderPlayerId','fastestPlayerId',
      'bestLap.playerId','bestLap.PlayerId','bestLap.driverId','bestLap.driver.id','bestLap.player.id','bestLap.pilot.id'
    ]);

    const pilotNameFromAny = (row) => clean(first(row, [
      'displayName','visibleName','cleanName','driverName','playerName','pilotName','name','Name',
      'driver.displayName','driver.visibleName','driver.name','player.displayName','player.name',
      'bestDriverName','fastestDriverName','leaderName',
      'bestLap.driverName','bestLap.playerName','bestLap.name','bestLap.driver','bestLap.player','bestLap.driver.name','bestLap.player.name'
    ]), 'Referencia');

    async function fetchMaybeJson(url) {
      try {
        const response = await fetch(url, { credentials:'include', cache:'no-store' });
        if (!response.ok) return null;
        return await response.json().catch(() => null);
      } catch (_) {
        return null;
      }
    }

    function ensureShell() {
      const summary = document.querySelector('.gc-week-combo__summary-v61');
      if (!summary) return null;

      let shell = document.getElementById(shellId);
      if (shell) return shell;

      shell = document.createElement('a');
      shell.id = shellId;
      shell.className = 'gc-week-combo__avatar-v134';
      shell.href = '/pilotos';
      shell.setAttribute('aria-label', 'Avatar del piloto con mejor referencia');
      shell.innerHTML = `
        <span class="gc-week-combo__avatar-frame-v134" data-gc-home-combo-avatar-frame>
          <img class="gc-week-combo__avatar-img-v134" src="${DEFAULT_AVATAR}" alt="Avatar del piloto de referencia" loading="lazy" decoding="async" />
        </span>
      `;

      const secondCell = summary.children[1] || null;
      summary.insertBefore(shell, secondCell);
      return shell;
    }

    async function resolveHomeReferencePilot() {
      const domName = clean(document.getElementById('gcWeekComboBestDriver')?.textContent || '');
      let playerId = '';
      let name = domName || 'Referencia';

      const [combosData, bestData, recentData, pilotsData] = await Promise.all([
        fetchMaybeJson('/api/combos/stats?limit=300&sort=recent'),
        fetchMaybeJson('/api/hotlaps?limit=12'),
        fetchMaybeJson('/api/laps?limit=12&sort=recent&valid=all'),
        fetchMaybeJson('/api/pilots?limit=800&valid=all')
      ]);

      const combos = items(combosData).filter(Boolean).sort((a, b) => {
        const aLaps = Number(first(a, ['totalLaps','laps','lapCount','visibleLaps']) || 0);
        const bLaps = Number(first(b, ['totalLaps','laps','lapCount','visibleLaps']) || 0);
        const aDate = Date.parse(first(a, ['lastActivityIso','lastSeenAt','latestLapAt','updatedAt','lastActivity','timestampIso']) || '') || 0;
        const bDate = Date.parse(first(b, ['lastActivityIso','lastSeenAt','latestLapAt','updatedAt','lastActivity','timestampIso']) || '') || 0;
        return bDate - aDate || bLaps - aLaps;
      });

      const source = combos[0] || items(bestData)[0] || items(recentData)[0] || null;
      if (source) {
        playerId = clean(playerIdFromAny(source));
        name = clean(pilotNameFromAny(source), name);
      }

      if ((!playerId || name === 'Referencia') && domName && domName !== 'Pendiente') {
        name = domName;
      }

      const pilots = items(pilotsData);
      if (!playerId && name && pilots.length) {
        const needle = normalize(name);
        const match = pilots.find((pilot) => normalize(pilotNameFromAny(pilot)) === needle)
          || pilots.find((pilot) => {
            const candidate = normalize(pilotNameFromAny(pilot));
            return candidate && needle && (candidate.includes(needle) || needle.includes(candidate));
          });
        if (match) {
          playerId = clean(playerIdFromAny(match));
          name = clean(pilotNameFromAny(match), name);
        }
      }

      return { playerId, name: name || 'Referencia' };
    }

    async function updateHomeAvatar() {
      const shell = ensureShell();
      if (!shell) return;
      const img = shell.querySelector('img');
      const frame = shell.querySelector('[data-gc-home-combo-avatar-frame]');
      try {
        const pilot = await resolveHomeReferencePilot();
        if (pilot.playerId) {
          const url = `/api/pilot-avatar/${encodeURIComponent(pilot.playerId)}?v=${Date.now()}`;
          if (img) {
            img.src = url;
            img.alt = `Avatar de ${pilot.name}`;
            img.onerror = () => { img.onerror = null; img.src = DEFAULT_AVATAR; };
          }
          if (frame) frame.dataset.gcAvatarFor = String(pilot.playerId);
          shell.href = `/pilotos/${encodeURIComponent(pilot.playerId)}`;
          shell.setAttribute('aria-label', `Abrir ficha de ${pilot.name}`);
          shell.title = pilot.name;
        } else {
          if (img) img.src = DEFAULT_AVATAR;
          shell.href = '/pilotos';
          shell.title = 'Pilotos GrassCutters';
        }
      } catch (_) {
        if (img) img.src = DEFAULT_AVATAR;
      }
    }

    ensureShell();
    window.setTimeout(updateHomeAvatar, 500);
    window.setTimeout(updateHomeAvatar, 1500);
    window.setTimeout(updateHomeAvatar, 3200);
  })();
</script>

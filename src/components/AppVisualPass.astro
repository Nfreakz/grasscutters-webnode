---
/*
  GC WebNode AppVisualPass v13.7
  Visual/responsive guard for platform pages.
  Scope: app layout pages only. No API/data logic.
*/
---

<style is:global>
  html[data-gc-scope="app"]{
    --gc-app-safe-gap: clamp(14px, 2vw, 24px);
    --gc-app-table-radius: 18px;
  }

  html[data-gc-scope="app"] *,
  html[data-gc-scope="app"] *::before,
  html[data-gc-scope="app"] *::after{
    box-sizing: border-box;
  }

  html[data-gc-scope="app"] .gc-main,
  html[data-gc-scope="app"] .gc-page,
  html[data-gc-scope="app"] .gc-section,
  html[data-gc-scope="app"] .gc-card,
  html[data-gc-scope="app"] .gc-live-panel,
  html[data-gc-scope="app"] .gc-hero,
  html[data-gc-scope="app"] .gc-toolbar,
  html[data-gc-scope="app"] .gc-table-wrap,
  html[data-gc-scope="app"] .gc-combo-table-shell-v42{
    min-width: 0;
    max-width: 100%;
  }

  html[data-gc-scope="app"] .gc-page{
    overflow-x: clip;
  }

  html[data-gc-scope="app"] .gc-title,
  html[data-gc-scope="app"] .gc-section-title,
  html[data-gc-scope="app"] h1,
  html[data-gc-scope="app"] h2,
  html[data-gc-scope="app"] h3,
  html[data-gc-scope="app"] strong,
  html[data-gc-scope="app"] .gc-chip,
  html[data-gc-scope="app"] .gc-btn{
    overflow-wrap: anywhere;
  }

  html[data-gc-scope="app"] .gc-subtitle,
  html[data-gc-scope="app"] .gc-section-head p,
  html[data-gc-scope="app"] .gc-muted-text,
  html[data-gc-scope="app"] .gc-note,
  html[data-gc-scope="app"] small{
    line-height: 1.45;
  }

  html[data-gc-scope="app"] .gc-toolbar{
    border: 1px solid color-mix(in srgb, var(--line, rgba(255,255,255,.12)) 82%, transparent);
    border-radius: 20px;
    padding: clamp(12px, 1.6vw, 16px);
    background:
      linear-gradient(135deg, rgba(255,255,255,.042), rgba(255,255,255,.016));
  }

  html[data-gc-scope="app"] .gc-toolbar .gc-field{
    min-width: 0;
  }

  html[data-gc-scope="app"] .gc-toolbar .gc-input,
  html[data-gc-scope="app"] .gc-toolbar .gc-select{
    width: 100%;
    min-width: 0;
  }

  html[data-gc-scope="app"] .gc-table-wrap,
  html[data-gc-scope="app"] .gc-combo-table-shell-v42{
    position: relative;
    overflow-x: auto !important;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: var(--gc-app-table-radius);
    border: 1px solid color-mix(in srgb, var(--line, rgba(255,255,255,.12)) 88%, transparent);
    background:
      linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.012));
    scrollbar-width: thin;
    scrollbar-color: color-mix(in srgb, var(--accent, #9dff00) 42%, rgba(255,255,255,.16)) rgba(255,255,255,.06);
  }

  html[data-gc-scope="app"] .gc-table-wrap::-webkit-scrollbar,
  html[data-gc-scope="app"] .gc-combo-table-shell-v42::-webkit-scrollbar{
    height: 10px;
    width: 10px;
  }

  html[data-gc-scope="app"] .gc-table-wrap::-webkit-scrollbar-track,
  html[data-gc-scope="app"] .gc-combo-table-shell-v42::-webkit-scrollbar-track{
    background: rgba(255,255,255,.045);
    border-radius: 999px;
  }

  html[data-gc-scope="app"] .gc-table-wrap::-webkit-scrollbar-thumb,
  html[data-gc-scope="app"] .gc-combo-table-shell-v42::-webkit-scrollbar-thumb{
    background: color-mix(in srgb, var(--accent, #9dff00) 36%, rgba(255,255,255,.18));
    border-radius: 999px;
  }

  html[data-gc-scope="app"] table{
    max-width: none;
    table-layout: auto;
  }

  html[data-gc-scope="app"] th,
  html[data-gc-scope="app"] td{
    overflow-wrap: anywhere;
  }

  html[data-gc-scope="app"] thead th{
    box-shadow: 0 1px 0 var(--line, rgba(255,255,255,.12));
  }

  html[data-gc-scope="app"] .gc-table-meta{
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 10px 14px;
    border-radius: 16px;
    padding: 12px 14px !important;
    background: rgba(255,255,255,.022);
  }

  html[data-gc-scope="app"] .gc-table-meta span{
    min-width: 0;
  }

  html[data-gc-scope="app"] .gc-chip,
  html[data-gc-scope="app"] .gc-status-row strong,
  html[data-gc-scope="app"] .gc-live-panel__title strong{
    max-width: 100%;
  }

  html[data-gc-scope="app"] .gc-status-row{
    min-width: 0;
    gap: 10px;
  }

  html[data-gc-scope="app"] .gc-status-row strong,
  html[data-gc-scope="app"] .gc-live-panel__title strong{
    text-align: right;
    overflow-wrap: anywhere;
  }

  /* /app dashboard */
  html[data-gc-scope="app"] .gc-app-dashboard-v3{
    gap: var(--gc-app-safe-gap) !important;
  }

  html[data-gc-scope="app"] .gc-app-top-grid-v3,
  html[data-gc-scope="app"] .gc-app-combo-body-v3,
  html[data-gc-scope="app"] .gc-app-readout-grid-v3,
  html[data-gc-scope="app"] .gc-app-action-grid-v3{
    min-width: 0;
  }

  html[data-gc-scope="app"] .gc-app-combo-v3,
  html[data-gc-scope="app"] .gc-app-readout-card-v3,
  html[data-gc-scope="app"] .gc-app-references-v3,
  html[data-gc-scope="app"] .gc-app-actions-v3{
    overflow: hidden;
  }

  html[data-gc-scope="app"] .gc-app-combo-body-v3 > *,
  html[data-gc-scope="app"] .gc-app-readout-v3,
  html[data-gc-scope="app"] .gc-app-action-card-v3{
    min-width: 0;
  }

  html[data-gc-scope="app"] .gc-app-combo-body-v3 h3,
  html[data-gc-scope="app"] .gc-app-readout-v3 strong,
  html[data-gc-scope="app"] .gc-app-action-card-v3 p,
  html[data-gc-scope="app"] .gc-app-table-v3 td{
    overflow-wrap: anywhere;
  }

  html[data-gc-scope="app"] .gc-app-pit-actions-v6 .gc-btn{
    flex: 1 1 160px;
    min-width: min(100%, 160px);
  }

  html[data-gc-scope="app"] .gc-app-table-wrap-v3{
    max-height: min(420px, 62vh) !important;
  }

  html[data-gc-scope="app"] .gc-app-table-v3{
    min-width: 860px;
  }

  /* /hotlaps */
  html[data-gc-scope="app"] .gc-hotlaps-v8{
    gap: var(--gc-app-safe-gap) !important;
  }

  html[data-gc-scope="app"] .gc-hotlaps-toolbar-v8{
    display: flex !important;
    flex-wrap: wrap !important;
    align-items: end !important;
  }

  html[data-gc-scope="app"] .gc-hotlaps-toolbar-v8 .gc-field{
    flex: 1 1 190px !important;
  }

  html[data-gc-scope="app"] .gc-hotlaps-toolbar-v8 .gc-hotlaps-search-v8{
    flex: 2 1 320px !important;
  }

  html[data-gc-scope="app"] .gc-hotlaps-toolbar-v8 .gc-btn{
    flex: 0 0 auto;
  }

  html[data-gc-scope="app"] .gc-hotlaps-table-wrap-v8{
    max-height: min(680px, calc(100vh - 230px)) !important;
    min-height: 320px !important;
  }

  html[data-gc-scope="app"] .gc-hotlaps-table-v8{
    min-width: 1120px !important;
  }

  html[data-gc-scope="app"] .gc-hotlaps-table-v8 td:nth-child(2),
  html[data-gc-scope="app"] .gc-hotlaps-table-v8 td:nth-child(3),
  html[data-gc-scope="app"] .gc-hotlaps-table-v8 td:nth-child(4){
    min-width: 150px !important;
    max-width: 260px;
  }

  html[data-gc-scope="app"] .gc-driver-link{
    display: inline-block;
    max-width: 100%;
  }

  /* /combos */
  html[data-gc-scope="app"] .gc-combos-page-v42{
    gap: var(--gc-app-safe-gap) !important;
  }

  html[data-gc-scope="app"] .gc-combos-hero-v42,
  html[data-gc-scope="app"] .gc-combo-feature-grid-v42,
  html[data-gc-scope="app"] .gc-combo-grid-v42,
  html[data-gc-scope="app"] .gc-combos-metrics-v42{
    min-width: 0;
  }

  html[data-gc-scope="app"] .gc-combos-sidecard-v42{
    border-radius: 18px;
    overflow: hidden;
  }

  html[data-gc-scope="app"] .gc-combos-sidecard-v42 div{
    min-width: 0;
  }

  html[data-gc-scope="app"] .gc-combos-sidecard-v42 strong{
    min-width: 0;
    text-align: right;
    overflow-wrap: anywhere;
  }

  html[data-gc-scope="app"] .gc-combos-toolbar-v42 .gc-btn{
    min-width: min(100%, 140px);
  }

  html[data-gc-scope="app"] .gc-combo-feature-v42,
  html[data-gc-scope="app"] .gc-combo-card-v42{
    min-width: 0;
    border-radius: 20px;
  }

  html[data-gc-scope="app"] .gc-feature-body-v42,
  html[data-gc-scope="app"] .gc-card-body-v42{
    min-width: 0;
  }

  html[data-gc-scope="app"] .gc-feature-body-v42 h3,
  html[data-gc-scope="app"] .gc-card-body-v42 h3,
  html[data-gc-scope="app"] .gc-fastest-line-v52 strong,
  html[data-gc-scope="app"] .gc-car-summary-line-v52,
  html[data-gc-scope="app"] .gc-stat-badge-v42{
    overflow-wrap: anywhere;
  }

  html[data-gc-scope="app"] .gc-stats-row-v42 .gc-btn{
    width: auto;
    min-width: min(100%, 160px);
  }

  html[data-gc-scope="app"] .gc-combo-table-shell-v42{
    max-height: min(680px, 70vh);
  }

  html[data-gc-scope="app"] .gc-combo-table-v42{
    min-width: 960px !important;
  }

  html[data-gc-scope="app"] .gc-combo-table-v42 thead th{
    position: sticky;
    top: 0;
    z-index: 2;
    background: color-mix(in srgb, var(--bg, #050805) 92%, black);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  html[data-gc-scope="app"] .gc-combo-table-v42 td:nth-child(1),
  html[data-gc-scope="app"] .gc-combo-table-v42 td:nth-child(2),
  html[data-gc-scope="app"] .gc-combo-table-v42 td:nth-child(6){
    min-width: 170px;
  }

  /* Shared roster/profile guards */
  html[data-gc-scope="app"] .gc-pilot-card-v9,
  html[data-gc-scope="app"] .gc-pilot-identity-v20,
  html[data-gc-scope="app"] .gc-pilot-list-row-v20{
    min-width: 0;
    overflow: hidden;
  }

  html[data-gc-scope="app"] .gc-pilot-card-v9__top,
  html[data-gc-scope="app"] .gc-pilot-card-v9__actions{
    min-width: 0;
  }

  html[data-gc-scope="app"] .gc-pilot-card-v9__name,
  html[data-gc-scope="app"] .gc-piloto-name-v9,
  html[data-gc-scope="app"] .gc-pilot-list-title-v20,
  html[data-gc-scope="app"] .gc-pilot-identity-v20 strong{
    overflow-wrap: anywhere;
  }

  html[data-gc-scope="app"] .gc-pilot-table-wrap-v20,
  html[data-gc-scope="app"] .gc-pilotos-table-wrap-v9{
    max-height: min(680px, 70vh) !important;
  }

  /* Clearer loading/error/empty states */
  html[data-gc-scope="app"] .gc-empty-card-v42,
  html[data-gc-scope="app"] .gc-pilot-empty-v20,
  html[data-gc-scope="app"] #pilotStatus,
  html[data-gc-scope="app"] #leaderboardHint,
  html[data-gc-scope="app"] #cardsMeta{
    overflow-wrap: anywhere;
  }

  html[data-gc-scope="app"] .gc-empty-card-v42,
  html[data-gc-scope="app"] .gc-pilot-empty-v20{
    border-radius: 16px;
    background:
      radial-gradient(circle at 0% 0%, color-mix(in srgb, var(--accent, #9dff00) 8%, transparent), transparent 18rem),
      rgba(255,255,255,.022);
  }

  @media (max-width: 1280px){
    html[data-gc-scope="app"] .gc-app-top-grid-v3{
      grid-template-columns: 1fr !important;
    }

    html[data-gc-scope="app"] .gc-app-action-grid-v3{
      grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    }
  }

  @media (max-width: 980px){
    html[data-gc-scope="app"] .gc-page{
      overflow-x: hidden;
    }

    html[data-gc-scope="app"] .gc-hero,
    html[data-gc-scope="app"] .gc-combos-hero-v42,
    html[data-gc-scope="app"] .gc-pilotos-hero-v9,
    html[data-gc-scope="app"] .gc-hotlaps-hero-v8,
    html[data-gc-scope="app"] .gc-pilot-hero-v20,
    html[data-gc-scope="app"] .gc-app-hero-v3{
      grid-template-columns: 1fr !important;
      align-items: start !important;
    }

    html[data-gc-scope="app"] .gc-live-panel,
    html[data-gc-scope="app"] .gc-combos-sidecard-v42,
    html[data-gc-scope="app"] .gc-hero-sidecard{
      width: 100%;
    }

    html[data-gc-scope="app"] .gc-table-wrap,
    html[data-gc-scope="app"] .gc-combo-table-shell-v42{
      max-height: none !important;
    }

    html[data-gc-scope="app"] .gc-combo-feature-grid-v42,
    html[data-gc-scope="app"] .gc-combo-grid-v42,
    html[data-gc-scope="app"] .gc-pilot-card-grid-v9,
    html[data-gc-scope="app"] .gc-pilot-top-grid-v20,
    html[data-gc-scope="app"] .gc-pilot-grid-2-v20{
      grid-template-columns: 1fr !important;
    }

    html[data-gc-scope="app"] .gc-combos-metrics-v42,
    html[data-gc-scope="app"] .gc-metrics{
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
  }

  @media (max-width: 760px){
    html[data-gc-scope="app"] .gc-main{
      padding-inline: clamp(12px, 4vw, 18px) !important;
    }

    html[data-gc-scope="app"] .gc-title{
      font-size: clamp(2.25rem, 16vw, 3.65rem) !important;
      line-height: .88 !important;
    }

    html[data-gc-scope="app"] .gc-subtitle{
      font-size: .98rem;
    }

    html[data-gc-scope="app"] .gc-toolbar{
      display: grid !important;
      grid-template-columns: 1fr !important;
      gap: 10px !important;
    }

    html[data-gc-scope="app"] .gc-toolbar .gc-field,
    html[data-gc-scope="app"] .gc-toolbar .gc-btn{
      width: 100% !important;
      flex: 1 1 100% !important;
    }

    html[data-gc-scope="app"] .gc-table-meta{
      align-items: flex-start;
      justify-content: flex-start;
    }

    html[data-gc-scope="app"] .gc-app-combo-body-v3,
    html[data-gc-scope="app"] .gc-app-readout-grid-v3,
    html[data-gc-scope="app"] .gc-app-mini-stats-v3,
    html[data-gc-scope="app"] .gc-app-action-grid-v3,
    html[data-gc-scope="app"] .gc-combos-metrics-v42,
    html[data-gc-scope="app"] .gc-metrics{
      grid-template-columns: 1fr !important;
    }

    html[data-gc-scope="app"] .gc-app-card-head-v3,
    html[data-gc-scope="app"] .gc-combos-section-head-v42,
    html[data-gc-scope="app"] .gc-section-head{
      display: grid !important;
      grid-template-columns: 1fr !important;
      align-items: start !important;
      gap: 10px !important;
    }

    html[data-gc-scope="app"] .gc-app-card-head-v3 .gc-btn,
    html[data-gc-scope="app"] .gc-combos-section-head-v42 .gc-btn,
    html[data-gc-scope="app"] .gc-section-head .gc-btn{
      width: 100%;
    }

    html[data-gc-scope="app"] .gc-track-banner-v42,
    html[data-gc-scope="app"] .gc-combo-card-v42 .gc-track-banner-v42{
      height: clamp(124px, 38vw, 170px) !important;
    }

    html[data-gc-scope="app"] .gc-combo-feature-v42,
    html[data-gc-scope="app"] .gc-combo-card-v42{
      min-height: 0 !important;
    }

    html[data-gc-scope="app"] .gc-pilot-card-v9__top,
    html[data-gc-scope="app"] .gc-pilot-card-v9__actions{
      align-items: flex-start;
      flex-direction: column;
    }

    html[data-gc-scope="app"] .gc-pilot-card-v9__actions .gc-btn{
      width: 100%;
    }
  }

  @media (max-width: 520px){
    html[data-gc-scope="app"] .gc-table-wrap,
    html[data-gc-scope="app"] .gc-combo-table-shell-v42{
      margin-inline: calc(clamp(12px, 4vw, 18px) * -1);
      width: calc(100% + clamp(12px, 4vw, 18px) * 2);
      border-radius: 0;
      border-left: 0;
      border-right: 0;
    }

    html[data-gc-scope="app"] .gc-hotlaps-table-v8,
    html[data-gc-scope="app"] .gc-combo-table-v42,
    html[data-gc-scope="app"] .gc-pilotos-table-v9,
    html[data-gc-scope="app"] .gc-pilot-table-v20,
    html[data-gc-scope="app"] .gc-app-table-v3{
      min-width: 760px !important;
    }

    html[data-gc-scope="app"] th,
    html[data-gc-scope="app"] td{
      padding: 10px 11px !important;
      font-size: .82rem;
    }
  }
</style>

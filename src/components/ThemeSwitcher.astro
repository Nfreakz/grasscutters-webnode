---
const themes = [
  ['grasscutters', 'GrassCutters', 'Paleta oficial'],
  ['ocean', 'Ocean', 'Azul eléctrico'],
  ['violet', 'Violet', 'Violeta'],
  ['amber', 'Amber', 'Ámbar'],
  ['crimson', 'Crimson', 'Rojo competición'],
  ['mono', 'Mono', 'Escala de grises']
];
---
<div class="gc-theme gc-theme--dropdown" aria-label="Selector de paleta" data-theme-widget>
  <button
    class="gc-theme__trigger"
    type="button"
    aria-haspopup="listbox"
    aria-expanded="false"
    data-theme-trigger
  >
    <span class="gc-theme__trigger-copy">Paleta</span>
    <span class="gc-theme__trigger-swatch" data-theme-current-swatch></span>
    <span class="gc-theme__trigger-caret" aria-hidden="true">▾</span>
  </button>

  <div class="gc-theme__menu" role="listbox" aria-label="Paletas disponibles" data-theme-menu hidden>
    {themes.map(([key, label, description]) => (
      <button
        class={`gc-theme__option gc-theme__option--${key}`}
        data-theme-select={key}
        type="button"
        role="option"
        aria-selected="false"
      >
        <span class="gc-theme__option-swatch" aria-hidden="true"></span>
        <span class="gc-theme__option-copy">
          <strong>{label}</strong>
          <small>{description}</small>
        </span>
      </button>
    ))}
  </div>
</div>

<style is:global>
  .gc-theme--dropdown{
    position:relative;
    display:inline-flex;
    align-items:center;
    z-index:80;
  }

  .gc-theme__trigger{
    height:34px;
    min-height:34px;
    display:inline-flex;
    align-items:center;
    gap:7px;
    padding:0 9px;
    border:1px solid var(--line, var(--gc-mk-line, rgba(255,255,255,.14)));
    background:color-mix(in srgb, var(--panel, var(--gc-mk-panel, #101710)) 70%, transparent);
    color:var(--text, var(--gc-mk-text, #f4fff1));
    text-transform:uppercase;
    letter-spacing:.075em;
    font-size:.6rem;
    font-weight:950;
    border-radius:999px;
    cursor:pointer;
    box-shadow:0 10px 28px rgba(0,0,0,.12);
    line-height:1;
  }

  .gc-theme__trigger:hover,
  .gc-theme__trigger[aria-expanded="true"]{
    border-color:var(--accent, var(--gc-mk-accent, #9dff00));
  }

  .gc-theme__trigger-copy{
    color:var(--dim, var(--gc-mk-soft, rgba(243,247,239,.55)));
  }

  .gc-theme__trigger-swatch,
  .gc-theme__option-swatch{
    width:14px;
    height:14px;
    display:inline-block;
    flex:0 0 auto;
    border-radius:999px;
    border:1px solid color-mix(in srgb, var(--text, var(--gc-mk-text, #fff)) 45%, transparent);
    background:linear-gradient(135deg, var(--accent, var(--gc-mk-accent, #9dff00)), var(--accent2, var(--gc-mk-accent-2, #35d3ff)));
    box-shadow:inset 0 0 0 1px rgba(0,0,0,.24);
  }

  .gc-theme__trigger-caret{
    color:var(--accent, var(--gc-mk-accent, #9dff00));
    font-size:.62rem;
    line-height:1;
  }

  .gc-theme__menu{
    position:absolute;
    right:0;
    top:calc(100% + 8px);
    width:230px;
    padding:8px;
    border:1px solid var(--line2, var(--gc-mk-line, rgba(255,255,255,.16)));
    border-radius:18px;
    background:color-mix(in srgb, var(--bg, var(--gc-mk-bg, #061008)) 94%, #000);
    backdrop-filter:blur(16px);
    box-shadow:0 22px 70px rgba(0,0,0,.42);
  }

  .gc-theme__menu::before{
    content:"";
    position:absolute;
    right:18px;
    top:-1px;
    width:44px;
    height:2px;
    border-radius:999px;
    background:var(--accent, var(--gc-mk-accent, #9dff00));
    box-shadow:0 0 18px color-mix(in srgb, var(--accent, var(--gc-mk-accent, #9dff00)) 55%, transparent);
  }

  .gc-theme__option{
    width:100%;
    min-height:46px;
    display:grid;
    grid-template-columns:20px 1fr;
    gap:10px;
    align-items:center;
    padding:8px;
    border:1px solid transparent;
    border-radius:14px;
    background:transparent;
    color:var(--text, var(--gc-mk-text, #fff));
    text-align:left;
    cursor:pointer;
  }

  .gc-theme__option:hover,
  .gc-theme__option[aria-selected="true"]{
    border-color:var(--line, var(--gc-mk-line, rgba(255,255,255,.14)));
    background:rgba(255,255,255,.045);
  }

  .gc-theme__option[aria-selected="true"]{
    border-left-color:var(--accent, var(--gc-mk-accent, #9dff00));
  }

  .gc-theme__option-copy{
    display:grid;
    gap:1px;
  }

  .gc-theme__option-copy strong{
    text-transform:uppercase;
    letter-spacing:.09em;
    font-size:.72rem;
  }

  .gc-theme__option-copy small{
    color:var(--dim, var(--gc-mk-soft, rgba(243,247,239,.55)));
    font-size:.72rem;
  }

  .gc-theme__option--grasscutters .gc-theme__option-swatch{background:linear-gradient(135deg,#8cff00,#23f0cf)}
  .gc-theme__option--ocean .gc-theme__option-swatch{background:linear-gradient(135deg,#31d8ff,#00ffb3)}
  .gc-theme__option--violet .gc-theme__option-swatch{background:linear-gradient(135deg,#ad7cff,#72d2ff)}
  .gc-theme__option--amber .gc-theme__option-swatch{background:linear-gradient(135deg,#ffb23e,#ffe066)}
  .gc-theme__option--crimson .gc-theme__option-swatch{background:linear-gradient(135deg,#ff5872,#ffb84d)}
  .gc-theme__option--mono .gc-theme__option-swatch{background:linear-gradient(135deg,#f2f4f2,#747a76)}

  .gc-floating-scrolltop{
    position:fixed !important;
    top:auto !important;
    left:auto !important;
    right:max(22px, env(safe-area-inset-right)) !important;
    bottom:max(22px, env(safe-area-inset-bottom)) !important;
    z-index:9999 !important;
    min-height:40px;
    display:flex;
    align-items:center;
    gap:10px;
    padding:0 13px 0 9px;
    border:1px solid var(--line2, var(--gc-mk-line, rgba(255,255,255,.18)));
    border-left:3px solid var(--accent, var(--gc-mk-accent, #9dff00));
    border-radius:0;
    background:color-mix(in srgb, var(--bg, var(--gc-mk-bg, #061008)) 88%, transparent);
    color:var(--text, var(--gc-mk-text, #fff));
    text-transform:uppercase;
    letter-spacing:.08em;
    font-size:.68rem;
    font-weight:950;
    box-shadow:0 16px 48px rgba(0,0,0,.28);
    backdrop-filter:blur(14px);
    opacity:0;
    pointer-events:none;
    transform:translateY(14px);
    transition:opacity .18s ease, transform .18s ease, border-color .18s ease, color .18s ease, background .18s ease;
    cursor:pointer;
  }

  .gc-floating-scrolltop[data-visible="true"]{
    opacity:1;
    pointer-events:auto;
    transform:translateY(0);
  }

  .gc-floating-scrolltop:hover{
    color:var(--accent, var(--gc-mk-accent, #9dff00));
    border-color:var(--accent, var(--gc-mk-accent, #9dff00));
    background:color-mix(in srgb, var(--bg, var(--gc-mk-bg, #061008)) 74%, transparent);
  }

  .gc-floating-scrolltop__mark{
    width:24px;
    height:24px;
    display:grid;
    place-items:center;
    border:1px solid var(--line, var(--gc-mk-line, rgba(255,255,255,.14)));
    color:var(--accent, var(--gc-mk-accent, #9dff00));
    font-size:1rem;
    font-weight:1000;
    line-height:1;
  }

  .gc-floating-scrolltop__copy{
    white-space:nowrap;
  }

  @media(max-width:820px){
    .gc-theme__trigger-copy,
    .gc-theme__trigger-name{display:none !important}
    .gc-theme__trigger{padding:0 9px}
    .gc-theme__menu{right:-44px;width:220px}
  }

  @media(max-width:560px){
    .gc-theme--dropdown{display:inline-flex}
    .gc-floating-scrolltop{
      right:14px !important;
      bottom:14px !important;
      min-height:38px;
      padding-right:10px;
    }
    .gc-floating-scrolltop__copy{display:none}
  }
</style>

<script is:inline>
  (() => {
    const storageKey = 'gc-theme';
    const root = document.documentElement;
    const widgets = [...document.querySelectorAll('[data-theme-widget]')];
    const themeNames = {
      grasscutters: 'GrassCutters',
      ocean: 'Ocean',
      violet: 'Violet',
      amber: 'Amber',
      crimson: 'Crimson',
      mono: 'Mono'
    };
    const legacyMap = { lfm: 'grasscutters', grass: 'grasscutters' };
    const themeVars = {
      grasscutters: {
        bg: '#061008', bg2: '#0a170c', panel: '#0e1d11', panel2: '#142418',
        line: 'rgba(255,255,255,.10)', line2: 'rgba(255,255,255,.18)',
        text: '#f4fff1', soft: '#c8dcc7', dim: '#748b75', muted: '#405342',
        accent: '#9dff00', accent2: '#35d3ff', ok: '#9dff00', warn: '#ffd166', danger: '#ff5872',
        mkBg: '#070a08', mkBg2: '#0d120f', mkAccent: '#9bf542', mkAccent2: '#27d3a0'
      },
      ocean: {
        bg: '#041014', bg2: '#071923', panel: '#0c2028', panel2: '#132c35',
        line: 'rgba(255,255,255,.11)', line2: 'rgba(255,255,255,.2)',
        text: '#f0fbff', soft: '#c2e7ef', dim: '#73a9b7', muted: '#385664',
        accent: '#31d8ff', accent2: '#00ffb3', ok: '#00ffb3', warn: '#ffd166', danger: '#ff5872',
        mkBg: '#041014', mkBg2: '#071923', mkAccent: '#31d8ff', mkAccent2: '#00ffb3'
      },
      violet: {
        bg: '#0c0816', bg2: '#141024', panel: '#1a142f', panel2: '#221a3f',
        line: 'rgba(255,255,255,.12)', line2: 'rgba(255,255,255,.21)',
        text: '#fbf6ff', soft: '#ddcef2', dim: '#a48ac4', muted: '#594a72',
        accent: '#ad7cff', accent2: '#72d2ff', ok: '#ad7cff', warn: '#ffd166', danger: '#ff5872',
        mkBg: '#0c0816', mkBg2: '#141024', mkAccent: '#ad7cff', mkAccent2: '#72d2ff'
      },
      amber: {
        bg: '#100b05', bg2: '#171006', panel: '#1b140a', panel2: '#261b0d',
        line: 'rgba(255,255,255,.11)', line2: 'rgba(255,255,255,.2)',
        text: '#fff8e8', soft: '#ead8b8', dim: '#a88954', muted: '#5d4b2c',
        accent: '#ffb23e', accent2: '#ffe066', ok: '#ffde6a', warn: '#ffd166', danger: '#ff5872',
        mkBg: '#100b05', mkBg2: '#171006', mkAccent: '#ffb23e', mkAccent2: '#ffe066'
      },
      crimson: {
        bg: '#12070b', bg2: '#1a0c11', panel: '#211016', panel2: '#301620',
        line: 'rgba(255,255,255,.12)', line2: 'rgba(255,255,255,.22)',
        text: '#fff4f6', soft: '#efc7ce', dim: '#b57884', muted: '#6c3a45',
        accent: '#ff5872', accent2: '#ffb84d', ok: '#ffb84d', warn: '#ffd166', danger: '#ff5872',
        mkBg: '#12070b', mkBg2: '#1a0c11', mkAccent: '#ff5872', mkAccent2: '#ffb84d'
      },
      mono: {
        bg: '#080908', bg2: '#101211', panel: '#151817', panel2: '#202423',
        line: 'rgba(255,255,255,.13)', line2: 'rgba(255,255,255,.22)',
        text: '#f4f5f2', soft: '#d4d8d2', dim: '#8e968e', muted: '#5e665f',
        accent: '#d7dad5', accent2: '#8c948e', ok: '#e4e6e1', warn: '#d2c49d', danger: '#c98282',
        mkBg: '#080908', mkBg2: '#111312', mkAccent: '#d7dad5', mkAccent2: '#8c948e'
      }
    };

    function normalizeTheme(value) {
      const key = String(value || '').trim().toLowerCase();
      return themeNames[key] ? key : (legacyMap[key] || 'grasscutters');
    }

    function setVars(vars) {
      if (!vars) return;
      root.style.setProperty('--bg', vars.bg);
      root.style.setProperty('--bg2', vars.bg2);
      root.style.setProperty('--panel', vars.panel);
      root.style.setProperty('--panel2', vars.panel2);
      root.style.setProperty('--line', vars.line);
      root.style.setProperty('--line2', vars.line2);
      root.style.setProperty('--text', vars.text);
      root.style.setProperty('--soft', vars.soft);
      root.style.setProperty('--dim', vars.dim);
      root.style.setProperty('--muted', vars.muted);
      root.style.setProperty('--accent', vars.accent);
      root.style.setProperty('--accent2', vars.accent2);
      root.style.setProperty('--ok', vars.ok);
      root.style.setProperty('--warn', vars.warn);
      root.style.setProperty('--danger', vars.danger);
      root.style.setProperty('--gc-mk-bg', vars.mkBg);
      root.style.setProperty('--gc-mk-bg-2', vars.mkBg2);
      root.style.setProperty('--gc-mk-accent', vars.mkAccent);
      root.style.setProperty('--gc-mk-accent-2', vars.mkAccent2);
    }

    function applyTheme(theme) {
      const safeTheme = normalizeTheme(theme);
      root.dataset.theme = safeTheme;
      setVars(themeVars[safeTheme]);
      try { localStorage.setItem(storageKey, safeTheme); } catch (_) {}

      widgets.forEach((widget) => {
        const trigger = widget.querySelector('[data-theme-trigger]');
        const swatch = widget.querySelector('[data-theme-current-swatch]');
        const options = [...widget.querySelectorAll('[data-theme-select]')];
        if (trigger) trigger.setAttribute('title', `Paleta: ${themeNames[safeTheme]}`);
        if (swatch) swatch.setAttribute('data-theme-current', safeTheme);
        options.forEach((option) => {
          const selected = option.dataset.themeSelect === safeTheme;
          option.setAttribute('aria-selected', String(selected));
        });
      });
    }

    function closeMenus() {
      widgets.forEach((widget) => {
        const trigger = widget.querySelector('[data-theme-trigger]');
        const menu = widget.querySelector('[data-theme-menu]');
        if (trigger) trigger.setAttribute('aria-expanded', 'false');
        if (menu) menu.hidden = true;
      });
    }

    widgets.forEach((widget) => {
      const trigger = widget.querySelector('[data-theme-trigger]');
      const menu = widget.querySelector('[data-theme-menu]');
      const options = [...widget.querySelectorAll('[data-theme-select]')];

      trigger?.addEventListener('click', (event) => {
        event.stopPropagation();
        const open = trigger.getAttribute('aria-expanded') === 'true';
        closeMenus();
        trigger.setAttribute('aria-expanded', String(!open));
        if (menu) menu.hidden = open;
      });

      options.forEach((option) => {
        option.addEventListener('click', () => {
          applyTheme(option.dataset.themeSelect);
          closeMenus();
        });
      });
    });

    document.addEventListener('click', closeMenus);
    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenus();
    });

    function ensureBackTopButton() {
      if (document.querySelector('.gc-floating-scrolltop')) return document.querySelector('.gc-floating-scrolltop');
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'gc-floating-scrolltop';
      button.setAttribute('aria-label', 'Volver arriba');
      button.setAttribute('title', 'Volver arriba');
      button.innerHTML = '<span class="gc-floating-scrolltop__mark" aria-hidden="true">↑</span><span class="gc-floating-scrolltop__copy">Volver arriba</span>';
      button.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      document.body.appendChild(button);
      return button;
    }

    const backTop = ensureBackTopButton();
    let ticking = false;
    const updateBackTop = () => {
      ticking = false;
      if (!backTop) return;
      backTop.dataset.visible = String(window.scrollY > 420);
    };
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateBackTop);
    }, { passive: true });

    const initialTheme = normalizeTheme(localStorage.getItem(storageKey) || root.dataset.theme || 'grasscutters');
    applyTheme(initialTheme);
    updateBackTop();
  })();
</script>

---
const themes = [
  ['grasscutters', 'GrassCutters', 'Paleta oficial'],
  ['ocean', 'Ocean', 'Azul eléctrico'],
  ['violet', 'Violet', 'Violeta'],
  ['amber', 'Amber', 'Ámbar'],
  ['crimson', 'Crimson', 'Rojo competición'],
  ['mono', 'Mono', 'Escala de grises']
];
---
<div class="gc-theme gc-theme--dropdown" aria-label="Selector de paleta" data-theme-widget>
  <button
    class="gc-theme__trigger"
    type="button"
    aria-haspopup="listbox"
    aria-expanded="false"
    data-theme-trigger
  >
    <span class="gc-theme__trigger-copy">Paleta</span>
    <span class="gc-theme__trigger-swatch" data-theme-current-swatch></span>
    <span class="gc-theme__trigger-name" data-theme-current-name>GrassCutters</span>
    <span class="gc-theme__trigger-caret" aria-hidden="true">▾</span>
  </button>

  <div class="gc-theme__menu" role="listbox" aria-label="Paletas disponibles" data-theme-menu hidden>
    {themes.map(([key, label, description]) => (
      <button
        class={`gc-theme__option gc-theme__option--${key}`}
        data-theme-select={key}
        type="button"
        role="option"
        aria-selected="false"
      >
        <span class="gc-theme__option-swatch" aria-hidden="true"></span>
        <span class="gc-theme__option-copy">
          <strong>{label}</strong>
          <small>{description}</small>
        </span>
      </button>
    ))}
  </div>
</div>

<button class="gc-scrolltop" type="button" data-scroll-top aria-label="Volver arriba">
  <span class="gc-scrolltop__mark" aria-hidden="true">↑</span>
  <span class="gc-scrolltop__copy">Volver arriba</span>
</button>

<style is:global>
  .gc-theme--dropdown{
    position:relative;
    display:inline-flex;
    align-items:center;
    z-index:80;
  }

  .gc-theme__trigger{
    height:36px;
    display:inline-flex;
    align-items:center;
    gap:8px;
    padding:0 10px;
    border:1px solid var(--line, var(--gc-mk-line, rgba(255,255,255,.14)));
    background:color-mix(in srgb, var(--panel, var(--gc-mk-panel, #101710)) 70%, transparent);
    color:var(--text, var(--gc-mk-text, #f4fff1));
    text-transform:uppercase;
    letter-spacing:.1em;
    font-size:.68rem;
    font-weight:950;
    border-radius:0;
    cursor:pointer;
    box-shadow:0 10px 28px rgba(0,0,0,.12);
  }

  .gc-theme__trigger:hover,
  .gc-theme__trigger[aria-expanded="true"]{border-color:var(--accent, var(--gc-mk-accent, #9dff00))}
  .gc-theme__trigger-copy{color:var(--dim, var(--gc-mk-soft, rgba(243,247,239,.55)))}

  .gc-theme__trigger-swatch,
  .gc-theme__option-swatch{
    width:16px;
    height:16px;
    display:inline-block;
    flex:0 0 auto;
    border:1px solid color-mix(in srgb, var(--text, var(--gc-mk-text, #fff)) 45%, transparent);
    background:linear-gradient(135deg,var(--accent, var(--gc-mk-accent, #9dff00)),var(--accent2, var(--gc-mk-accent-2, #35d3ff)));
    box-shadow:inset 0 0 0 1px rgba(0,0,0,.24);
  }

  .gc-theme__trigger-name{min-width:92px;text-align:left;color:var(--text, var(--gc-mk-text, #fff))}
  .gc-theme__trigger-caret{margin-left:1px;color:var(--accent, var(--gc-mk-accent, #9dff00));font-size:.74rem;line-height:1}

  .gc-theme__menu{
    position:absolute;
    right:0;
    top:calc(100% + 8px);
    width:230px;
    padding:8px;
    border:1px solid var(--line2, var(--gc-mk-line, rgba(255,255,255,.16)));
    background:color-mix(in srgb, var(--bg, var(--gc-mk-bg, #061008)) 94%, #000);
    backdrop-filter:blur(16px);
    box-shadow:0 22px 70px rgba(0,0,0,.42);
  }

  .gc-theme__menu::before{
    content:"";
    position:absolute;
    right:18px;
    top:-1px;
    width:44px;
    height:2px;
    background:var(--accent, var(--gc-mk-accent, #9dff00));
    box-shadow:0 0 18px color-mix(in srgb, var(--accent, var(--gc-mk-accent, #9dff00)) 55%, transparent);
  }

  .gc-theme__option{
    width:100%;
    min-height:46px;
    display:grid;
    grid-template-columns:20px 1fr;
    gap:10px;
    align-items:center;
    padding:8px;
    border:1px solid transparent;
    background:transparent;
    color:var(--text, var(--gc-mk-text, #fff));
    text-align:left;
    cursor:pointer;
  }

  .gc-theme__option:hover,
  .gc-theme__option[aria-selected="true"]{
    border-color:var(--line, var(--gc-mk-line, rgba(255,255,255,.14)));
    background:rgba(255,255,255,.045);
  }

  .gc-theme__option[aria-selected="true"]{border-left-color:var(--accent, var(--gc-mk-accent, #9dff00))}
  .gc-theme__option-copy{display:grid;gap:1px}
  .gc-theme__option-copy strong{text-transform:uppercase;letter-spacing:.09em;font-size:.72rem}
  .gc-theme__option-copy small{color:var(--dim, var(--gc-mk-soft, rgba(243,247,239,.55)));font-size:.72rem}

  .gc-theme__option--grasscutters .gc-theme__option-swatch{background:linear-gradient(135deg,#8cff00,#23f0cf)}
  .gc-theme__option--ocean .gc-theme__option-swatch{background:linear-gradient(135deg,#31d8ff,#00ffb3)}
  .gc-theme__option--violet .gc-theme__option-swatch{background:linear-gradient(135deg,#ad7cff,#72d2ff)}
  .gc-theme__option--amber .gc-theme__option-swatch{background:linear-gradient(135deg,#ffb23e,#ffe066)}
  .gc-theme__option--crimson .gc-theme__option-swatch{background:linear-gradient(135deg,#ff5872,#ffb84d)}
  .gc-theme__option--mono .gc-theme__option-swatch{background:linear-gradient(135deg,#f2f4f2,#747a76)}

  html[data-theme="mono"]{
    --bg:#080908;--bg2:#101211;--panel:#151817;--panel2:#202423;
    --line:rgba(255,255,255,.13);--line2:rgba(255,255,255,.22);
    --text:#f4f5f2;--soft:#d4d8d2;--dim:#8e968e;--muted:#5e665f;
    --accent:#d7dad5;--accent2:#8c948e;--ok:#e4e6e1;--warn:#d2c49d;--danger:#c98282;
    --gc-mk-bg:#080908;--gc-mk-bg-2:#111312;--gc-mk-panel:rgba(255,255,255,.055);
    --gc-mk-panel-strong:rgba(255,255,255,.085);--gc-mk-line:rgba(255,255,255,.14);
    --gc-mk-line-soft:rgba(255,255,255,.08);--gc-mk-text:#f4f5f2;
    --gc-mk-muted:rgba(244,245,242,.74);--gc-mk-soft:rgba(244,245,242,.52);
    --gc-mk-accent:#d7dad5;--gc-mk-accent-2:#8c948e;
  }

  html[data-theme="mono"] .gc-btn--primary,
  html[data-theme="mono"] .gc-btn-primary,
  html[data-theme="mono"] .gc-public-nav a.is-active,
  html[data-theme="mono"] .gc-public-cta,
  html[data-theme="mono"] .gc-public-brand-mark,
  html[data-theme="mono"] .gc-brand__mark,
  html[data-theme="mono"] .gc-card code,
  html[data-theme="mono"] .gc-lane > span,
  html[data-theme="mono"] .gc-row-num,
  html[data-theme="mono"] .gc-policy-card span{
    background:linear-gradient(135deg,#f2f4f2,#a5aaa6);
    color:#0d0f0e;
  }

  .gc-auth-status{
    height:36px;
    display:inline-flex;
    align-items:center;
    gap:8px;
    padding:0 11px;
    border:1px solid color-mix(in srgb,var(--accent, var(--gc-mk-accent, #9dff00)) 55%, transparent);
    color:var(--accent, var(--gc-mk-accent, #9dff00));
    text-transform:uppercase;
    letter-spacing:.1em;
    font-size:.68rem;
    font-weight:950;
    background:rgba(255,255,255,.018);
    white-space:nowrap;
  }
  .gc-auth-status::before{
    content:"";
    width:7px;
    height:7px;
    background:currentColor;
    box-shadow:0 0 14px currentColor;
  }
  .gc-auth-profile-link.is-authenticated{
    border-color:var(--accent, var(--gc-mk-accent, #9dff00));
  }

  .gc-scrolltop{
    position:fixed;
    right:22px;
    bottom:84px;
    z-index:75;
    min-height:42px;
    display:flex;
    align-items:center;
    gap:10px;
    padding:0 14px 0 10px;
    border:1px solid var(--line2, var(--gc-mk-line, rgba(255,255,255,.18)));
    border-left:3px solid var(--accent, var(--gc-mk-accent, #9dff00));
    background:color-mix(in srgb, var(--bg, var(--gc-mk-bg, #061008)) 86%, transparent);
    color:var(--text, var(--gc-mk-text, #fff));
    text-transform:uppercase;
    letter-spacing:.09em;
    font-size:.72rem;
    font-weight:950;
    opacity:0;
    pointer-events:none;
    transform:translateY(14px);
    transition:opacity .18s ease, transform .18s ease, border-color .18s ease, color .18s ease;
    backdrop-filter:blur(14px);
    box-shadow:0 16px 48px rgba(0,0,0,.28);
  }

  .gc-scrolltop[data-visible="true"]{opacity:1;pointer-events:auto;transform:translateY(0)}
  .gc-scrolltop:hover{color:var(--accent, var(--gc-mk-accent, #9dff00));border-color:var(--accent, var(--gc-mk-accent, #9dff00))}
  .gc-scrolltop__mark{width:24px;height:24px;display:grid;place-items:center;border:1px solid var(--line, var(--gc-mk-line, rgba(255,255,255,.14)));color:var(--accent, var(--gc-mk-accent, #9dff00))}

  @media(max-width:820px){
    .gc-theme__trigger-copy,.gc-theme__trigger-name{display:none}
    .gc-theme__trigger{padding:0 9px}
    .gc-theme__menu{right:-44px;width:220px}
    .gc-auth-status{display:none}
  }
  @media(max-width:560px){
    .gc-theme--dropdown{display:inline-flex}
    .gc-scrolltop{right:14px;bottom:76px;min-height:38px;padding-right:10px}
    .gc-scrolltop__copy{display:none}
  }
</style>

<script is:inline>
  (() => {
    const storageKey = 'gc-theme';
    const root = document.documentElement;
    const widgets = [...document.querySelectorAll('[data-theme-widget]')];
    const scrollTopButton = document.querySelector('[data-scroll-top]');
    const themeNames = {
      grasscutters: 'GrassCutters',
      ocean: 'Ocean',
      violet: 'Violet',
      amber: 'Amber',
      crimson: 'Crimson',
      mono: 'Mono'
    };
    const legacyMap = { lfm: 'grasscutters', grass: 'grasscutters' };
    const themeVars = {
      grasscutters: { accent: '#8cff00', accent2: '#23f0cf', mkAccent: '#8cff00', mkAccent2: '#23f0cf' },
      ocean: { accent: '#31d8ff', accent2: '#00ffb3', mkAccent: '#31d8ff', mkAccent2: '#00ffb3' },
      violet: { accent: '#ad7cff', accent2: '#72d2ff', mkAccent: '#ad7cff', mkAccent2: '#72d2ff' },
      amber: { accent: '#ffb23e', accent2: '#ffe066', mkAccent: '#ffb23e', mkAccent2: '#ffe066' },
      crimson: { accent: '#ff5872', accent2: '#ffb84d', mkAccent: '#ff5872', mkAccent2: '#ffb84d' },
      mono: { accent: '#d7dad5', accent2: '#8c948e', mkAccent: '#d7dad5', mkAccent2: '#8c948e' }
    };
    const allowed = new Set(Object.keys(themeNames));

    const applyThemeVars = (theme) => {
      const vars = themeVars[theme] || themeVars.grasscutters;
      root.style.setProperty('--accent', vars.accent);
      root.style.setProperty('--accent2', vars.accent2);
      root.style.setProperty('--ok', theme === 'mono' ? '#e4e6e1' : vars.accent);
      root.style.setProperty('--gc-mk-accent', vars.mkAccent);
      root.style.setProperty('--gc-mk-accent-2', vars.mkAccent2);
    };

    const closeAllMenus = () => {
      widgets.forEach((widget) => {
        widget.querySelector('[data-theme-menu]')?.setAttribute('hidden', '');
        widget.querySelector('[data-theme-trigger]')?.setAttribute('aria-expanded', 'false');
      });
    };

    const setTheme = (theme) => {
      const mapped = legacyMap[theme] || theme;
      const next = allowed.has(mapped) ? mapped : 'grasscutters';
      root.dataset.theme = next;
      applyThemeVars(next);
      try { localStorage.setItem(storageKey, next); } catch (_) {}
      widgets.forEach((widget) => {
        const name = widget.querySelector('[data-theme-current-name]');
        if (name) name.textContent = themeNames[next];
        widget.querySelectorAll('[data-theme-select]').forEach((item) => {
          item.setAttribute('aria-selected', String(item.dataset.themeSelect === next));
        });
      });
    };

    let saved = 'grasscutters';
    try { saved = localStorage.getItem(storageKey) || 'grasscutters'; } catch (_) {}
    setTheme(saved);

    widgets.forEach((widget) => {
      const trigger = widget.querySelector('[data-theme-trigger]');
      const menu = widget.querySelector('[data-theme-menu]');
      trigger?.addEventListener('click', (event) => {
        event.stopPropagation();
        const willOpen = menu?.hasAttribute('hidden');
        closeAllMenus();
        if (willOpen) {
          menu?.removeAttribute('hidden');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
      widget.querySelectorAll('[data-theme-select]').forEach((item) => {
        item.addEventListener('click', (event) => {
          event.stopPropagation();
          setTheme(item.dataset.themeSelect);
          closeAllMenus();
        });
      });
    });

    document.addEventListener('click', closeAllMenus);
    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeAllMenus();
    });

    const updateScrollTop = () => {
      if (!scrollTopButton) return;
      scrollTopButton.dataset.visible = String(window.scrollY > 520);
    };

    scrollTopButton?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    updateScrollTop();
    window.addEventListener('scroll', updateScrollTop, { passive: true });

    const findUser = (data) => {
      const candidates = [
        data?.user,
        data?.currentUser,
        data?.auth?.user,
        data?.session?.user,
        data?.account,
        data?.profile
      ].filter(Boolean);
      return candidates[0] || null;
    };

    const getUserName = (user) => {
      const raw = user?.displayName || user?.display_name || user?.name || user?.username || user?.email || '';
      const text = String(raw || '').trim();
      if (!text) return 'Mi perfil';
      return text.includes('@') ? text.split('@')[0] : text;
    };

    const findLoginLinks = () => {
      const selectors = [
        '.gc-public-header a[href="/login"]',
        '.gc-public-actions a[href="/login"]',
        '.gc-topbar a[href="/login"]',
        '.gc-login-link',
        'header a[href="/login"]'
      ];
      return [...new Set(selectors.flatMap((selector) => [...document.querySelectorAll(selector)]))];
    };

    const ensureAuthStatus = (container, name) => {
      if (!container) return;
      let status = container.querySelector('[data-gc-auth-status]');
      if (!status) {
        status = document.createElement('span');
        status.className = 'gc-auth-status';
        status.setAttribute('data-gc-auth-status', 'true');
        const firstLogin = container.querySelector('a[href="/login"], .gc-login-link, .gc-public-link');
        if (firstLogin) container.insertBefore(status, firstLogin);
        else container.appendChild(status);
      }
      status.textContent = 'Conectado';
      status.title = `Conectado como ${name}`;
      status.hidden = false;
    };

    const hideAuthStatus = () => {
      document.querySelectorAll('[data-gc-auth-status], .gc-auth-status').forEach((item) => {
        item.hidden = true;
      });
    };

    const setLoggedOutHeader = () => {
      hideAuthStatus();
      findLoginLinks().forEach((link) => {
        link.textContent = 'Login';
        link.setAttribute('href', '/login');
        link.classList.remove('is-authenticated', 'gc-auth-profile-link');
      });
    };

    const setLoggedInHeader = (user) => {
      const name = getUserName(user);
      findLoginLinks().forEach((link) => {
        link.textContent = name;
        link.setAttribute('href', '/perfil');
        link.classList.add('is-authenticated', 'gc-auth-profile-link');
        link.setAttribute('title', `Ir al perfil de ${name}`);
      });
      ensureAuthStatus(document.querySelector('.gc-public-actions'), name);
      ensureAuthStatus(document.querySelector('.gc-topbar__right'), name);
    };

    fetch('/api/auth/status', { credentials: 'include', cache: 'no-store' })
      .then((res) => res.ok ? res.json() : null)
      .then((data) => {
        const user = findUser(data || {});
        const authenticated = Boolean(data?.authenticated || data?.okAuthenticated || data?.loggedIn || data?.isAuthenticated || user);
        if (authenticated && user) setLoggedInHeader(user);
        else setLoggedOutHeader();
      })
      .catch(setLoggedOutHeader);
  })();
</script>

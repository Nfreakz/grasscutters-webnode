---
import AppLayout from '../../layouts/AppLayout.astro';
import AdminSubnav from '../../components/AdminSubnav.astro';

const categories = ['Update', 'Sim racing', 'Motorsport', 'Herramientas', 'GrassCutters'];
---

<AppLayout title="Noticias | Admin GrassCutters">
  <div class="gc-page gc-admin-page-clean gc-news-admin-system-v1">
    <section class="gc-hero gc-hero--compact">
      <div>
        <span class="gc-kicker">Noticias</span>
        <h1 class="gc-title">Gestión de noticias.</h1>
        <p class="gc-subtitle">Newsroom con buscador, filtros, paginación y editor simple. Mismo criterio que Archivo, pero adaptado a publicaciones rápidas.</p>
      </div>

      <aside class="gc-live-panel">
        <div class="gc-live-panel__title"><span>Noticias</span><strong id="newsAdminState">Cargando</strong></div>
        <div class="gc-status-list">
          <div class="gc-status-row"><span>Total</span><strong id="newsTotal">...</strong></div>
          <div class="gc-status-row"><span>Publicadas</span><strong id="newsPublished">...</strong></div>
          <div class="gc-status-row"><span>Sin imagen</span><strong id="newsMissingImages">...</strong></div>
        </div>
      </aside>
    </section>

    <AdminSubnav />

    <section class="gc-news-admin-layout-v1">
      <article class="gc-section">
        <div class="gc-section-head">
          <div>
            <span class="gc-kicker">Listado</span>
            <h2>Noticias</h2>
            <p>Filtra por categoría, estado, imagen o texto. Preparado para cuando el newsroom crezca.</p>
          </div>
          <div class="gc-admin-actions">
            <button class="gc-btn gc-btn--primary" id="newPostBtn" type="button">Nueva noticia</button>
            <a class="gc-btn" href="/admin/noticias/importar">Importar</a>
            <a class="gc-btn" href="/admin/noticias/imagenes">Imágenes</a>
            <button class="gc-btn" id="refreshNewsBtn" type="button">Recargar</button>
            <button class="gc-btn" id="demoNewsBtn" type="button">Demo</button>
          </div>
        </div>

        <div class="gc-slab gc-news-toolbar-v1">
          <label class="gc-news-field">
            <span>Buscar</span>
            <input id="newsSearchInput" type="search" placeholder="HUD, sim racing, motorsport, update..." autocomplete="off" />
          </label>

          <div class="gc-news-filter-grid-v1">
            <label><span>Categoría</span><select id="newsCategoryFilter"><option value="all">Todo</option>{categories.map((category) => <option value={category}>{category}</option>)}</select></label>
            <label><span>Estado</span><select id="newsStatusFilter"><option value="all">Todo</option><option value="published">Publicado</option><option value="draft">Borrador</option><option value="hidden">Oculto</option></select></label>
            <label><span>Imagen</span><select id="newsImageFilter"><option value="all">Todo</option><option value="with">Con imagen</option><option value="missing">Sin imagen</option></select></label>
            <label><span>Orden</span><select id="newsSortSelect"><option value="date-desc">Fecha reciente</option><option value="title-asc">Título A-Z</option><option value="category-asc">Categoría</option><option value="status-asc">Estado</option></select></label>
            <label><span>Por página</span><select id="newsPageSize"><option value="10">10</option><option value="20" selected>20</option><option value="40">40</option><option value="80">80</option></select></label>
          </div>

          <div class="gc-news-pills-v1">
            <button type="button" class="is-active" data-news-quick="all">Todo</button>
            {categories.map((category) => <button type="button" data-news-quick={category}>{category}</button>)}
            <button type="button" data-news-image-quick="missing">Sin imagen</button>
          </div>

          <div class="gc-news-list-summary-v1">
            <strong id="newsVisibleCount">0</strong>
            <span>noticias visibles</span>
            <button class="gc-btn" id="newsClearFilters" type="button">Limpiar filtros</button>
          </div>
        </div>

        <div class="gc-slab" id="newsNotice" hidden><h3 id="newsNoticeTitle">Aviso</h3><p id="newsNoticeText"></p></div>

        <div class="gc-news-table-head-v1">
          <span>Noticia</span>
          <span>Categoría</span>
          <span>Estado</span>
          <span>Imagen</span>
          <span>Acciones</span>
        </div>

        <div class="gc-news-list-v1" id="newsList"><div class="gc-admin-empty">Cargando noticias...</div></div>

        <nav class="gc-news-pagination-v1" aria-label="Paginación noticias">
          <button class="gc-btn" type="button" id="newsPrevPage">Anterior</button>
          <span id="newsPageInfo">Página 1/1</span>
          <button class="gc-btn" type="button" id="newsNextPage">Siguiente</button>
        </nav>
      </article>

      <aside class="gc-section gc-news-editor-panel-v1">
        <div class="gc-section-head">
          <div>
            <span class="gc-kicker">Editor</span>
            <h2 id="editorTitle">Nueva noticia</h2>
            <p id="editorHint">Rellena los campos y guarda como borrador o publicado.</p>
          </div>
        </div>

        <form id="newsForm" class="gc-news-editor-form-v1">
          <input type="hidden" id="fieldId" />

          <details class="gc-news-editor-block-v1" open>
            <summary><strong>1. Básico</strong><span>Título, estado, categoría y fecha</span></summary>
            <div>
              <label class="gc-news-field gc-field--full"><span>Título</span><input id="fieldTitle" required /></label>
              <label class="gc-news-field"><span>Slug</span><input id="fieldSlug" placeholder="se genera desde el título" /></label>
              <label class="gc-news-field"><span>Estado</span><select id="fieldStatus"><option value="draft">Borrador</option><option value="published">Publicado</option><option value="hidden">Oculto</option></select></label>
              <label class="gc-news-field"><span>Categoría</span><select id="fieldCategory">{categories.map((category) => <option value={category}>{category}</option>)}</select></label>
              <label class="gc-news-field"><span>Fecha publicación</span><input id="fieldPublishedAt" type="datetime-local" /></label>
              <label class="gc-news-field"><span>Destacada</span><select id="fieldFeatured"><option value="false">No</option><option value="true">Sí</option></select></label>
              <label class="gc-news-field"><span>Fijada arriba</span><select id="fieldPinned"><option value="false">No</option><option value="true">Sí</option></select></label>
            </div>
          </details>

          <details class="gc-news-editor-block-v1" open>
            <summary><strong>2. Imagen</strong><span>URL, subida y créditos</span></summary>
            <div>
              <label class="gc-news-field gc-field--full"><span>Imagen URL</span><input id="fieldImage" placeholder="/uploads/news/imagen.webp" /></label>
              <label class="gc-news-field gc-field--full"><span>Subir imagen</span><input id="fieldImageFile" type="file" accept="image/png,image/jpeg,image/webp,image/svg+xml" /></label>
              <label class="gc-news-field gc-field--full"><span>Alt imagen</span><input id="fieldImageAlt" placeholder="Descripción breve de la imagen" /></label>
              <label class="gc-news-field"><span>Fuente</span><input id="fieldImageSource" placeholder="GrassCutters Racing" /></label>
              <label class="gc-news-field"><span>Autor</span><input id="fieldImageAuthor" /></label>
              <label class="gc-news-field"><span>Licencia</span><input id="fieldImageLicense" placeholder="Imagen propia / CC BY..." /></label>
              <label class="gc-news-field"><span>URL fuente</span><input id="fieldImageSourceUrl" /></label>
              <div class="gc-news-image-preview-v1 gc-field--full">
                <img id="newsImagePreview" src="" alt="" hidden />
                <span id="newsImagePreviewEmpty">Preview de imagen</span>
              </div>
            </div>
          </details>

          <details class="gc-news-editor-block-v1" open>
            <summary><strong>3. Contenido</strong><span>Resumen, cuerpo y enlaces</span></summary>
            <div>
              <label class="gc-news-field gc-field--full"><span>Resumen</span><textarea id="fieldExcerpt" rows="3"></textarea></label>
              <label class="gc-news-field gc-field--full"><span>Cuerpo</span><textarea id="fieldBody" rows="9"></textarea></label>
              <label class="gc-news-field gc-field--full"><span>Enlace opcional</span><input id="fieldHref" placeholder="puede quedar vacío" /></label>
              <label class="gc-news-field gc-field--full"><span>Tags</span><input id="fieldTags" placeholder="HUD||Sim racing||Update" /></label>
            </div>
          </details>

          <details class="gc-news-editor-block-v1">
            <summary><strong>4. SEO</strong><span>Opcional</span></summary>
            <div>
              <label class="gc-news-field gc-field--full"><span>SEO title</span><input id="fieldSeoTitle" /></label>
              <label class="gc-news-field gc-field--full"><span>SEO description</span><textarea id="fieldSeoDescription" rows="3"></textarea></label>
            </div>
          </details>

          <div class="gc-actions gc-news-editor-actions-v1">
            <button class="gc-btn gc-btn--primary" type="submit" id="saveNewsBtn">Guardar noticia</button>
            <button class="gc-btn" type="button" id="resetNewsBtn">Limpiar</button>
            <button class="gc-btn gc-btn--danger" type="button" id="deleteNewsBtn" hidden>Eliminar</button>
          </div>

          <p class="gc-message" id="newsEditorMessage"></p>
        </form>
      </aside>
    </section>
  </div>

  <style is:global>
    .gc-news-admin-system-v1{max-width:1440px;margin:0 auto;display:grid;gap:clamp(18px,2vw,26px)}
    .gc-news-admin-layout-v1{display:grid;grid-template-columns:minmax(0,1fr) minmax(380px,.42fr);gap:16px;align-items:start}
    .gc-news-editor-panel-v1{position:sticky;top:86px}
    .gc-news-toolbar-v1{display:grid;gap:14px;margin-bottom:16px}
    .gc-news-field{display:grid;gap:7px;min-width:0}
    .gc-news-field span{color:var(--soft);font-size:.72rem;font-weight:900;letter-spacing:.1em;text-transform:uppercase}
    .gc-news-field input,.gc-news-field select,.gc-news-field textarea{width:100%;box-sizing:border-box;border:1px solid rgba(255,255,255,.13);border-radius:12px;background:rgba(4,9,6,.62);color:inherit;padding:11px 12px;font:inherit;outline:none}
    .gc-news-field textarea{resize:vertical;line-height:1.55}
    .gc-news-field input:focus,.gc-news-field select:focus,.gc-news-field textarea:focus{border-color:rgba(156,255,63,.36);box-shadow:0 0 0 4px rgba(156,255,63,.08)}
    .gc-news-filter-grid-v1{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:10px}
    .gc-news-pills-v1{display:flex;flex-wrap:wrap;gap:8px}
    .gc-news-pills-v1 button{min-height:34px;padding:0 12px;border:1px solid rgba(255,255,255,.11);border-radius:999px;background:rgba(255,255,255,.035);color:inherit;font-weight:900;font-size:.74rem;letter-spacing:.08em;text-transform:uppercase;cursor:pointer}
    .gc-news-pills-v1 button.is-active{color:#071006;background:var(--accent,#9cff3f);border-color:transparent}
    .gc-news-list-summary-v1{display:flex;flex-wrap:wrap;gap:10px;align-items:center;justify-content:space-between}
    .gc-news-list-summary-v1 strong{color:var(--accent,#9cff3f);font-size:1.5rem;line-height:1}
    .gc-news-list-summary-v1 span{margin-right:auto;color:var(--soft);font-size:.9rem}
    .gc-news-table-head-v1{display:grid;grid-template-columns:minmax(0,1.55fr) 130px 110px 100px 210px;gap:10px;padding:0 14px 8px;color:var(--dim);font-size:.72rem;font-weight:900;letter-spacing:.1em;text-transform:uppercase}
    .gc-news-list-v1{display:grid;gap:8px}
    .gc-news-row-v1{display:grid;grid-template-columns:72px minmax(0,1fr) 130px 110px 100px 210px;gap:10px;align-items:center;padding:10px;border:1px solid rgba(255,255,255,.09);border-radius:16px;background:rgba(255,255,255,.025);color:inherit;text-align:left}
    .gc-news-row-v1.is-selected,.gc-news-row-v1:hover{border-color:rgba(156,255,63,.28);background:rgba(156,255,63,.045)}
    .gc-news-thumb-v1{width:72px;aspect-ratio:16/10;border-radius:10px;overflow:hidden;border:1px solid rgba(255,255,255,.10);background:linear-gradient(180deg,rgba(8,14,10,.72),rgba(4,8,5,.8)),url("/ui/home2/gc-home2-grid.svg");background-size:cover}
    .gc-news-thumb-v1 img{width:100%;height:100%;object-fit:cover;display:block}
    .gc-news-row-main-v1{min-width:0}
    .gc-news-row-main-v1 strong{display:block;color:var(--text);font-size:1rem;line-height:1.1;overflow-wrap:anywhere}
    .gc-news-row-main-v1 p{margin:5px 0 0;color:var(--soft);font-size:.86rem;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .gc-news-pill-v1{display:inline-flex;min-height:26px;align-items:center;justify-content:center;padding:0 9px;border:1px solid rgba(255,255,255,.10);border-radius:999px;color:var(--soft);font-size:.72rem;font-weight:900;letter-spacing:.07em;text-transform:uppercase;white-space:nowrap}
    .gc-news-pill-v1.is-ok{color:#071006;background:var(--accent,#9cff3f);border-color:transparent}
    .gc-news-pill-v1.is-warn{color:#ffe0a3;border-color:rgba(255,194,87,.22);background:rgba(255,194,87,.065)}
    .gc-news-row-actions-v1{display:flex;flex-wrap:wrap;gap:6px;justify-content:flex-end}
    .gc-news-row-actions-v1 button,.gc-news-row-actions-v1 a{min-height:30px;display:inline-flex;align-items:center;justify-content:center;padding:0 10px;border:1px solid rgba(255,255,255,.10);border-radius:999px;background:rgba(255,255,255,.035);color:inherit;text-decoration:none;font-size:.72rem;font-weight:900;letter-spacing:.07em;text-transform:uppercase;cursor:pointer}
    .gc-news-row-actions-v1 button:first-child{color:#071006;background:var(--accent,#9cff3f);border-color:transparent}
    .gc-news-pagination-v1{display:flex;gap:10px;align-items:center;justify-content:center;margin-top:16px}
    .gc-news-pagination-v1 span{color:var(--soft);font-weight:900;font-size:.82rem;letter-spacing:.08em;text-transform:uppercase}
    .gc-news-editor-form-v1{display:grid;gap:12px}
    .gc-news-editor-block-v1{border:1px solid rgba(255,255,255,.10);border-radius:18px;background:rgba(255,255,255,.025);overflow:hidden}
    .gc-news-editor-block-v1 summary{list-style:none;cursor:pointer;display:flex;justify-content:space-between;gap:12px;padding:13px 14px;border-bottom:1px solid transparent}
    .gc-news-editor-block-v1[open] summary{border-bottom-color:rgba(255,255,255,.075)}
    .gc-news-editor-block-v1 summary::-webkit-details-marker{display:none}
    .gc-news-editor-block-v1 summary strong{font-size:.82rem;text-transform:uppercase;letter-spacing:.08em}
    .gc-news-editor-block-v1 summary span{color:var(--dim);font-size:.76rem}
    .gc-news-editor-block-v1 > div{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;padding:14px}
    .gc-news-editor-block-v1 .gc-field--full{grid-column:1/-1}
    .gc-news-image-preview-v1{display:grid;place-items:center;aspect-ratio:16/9;border:1px solid rgba(255,255,255,.10);border-radius:16px;background:rgba(0,0,0,.22);overflow:hidden;color:var(--dim)}
    .gc-news-image-preview-v1 img{width:100%;height:100%;object-fit:cover}
    .gc-news-editor-actions-v1{position:sticky;bottom:12px;padding:12px;border:1px solid rgba(255,255,255,.10);border-radius:18px;background:rgba(5,10,6,.92);backdrop-filter:blur(10px)}
    .gc-btn--danger{border-color:rgba(255,95,95,.35);color:#ffaaaa}
    @media(max-width:1180px){.gc-news-admin-layout-v1{grid-template-columns:1fr}.gc-news-editor-panel-v1{position:static}.gc-news-filter-grid-v1{grid-template-columns:repeat(2,minmax(0,1fr))}.gc-news-table-head-v1{display:none}.gc-news-row-v1{grid-template-columns:82px minmax(0,1fr)}.gc-news-row-v1 > .gc-news-pill-v1,.gc-news-row-actions-v1{grid-column:2;justify-content:flex-start}}
    @media(max-width:680px){.gc-news-filter-grid-v1,.gc-news-row-v1,.gc-news-editor-block-v1 > div{grid-template-columns:1fr}.gc-news-thumb-v1{width:100%}.gc-news-row-v1 > .gc-news-pill-v1,.gc-news-row-actions-v1{grid-column:auto}}
  </style>

  <script is:inline>
    (() => {
      const API = '/api/admin/news';
      const CATEGORIES = ['Update','Sim racing','Motorsport','Herramientas','GrassCutters'];
      const $ = (id) => document.getElementById(id);
      const esc = (v) => String(v ?? '').replace(/[&<>'"]/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));

      const fields = {
        id:$('fieldId'), title:$('fieldTitle'), slug:$('fieldSlug'), status:$('fieldStatus'),
        category:$('fieldCategory'), publishedAt:$('fieldPublishedAt'), image:$('fieldImage'), imageFile:$('fieldImageFile'),
        imageAlt:$('fieldImageAlt'), imageSource:$('fieldImageSource'), imageAuthor:$('fieldImageAuthor'),
        imageLicense:$('fieldImageLicense'), imageSourceUrl:$('fieldImageSourceUrl'),
        href:$('fieldHref'), featured:$('fieldFeatured'), pinned:$('fieldPinned'),
        excerpt:$('fieldExcerpt'), body:$('fieldBody'), tags:$('fieldTags'), seoTitle:$('fieldSeoTitle'), seoDescription:$('fieldSeoDescription')
      };

      const els = {
        state:$('newsAdminState'), total:$('newsTotal'), published:$('newsPublished'), missing:$('newsMissingImages'),
        list:$('newsList'), notice:$('newsNotice'), noticeTitle:$('newsNoticeTitle'), noticeText:$('newsNoticeText'),
        newBtn:$('newPostBtn'), refresh:$('refreshNewsBtn'), demo:$('demoNewsBtn'), form:$('newsForm'),
        save:$('saveNewsBtn'), reset:$('resetNewsBtn'), del:$('deleteNewsBtn'), title:$('editorTitle'),
        hint:$('editorHint'), message:$('newsEditorMessage'), preview:$('newsImagePreview'), previewEmpty:$('newsImagePreviewEmpty'),
        search:$('newsSearchInput'), categoryFilter:$('newsCategoryFilter'), statusFilter:$('newsStatusFilter'), imageFilter:$('newsImageFilter'),
        sort:$('newsSortSelect'), pageSize:$('newsPageSize'), visible:$('newsVisibleCount'), clear:$('newsClearFilters'),
        prev:$('newsPrevPage'), next:$('newsNextPage'), pageInfo:$('newsPageInfo')
      };

      let allPosts = [];
      let filteredPosts = [];
      let page = 1;

      function normalize(v) { return String(v || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, ''); }
      function slugify(value) { return String(value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').replace(/-{2,}/g, '-').slice(0, 120); }
      function toLocalDateTime(value) { if (!value) return ''; const date = new Date(value); if (Number.isNaN(date.getTime())) return ''; return new Date(date.getTime() - date.getTimezoneOffset() * 60000).toISOString().slice(0, 16); }
      function fromLocalDateTime(value) { if (!value) return ''; const date = new Date(value); return Number.isNaN(date.getTime()) ? '' : date.toISOString(); }
      function hasImage(post) { return Boolean(post.image); }
      function publicHref(post) { return post.href || `/noticias/${post.slug}`; }
      function statusLabel(status) { if (status === 'published') return 'Publicado'; if (status === 'hidden') return 'Oculto'; return 'Borrador'; }
      function categoryLabel(category) { return CATEGORIES.find((item) => normalize(item) === normalize(category)) || 'Update'; }

      async function fetchJson(url, options={}) {
        const response = await fetch(url, { credentials:'include', cache:'no-store', headers:{'Content-Type':'application/json'}, ...options });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || data.ok === false) throw new Error(data.message || data.error || `HTTP ${response.status}`);
        return data;
      }

      function showNotice(title, text) { els.notice.hidden = false; els.noticeTitle.textContent = title; els.noticeText.textContent = text; }
      function clearNotice() { els.notice.hidden = true; }

      function maxPage() { return Math.max(1, Math.ceil(filteredPosts.length / Number(els.pageSize.value || 20))); }

      function updateQuickButtons() {
        document.querySelectorAll('[data-news-quick]').forEach((button) => button.classList.toggle('is-active', button.dataset.newsQuick === els.categoryFilter.value));
        document.querySelectorAll('[data-news-image-quick]').forEach((button) => button.classList.toggle('is-active', button.dataset.newsImageQuick === els.imageFilter.value));
      }

      function applyFilters() {
        const q = normalize(els.search.value);
        const category = els.categoryFilter.value;
        const status = els.statusFilter.value;
        const image = els.imageFilter.value;

        filteredPosts = allPosts.filter((post) => {
          const text = normalize([post.title, post.slug, post.category, post.excerpt, post.body, post.tags].join(' '));
          const categoryOk = category === 'all' || normalize(categoryLabel(post.category)) === normalize(category);
          const statusOk = status === 'all' || post.status === status;
          const imageOk = image === 'all' || (image === 'with' ? hasImage(post) : !hasImage(post));
          const queryOk = !q || text.includes(q);
          return categoryOk && statusOk && imageOk && queryOk;
        });

        const sort = els.sort.value;
        filteredPosts.sort((a,b) => {
          if (sort === 'title-asc') return String(a.title || '').localeCompare(String(b.title || ''), 'es');
          if (sort === 'category-asc') return categoryLabel(a.category).localeCompare(categoryLabel(b.category), 'es') || String(a.title || '').localeCompare(String(b.title || ''), 'es');
          if (sort === 'status-asc') return String(a.status || '').localeCompare(String(b.status || ''), 'es') || String(a.title || '').localeCompare(String(b.title || ''), 'es');
          return String(b.publishedAt || b.updatedAt || '').localeCompare(String(a.publishedAt || a.updatedAt || ''));
        });

        page = Math.min(page, maxPage());
        if (page < 1) page = 1;
        updateQuickButtons();
        renderList();
      }

      function renderList() {
        els.visible.textContent = String(filteredPosts.length);
        els.pageInfo.textContent = `Página ${page}/${maxPage()}`;
        els.prev.disabled = page <= 1;
        els.next.disabled = page >= maxPage();

        const pageSize = Number(els.pageSize.value || 20);
        const start = (page - 1) * pageSize;
        const posts = filteredPosts.slice(start, start + pageSize);

        if (!posts.length) {
          els.list.innerHTML = '<div class="gc-admin-empty">No hay noticias con estos filtros.</div>';
          return;
        }

        els.list.innerHTML = posts.map((post) => `
          <article class="gc-news-row-v1 ${fields.id.value === post.id ? 'is-selected' : ''}">
            <button class="gc-news-thumb-v1" type="button" data-edit-post="${esc(post.id)}" aria-label="Editar ${esc(post.title || '')}">
              ${post.image ? `<img src="${esc(post.image)}" alt="" loading="lazy" />` : ''}
            </button>
            <div class="gc-news-row-main-v1">
              <strong>${esc(post.title || 'Sin título')}</strong>
              <p>${esc(post.excerpt || 'Sin resumen')}</p>
            </div>
            <span class="gc-news-pill-v1">${esc(categoryLabel(post.category))}</span>
            <span class="gc-news-pill-v1 ${post.status === 'published' ? 'is-ok' : 'is-warn'}">${esc(statusLabel(post.status))}</span>
            <span class="gc-news-pill-v1 ${hasImage(post) ? 'is-ok' : 'is-warn'}">${hasImage(post) ? 'Con imagen' : 'Sin imagen'}</span>
            <div class="gc-news-row-actions-v1">
              <button type="button" data-edit-post="${esc(post.id)}">Editar</button>
              <a href="${esc(publicHref(post))}" target="_blank" rel="noreferrer">Ver</a>
              <a href="/admin/noticias/imagenes?post=${encodeURIComponent(post.id || '')}">Imagen</a>
            </div>
          </article>
        `).join('');

        els.list.querySelectorAll('[data-edit-post]').forEach((button) => button.addEventListener('click', () => editPost(button.dataset.editPost)));
      }

      function renderStats() {
        els.state.textContent = 'Operativo';
        els.total.textContent = allPosts.length;
        els.published.textContent = allPosts.filter((post) => post.status === 'published').length;
        els.missing.textContent = allPosts.filter((post) => !hasImage(post)).length;
      }

      function updatePreview() {
        const url = fields.image.value.trim();
        if (url) {
          els.preview.src = url;
          els.preview.hidden = false;
          els.previewEmpty.hidden = true;
        } else {
          els.preview.hidden = true;
          els.previewEmpty.hidden = false;
        }
      }

      function clearForm() {
        fields.id.value = '';
        fields.title.value = '';
        fields.slug.value = '';
        fields.status.value = 'draft';
        fields.category.value = 'Update';
        fields.publishedAt.value = toLocalDateTime(new Date().toISOString());
        fields.image.value = '';
        if (fields.imageFile) fields.imageFile.value = '';
        fields.imageAlt.value = '';
        fields.imageSource.value = 'GrassCutters Racing';
        fields.imageAuthor.value = 'GrassCutters Racing';
        fields.imageLicense.value = 'Imagen propia / GrassCutters Racing';
        fields.imageSourceUrl.value = '';
        fields.href.value = '';
        fields.featured.value = 'false';
        fields.pinned.value = 'false';
        fields.excerpt.value = '';
        fields.body.value = '';
        fields.tags.value = '';
        fields.seoTitle.value = '';
        fields.seoDescription.value = '';
        els.title.textContent = 'Nueva noticia';
        els.hint.textContent = 'Rellena los campos y guarda como borrador o publicado.';
        els.del.hidden = true;
        els.message.textContent = '';
        updatePreview();
        renderList();
      }

      function editPost(id) {
        const post = allPosts.find((entry) => entry.id === id);
        if (!post) return;
        fields.id.value = post.id || '';
        fields.title.value = post.title || '';
        fields.slug.value = post.slug || '';
        fields.status.value = post.status || 'draft';
        fields.category.value = categoryLabel(post.category);
        fields.publishedAt.value = toLocalDateTime(post.publishedAt);
        fields.image.value = post.image || '';
        if (fields.imageFile) fields.imageFile.value = '';
        fields.imageAlt.value = post.imageAlt || post.alt || '';
        fields.imageSource.value = post.imageSource || '';
        fields.imageAuthor.value = post.imageAuthor || '';
        fields.imageLicense.value = post.imageLicense || '';
        fields.imageSourceUrl.value = post.imageSourceUrl || '';
        fields.href.value = post.href || '';
        fields.featured.value = post.featured ? 'true' : 'false';
        fields.pinned.value = post.pinned ? 'true' : 'false';
        fields.excerpt.value = post.excerpt || '';
        fields.body.value = post.body || '';
        fields.tags.value = post.tags || '';
        fields.seoTitle.value = post.seoTitle || '';
        fields.seoDescription.value = post.seoDescription || '';
        els.title.textContent = 'Editar noticia';
        els.hint.textContent = post.slug ? `/noticias/${post.slug}` : 'Editando noticia.';
        els.del.hidden = false;
        els.message.textContent = '';
        updatePreview();
        renderList();
      }

      function payload() {
        const title = fields.title.value.trim();
        return {
          id: fields.id.value || undefined,
          title,
          slug: fields.slug.value.trim() || slugify(title),
          status: fields.status.value,
          category: fields.category.value || 'Update',
          publishedAt: fromLocalDateTime(fields.publishedAt.value) || new Date().toISOString(),
          image: fields.image.value.trim(),
          imageAlt: fields.imageAlt.value.trim(),
          imageSource: fields.imageSource.value.trim(),
          imageAuthor: fields.imageAuthor.value.trim(),
          imageLicense: fields.imageLicense.value.trim(),
          imageSourceUrl: fields.imageSourceUrl.value.trim(),
          href: fields.href.value.trim(),
          featured: fields.featured.value === 'true',
          pinned: fields.pinned.value === 'true',
          excerpt: fields.excerpt.value.trim(),
          body: fields.body.value.trim(),
          tags: fields.tags.value.trim(),
          seoTitle: fields.seoTitle.value.trim(),
          seoDescription: fields.seoDescription.value.trim(),
        };
      }

      async function load() {
        clearNotice();
        els.state.textContent = 'Cargando';
        try {
          const data = await fetchJson(API);
          allPosts = Array.isArray(data.posts) ? data.posts : [];
          renderStats();
          page = 1;
          applyFilters();
        } catch (error) {
          els.state.textContent = 'API error';
          els.list.innerHTML = '<div class="gc-admin-empty">No se pudieron cargar noticias.</div>';
          showNotice('No se pudo leer Noticias', error.message || 'Error desconocido');
        }
      }

      function fileToDataUrl(file) {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve(String(reader.result || ''));
          reader.onerror = () => reject(reader.error || new Error('No se pudo leer la imagen.'));
          reader.readAsDataURL(file);
        });
      }

      async function uploadSelectedImage(title) {
        const file = fields.imageFile?.files?.[0];
        if (!file) return '';
        const dataUrl = await fileToDataUrl(file);
        const data = await fetchJson(`${API}/image-upload`, {
          method: 'POST',
          body: JSON.stringify({ dataUrl, title: title || file.name, fileName: file.name })
        });
        return data.url || data.localUrl || '';
      }

      async function save(event) {
        event.preventDefault();
        clearNotice();
        els.save.disabled = true;
        els.save.textContent = 'Guardando...';
        try {
          const body = payload();
          const uploadedUrl = await uploadSelectedImage(body.title);
          if (uploadedUrl) {
            body.image = uploadedUrl;
            fields.image.value = uploadedUrl;
            if (fields.imageFile) fields.imageFile.value = '';
          }
          const id = fields.id.value;
          const data = await fetchJson(id ? `${API}/${encodeURIComponent(id)}` : API, {
            method: id ? 'PUT' : 'POST',
            body: JSON.stringify(body)
          });
          els.message.innerHTML = `Noticia guardada. <a href="/noticias/${data.post.slug}" target="_blank" rel="noreferrer">Ver noticia</a>`;
          await load();
          editPost(data.post.id);
        } catch (error) {
          els.message.textContent = error.message || 'No se pudo guardar.';
        } finally {
          els.save.disabled = false;
          els.save.textContent = 'Guardar noticia';
        }
      }

      async function remove() {
        const id = fields.id.value;
        if (!id || !confirm('¿Eliminar esta noticia?')) return;
        clearNotice();
        els.del.disabled = true;
        els.del.textContent = 'Eliminando...';
        try {
          await fetchJson(`${API}/${encodeURIComponent(id)}`, { method:'DELETE' });
          clearForm();
          await load();
        } catch (error) {
          els.message.textContent = error.message || 'No se pudo eliminar.';
        } finally {
          els.del.disabled = false;
          els.del.textContent = 'Eliminar';
        }
      }

      async function demo() {
        clearNotice();
        els.demo.disabled = true;
        els.demo.textContent = 'Creando...';
        try {
          const data = await fetchJson(`${API}/demo`, { method:'POST' });
          allPosts = Array.isArray(data.posts) ? data.posts : [];
          renderStats();
          applyFilters();
          showNotice('Demo creada', `Creadas ${data.created}, omitidas ${data.skipped}.`);
        } catch (error) {
          showNotice('No se pudo crear la demo', error.message || 'Error desconocido');
        } finally {
          els.demo.disabled = false;
          els.demo.textContent = 'Demo';
        }
      }

      fields.title.addEventListener('input', () => {
        if (!fields.slug.value || fields.slug.dataset.auto === '1') {
          fields.slug.dataset.auto = '1';
          fields.slug.value = slugify(fields.title.value);
        }
      });
      fields.slug.addEventListener('input', () => { fields.slug.dataset.auto = fields.slug.value ? '0' : '1'; });
      fields.image.addEventListener('input', updatePreview);

      [els.search, els.categoryFilter, els.statusFilter, els.imageFilter, els.sort, els.pageSize].forEach((input) => {
        input?.addEventListener('input', () => { page = 1; applyFilters(); });
        input?.addEventListener('change', () => { page = 1; applyFilters(); });
      });

      document.querySelectorAll('[data-news-quick]').forEach((button) => {
        button.addEventListener('click', () => {
          els.categoryFilter.value = button.dataset.newsQuick || 'all';
          page = 1;
          applyFilters();
        });
      });

      document.querySelectorAll('[data-news-image-quick]').forEach((button) => {
        button.addEventListener('click', () => {
          els.imageFilter.value = els.imageFilter.value === button.dataset.newsImageQuick ? 'all' : (button.dataset.newsImageQuick || 'all');
          page = 1;
          applyFilters();
        });
      });

      els.clear.addEventListener('click', () => {
        els.search.value = '';
        els.categoryFilter.value = 'all';
        els.statusFilter.value = 'all';
        els.imageFilter.value = 'all';
        els.sort.value = 'date-desc';
        els.pageSize.value = '20';
        page = 1;
        applyFilters();
      });

      els.prev.addEventListener('click', () => { page = Math.max(1, page - 1); renderList(); });
      els.next.addEventListener('click', () => { page = Math.min(maxPage(), page + 1); renderList(); });

      els.form.addEventListener('submit', save);
      els.del.addEventListener('click', remove);
      els.reset.addEventListener('click', clearForm);
      els.newBtn.addEventListener('click', clearForm);
      els.refresh.addEventListener('click', load);
      els.demo.addEventListener('click', demo);

      clearForm();
      load();
    })();
  </script>
</AppLayout>

{
  "name": "grasscutters-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "astro dev --host 0.0.0.0 --port 4321",
    "dev:server": "tsx watch src/server/index.ts",
    "prebuild": "node scripts/ensure-hostinger-runtime.mjs",
    "build": "astro build",
    "start": "tsx src/server/index.ts",
    "preview": "npm run build && npm start",
    "check": "astro check",
    "format": "prettier . --write",
    "mysql:migrate-json": "node scripts/migrate-json-to-mysql.mjs",
    "sqlite:migrate-json": "node scripts/migrate-json-to-sqlite.mjs"
  },
  "dependencies": {
    "@astrojs/check": "latest",
    "@astrojs/node": "latest",
    "astro": "latest",
    "concurrently": "latest",
    "dotenv": "latest",
    "express": "latest",
    "mysql2": "latest",
    "sql.js": "latest",
    "ssh2-sftp-client": "latest",
    "tsx": "latest",
    "typescript": "latest"
  },
  "devDependencies": {
    "@types/express": "latest",
    "@types/node": "latest",
    "prettier": "latest"
  }
}
